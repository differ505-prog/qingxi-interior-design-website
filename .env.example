# ==================== Contentful CMS 配置 ====================
# 用於連接 Contentful 內容管理系統
CONTENTFUL_SPACE_ID=你的_space_id
CONTENTFUL_ACCESS_TOKEN=你的_access_token

# ==================== 預覽密碼保護 ====================
# ⚠️ 注意：本地開發時不需要配置此項！
# 只在 Vercel 線上部署時，在 Vercel Dashboard 的環境變數中設置

# 啟用密碼保護（true/false）
# 在 Vercel 中設置為 true，訪客需要輸入密碼才能訪問網站
# PREVIEW_PROTECTION_ENABLED=true

# 訪問密碼（在 Vercel 中設置）
# 請使用安全的密碼，建議 8 位以上
# PREVIEW_PASSWORD=您的密碼

# ==================== 維護模式 ====================
# 啟用維護模式（true/false）
# 設為 true 時，所有訪客會看到建置中頁面
MAINTENANCE_MODE=false

# ==================== 表單收件設定 ====================
# 將 Formspree 的 form ID 填入以下欄位，需求表與快速諮詢才會正式送出
# 正式站建議 PUBLIC 與 server 端都設成同一個 form ID
# 例如：
# PUBLIC_FORMSPREE_REQUIREMENT_FORM_ID=xblyzabc
# FORMSPREE_REQUIREMENT_FORM_ID=xblyzabc
# 若裝修估價器問題回報想獨立收件，可另外設一組 feedback form ID；
# 若留空，會自動沿用 requirement form ID
# PUBLIC_FORMSPREE_ESTIMATOR_FEEDBACK_FORM_ID=xyzpqwer
# FORMSPREE_ESTIMATOR_FEEDBACK_FORM_ID=xyzpqwer
PUBLIC_FORMSPREE_REQUIREMENT_FORM_ID=
FORMSPREE_REQUIREMENT_FORM_ID=
PUBLIC_FORMSPREE_ESTIMATOR_FEEDBACK_FORM_ID=
FORMSPREE_ESTIMATOR_FEEDBACK_FORM_ID=

# ==================== 流量追蹤設定 ====================
# Google Analytics 4 Measurement ID
# 例如：PUBLIC_GA_MEASUREMENT_ID=G-ABC1234567
PUBLIC_GA_MEASUREMENT_ID=

# 若要讓設計師工作台直接讀 GA4 報表，還需要以下 server 端設定
# 例如：GA4_PROPERTY_ID=123456789
# 例如：GA4_SERVICE_ACCOUNT_CLIENT_EMAIL=ga4-reader@your-project.iam.gserviceaccount.com
# 私鑰可直接貼完整內容，換行可保留原樣或使用 \n
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_CLIENT_EMAIL=
GA4_SERVICE_ACCOUNT_PRIVATE_KEY=

# ==================== 合約短連結儲存 ====================
# 若已接上 Vercel KV，合約工作台分享給客戶時會優先產生短 token 簽約連結
# 例如：
# KV_REST_API_URL=https://your-kv-url.upstash.io
# KV_REST_API_TOKEN=your_kv_rest_token
KV_REST_API_URL=
KV_REST_API_TOKEN=

# 允許訪問的IP列表（可選）
# 多個IP用逗號分隔
ALLOWED_IPS=
