---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleQuestionBox from "./ArticleQuestionBox.astro";
import { SOCIAL_OPS_AUTH_CONFIG } from "../../lib/social-ops-auth";

interface Props {
  title: string;
  description: string;
  ogImage: string;
  publishedTime: string;
  modifiedTime?: string;
  structuredData?: unknown;
  track: string;
  chapter: string;
  siteCategory: string;
  tags?: string[];
  kicker?: string;
  dek?: string;
  coverAlt?: string;
  backHref?: string;
  backLabel?: string;
  htmlContent?: string;
  editorialRefreshStamp?: string;
}

const {
  title,
  description,
  ogImage,
  publishedTime,
  modifiedTime = publishedTime,
  structuredData,
  track,
  chapter,
  siteCategory,
  tags = [],
  kicker = "Qingxi Journal",
  dek = description,
  coverAlt = title,
  backHref = "/blog",
  backLabel = "← 返回知識分享",
  htmlContent,
  editorialRefreshStamp,
} = Astro.props;

const articleShellClass = editorialRefreshStamp
  ? "article-shell article-shell-refined"
  : "article-shell";
const articlePathname = Astro.url.pathname;
const articleSlug = articlePathname.startsWith("/blog/")
  ? articlePathname.slice("/blog/".length).replace(/\/$/, "")
  : "";
const hasSocialOpsAccess =
  Astro.cookies.get(SOCIAL_OPS_AUTH_CONFIG.cookieName)?.value === "true";
const privateQuestionPoolHref = articleSlug
  ? `${SOCIAL_OPS_AUTH_CONFIG.defaultNextPath}?article=${encodeURIComponent(articleSlug)}#article-question-pool`
  : SOCIAL_OPS_AUTH_CONFIG.defaultNextPath;
---

<style>
  .article-shell {
    position: relative;
    max-width: 1240px;
    margin: 0 auto;
    padding: 6.5rem 1.5rem 8.4rem;
  }

  .article-shell::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 2.6rem;
    width: min(260px, calc(100% - 5rem));
    height: 36px;
    transform: translateX(-50%);
    border-top: 1px solid rgba(164, 171, 160, 0.18);
    background: linear-gradient(
      180deg,
      rgba(248, 245, 239, 0.78) 0%,
      rgba(248, 245, 239, 0.18) 58%,
      rgba(248, 245, 239, 0) 100%
    );
    pointer-events: none;
  }

  .article-header {
    max-width: 1120px;
    margin: 0 auto 5.2rem;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1.6rem;
    align-items: end;
  }

  .article-shell-refined .article-header {
    position: relative;
  }

  .article-shell-refined .article-header::after {
    content: "";
    position: absolute;
    top: 0.45rem;
    right: 0.25rem;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: rgba(51, 46, 41, 0.14);
    box-shadow: 0 0 0 3px rgba(255, 252, 248, 0.72);
    pointer-events: none;
  }

  .article-intro {
    grid-column: 1 / span 7;
  }

  .article-journal-note {
    grid-column: 9 / -1;
    align-self: start;
    display: grid;
    gap: 0.85rem;
    max-width: 17rem;
    padding: 0.95rem 0 0 1.15rem;
    border-left: 1px solid rgba(164, 171, 160, 0.16);
  }

  .article-journal-label {
    margin: 0;
    font-size: 0.74rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #8a837b;
  }

  .article-journal-note p:last-child {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.84;
    color: color-mix(in srgb, var(--gray-darkest) 58%, transparent);
  }

  .article-kicker {
    margin: 0 0 1rem;
    color: var(--art-accent-text);
    font-size: 0.78rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  .article-meta {
    justify-content: flex-start;
    align-items: center;
    display: flex;
    gap: 0.72rem;
    margin-bottom: 1.2rem;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    color: color-mix(in srgb, var(--gray-darkest) 56%, transparent);
    flex-wrap: wrap;
    text-transform: uppercase;
  }

  .article-category {
    background: rgba(244, 240, 234, 0.58);
    color: var(--art-accent-text);
    padding: 0.32rem 0.72rem;
    border-radius: 999px;
    font-weight: 500;
    letter-spacing: 0.12em;
  }

  .article-meta-detail {
    padding: 0.32rem 0.68rem;
    border-radius: 999px;
    background: rgba(255, 252, 248, 0.48);
    border: 1px solid rgba(164, 171, 160, 0.14);
  }

  .article-title {
    margin: 0;
    font-family: var(--font-display);
    max-width: 11.4ch;
    font-size: clamp(3.15rem, 5.35vw, 5.2rem);
    font-weight: 400;
    color: var(--gray-darkest);
    line-height: 1.25;
    letter-spacing: 0.02em;
    text-wrap: balance;
  }

  .article-dek {
    max-width: 34rem;
    margin: 1.35rem 0 0;
    color: color-mix(in srgb, var(--gray-darkest) 62%, transparent);
    font-size: 1rem;
    line-height: 1.82;
    letter-spacing: 0.01em;
  }

  .article-tags {
    display: flex;
    justify-content: flex-start;
    gap: 0.45rem 0.55rem;
    flex-wrap: wrap;
    margin: 1rem 0 0;
    max-width: 42rem;
  }

  .article-tag {
    padding: 0.28rem 0.62rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.34);
    color: color-mix(in srgb, var(--gray-darkest) 60%, transparent);
    font-size: 0.76rem;
    letter-spacing: 0.06em;
    border: 1px solid rgba(164, 171, 160, 0.12);
    backdrop-filter: blur(10px);
  }

  .article-cover {
    max-width: 1120px;
    width: 100%;
    margin: 0 auto 4.8rem;
    border-radius: 32px;
    overflow: hidden;
    box-shadow: 0 32px 90px rgba(var(--brand-dark-rgb), 0.14);
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.72),
      rgba(243, 246, 246, 0.62)
    );
    backdrop-filter: blur(24px) saturate(135%);
  }

  .article-cover img {
    width: 100%;
    display: block;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background-color: var(--art-paper);
  }

  .article-content {
    max-width: 760px;
    margin: 0 auto;
    font-family: var(--font-sans);
    font-size: 1.08rem;
    font-weight: 400;
    line-height: 1.92;
    color: color-mix(in srgb, var(--gray-darkest) 84%, transparent);
    letter-spacing: 0.01em;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  .article-content :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4vw, 4.1rem);
    font-weight: 500;
    color: var(--gray-darkest);
    margin-top: 5.6rem;
    margin-bottom: 1.6rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(164, 171, 160, 0.16);
    letter-spacing: 0.02em;
    line-height: 1.25;
  }

  .article-content :global(h3) {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2.3vw, 2.4rem);
    font-weight: 500;
    color: color-mix(in srgb, var(--gray-darkest) 92%, transparent);
    margin-top: 2.8rem;
    margin-bottom: 0.95rem;
    letter-spacing: 0.02em;
    line-height: 1.32;
  }

  .article-content :global(p) {
    margin: 0 0 1.55rem;
  }

  .article-content :global(.article-lead) {
    font-size: 1.28rem;
    line-height: 1.88;
    color: color-mix(in srgb, var(--gray-darkest) 88%, transparent);
    letter-spacing: 0.01em;
    margin-bottom: 2.4rem;
    position: relative;
  }

  .article-content :global(.article-lead)::first-letter {
    float: left;
    margin: 0.12rem 0.35rem 0 0;
    font-family: var(--font-display);
    font-size: 4.8rem;
    line-height: 0.86;
    letter-spacing: 0.06em;
    color: var(--gray-darkest);
  }

  .article-content :global(strong) {
    color: #332e29;
    font-weight: 600;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 0 0 1.75rem;
    padding-left: 1.35rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.85rem;
    padding-left: 0.2rem;
  }

  .article-content :global(blockquote) {
    margin: 3.2rem 0 3.4rem;
    padding: 1.6rem 1.8rem 1.7rem 2rem;
    border-top: 0;
    border-bottom: 0;
    border-left: 1px solid rgba(150, 160, 150, 0.32);
    border-radius: 0 28px 28px 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.54),
      rgba(244, 240, 234, 0.18)
    );
    color: color-mix(in srgb, var(--gray-darkest) 76%, transparent);
    font-family: var(--font-display);
    font-size: 1.24rem;
    line-height: 1.72;
    letter-spacing: 0.04em;
    backdrop-filter: blur(18px);
  }

  .article-content :global(a) {
    color: var(--art-accent-text);
    text-decoration: underline;
    text-decoration-color: rgba(124, 131, 122, 0.32);
    text-underline-offset: 0.16em;
  }

  .article-content :global(img) {
    width: 100%;
    display: block;
    border-radius: 18px;
    background: var(--art-paper);
    border: 1px solid var(--art-accent-line);
    margin: 2.45rem 0 0;
    box-shadow: 0 18px 42px rgba(58, 52, 46, 0.1);
  }

  .article-content :global(.image-caption) {
    max-width: 32rem;
    margin: 0.95rem auto 2.2rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.72;
    color: #8a837b;
    text-align: center;
    letter-spacing: 0.01em;
  }

  .article-content :global(.article-figure) {
    margin: 2.45rem 0 2.7rem;
  }

  .article-content :global(.article-figure img) {
    margin: 0;
  }

  .article-content :global(.article-figure figcaption) {
    max-width: 32rem;
    margin: 0.82rem auto 0;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.7;
    color: #8a837b;
    text-align: center;
    letter-spacing: 0.01em;
  }

  .article-content :global(.article-gallery) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.45rem;
    margin: 2.7rem 0 0.55rem;
  }

  .article-content :global(.article-insight-panel) {
    position: relative;
    margin: 3.35rem 0 2.2rem;
    padding: 1.85rem 0 0.1rem;
    border-radius: 0;
    border: 0;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
  }

  .article-content :global(.article-insight-panel::before) {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: min(210px, 46%);
    height: 1px;
    background: linear-gradient(90deg, rgba(115, 103, 94, 0.56), rgba(115, 103, 94, 0.08));
  }

  .article-content :global(.article-insight-panel::after) {
    content: "";
    position: absolute;
    top: 0.7rem;
    right: 0;
    width: min(110px, 18%);
    height: 1px;
    background: linear-gradient(90deg, rgba(164, 171, 160, 0.08), rgba(164, 171, 160, 0.26));
  }

  .article-content :global(.article-insight-label) {
    display: inline-block;
    margin: 0 0 0.8rem;
    padding: 0;
    border-radius: 0;
    background: none;
    border: 0;
    font-family: var(--font-sans);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    color: #6f685f;
    text-transform: uppercase;
  }

  .article-content :global(.article-insight-title) {
    margin: 0 0 0.7rem;
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2.3vw, 2.5rem);
    line-height: 1.32;
    letter-spacing: 0.02em;
    color: var(--gray-darkest);
    font-weight: 500;
    max-width: 16ch;
  }

  .article-content :global(.article-insight-panel p:last-child) {
    margin-bottom: 0;
    max-width: 34rem;
  }

  .article-content :global(.article-insight-panel + .article-step-flow) {
    margin-top: 2.15rem;
  }

  .article-content :global(.article-step-flow + h2) {
    position: relative;
    margin-top: 5rem;
    padding-top: 1.3rem;
  }

  .article-content :global(.article-step-flow + h2::before) {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: min(180px, 38%);
    height: 1px;
    background: linear-gradient(90deg, rgba(115, 103, 94, 0.42), rgba(115, 103, 94, 0.06));
  }

  .article-content :global(.article-card-grid) {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1.5rem 1.3rem;
    margin: 2.9rem 0 3.2rem;
  }

  .article-content :global(.article-card) {
    position: relative;
    grid-column: span 6;
    padding: 1.7rem 0 0;
    border-radius: 0;
    border: 0;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
  }

  .article-content :global(.article-card::before) {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: min(170px, 46%);
    height: 1px;
    background: linear-gradient(90deg, rgba(115, 103, 94, 0.5), rgba(115, 103, 94, 0.08));
  }

  .article-content :global(.article-card:nth-child(3n + 1)) {
    grid-column: 1 / span 6;
  }

  .article-content :global(.article-card:nth-child(3n + 2)) {
    grid-column: 7 / -1;
    transform: translateY(1.35rem);
  }

  .article-content :global(.article-card:nth-child(3n)) {
    grid-column: 2 / span 7;
  }

  .article-content :global(.article-card h3) {
    margin-top: 0;
    margin-bottom: 0.7rem;
    max-width: 14ch;
  }

  .article-content :global(.article-card p:last-child) {
    margin-bottom: 0;
  }

  .article-content :global(.article-card ul:last-child) {
    margin-bottom: 0;
  }

  .article-content :global(.article-card-kicker) {
    display: inline-block;
    margin: 0 0 0.8rem;
    font-family: var(--font-sans);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #8a837b;
  }

  .article-content :global(.article-check-grid) {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1.2rem 1.3rem;
    margin: 2.95rem 0 3.05rem;
  }

  .article-content :global(.article-check-item) {
    position: relative;
    grid-column: span 6;
    padding: 1.45rem 0 0 1.55rem;
    border-radius: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
    backdrop-filter: none;
  }

  .article-content :global(.article-check-item::before) {
    content: "";
    position: absolute;
    left: 0;
    top: 1.68rem;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: rgba(138, 131, 123, 0.9);
    box-shadow: 0 0 0 5px rgba(250, 247, 242, 0.96);
  }

  .article-content :global(.article-check-item:nth-child(3n + 1)) {
    grid-column: 1 / span 4;
  }

  .article-content :global(.article-check-item:nth-child(3n + 2)) {
    grid-column: 5 / span 4;
    margin-top: 1.3rem;
  }

  .article-content :global(.article-check-item:nth-child(3n)) {
    grid-column: 9 / -1;
  }

  .article-content :global(.article-check-item strong) {
    display: block;
    margin-bottom: 0.45rem;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.8vw, 1.7rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--gray-darkest);
  }

  .article-content :global(.article-check-item p) {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.78;
  }

  .article-content :global(.article-step-flow) {
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1.6rem 1.25rem;
    margin: 4.05rem 0 4.3rem;
    padding-top: 1.7rem;
  }

  .article-content :global(.article-step-flow::before) {
    content: "";
    position: absolute;
    top: 0.42rem;
    left: 0;
    width: min(540px, 82%);
    height: 1px;
    background: linear-gradient(90deg, rgba(164, 171, 160, 0.08) 0%, rgba(115, 103, 94, 0.28) 20%, rgba(115, 103, 94, 0.16) 74%, rgba(164, 171, 160, 0) 100%);
  }

  .article-content :global(.article-step-flow::after) {
    content: "";
    position: absolute;
    top: 0.92rem;
    right: 0;
    width: min(110px, 16%);
    height: 1px;
    background: linear-gradient(90deg, rgba(164, 171, 160, 0.04), rgba(164, 171, 160, 0.22));
  }

  .article-content :global(.article-step-card) {
    position: relative;
    grid-column: span 4;
    display: grid;
    align-content: start;
    padding: 1.35rem 0 0.1rem;
    border-radius: 0;
    border: 0;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
  }

  .article-content :global(.article-step-card:nth-child(3n + 1)) {
    grid-column: 1 / span 4;
    max-width: 14.8rem;
  }

  .article-content :global(.article-step-card:nth-child(3n + 2)) {
    grid-column: 5 / span 4;
    max-width: 13.8rem;
    margin-top: 2.8rem;
    justify-self: center;
  }

  .article-content :global(.article-step-card:nth-child(3n)) {
    grid-column: 9 / -1;
    max-width: 15.1rem;
    margin-top: 1.2rem;
    justify-self: end;
  }

  .article-content :global(.article-step-card::before) {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: min(170px, 44%);
    height: 1px;
    border-radius: 0;
    background: linear-gradient(90deg, rgba(115, 103, 94, 0.54), rgba(115, 103, 94, 0.08));
    box-shadow: none;
  }

  .article-content :global(.article-step-index) {
    display: inline-flex;
    align-items: center;
    margin: 0 0 0.78rem;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #8a837b;
  }

  .article-content :global(.article-step-card h3) {
    margin-top: 0;
    margin-bottom: 0.58rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 1.75vw, 1.82rem);
    font-weight: 500;
    line-height: 1.22;
    letter-spacing: 0.035em;
    max-width: 11ch;
  }

  .article-content :global(.article-step-card p:last-child) {
    margin-bottom: 0;
    max-width: 16.8rem;
    font-size: 0.95rem;
    line-height: 1.76;
    color: color-mix(in srgb, var(--gray-darkest) 76%, transparent);
  }

  .article-content :global(.article-reference-table-wrap) {
    margin: 2.2rem 0 2.55rem;
    border-radius: 24px;
    border: 1px solid rgba(164, 171, 160, 0.2);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.95),
      rgba(247, 244, 238, 0.94)
    );
    box-shadow: 0 18px 40px rgba(58, 52, 46, 0.06);
    overflow: hidden;
  }

  .article-content :global(.article-reference-table-scroll) {
    overflow-x: auto;
  }

  .article-content :global(.article-reference-table) {
    width: 100%;
    min-width: 720px;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: 0.94rem;
    line-height: 1.72;
  }

  .article-content :global(.article-reference-table thead) {
    background: rgba(244, 240, 234, 0.88);
  }

  .article-content :global(.article-reference-table th) {
    padding: 1rem 1rem 0.95rem;
    text-align: left;
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6f685f;
    border-bottom: 1px solid rgba(164, 171, 160, 0.2);
  }

  .article-content :global(.article-reference-table td) {
    padding: 1rem;
    vertical-align: top;
    color: #4a433d;
    border-bottom: 1px solid rgba(164, 171, 160, 0.14);
  }

  .article-content :global(.article-reference-table tbody tr:last-child td) {
    border-bottom: 0;
  }

  .article-content :global(.article-reference-table td:first-child) {
    font-weight: 600;
    color: #352f2a;
    white-space: nowrap;
  }

  .article-content :global(.article-reference-table-note) {
    margin: 0;
    padding: 0.95rem 1rem 1rem;
    border-top: 1px solid rgba(164, 171, 160, 0.14);
    font-family: var(--font-sans);
    font-size: 0.86rem;
    line-height: 1.68;
    color: #7c746c;
    background: rgba(255, 255, 255, 0.55);
  }

  .article-admin-link {
    margin: 2.4rem auto 0;
    max-width: 720px;
    display: flex;
    justify-content: flex-end;
  }

  .article-admin-link a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.62rem 0.9rem;
    border-radius: 999px;
    background: rgba(255, 252, 248, 0.72);
    color: #6a645d;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    box-shadow: inset 0 0 0 1px rgba(164, 171, 160, 0.16);
  }

  .article-admin-link a:hover {
    background: rgba(244, 240, 234, 0.92);
    color: #332e29;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    margin-top: 4.6rem;
    padding: 0.9rem 0 0;
    background: none;
    color: var(--gray-darkest);
    text-decoration: none;
    border-radius: 0;
    font-weight: 500;
    letter-spacing: 0.08em;
    transition:
      transform var(--motion-duration-fast) var(--motion-standard),
      color var(--motion-duration-fast) var(--motion-standard);
    border: 0;
    border-top: 1px solid rgba(164, 171, 160, 0.2);
    backdrop-filter: none;
    box-shadow: none;
  }

  .back-link:hover {
    color: color-mix(in srgb, var(--gray-darkest) 78%, transparent);
    transform: translateX(-3px);
  }

  @media (max-width: 768px) {
    .article-shell {
      padding: 4.6rem 1.15rem 6.2rem;
    }

    .article-shell::after {
      bottom: 1.9rem;
      width: min(180px, calc(100% - 2.3rem));
      height: 28px;
    }

    .article-header {
      margin-bottom: 2.7rem;
      grid-template-columns: 1fr;
      gap: 1.4rem;
    }

    .article-intro,
    .article-journal-note {
      grid-column: auto;
    }

    .article-journal-note {
      padding: 0.9rem 0 0 0;
      border-left: 0;
      border-top: 1px solid rgba(164, 171, 160, 0.2);
    }

    .article-title {
      font-size: clamp(1.95rem, 8.4vw, 2.55rem);
      line-height: 1.32;
      letter-spacing: 0.02em;
      max-width: none;
    }

    .article-dek,
    .article-content {
      font-size: 1rem;
    }

    .article-content :global(.article-lead) {
      font-size: 1.08rem;
    }

    .article-content :global(.article-lead)::first-letter {
      font-size: 3.6rem;
      margin-top: 0.06rem;
    }

    .article-content :global(h2) {
      font-size: clamp(2rem, 8vw, 2.7rem);
      margin-top: 4rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
    }

    .article-content :global(.article-gallery) {
      grid-template-columns: 1fr;
      margin-top: 2.2rem;
    }

    .article-content :global(.article-card-grid),
    .article-content :global(.article-check-grid),
    .article-content :global(.article-step-flow) {
      grid-template-columns: 1fr;
      gap: 1.1rem;
    }

    .article-content :global(.article-card),
    .article-content :global(.article-check-item),
    .article-content :global(.article-step-card) {
      grid-column: auto;
      transform: none;
      margin-top: 0;
    }

    .article-content :global(.article-card:nth-child(3n + 1)),
    .article-content :global(.article-card:nth-child(3n + 2)),
    .article-content :global(.article-card:nth-child(3n)),
    .article-content :global(.article-check-item:nth-child(3n + 1)),
    .article-content :global(.article-check-item:nth-child(3n + 2)),
    .article-content :global(.article-check-item:nth-child(3n)),
    .article-content :global(.article-step-card:nth-child(3n + 1)),
    .article-content :global(.article-step-card:nth-child(3n + 2)),
    .article-content :global(.article-step-card:nth-child(3n)) {
      grid-column: auto;
      max-width: none;
      justify-self: auto;
      transform: none;
      margin-top: 0;
    }

    .article-content :global(.article-step-flow) {
      padding-top: 0;
      gap: 1.4rem;
    }

    .article-content :global(.article-step-flow::before) {
      display: none;
    }

    .article-content :global(.article-step-flow::after) {
      display: none;
    }

    .article-content :global(.article-step-card) {
      max-width: none;
      padding: 1rem 0 0.1rem;
    }

    .article-content :global(.article-step-card::before) {
      top: 0;
      right: auto;
      left: 0;
      width: min(150px, 48%);
      height: 1px;
      box-shadow: none;
    }

    .article-content :global(.article-step-card h3) {
      max-width: none;
    }

    .article-content :global(.article-card h3) {
      max-width: none;
    }

    .article-content :global(.article-insight-panel) {
      padding: 1.2rem 0 0.1rem;
      margin: 2.2rem 0 1.55rem;
    }

    .article-content :global(.article-insight-panel::after) {
      display: none;
    }

    .article-content :global(.article-insight-title) {
      max-width: none;
    }

    .article-content :global(.article-insight-panel + .article-step-flow) {
      margin-top: 1.35rem;
    }

    .article-content :global(.article-step-flow + h2) {
      margin-top: 3.45rem;
      padding-top: 0.9rem;
    }

    .article-content :global(.article-step-flow + h2::before) {
      width: min(132px, 44%);
    }

    .article-cover {
      margin-bottom: 2.45rem;
    }

    .article-admin-link {
      justify-content: flex-start;
      margin-top: 1.7rem;
    }

    .back-link {
      margin-top: 3.6rem;
    }

    .article-content :global(blockquote) {
      margin: 2.15rem 0 2.3rem;
      padding: 1rem 1.05rem 1rem 1.2rem;
      font-size: 1.08rem;
      line-height: 1.68;
    }
  }
</style>

<BaseLayout
  title={`${title} - 青曦空間設計`}
  description={description}
  ogImage={ogImage}
  pageType="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  structuredData={structuredData}
>
  <article
    class={articleShellClass}
    data-qingxi-refresh={editorialRefreshStamp}
  >
    <header class="article-header">
      <div class="article-intro">
        <p class="article-kicker">{kicker}</p>
        <div class="article-meta">
          <span class="article-category">{track}</span>
          <span class="article-meta-detail">{chapter}</span>
          <span class="article-meta-detail">{siteCategory}</span>
        </div>
        <h1 class="article-title">{title}</h1>
        <p class="article-dek">{dek}</p>
        {tags.length > 0 && (
          <div class="article-tags">
            {tags.map((tag) => (
              <span class="article-tag">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <aside class="article-journal-note" aria-label="文章導讀">
        <p class="article-journal-label">Space Journal</p>
        <p>從 {track}、{chapter} 到 {siteCategory}，把施工判斷、尺度感與日常使用節奏慢慢說清楚。</p>
      </aside>
    </header>

    <figure class="article-cover">
      <img
        src={ogImage}
        alt={coverAlt}
        width="1600"
        height="900"
        sizes="(max-width: 900px) 100vw, 960px"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </figure>

    {
      htmlContent ? (
        <div class="article-content" set:html={htmlContent} />
      ) : (
        <div class="article-content">
          <slot />
        </div>
      )
    }

    {articleSlug && (
      <ArticleQuestionBox
        articleSlug={articleSlug}
        articleTitle={title}
        articlePathname={articlePathname}
      />
    )}

    {hasSocialOpsAccess && articleSlug && (
      <div class="article-admin-link">
        <a href={privateQuestionPoolHref}>前往私有提問池</a>
      </div>
    )}

    <a href={backHref} class="back-link">{backLabel}</a>
  </article>
</BaseLayout>
