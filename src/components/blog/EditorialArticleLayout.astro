import BaseLayout from "../../layouts/BaseLayout.astro";
import { SOCIAL_OPS_AUTH_CONFIG } from "../../lib/social-ops-auth";

interface Props {
  title: string;
  description: string;
  ogImage: string;
  publishedTime: string;
  modifiedTime?: string;
  structuredData?: unknown;
  track: string;
  chapter: string;
  siteCategory: string;
  tags?: string[];
  kicker?: string;
  dek?: string;
  coverAlt?: string;
  backHref?: string;
  backLabel?: string;
  htmlContent?: string;
  editorialRefreshStamp?: string;
}

const {
  title,
  description,
  ogImage,
  publishedTime,
  modifiedTime = publishedTime,
  structuredData,
  track,
  chapter,
  siteCategory,
  tags = [],
  kicker = "Qingxi Journal",
  dek = description,
  coverAlt = title,
  backHref = "/blog",
  backLabel = "← 返回知識分享",
  htmlContent,
  editorialRefreshStamp,
} = Astro.props;

const articleShellClass = editorialRefreshStamp
  ? "article-shell article-shell-refined"
  : "article-shell";
const articlePathname = Astro.url.pathname;
const articleSlug = articlePathname.startsWith("/blog/")
  ? articlePathname.slice("/blog/".length).replace(/\/$/, "")
  : "";
const hasSocialOpsAccess =
  Astro.cookies.get(SOCIAL_OPS_AUTH_CONFIG.cookieName)?.value === "true";
const privateQuestionPoolHref = articleSlug
  ? `${SOCIAL_OPS_AUTH_CONFIG.defaultNextPath}?article=${encodeURIComponent(articleSlug)}#article-question-pool`
  : SOCIAL_OPS_AUTH_CONFIG.defaultNextPath;
const publicArticleQuestionApiUrl = "/api/article-question";
---

<style>
  .article-shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 5.1rem 1.5rem 6rem;
  }

  .article-header {
    max-width: 860px;
    margin: 0 auto 3.1rem;
    text-align: center;
  }

  .article-shell-refined .article-header {
    position: relative;
  }

  .article-shell-refined .article-header::after {
    content: "";
    position: absolute;
    top: 0.45rem;
    right: 0.25rem;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: rgba(51, 46, 41, 0.14);
    box-shadow: 0 0 0 3px rgba(255, 252, 248, 0.72);
    pointer-events: none;
  }

  .article-kicker {
    margin: 0 0 1rem;
    color: var(--art-accent-text);
    font-size: 0.78rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .article-meta {
    justify-content: center;
    align-items: center;
    display: flex;
    gap: 1rem;
    margin-bottom: 1.05rem;
    font-size: 0.84rem;
    letter-spacing: 0.14em;
    color: #7a756f;
    flex-wrap: wrap;
    text-transform: uppercase;
  }

  .article-category {
    background: rgba(244, 240, 234, 0.88);
    color: var(--art-accent-text);
    padding: 0.38rem 0.82rem;
    border-radius: 999px;
    font-weight: 500;
    letter-spacing: 0.12em;
  }

  .article-meta-detail {
    padding: 0.38rem 0.78rem;
    border-radius: 999px;
    background: rgba(255, 252, 248, 0.84);
    border: 1px solid var(--art-accent-line);
  }

  .article-title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(2.65rem, 4.4vw, 4.45rem);
    font-weight: 600;
    color: #332e29;
    line-height: 1.36;
    letter-spacing: 0.024em;
  }

  .article-dek {
    max-width: 42rem;
    margin: 1.2rem auto 0;
    color: #6a645d;
    font-size: 1.04rem;
    line-height: 1.9;
    letter-spacing: 0.008em;
  }

  .article-tags {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin: 1.05rem auto 0;
    max-width: 42rem;
  }

  .article-tag {
    padding: 0.35rem 0.72rem;
    border-radius: 999px;
    background: rgba(244, 240, 234, 0.84);
    color: #6a645d;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
  }

  .article-cover {
    max-width: 980px;
    width: 100%;
    margin: 0 auto 3.15rem;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 26px 60px rgba(58, 52, 46, 0.12);
    border: 1px solid var(--art-accent-line);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92),
      rgba(243, 246, 246, 0.92)
    );
  }

  .article-cover img {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .article-content {
    max-width: 720px;
    margin: 0 auto;
    font-family: var(--font-serif);
    font-size: 1.08rem;
    font-weight: 400;
    line-height: 1.96;
    color: #463f39;
    letter-spacing: 0.012em;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  .article-content :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.85rem;
    font-weight: 600;
    color: #332e29;
    margin-top: 4.2rem;
    margin-bottom: 1.2rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid rgba(164, 171, 160, 0.22);
    letter-spacing: 0.014em;
    line-height: 1.46;
  }

  .article-content :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.34rem;
    font-weight: 600;
    color: #49423c;
    margin-top: 2.15rem;
    margin-bottom: 0.8rem;
    letter-spacing: 0.012em;
    line-height: 1.58;
  }

  .article-content :global(p) {
    margin: 0 0 1.55rem;
  }

  .article-content :global(.article-lead) {
    font-size: 1.22rem;
    line-height: 1.92;
    color: #3f3832;
    letter-spacing: 0.014em;
    margin-bottom: 2rem;
  }

  .article-content :global(strong) {
    color: #332e29;
    font-weight: 600;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 0 0 1.75rem;
    padding-left: 1.35rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.85rem;
    padding-left: 0.2rem;
  }

  .article-content :global(blockquote) {
    margin: 2.5rem 0 2.65rem;
    padding: 1.15rem 1.35rem 1.15rem 1.5rem;
    border-top: 0;
    border-bottom: 0;
    border-left: 2px solid rgba(150, 160, 150, 0.46);
    border-radius: 0 14px 14px 0;
    background: linear-gradient(
      135deg,
      rgba(244, 240, 234, 0.62),
      rgba(244, 240, 234, 0.2)
    );
    color: #5b544d;
    font-size: 1rem;
    line-height: 1.84;
    letter-spacing: 0.01em;
  }

  .article-content :global(a) {
    color: var(--art-accent-text);
    text-decoration: underline;
    text-decoration-color: rgba(124, 131, 122, 0.32);
    text-underline-offset: 0.16em;
  }

  .article-content :global(img) {
    width: 100%;
    display: block;
    border-radius: 18px;
    box-shadow: 0 18px 42px rgba(58, 52, 46, 0.1);
    background: #f7f4ee;
    border: 1px solid var(--art-accent-line);
    margin: 2.45rem 0 0;
  }

  .article-content :global(.image-caption) {
    max-width: 32rem;
    margin: 0.95rem auto 2.2rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.72;
    color: #8a837b;
    text-align: center;
    letter-spacing: 0.01em;
  }

  .article-content :global(.article-figure) {
    margin: 2.45rem 0 2.7rem;
  }

  .article-content :global(.article-figure img) {
    margin: 0;
  }

  .article-content :global(.article-figure figcaption) {
    max-width: 32rem;
    margin: 0.82rem auto 0;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.7;
    color: #8a837b;
    text-align: center;
    letter-spacing: 0.01em;
  }

  .article-content :global(.article-gallery) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.45rem;
    margin: 2.7rem 0 0.55rem;
  }

  .article-content :global(.article-insight-panel) {
    margin: 2.35rem 0 2.7rem;
    padding: 1.35rem 1.45rem 1.45rem;
    border-radius: 22px;
    border: 1px solid rgba(164, 171, 160, 0.22);
    background: linear-gradient(
      180deg,
      rgba(255, 252, 248, 0.94),
      rgba(244, 240, 234, 0.68)
    );
    box-shadow: 0 18px 42px rgba(58, 52, 46, 0.07);
  }

  .article-content :global(.article-insight-label) {
    display: inline-flex;
    align-items: center;
    margin: 0 0 0.8rem;
    padding: 0.35rem 0.72rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(164, 171, 160, 0.22);
    font-family: var(--font-sans);
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    color: #6f685f;
    text-transform: uppercase;
  }

  .article-content :global(.article-insight-title) {
    margin: 0 0 0.7rem;
    font-family: var(--font-serif);
    font-size: 1.28rem;
    line-height: 1.55;
    color: #352f2a;
  }

  .article-content :global(.article-insight-panel p:last-child) {
    margin-bottom: 0;
  }

  .article-content :global(.article-card-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.1rem;
    margin: 2.25rem 0 2.5rem;
  }

  .article-content :global(.article-card) {
    padding: 1.2rem 1.2rem 1.15rem;
    border-radius: 20px;
    border: 1px solid rgba(164, 171, 160, 0.22);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 14px 30px rgba(58, 52, 46, 0.06);
  }

  .article-content :global(.article-card h3) {
    margin-top: 0;
    margin-bottom: 0.55rem;
  }

  .article-content :global(.article-card p:last-child) {
    margin-bottom: 0;
  }

  .article-content :global(.article-card ul:last-child) {
    margin-bottom: 0;
  }

  .article-content :global(.article-card-kicker) {
    display: inline-block;
    margin: 0 0 0.62rem;
    font-family: var(--font-sans);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #8a837b;
  }

  .article-content :global(.article-check-grid) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.95rem;
    margin: 2.1rem 0 2.45rem;
  }

  .article-content :global(.article-check-item) {
    padding: 1.05rem 1rem;
    border-radius: 18px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92),
      rgba(247, 244, 238, 0.88)
    );
    border: 1px solid rgba(164, 171, 160, 0.18);
    box-shadow: 0 12px 26px rgba(58, 52, 46, 0.05);
  }

  .article-content :global(.article-check-item strong) {
    display: block;
    margin-bottom: 0.35rem;
  }

  .article-content :global(.article-check-item p) {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.78;
  }

  .article-content :global(.article-step-flow) {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin: 2.25rem 0 2.6rem;
    padding-top: 1.45rem;
  }

  .article-content :global(.article-step-flow::before) {
    content: "";
    position: absolute;
    top: 0.45rem;
    left: 1.35rem;
    right: 1.35rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(164, 171, 160, 0.12) 0%, rgba(164, 171, 160, 0.5) 18%, rgba(164, 171, 160, 0.5) 82%, rgba(164, 171, 160, 0.12) 100%);
  }

  .article-content :global(.article-step-card) {
    position: relative;
    padding: 1.7rem 1.15rem 1.15rem;
    border-radius: 20px;
    border: 1px solid rgba(164, 171, 160, 0.2);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(246, 242, 236, 0.88));
    box-shadow: 0 16px 34px rgba(58, 52, 46, 0.06);
  }

  .article-content :global(.article-step-card::before) {
    content: "";
    position: absolute;
    top: -1rem;
    left: 1.1rem;
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: #8a837b;
    box-shadow: 0 0 0 6px rgba(250, 247, 242, 0.96);
  }

  .article-content :global(.article-step-index) {
    display: inline-flex;
    align-items: center;
    margin: 0 0 0.7rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #7b736b;
  }

  .article-content :global(.article-step-card h3) {
    margin-top: 0;
    margin-bottom: 0.55rem;
  }

  .article-content :global(.article-step-card p:last-child) {
    margin-bottom: 0;
  }

  .article-content :global(.article-reference-table-wrap) {
    margin: 2.2rem 0 2.55rem;
    border-radius: 24px;
    border: 1px solid rgba(164, 171, 160, 0.2);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.95),
      rgba(247, 244, 238, 0.94)
    );
    box-shadow: 0 18px 40px rgba(58, 52, 46, 0.06);
    overflow: hidden;
  }

  .article-content :global(.article-reference-table-scroll) {
    overflow-x: auto;
  }

  .article-content :global(.article-reference-table) {
    width: 100%;
    min-width: 720px;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: 0.94rem;
    line-height: 1.72;
  }

  .article-content :global(.article-reference-table thead) {
    background: rgba(244, 240, 234, 0.88);
  }

  .article-content :global(.article-reference-table th) {
    padding: 1rem 1rem 0.95rem;
    text-align: left;
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6f685f;
    border-bottom: 1px solid rgba(164, 171, 160, 0.2);
  }

  .article-content :global(.article-reference-table td) {
    padding: 1rem;
    vertical-align: top;
    color: #4a433d;
    border-bottom: 1px solid rgba(164, 171, 160, 0.14);
  }

  .article-content :global(.article-reference-table tbody tr:last-child td) {
    border-bottom: 0;
  }

  .article-content :global(.article-reference-table td:first-child) {
    font-weight: 600;
    color: #352f2a;
    white-space: nowrap;
  }

  .article-content :global(.article-reference-table-note) {
    margin: 0;
    padding: 0.95rem 1rem 1rem;
    border-top: 1px solid rgba(164, 171, 160, 0.14);
    font-family: var(--font-sans);
    font-size: 0.86rem;
    line-height: 1.68;
    color: #7c746c;
    background: rgba(255, 255, 255, 0.55);
  }

  .article-admin-link {
    margin: 2rem auto 0;
    max-width: 720px;
    display: flex;
    justify-content: flex-end;
  }

  .article-admin-link a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.62rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(164, 171, 160, 0.22);
    background: rgba(255, 252, 248, 0.72);
    color: #6a645d;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-decoration: none;
  }

  .article-admin-link a:hover {
    background: rgba(244, 240, 234, 0.92);
    color: #332e29;
  }

  .article-question-box {
    max-width: 720px;
    margin: 3rem auto 0;
    padding: 1.45rem 1.35rem 1.4rem;
    border-radius: 24px;
    border: 1px solid rgba(164, 171, 160, 0.2);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(249, 246, 241, 0.88));
    box-shadow: 0 18px 34px rgba(58, 52, 46, 0.08);
  }

  .article-question-box-head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .article-question-box-head p,
  .article-question-box-head h2,
  .article-question-box-head small,
  .article-question-feedback {
    margin: 0;
  }

  .article-question-box-head p {
    color: #8a7f74;
    font-family: var(--font-sans);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .article-question-box-head h2 {
    color: #332e29;
    font-family: var(--font-serif);
    font-size: 1.52rem;
    line-height: 1.45;
  }

  .article-question-box-head small {
    color: #746c64;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    line-height: 1.7;
  }

  .article-question-form {
    display: grid;
    gap: 0.95rem;
  }

  .article-question-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .article-question-field {
    display: flex;
    flex-direction: column;
    gap: 0.42rem;
    font-family: var(--font-sans);
  }

  .article-question-field.is-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .article-question-field span {
    color: #5d554d;
    font-size: 0.82rem;
    letter-spacing: 0.03em;
  }

  .article-question-field input,
  .article-question-field textarea {
    width: 100%;
    border-radius: 16px;
    border: 1px solid rgba(164, 171, 160, 0.22);
    background: rgba(255, 252, 248, 0.9);
    color: #332e29;
    font: inherit;
    font-size: 0.95rem;
    line-height: 1.7;
    padding: 0.85rem 0.95rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .article-question-field textarea {
    min-height: 150px;
    resize: vertical;
  }

  .article-question-field input:focus,
  .article-question-field textarea:focus {
    outline: none;
    border-color: rgba(86, 97, 88, 0.34);
    box-shadow: 0 0 0 4px rgba(244, 240, 234, 0.9);
    background: rgba(255, 255, 255, 0.98);
  }

  .article-question-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .article-question-privacy {
    color: #7a726a;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    line-height: 1.7;
  }

  .article-question-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.85rem 1.25rem;
    border: 0;
    border-radius: 999px;
    background: #332e29;
    color: #f7f3ed;
    font-family: var(--font-sans);
    font-size: 0.86rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .article-question-submit:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .article-question-submit:disabled {
    opacity: 0.56;
    cursor: wait;
    transform: none;
  }

  .article-question-feedback {
    min-height: 1.45rem;
    color: #746c64;
    font-family: var(--font-sans);
    font-size: 0.84rem;
    line-height: 1.7;
  }

  .article-question-feedback.is-success {
    color: #4f5a4f;
  }

  .article-question-feedback.is-error {
    color: #8c5045;
  }

  .back-link {
    display: inline-block;
    margin-top: 4rem;
    padding: 0.85rem 1.55rem;
    background: rgba(244, 240, 234, 0.9);
    color: #332e29;
    text-decoration: none;
    border-radius: 999px;
    font-weight: 500;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
    border: 1px solid var(--art-accent-line);
  }

  .back-link:hover {
    background: rgba(236, 231, 224, 0.96);
    transform: translateX(-3px);
  }

  @media (max-width: 768px) {
    .article-shell {
      padding: 4.3rem 1.15rem 5rem;
    }

    .article-header {
      margin-bottom: 2.4rem;
    }

    .article-title {
      font-size: 2.15rem;
    }

    .article-dek,
    .article-content {
      font-size: 1rem;
    }

    .article-content :global(.article-lead) {
      font-size: 1.08rem;
    }

    .article-content :global(h2) {
      font-size: 1.5rem;
      margin-top: 3.35rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
    }

    .article-content :global(.article-gallery) {
      grid-template-columns: 1fr;
      margin-top: 2.2rem;
    }

    .article-content :global(.article-card-grid),
    .article-content :global(.article-check-grid),
    .article-content :global(.article-step-flow) {
      grid-template-columns: 1fr;
      gap: 0.9rem;
    }

    .article-content :global(.article-step-flow) {
      padding-top: 0;
    }

    .article-content :global(.article-step-flow::before) {
      display: none;
    }

    .article-content :global(.article-step-card::before) {
      top: 1rem;
      right: 1rem;
      left: auto;
      width: 10px;
      height: 10px;
      box-shadow: 0 0 0 5px rgba(250, 247, 242, 0.96);
    }

    .article-content :global(.article-insight-panel) {
      padding: 1.15rem 1.1rem 1.2rem;
      margin: 2rem 0 2.2rem;
    }

    .article-cover {
      margin-bottom: 2.45rem;
    }

    .article-admin-link {
      justify-content: flex-start;
      margin-top: 1.7rem;
    }

    .article-question-box {
      margin-top: 2.3rem;
      padding: 1.15rem 1rem 1.05rem;
      border-radius: 20px;
    }

    .article-question-grid {
      grid-template-columns: 1fr;
      gap: 0.7rem;
    }

    .article-question-actions {
      align-items: stretch;
    }

    .article-question-submit {
      width: 100%;
    }

    .article-content :global(blockquote) {
      margin: 2.15rem 0 2.3rem;
      padding: 1rem 1.05rem 1rem 1.2rem;
    }
  }
</style>

<BaseLayout
  title={`${title} - 青曦空間設計`}
  description={description}
  ogImage={ogImage}
  pageType="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  structuredData={structuredData}
>
  <article
    class={articleShellClass}
    data-qingxi-refresh={editorialRefreshStamp}
  >
    <header class="article-header">
      <p class="article-kicker">{kicker}</p>
      <div class="article-meta">
        <span class="article-category">{track}</span>
        <span class="article-meta-detail">{chapter}</span>
        <span class="article-meta-detail">{siteCategory}</span>
      </div>
      <h1 class="article-title">{title}</h1>
      <p class="article-dek">{dek}</p>
      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <span class="article-tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <figure class="article-cover">
      <img src={ogImage} alt={coverAlt} />
    </figure>

    {
      htmlContent ? (
        <div class="article-content" set:html={htmlContent} />
      ) : (
        <div class="article-content">
          <slot />
        </div>
      )
    }

    {articleSlug && (
      <section class="article-question-box" aria-labelledby="article-question-title">
        <div class="article-question-box-head">
          <p>Private Intake</p>
          <h2 id="article-question-title">這篇文章若有延伸問題，可直接私下送出</h2>
          <small>問題會綁定到這一篇文章，只供青曦內部整理、補充 FAQ 與後續內容修訂，不會公開顯示。</small>
        </div>

        <form
          class="article-question-form"
          data-article-question-form
          data-api-url={publicArticleQuestionApiUrl}
          data-article-slug={articleSlug}
          data-article-title={title}
          data-article-url={articlePathname}
        >
          <div class="article-question-grid">
            <label class="article-question-field">
              <span>稱呼</span>
              <input type="text" name="submitterName" maxlength="40" placeholder="方便青曦辨識即可，可不填" />
            </label>

            <label class="article-question-field">
              <span>聯絡方式</span>
              <input type="text" name="contactInfo" maxlength="120" placeholder="Line、Email 或手機，可不填" />
            </label>
          </div>

          <label class="article-question-field">
            <span>你的問題</span>
            <textarea name="question" minlength="8" required placeholder="例如：局部翻新如果先不動天花板，預算與工序要注意哪些風險？"></textarea>
          </label>

          <label class="article-question-field">
            <span>補充背景</span>
            <textarea name="detail" rows="4" placeholder="可補充空間現況、預算範圍、家中成員，或你最卡住的判斷點。"></textarea>
          </label>

          <label class="article-question-field is-hidden" aria-hidden="true">
            <span>公司</span>
            <input type="text" name="company" tabindex="-1" autocomplete="off" />
          </label>

          <div class="article-question-actions">
            <div class="article-question-privacy">送出後不會公開顯示，只會進入青曦內部文章提問池。</div>
            <button type="submit" class="article-question-submit">送出這篇文章的問題</button>
          </div>

          <p class="article-question-feedback" data-article-question-feedback aria-live="polite"></p>
        </form>
      </section>
    )}

    {hasSocialOpsAccess && articleSlug && (
      <div class="article-admin-link">
        <a href={privateQuestionPoolHref}>前往私有提問池</a>
      </div>
    )}

    <a href={backHref} class="back-link">{backLabel}</a>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const form = document.querySelector("[data-article-question-form]");
    const feedback = document.querySelector("[data-article-question-feedback]");
    if (!(form instanceof HTMLFormElement) || !(feedback instanceof HTMLElement)) return;

    const submitButton = form.querySelector('button[type="submit"]');

    const setFeedback = (message, mode = "") => {
      feedback.className = `article-question-feedback ${mode}`.trim();
      feedback.textContent = message;
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const apiUrl = form.dataset.apiUrl || "";
      const articleSlug = form.dataset.articleSlug || "";
      const articleTitle = form.dataset.articleTitle || "";
      const articleUrl = form.dataset.articleUrl || "";
      if (!apiUrl || !articleSlug || !articleTitle) {
        setFeedback("表單設定不完整，請稍後再試。", "is-error");
        return;
      }

      const formData = new FormData(form);
      const question = String(formData.get("question") || "").trim();
      if (question.length < 8) {
        setFeedback("問題至少需要 8 個字，方便青曦判斷重點。", "is-error");
        return;
      }

      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;
      setFeedback("正在送出問題...");

      try {
        const response = await fetch(apiUrl, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify({
            articleSlug,
            articleTitle,
            articleUrl,
            submitterName: String(formData.get("submitterName") || "").trim(),
            contactInfo: String(formData.get("contactInfo") || "").trim(),
            question,
            detail: String(formData.get("detail") || "").trim(),
            company: String(formData.get("company") || "").trim(),
          }),
        });

        const result = await response.json();
        if (!response.ok || result?.status !== "ok") {
          throw new Error(result?.note || `ARTICLE_QUESTION_SUBMIT_FAILED:${response.status}`);
        }

        form.reset();
        setFeedback(result?.note || "問題已送出，青曦會留作後續整理參考。", "is-success");
      } catch (error) {
        console.error("文章提問送出失敗：", error);
        setFeedback(error instanceof Error ? error.message : "問題送出失敗，請稍後再試。", "is-error");
      } finally {
        if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
      }
    });
  })();
</script>
