---
interface Props {
  articleSlug: string;
  articleTitle: string;
  articlePathname: string;
}

const {
  articleSlug,
  articleTitle,
  articlePathname,
} = Astro.props;

const publicArticleQuestionApiUrl = "/api/article-question";
---

<style>
  .article-question-box {
    position: relative;
    max-width: 720px;
    margin: 3.4rem auto 0;
    padding: 1.65rem 0 0;
    border-radius: 0;
    border: 0;
    background: transparent;
    box-shadow: none;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(220px, 0.9fr);
    column-gap: 2rem;
    align-items: start;
  }

  .article-question-box::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: min(220px, 42%);
    height: 1px;
    background: linear-gradient(90deg, rgba(115, 103, 94, 0.52), rgba(115, 103, 94, 0.08));
  }

  .article-question-box::after {
    content: "";
    position: absolute;
    top: 0.72rem;
    right: 0;
    width: min(110px, 18%);
    height: 1px;
    background: linear-gradient(90deg, rgba(164, 171, 160, 0.08), rgba(164, 171, 160, 0.24));
  }

  .article-question-box-head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0;
  }

  .article-question-box-head p,
  .article-question-box-head h2,
  .article-question-box-head small,
  .article-question-feedback {
    margin: 0;
  }

  .article-question-box-head p {
    color: var(--gray-medium);
    font-family: var(--font-sans);
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .article-question-box-head h2 {
    color: var(--gray-darkest);
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2vw, 1.9rem);
    line-height: 1.26;
    letter-spacing: 0.035em;
    max-width: 15ch;
  }

  .article-question-box-head small {
    color: color-mix(in srgb, var(--gray-darkest) 60%, transparent);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    line-height: 1.74;
    max-width: 24rem;
  }

  .article-question-form {
    display: grid;
    gap: 0.95rem;
    grid-column: 1 / -1;
    margin-top: 1.4rem;
  }

  .article-question-trust-row {
    display: grid;
    gap: 0.4rem;
    align-self: start;
    padding-top: 0.1rem;
  }

  .article-question-trust-chip {
    display: inline-flex;
    align-items: center;
    min-height: auto;
    padding: 0 0 0 0.95rem;
    border: 0;
    background: transparent;
    color: var(--gray-medium);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    line-height: 1.55;
    letter-spacing: 0.03em;
    position: relative;
  }

  .article-question-trust-chip::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62rem;
    width: 0.52rem;
    height: 1px;
    background: rgba(115, 103, 94, 0.42);
  }

  .article-question-field {
    display: flex;
    flex-direction: column;
    gap: 0.42rem;
    font-family: var(--font-sans);
  }

  .article-question-field.is-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .article-question-field span {
    color: var(--gray-dark);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
  }

  .article-question-field input,
  .article-question-field textarea {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
    border-radius: 14px;
    border: 1px solid rgba(164, 171, 160, 0.18);
    background: rgba(255, 252, 248, 0.72);
    color: var(--gray-darkest);
    font: inherit;
    font-size: 0.94rem;
    line-height: 1.7;
    padding: 0.82rem 0.9rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .article-question-field textarea {
    min-height: 112px;
    resize: none;
  }

  .article-question-field input:focus,
  .article-question-field textarea:focus {
    outline: none;
    border-color: rgba(86, 97, 88, 0.34);
    box-shadow: 0 0 0 4px rgba(244, 240, 234, 0.9);
    background: rgba(255, 255, 255, 0.98);
  }

  .article-question-field--primary textarea {
    min-height: 128px;
  }

  .article-question-hint {
    margin: 0;
    color: var(--gray-medium);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    line-height: 1.65;
  }

  .article-question-meta {
    border: 0;
    border-top: 1px solid rgba(164, 171, 160, 0.16);
    border-bottom: 1px solid rgba(164, 171, 160, 0.12);
    background: transparent;
    overflow: visible;
  }

  .article-question-meta summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    padding: 0.85rem 0;
    color: var(--gray-dark);
    font-family: var(--font-sans);
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .article-question-meta summary::-webkit-details-marker {
    display: none;
  }

  .article-question-meta-summary-copy {
    display: grid;
    gap: 0.18rem;
  }

  .article-question-meta-summary-copy strong,
  .article-question-meta-summary-copy small {
    margin: 0;
    font: inherit;
  }

  .article-question-meta-summary-copy small {
    color: var(--gray-medium);
    font-size: 0.76rem;
    font-weight: 400;
    line-height: 1.6;
  }

  .article-question-meta-summary-toggle {
    flex-shrink: 0;
    color: var(--gray-medium);
    font-size: 0.76rem;
    font-weight: 500;
  }

  .article-question-meta[open] summary {
    border-bottom: 1px solid rgba(164, 171, 160, 0.12);
    background: transparent;
  }

  .article-question-meta-body {
    display: grid;
    gap: 0.8rem;
    padding: 0.95rem 0 1rem;
  }

  .article-question-actions {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.35rem;
    border-top: 1px solid rgba(164, 171, 160, 0.1);
  }

  .article-question-privacy {
    color: var(--gray-medium);
    font-family: var(--font-sans);
    font-size: 0.82rem;
    line-height: 1.7;
    max-width: 28rem;
  }

  .article-question-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    flex-shrink: 0;
    padding: 0.76rem 0.98rem;
    border-radius: 999px;
    background: rgba(255, 252, 248, 0.5);
    color: var(--gray-darkest);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease, background-color 0.2s ease;
    box-shadow: inset 0 0 0 1px rgba(115, 103, 94, 0.14);
  }

  .article-question-submit:hover {
    background: rgba(244, 240, 234, 0.68);
    transform: translateY(-1px);
  }

  .article-question-submit:disabled {
    opacity: 0.56;
    cursor: wait;
    transform: none;
  }

  .article-question-feedback {
    min-height: 1.45rem;
    color: var(--gray-medium);
    font-family: var(--font-sans);
    font-size: 0.84rem;
    line-height: 1.7;
  }

  .article-question-feedback.is-success {
    color: var(--gray-dark);
  }

  .article-question-feedback.is-error {
    color: var(--art-accent-solid);
  }

  @media (max-width: 768px) {
    .article-question-box {
      margin-top: 2.3rem;
      padding: 1.2rem 0 0;
      grid-template-columns: 1fr;
      row-gap: 0.9rem;
      column-gap: 0;
    }

    .article-question-box::after {
      display: none;
    }

    .article-question-box-head h2 {
      font-size: 1.15rem;
      max-width: none;
    }

    .article-question-actions {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.8rem;
    }

    .article-question-trust-row {
      gap: 0.35rem;
    }

    .article-question-submit {
      width: auto;
      min-width: 10.5rem;
      padding-left: 0.92rem;
      padding-right: 0.92rem;
    }

    .article-question-meta summary,
    .article-question-meta-body {
      padding-left: 0;
      padding-right: 0;
    }

    .article-question-form {
      margin-top: 0.7rem;
    }
  }
</style>

<section class="article-question-box" aria-label="文章提問表單">
  <div class="article-question-box-head">
    <p>文章延伸提問</p>
    <h2>看完這篇，還有卡住的地方？</h2>
    <small>請直接留下疑問，內容將做為青曦後續補充與修訂文章的參考。</small>
  </div>

  <div class="article-question-trust-row" aria-label="提問說明">
    <span class="article-question-trust-chip">一句話也可以</span>
    <span class="article-question-trust-chip">可不留聯絡方式</span>
    <span class="article-question-trust-chip">不會公開顯示</span>
  </div>

  <form
    class="article-question-form"
    data-article-question-form="true"
    data-api-url={publicArticleQuestionApiUrl}
    data-article-slug={articleSlug}
    data-article-title={articleTitle}
    data-article-url={articlePathname}
  >
    <label class="article-question-field article-question-field--primary">
      <span>你的問題</span>
      <textarea name="question" minlength="8" required placeholder="例如：局部翻新如果先不動天花板，預算與工序要注意哪些風險？"></textarea>
    </label>
    <p class="article-question-hint">無須整理成完整需求，簡單一句話即可。</p>

    <details class="article-question-meta">
      <summary>
        <span class="article-question-meta-summary-copy">
          <strong>補充背景或聯絡方式</strong>
          <small>協助青曦精準理解情境；若留下聯絡方式，將於文章補充或解答時主動回覆。</small>
        </span>
        <span class="article-question-meta-summary-toggle">選填</span>
      </summary>
      <div class="article-question-meta-body">
        <label class="article-question-field">
          <span>補充背景</span>
          <textarea name="detail" rows="3" placeholder="可補充空間現況、預算範圍、家中成員，或你最卡住的判斷點。"></textarea>
        </label>

        <label class="article-question-field">
          <span>稱呼</span>
          <input type="text" name="submitterName" maxlength="40" placeholder="方便青曦辨識（選填）" />
        </label>

        <label class="article-question-field">
          <span>聯絡方式</span>
          <input type="text" name="contactInfo" maxlength="120" placeholder="Line、Email 或手機（選填）" />
        </label>
      </div>
    </details>

    <label class="article-question-field is-hidden" aria-hidden="true">
      <span>公司</span>
      <input type="text" name="company" tabindex="-1" autocomplete="off" />
    </label>

    <div class="article-question-actions">
      <div class="article-question-privacy">送出後只會進入青曦內部提問池，不會在網站上公開。</div>
      <button type="submit" class="article-question-submit">送出問題</button>
    </div>

    <p class="article-question-feedback" data-article-question-feedback="true" aria-live="polite"></p>
  </form>
</section>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-article-question-form="true"]');
    const feedback = document.querySelector('[data-article-question-feedback="true"]');
    if (!(form instanceof HTMLFormElement) || !(feedback instanceof HTMLElement)) return;

    const submitButton = form.querySelector('button[type="submit"]');

    const setFeedback = (message, mode = "") => {
      feedback.className = `article-question-feedback ${mode}`.trim();
      feedback.textContent = message;
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const apiUrl = form.dataset.apiUrl || "";
      const question = String(new FormData(form).get("question") || "").trim();
      if (!apiUrl) {
        setFeedback("表單設定不完整，請稍後再試。", "is-error");
        return;
      }
      if (question.length < 8) {
        setFeedback("問題至少需要 8 個字，方便青曦判斷重點。", "is-error");
        return;
      }

      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;
      setFeedback("正在送出問題...");

      try {
        const formData = new FormData(form);
        const response = await fetch(apiUrl, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify({
            articleSlug: form.dataset.articleSlug || "",
            articleTitle: form.dataset.articleTitle || "",
            articleUrl: form.dataset.articleUrl || "",
            submitterName: String(formData.get("submitterName") || "").trim(),
            contactInfo: String(formData.get("contactInfo") || "").trim(),
            question,
            detail: String(formData.get("detail") || "").trim(),
            company: String(formData.get("company") || "").trim(),
          }),
        });

        const result = await response.json();
        if (!response.ok || result?.status !== "ok") {
          throw new Error(result?.note || `ARTICLE_QUESTION_SUBMIT_FAILED:${response.status}`);
        }

        form.reset();
        setFeedback(result?.note || "問題已送出，青曦會留作後續整理參考。", "is-success");
      } catch (error) {
        console.error("文章提問送出失敗：", error);
        setFeedback(error instanceof Error ? error.message : "問題送出失敗，請稍後再試。", "is-error");
      } finally {
        if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
      }
    });
  })();
</script>
