---
// 首頁主視覺 - 單張大圖，點擊進入專案圖集
const heroProject = {
  title: '青曦空間設計作品',
  image: '/images/汐止中興路-客廳-01.jpg',
  slug: 'xizhi-zhongxing-rd',
};
---

<section
  id="hero-banner"
  style="position:relative; width:100%; height:100vh; overflow:hidden; background:#000; margin-top:-80px;"
>
  <a
    href={`/portfolio/${heroProject.slug}`}
    style="display:block; width:100%; height:100%; cursor:pointer; text-decoration:none;"
    aria-label="查看作品"
  >
    <img 
      id="hero-img"
      src={heroProject.image} 
      alt={heroProject.title}
      loading="eager"
      style="width:100%; height:100%; object-fit:cover; object-position:center;"
    />
  </a>
</section>

<style is:inline>
  @keyframes heroSlowZoom {
    0%   { transform: scale(1); }
    100% { transform: scale(1.15); }
  }
  #hero-img {
    animation: heroSlowZoom 15s ease-in-out forwards;
    will-change: transform;
  }
  @media (max-width: 768px) {
    #hero-banner {
      height: 50vh !important;
    }
  }
</style>
