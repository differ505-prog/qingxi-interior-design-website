---
const { title, coverImage, summary, slug } = Astro.props;
---

<style>
  .card {
    display: block;
    background: linear-gradient(180deg, rgba(255, 253, 249, 0.72) 0%, rgba(245, 241, 236, 0.56) 100%);
    border-radius: 30px;
    box-shadow: 0 24px 60px rgba(var(--brand-dark-rgb), 0.08), inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    overflow: hidden;
    backdrop-filter: blur(24px) saturate(135%);
    transition:
      transform var(--motion-duration) var(--motion-standard),
      box-shadow var(--motion-duration) var(--motion-standard);
    text-decoration: none;
    color: inherit;
  }
  
  .card:hover {
    transform: translateY(-12px);
    box-shadow: 0 32px 76px rgba(var(--brand-dark-rgb), 0.12);
  }

  .card-media {
    position: relative;
    overflow: hidden;
    background: var(--gray-bg);
    min-height: 200px;
  }
  
  .card img {
    width: 100%;
    height: 20rem;
    object-fit: cover;
    transition: transform 1.05s var(--motion-standard);
    background-color: var(--gray-bg);
    min-height: 200px;
  }
  
  .card:hover img {
    transform: scale(1.05);
  }

  .card-badge {
    position: absolute;
    left: 1.25rem;
    top: 1.25rem;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: rgba(20, 20, 20, 0.42);
    color: var(--white);
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    backdrop-filter: blur(18px);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }
  
  .card-content {
    padding: 1.9rem 1.8rem 2rem;
  }
  
  .card h3 {
    font-size: clamp(1.9rem, 3vw, 2.7rem);
    font-weight: 760;
    font-family: var(--font-sans);
    color: var(--gray-darkest);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.045em;
    transition: color var(--motion-duration-fast) var(--motion-standard);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  
  .card:hover h3 {
    color: var(--gray-darkest);
  }
  
  .card p {
    color: color-mix(in srgb, var(--gray-darkest) 62%, transparent);
    line-height: 1.82;
    margin: 1rem 0 0;
    letter-spacing: 0.01em;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1.55rem;
    color: var(--art-accent-text);
    font-size: 0.9rem;
    letter-spacing: 0.08em;
  }

  .card-link::after {
    content: "→";
    transition: transform var(--motion-duration-fast) var(--motion-standard);
  }

  .card:hover .card-link::after {
    transform: translateX(3px);
  }
</style>

<a href={`/portfolio/${slug}`} class="card">
  <div class="card-media">
    <img
      src={coverImage}
      alt={title}
      width="1200"
      height="900"
      loading="lazy"
      decoding="async"
    />
    <span class="card-badge">CURATED SPACE</span>
  </div>
  <div class="card-content">
    <h3>{title}</h3>
    <p>{summary}</p>
    <span class="card-link">空間細節</span>
  </div>
</a>
