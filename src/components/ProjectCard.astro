---
const { title, coverImage, summary, slug } = Astro.props;
---

<style>
  .card {
    display: block;
    background: linear-gradient(180deg, rgba(255, 253, 249, 0.98) 0%, rgba(245, 241, 236, 1) 100%);
    border-radius: 24px;
    box-shadow: 0 18px 45px rgba(58, 52, 46, 0.08);
    border: 1px solid var(--art-accent-line);
    overflow: hidden;
    transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
    text-decoration: none;
    color: inherit;
  }
  
  .card:hover {
    transform: translateY(-10px);
    box-shadow: 0 24px 50px rgba(58, 52, 46, 0.12);
    border-color: var(--art-accent-line-strong);
  }

  .card-media {
    position: relative;
    overflow: hidden;
    background: var(--gray-bg);
  }
  
  .card img {
    width: 100%;
    height: 20rem;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  
  .card:hover img {
    transform: scale(1.05);
  }

  .card-badge {
    position: absolute;
    left: 1.25rem;
    top: 1.25rem;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: rgba(20, 20, 20, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: var(--white);
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    backdrop-filter: blur(10px);
  }
  
  .card-content {
    padding: 1.6rem 1.6rem 1.8rem;
  }
  
  .card h3 {
    font-size: 1.55rem;
    font-weight: 500;
    font-family: 'Noto Serif TC', serif;
    color: var(--gray-darkest);
    margin: 0;
    transition: color 0.3s ease;
  }
  
  .card:hover h3 {
    color: var(--gray-darkest);
  }
  
  .card p {
    color: var(--gray-medium);
    line-height: 1.8;
    margin: 0.85rem 0 0;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1.25rem;
    color: var(--art-accent-text);
    font-size: 0.9rem;
    letter-spacing: 0.08em;
  }

  .card-link::after {
    content: "→";
    transition: transform 0.25s ease;
  }

  .card:hover .card-link::after {
    transform: translateX(3px);
  }
</style>

<a href={`/portfolio/${slug}`} class="card">
  <div class="card-media">
    <img src={coverImage} alt={title} />
    <span class="card-badge">CURATED SPACE</span>
  </div>
  <div class="card-content">
    <h3>{title}</h3>
    <p>{summary}</p>
    <span class="card-link">進入空間</span>
  </div>
</a>
