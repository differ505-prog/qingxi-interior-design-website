---
import BookshelfCard from "./BookshelfCard.astro";

type CannedReplyEntry = {
  id: string;
  category: string;
  promptTitle: string;
  promptHint: string;
  message: string;
};

interface Props {
  replies: ReadonlyArray<CannedReplyEntry>;
}

const { replies } = Astro.props;
---

<details class="ops-panel bookshelf-canned-replies bookshelf-canned-replies-priority ops-canned-sidebar" data-default-folded="true">
  <summary class="ops-fold-summary">
    <div>
      <p class="panel-tag">快速工具</p>
      <h2>常見罐頭回覆</h2>
    </div>
    <small>展開查看</small>
  </summary>
  <div class="panel-heading panel-heading-compact">
    <div>
      <p class="panel-tag">快速工具</p>
      <h2>常見罐頭回覆</h2>
    </div>
      <p>可直接複製貼上</p>
  </div>
  <div class="bookshelf-reply-grid bookshelf-canned-grid">
    {replies.map((reply) => (
      <BookshelfCard variant="canned-reply" entry={reply} />
    ))}
  </div>
</details>
