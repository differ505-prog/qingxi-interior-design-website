---
import BookshelfCard from "./BookshelfCard.astro";

type PromptLibraryEntry = {
  id: string;
  category: string;
  title: string;
  hint: string;
  note: string;
  prompt: string;
};

interface Props {
  entries: ReadonlyArray<PromptLibraryEntry>;
  feedbackId?: string;
}

const { entries, feedbackId = "prompt-library-feedback" } = Astro.props;
---

<section class="bookshelf-prompt-library">
  <div class="bookshelf-preview-head">
    <p>提示詞專區</p>
  </div>
  <div class="bookshelf-prompt-library-grid">
    {entries.map((entry) => (
      <BookshelfCard variant="prompt-library" entry={entry} />
    ))}
  </div>
  <p id={feedbackId} class="bookshelf-ai-feedback" aria-live="polite"></p>
</section>
