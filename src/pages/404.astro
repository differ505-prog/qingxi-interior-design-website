---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 - 找不到頁面" description="抱歉，您訪問的頁面不存在" noindex={true}>
    <div class="error-container">
        <div class="error-content">
            <div class="error-animation">
                <div class="error-number">404</div>
                <div class="error-icon">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                </div>
            </div>

            <h1>找不到頁面</h1>
            <p class="error-message">抱歉，您訪問的頁面不存在或已被移除</p>

            <div class="error-actions">
                <a href="/" class="btn btn-primary">返回首頁</a>
                <a href="/contact" class="btn btn-secondary">聯絡我們</a>
            </div>

            <div class="quick-links">
                <h3>您可能在尋找...</h3>
                <ul>
                    <li><a href="/portfolio">查看精選作品</a></li>
                    <li><a href="/blog">閱讀知識分享</a></li>
                    <li><a href="/tools">開始裝修估價</a></li>
                    <li><a href="/requirement-form">填寫需求表</a></li>
                </ul>
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    .error-container {
        min-height: calc(100vh - 80px);
        margin-top: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background: linear-gradient(
            135deg,
            var(--off-white) 0%,
            var(--gray-bg) 100%
        );
    }

    .error-content {
        max-width: 600px;
        text-align: center;
    }

    .error-animation {
        position: relative;
        margin-bottom: 2rem;
    }

    .error-number {
        font-size: 8rem;
        font-weight: 700;
        color: var(--gray-lighter);
        line-height: 1;
        margin-bottom: 1rem;
        font-family: "Noto Sans", sans-serif;
        animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-20px);
        }
    }

    .error-icon {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100px;
        height: 100px;
        color: var(--tiffany-primary);
        animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }
        50% {
            opacity: 0.6;
            transform: translate(-50%, -50%) scale(1.1);
        }
    }

    .error-icon svg {
        width: 100%;
        height: 100%;
    }

    h1 {
        font-size: 2.5rem;
        font-weight: 600;
        color: var(--gray-dark);
        margin-bottom: 1rem;
    }

    .error-message {
        font-size: 1.1rem;
        color: var(--gray-medium);
        margin-bottom: 2.5rem;
        line-height: 1.6;
    }

    .error-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-bottom: 3rem;
    }

    .btn {
        padding: 0.875rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 500;
        font-size: 1rem;
        transition: all 0.3s ease;
        display: inline-block;
    }

    .btn-primary {
        background: var(--tiffany-primary);
        color: var(--white);
        border: 2px solid var(--tiffany-primary);
    }

    .btn-primary:hover {
        background: var(--tiffany-dark);
        border-color: var(--tiffany-dark);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(108, 120, 118, 0.3);
    }

    .btn-secondary {
        background: var(--white);
        color: var(--tiffany-primary);
        border: 2px solid var(--tiffany-primary);
    }

    .btn-secondary:hover {
        background: var(--tiffany-pale);
        transform: translateY(-2px);
    }

    .quick-links {
        background: var(--white);
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        border: 2px solid var(--gray-lighter);
    }

    .quick-links h3 {
        font-size: 1.25rem;
        color: var(--gray-dark);
        margin-bottom: 1.5rem;
        font-weight: 500;
    }

    .quick-links ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .quick-links li {
        margin: 0;
    }

    .quick-links a {
        display: block;
        padding: 0.75rem 1rem;
        background: var(--off-white);
        border: 2px solid var(--gray-bg);
        border-radius: 8px;
        color: var(--gray-dark);
        text-decoration: none;
        transition: all 0.3s ease;
        text-align: center;
        font-size: 0.95rem;
    }

    .quick-links a:hover {
        background: var(--tiffany-pale);
        border-color: var(--tiffany-light);
        color: var(--tiffany-primary);
        transform: translateY(-2px);
    }

    @media (max-width: 768px) {
        .error-container {
            margin-top: 60px;
            padding: 1.5rem;
        }

        .error-number {
            font-size: 6rem;
        }

        .error-icon {
            width: 80px;
            height: 80px;
        }

        h1 {
            font-size: 2rem;
        }

        .error-message {
            font-size: 1rem;
        }

        .error-actions {
            flex-direction: column;
        }

        .btn {
            width: 100%;
        }

        .quick-links ul {
            grid-template-columns: 1fr;
        }
    }
</style>
