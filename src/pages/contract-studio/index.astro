---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  contractDefaultChecklist,
  contractDefaultMaterialSpecs,
  contractDefaultPaymentStages,
  contractDefaultSections,
} from "../../lib/contract-studio";
import { isContractLinkStorageConfigured } from "../../lib/contract-link-store";

const contractDefaultPaymentStagesJson = JSON.stringify(contractDefaultPaymentStages);
const contractDefaultSectionsJson = JSON.stringify(contractDefaultSections);
const contractDefaultChecklistJson = JSON.stringify(contractDefaultChecklist);
const contractDefaultMaterialSpecsJson = JSON.stringify(contractDefaultMaterialSpecs);
const shortLinkStorageConfigured = isContractLinkStorageConfigured();
const shortLinkStorageConfiguredJson = JSON.stringify(shortLinkStorageConfigured);
---

<BaseLayout
  title="合約工作台 - 青曦空間設計"
  description="青曦內部使用的合約工作台，可整理合約內容並生成客戶簽署頁。"
  noindex={true}
>
  <section class="contract-studio-page">
    <div class="contract-studio-shell">
      <header class="studio-hero">
        <div>
          <p class="studio-eyebrow">INTERNAL CONTRACT STUDIO</p>
          <h1>合約工作台</h1>
          <p class="studio-description">
            先整理合約摘要、付款節點與條款，再產生給客戶手機簽署的專屬連結。
          </p>
        </div>
        <div class="studio-actions">
          <a id="open-sign-link" href="/contract-studio/sign" target="_blank" rel="noreferrer" class="btn btn-primary">
            預覽客戶簽署頁
          </a>
          <button type="button" id="copy-sign-link" class="btn btn-secondary">複製給客戶的簽約連結</button>
          <button type="button" id="copy-contract-llm-review" class="btn btn-secondary">複製 LLM 合約覆核文字</button>
          <button type="button" id="reset-contract" class="btn btn-secondary btn-muted">重設本次合約</button>
        </div>
        <p class="studio-route-note">此頁未加入前台導覽，且已設為 `noindex`；若已接上 Vercel KV，分享會優先產生短簽約連結，未接上時則自動退回內嵌長連結。</p>
        <div id="share-link-status" class:list={["share-link-status", shortLinkStorageConfigured ? "is-ready" : "is-warning"]}>
          <strong>{shortLinkStorageConfigured ? "短簽約連結已啟用" : "短簽約連結尚未啟用"}</strong>
          <p id="share-link-status-note">
            {
              shortLinkStorageConfigured
                ? "目前分享給客戶時，會優先產生較短的 token 簽約連結，比較適合直接傳 LINE。"
                : "目前仍會退回完整長連結；請在 Vercel 補上 KV_REST_API_URL 與 KV_REST_API_TOKEN 後重新部署。"
            }
          </p>
        </div>
        <p id="share-link-feedback" class="share-link-feedback" aria-live="polite"></p>
      </header>

      <div class="studio-grid">
        <div class="studio-main">
          <section class="studio-card">
            <div class="section-heading">
              <h2>合約基本資訊</h2>
              <p>這些內容會直接顯示在客戶簽署頁，建議與本案報價或材料確認表一致。</p>
            </div>
            <div class="form-grid">
              <label class="field">
                <span>合約標題</span>
                <input data-field="contractTitle" type="text" placeholder="例如：住宅空間裝修工程合約書" />
              </label>
              <label class="field">
                <span>合約編號</span>
                <input data-field="contractNumber" type="text" placeholder="例如：QX-202606-001" />
              </label>
              <label class="field">
                <span>客戶姓名</span>
                <input data-field="clientName" type="text" placeholder="例如：王小姐" />
              </label>
              <label class="field">
                <span>聯絡電話</span>
                <input data-field="clientPhone" type="text" placeholder="例如：09xx-xxx-xxx" />
              </label>
              <label class="field">
                <span>Email</span>
                <input data-field="clientEmail" type="email" placeholder="例如：client@example.com" />
              </label>
              <label class="field">
                <span>身分證末四碼 / 統編後四碼</span>
                <input data-field="clientIdentityCode" type="text" placeholder="例如：1234" />
              </label>
              <label class="field">
                <span>指定專案代理人</span>
                <input data-field="projectAgentName" type="text" placeholder="例如：王太太 / 家人 / 代理窗口" />
              </label>
              <label class="field">
                <span>代理人關係 / 權限</span>
                <input data-field="projectAgentRole" type="text" placeholder="例如：配偶，現場確認與材料回覆視同業主確認" />
              </label>
              <label class="field">
                <span>案件名稱</span>
                <input data-field="projectName" type="text" placeholder="例如：林口新成屋裝修" />
              </label>
              <label class="field">
                <span>案件地址</span>
                <input data-field="projectAddress" type="text" placeholder="例如：新北市林口區..." />
              </label>
              <label class="field">
                <span>報價 / 規格參照</span>
                <input data-field="referenceLabel" type="text" placeholder="例如：初估單 v3、材料確認表 A 版" />
              </label>
              <label class="field">
                <span>附件版次</span>
                <input data-field="attachmentVersion" type="text" placeholder="例如：施工圖 A 版 / 規格表 v2" />
              </label>
              <label class="field">
                <span>中期款查驗里程碑</span>
                <input data-field="midpointMilestone" type="text" placeholder="例如：管線配置完成 / 泥作打底完成" />
              </label>
              <label class="field">
                <span>合約總額</span>
                <div class="input-with-prefix">
                  <span>NT$</span>
                  <input data-field="contractAmount" type="number" min="0" step="1000" placeholder="例如：680000" />
                </div>
              </label>
              <label class="field">
                <span>簽約日期</span>
                <input data-field="contractDate" type="date" />
              </label>
              <label class="field">
                <span>預計開工</span>
                <input data-field="plannedStartDate" type="date" />
              </label>
              <label class="field">
                <span>預計完工</span>
                <input data-field="plannedEndDate" type="date" />
              </label>
              <label class="field">
                <span>一般裝修保固</span>
                <input data-field="generalWarrantyYears" type="text" placeholder="例如：1 年" />
              </label>
              <label class="field">
                <span>防水工程保固</span>
                <input data-field="waterproofWarrantyYears" type="text" placeholder="例如：3 年" />
              </label>
              <label class="field">
                <span>約定通知管道</span>
                <input data-field="notificationChannel" type="text" placeholder="例如：Email 與 LINE" />
              </label>
              <label class="field">
                <span>通知帳號 / 地址</span>
                <input data-field="notificationAccount" type="text" placeholder="例如：client@example.com / LINE ID" />
              </label>
              <label class="field">
                <span>爭議處理管道</span>
                <input data-field="disputeVenue" type="text" placeholder="例如：案場所在地法院 / 先行調解" />
              </label>
              <label class="field">
                <span>逾期違約金</span>
                <input data-field="delayPenaltyRate" type="text" placeholder="例如：千分之一 / 日" />
              </label>
              <label class="field">
                <span>違約金上限</span>
                <input data-field="delayPenaltyCap" type="text" placeholder="例如：合約總額 10%" />
              </label>
              <label class="field">
                <span>終止結算標準</span>
                <input data-field="settlementMethod" type="text" placeholder="例如：依原報價單單價與完成比例結算" />
              </label>
              <label class="field">
                <span>退款帳戶戶名</span>
                <input data-field="refundAccountName" type="text" placeholder="例如：王小姐本人帳戶" />
              </label>
              <label class="field">
                <span>退款 / 結算指定帳戶</span>
                <input data-field="refundAccount" type="text" placeholder="例如：王小姐 / 銀行代碼 000 / 帳號末五碼 12345" />
              </label>
              <label class="field field-full">
                <span>合約摘要</span>
                <textarea
                  data-field="contractSummary"
                  rows="4"
                  placeholder="例如：本案為新成屋住宅裝修，含拆除、水電、泥作、木作、油漆與系統櫃工程。"
                ></textarea>
              </label>
            </div>
          </section>

          <section class="studio-card">
            <div class="section-heading">
              <h2>付款節點</h2>
              <p>第一版先用百分比分配，客戶頁會同步換算成金額。</p>
            </div>
            <div id="payment-stage-list" class="payment-stage-list"></div>
          </section>

          <section class="studio-card">
            <div class="section-heading">
              <h2>核心條款</h2>
              <p>先用常見的合約骨架整理，再依案件需要微調。</p>
            </div>
            <div id="contract-section-list" class="contract-section-list"></div>
          </section>

          <section class="studio-card">
            <div class="section-heading">
              <h2>材料規格確認表</h2>
              <p>把本案最容易吵的板材、五金、磁磚、玻璃、衛浴與清潔交付標準先鎖在同一份附件裡。</p>
            </div>
            <div id="material-spec-list" class="material-spec-list"></div>
          </section>

          <section class="studio-card">
            <div class="section-heading">
              <h2>簽署與留證設定</h2>
              <p>目前可整理線上簽署內容、手機手寫簽名與簽署摘要留證；若案件需要更高證據力，再補 OTP 與存證機制即可。</p>
            </div>
            <label class="field field-full">
              <span>簽署完成提醒</span>
              <textarea
                data-field="signNotice"
                rows="3"
                placeholder="例如：簽署完成後，請雙方各自留存 PDF；若有追加減項，會再附上確認單。"
              ></textarea>
            </label>
            <div class="checklist-shell">
              <h3>客戶簽署前會再次確認以下內容</h3>
              <ul id="checklist-list"></ul>
            </div>
          </section>
        </div>

        <aside class="studio-sidebar">
          <section class="studio-card summary-card">
            <div class="section-heading">
              <h2>即時摘要</h2>
              <p>確認付款比例是否為 100%，再分享給客戶。</p>
            </div>
            <div id="summary-content" class="summary-content"></div>
          </section>
          <section class="studio-card summary-card">
            <div class="section-heading">
              <h2>模組定位</h2>
              <p>目前可作為可操作的線上合約確認與手機簽署流程。</p>
            </div>
            <ul class="support-list">
              <li>客戶可在手機上手寫簽名</li>
              <li>簽署頁可列印或另存 PDF</li>
              <li>保留簽署時間與裝置摘要</li>
              <li>可先防堵尾款未清就提前入住的風險</li>
              <li>後續可再補 OTP 與更高證據力存證</li>
            </ul>
          </section>
          <section class="studio-card summary-card">
            <div class="section-heading">
              <h2>LLM 合約覆核</h2>
              <p>可一鍵提取這份合約架構，交給 LLM 評分、抓風險與給改寫建議。</p>
            </div>
            <div class="llm-review-card">
              <strong id="llm-review-label">給 LLM 的合約覆核文字</strong>
              <p id="llm-review-note">這段會帶出合約摘要、付款節點、條款與簽署留證設定，讓 LLM 直接用 10 分制評分與覆核。</p>
              <textarea id="llm-review-output" class="llm-review-output" rows="14" readonly></textarea>
            </div>
          </section>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script
  is:inline
  define:vars={{
    contractDefaultPaymentStagesJson,
    contractDefaultSectionsJson,
    contractDefaultChecklistJson,
    contractDefaultMaterialSpecsJson,
    shortLinkStorageConfiguredJson,
  }}
>
  // @ts-nocheck
  const paymentStageTemplate = JSON.parse(contractDefaultPaymentStagesJson);
  const contractSectionTemplate = JSON.parse(contractDefaultSectionsJson);
  const contractChecklist = JSON.parse(contractDefaultChecklistJson);
  const materialSpecTemplate = JSON.parse(contractDefaultMaterialSpecsJson);
  const shortLinkStorageConfigured = JSON.parse(shortLinkStorageConfiguredJson);
  const draftKey = "qingxi-contract-studio-draft-v2";

  function buildDefaultContractNumber() {
    const now = new Date();
    const year = now.getFullYear();
    const month = String(now.getMonth() + 1).padStart(2, "0");
    const day = String(now.getDate()).padStart(2, "0");
    return `QX-${year}${month}${day}`;
  }

  function formatCurrency(value) {
    return new Intl.NumberFormat("zh-TW", {
      style: "currency",
      currency: "TWD",
      maximumFractionDigits: 0,
    }).format(Number.isFinite(value) ? value : 0);
  }

  function parseNumber(value) {
    const normalized = Number(value);
    return Number.isFinite(normalized) ? normalized : 0;
  }

  function normalizeLegacyContractText(value) {
    if (typeof value !== "string") return value;

    return value
      .replaceAll("正式合約", "本合約")
      .replaceAll("正式報價", "本案報價")
      .replaceAll("正式附件", "附件")
      .replaceAll("正式通知管道", "約定通知管道")
      .replaceAll("正式書面往來管道", "約定書面往來管道")
      .replaceAll("正式點交", "雙方點交")
      .replaceAll("正式委任程序", "另行委任程序")
      .replaceAll("正式委任文件", "另行委任文件")
      .replaceAll("正式 PDF 定稿存證", "定稿 PDF 存證")
      .replaceAll("正式副本", "定稿副本")
      .replaceAll("第三方電子簽署", "外部簽署服務")
      .replaceAll("法院認證版本", "高證據力版本")
      .replaceAll("MVP", "目前版本");
  }

  function normalizeContractState(nextState) {
    const normalizedMeta = Object.fromEntries(
      Object.entries(nextState.meta || {}).map(([key, value]) => [key, normalizeLegacyContractText(value)]),
    );

    return {
      ...nextState,
      meta: normalizedMeta,
      paymentStages: (nextState.paymentStages || []).map((stage) => ({
        ...stage,
        label: normalizeLegacyContractText(stage.label),
        note: normalizeLegacyContractText(stage.note),
      })),
      sections: (nextState.sections || []).map((section) => ({
        ...section,
        title: normalizeLegacyContractText(section.title),
        body: normalizeLegacyContractText(section.body),
      })),
      materialSpecs: (nextState.materialSpecs || []).map((section) => ({
        ...section,
        title: normalizeLegacyContractText(section.title),
        description: normalizeLegacyContractText(section.description),
        baseline: normalizeLegacyContractText(section.baseline),
        selection: normalizeLegacyContractText(section.selection),
        finishScope: normalizeLegacyContractText(section.finishScope),
        note: normalizeLegacyContractText(section.note),
      })),
    };
  }

  function createInitialState() {
    const today = new Date();
    const todayString = today.toISOString().slice(0, 10);
    const endDate = new Date(today);
    endDate.setMonth(endDate.getMonth() + 2);

    return {
      meta: {
        contractTitle: "住宅空間裝修工程合約書",
        contractNumber: buildDefaultContractNumber(),
        clientName: "",
        clientPhone: "",
        clientEmail: "",
        projectAgentName: "",
        projectAgentRole: "",
        projectName: "",
        projectAddress: "",
        referenceLabel: "",
        contractAmount: 0,
        contractDate: todayString,
        plannedStartDate: todayString,
        plannedEndDate: endDate.toISOString().slice(0, 10),
        contractSummary:
          "本案依雙方已確認之需求、報價單與材料方向進行裝修工程施作，詳細內容以本合約與附件共同構成。",
        signNotice:
          "簽署完成後，建議雙方立即列印或另存 PDF 留存；後續若有追加減，會再附確認單共同簽認。",
        clientIdentityCode: "",
        attachmentVersion: "",
        midpointMilestone: "管線配置完成 / 泥作打底完成",
        generalWarrantyYears: "1 年",
        waterproofWarrantyYears: "3 年",
        notificationChannel: "Email 與 LINE",
        notificationAccount: "",
        disputeVenue: "如需進一步處理，原則先協調或調解，必要時以案場所在地法院為第一審管轄法院。",
        delayPenaltyRate: "千分之一 / 日",
        delayPenaltyCap: "合約總額 10%",
        settlementMethod: "依原報價單單價、已完成比例與已發生成本結算；必要時由第三方專業單位協助認定。",
        refundAccountName: "",
        refundAccount: "",
      },
      paymentStages: paymentStageTemplate.map((stage) => ({ ...stage })),
      sections: contractSectionTemplate.map((section) => ({ ...section })),
      materialSpecs: materialSpecTemplate.map((section) => ({ ...section })),
    };
  }

  let state = createInitialState();

  function saveDraft() {
    localStorage.setItem(draftKey, JSON.stringify(state));
  }

  function loadDraft() {
    try {
      const saved = localStorage.getItem(draftKey);
      if (!saved) return;
      const parsed = JSON.parse(saved);
      state = normalizeContractState({
        meta: { ...state.meta, ...(parsed.meta || {}) },
        paymentStages: Array.isArray(parsed.paymentStages) && parsed.paymentStages.length
          ? parsed.paymentStages
          : state.paymentStages,
        sections: Array.isArray(parsed.sections) && parsed.sections.length
          ? parsed.sections
          : state.sections,
        materialSpecs: Array.isArray(parsed.materialSpecs) && parsed.materialSpecs.length
          ? parsed.materialSpecs
          : state.materialSpecs,
      });
    } catch (error) {
      console.error("無法讀取合約草稿：", error);
    }
  }

  function encodePayload(payload) {
    const bytes = new TextEncoder().encode(JSON.stringify(payload));
    const binary = Array.from(bytes, (byte) => String.fromCharCode(byte)).join("");
    return btoa(binary);
  }

  function buildPayload() {
    const amount = parseNumber(state.meta.contractAmount);
    const paymentStages = state.paymentStages.map((stage) => ({
      ...stage,
      percent: parseNumber(stage.percent),
      amount: Math.round((amount * parseNumber(stage.percent)) / 100),
    }));

    return {
      meta: {
        ...state.meta,
        contractAmount: amount,
      },
      paymentStages,
      sections: state.sections,
      materialSpecs: state.materialSpecs,
      checklist: contractChecklist,
      generatedAt: new Date().toISOString(),
      source: "qingxi-contract-studio",
    };
  }

  function buildInlineSignUrl() {
    const payload = encodePayload(buildPayload());
    const url = new URL("/contract-studio/sign", window.location.origin);
    url.searchParams.set("contract", payload);
    return url.toString();
  }

  async function createShareLink() {
    const fallbackUrl = buildInlineSignUrl();

    try {
      const response = await fetch("/api/contracts/share", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          payload: buildPayload(),
        }),
      });

      if (!response.ok) {
        throw new Error(`Share link request failed with status ${response.status}`);
      }

      const result = await response.json();
      return {
        mode: result.mode || "inline",
        url: result.url || fallbackUrl,
        warning: result.warning || "",
      };
    } catch (error) {
      console.error("建立分享連結失敗，改用長連結：", error);
      return {
        mode: "inline",
        url: fallbackUrl,
        warning: "CREATE_SHARE_LINK_FAILED",
      };
    }
  }

  function renderShareLinkStatus(result) {
    const statusShell = document.getElementById("share-link-status");
    const statusTitle = statusShell?.querySelector("strong");
    const statusNote = document.getElementById("share-link-status-note");
    const feedback = document.getElementById("share-link-feedback");
    if (!statusShell || !statusTitle || !statusNote || !feedback) return;

    if (!result) {
      statusShell.className = `share-link-status ${shortLinkStorageConfigured ? "is-ready" : "is-warning"}`;
      statusTitle.textContent = shortLinkStorageConfigured ? "短簽約連結已啟用" : "短簽約連結尚未啟用";
      statusNote.textContent = shortLinkStorageConfigured
        ? "目前分享給客戶時，會優先產生較短的 token 簽約連結，比較適合直接傳 LINE。"
        : "目前仍會退回完整長連結；請在 Vercel 補上 KV_REST_API_URL 與 KV_REST_API_TOKEN 後重新部署。";
      feedback.className = "share-link-feedback";
      feedback.textContent = "";
      return;
    }

    if (result.mode === "short") {
      statusShell.className = "share-link-status is-ready";
      statusTitle.textContent = "短簽約連結已啟用";
      statusNote.textContent = "本次已成功產生短簽約連結，適合直接貼給客戶。";
      feedback.className = "share-link-feedback is-ready";
      feedback.textContent = "這次拿到的是短簽約連結。";
      return;
    }

    statusShell.className = "share-link-status is-warning";
    statusTitle.textContent = "目前使用完整長連結";

    if (result.warning === "SHORT_LINK_STORAGE_NOT_CONFIGURED") {
      statusNote.textContent =
        "短連結儲存尚未啟用，所以目前複製或預覽都會退回完整長連結；請在 Vercel 補上 KV_REST_API_URL 與 KV_REST_API_TOKEN 後重新部署。";
      feedback.className = "share-link-feedback is-warning";
      feedback.textContent = "這次拿到的是完整長連結，還不是短網址。";
      return;
    }

    statusNote.textContent = "短連結建立失敗，系統已暫時改用完整長連結，建議檢查 KV 設定或部署狀態。";
    feedback.className = "share-link-feedback is-warning";
    feedback.textContent = "短連結建立失敗，這次已改用完整長連結。";
  }

  function buildContractLlmReviewText() {
    const payload = buildPayload();
    const paymentLines = payload.paymentStages
      .map(
        (stage) =>
          `- ${stage.label}：${stage.percent}%（${formatCurrency(stage.amount)}）；說明：${stage.note || "未填寫"}`,
      )
      .join("\n");
    const sectionLines = payload.sections
      .map((section) => `- ${section.title}：${section.body || "未填寫"}`)
      .join("\n");
    const materialSpecLines = (payload.materialSpecs || [])
      .map(
        (section) =>
          `- [${section.title}] 基準：${section.baseline || "未填寫"}；品牌/型號/等級：${section.selection || "未填寫"}；顏色/完成面/範圍：${section.finishScope || "未填寫"}；補充：${section.note || "未填寫"}`,
      )
      .join("\n");
    const checklistLines = payload.checklist.map((item) => `- ${item}`).join("\n");

    return [
      "請你以室內設計 / 裝修合約覆核顧問的角色，協助檢查以下合約工作台的預設架構。",
      "這是一套給室內設計工作室內部使用的線上合約簽署工作台，目標是先把合約骨架、付款節點、附件版次、通知管道與手機簽署流程整理完整，再持續補強證據留存能力。",
      "請先以『室內設計合約架構是否清楚、是否能降低雙方爭議』為主軸評分；不要只因尚未接 OTP、CA 或不可竄改存證，就過度壓低整體可用度。",
      "請在回覆中同時區分：1. 目前版本作為線上簽署工作流的成熟度；2. 若要升級成更高證據力簽署系統，還缺哪些能力。",
      "",
      "請優先指出：",
      "1. 合約主體、工程範圍、付款節點與簽署流程是否完整",
      "2. 哪些條款對客戶或承攬方來說仍有爭議風險",
      "3. 哪些文案仍過於模糊，應補上定義、上限或免責界線",
      "4. 這套合約簽署模組目前版本的可用度評分（滿分 10 分）",
      "5. 若要再升級成更高證據力的簽署流程，最優先應補哪些機制",
      "6. 請特別檢查：違約金預設值、終止結算標準、中期款里程碑、附件版次與退款帳戶是否足夠實務",
      "7. 請一起檢查材料規格確認表是否足以作為本案附件，哪些欄位仍可能造成品牌、等級、顏色、五金或清潔交付標準的爭議",
      "8. 請特別檢查：尾款未清前先入住、先行使用、分區點交與保固起算的風險是否已被清楚處理",
      "9. 請特別檢查：個人承攬適用範圍、需切換合法專業單位承接時的條款與責任界線是否清楚，避免誤寫成已承諾特定建築師或立案業者一定承接",
      "",
      "【合約基本資訊】",
      `- 合約標題：${payload.meta.contractTitle || "未填寫"}`,
      `- 合約編號：${payload.meta.contractNumber || "未填寫"}`,
      `- 客戶姓名：${payload.meta.clientName || "未填寫"}`,
      `- 身分識別：${payload.meta.clientIdentityCode || "未填寫"}`,
      `- 指定代理人：${payload.meta.projectAgentName || "未填寫"} / ${payload.meta.projectAgentRole || "未填寫"}`,
      `- 案件名稱：${payload.meta.projectName || "未填寫"}`,
      `- 案件地址：${payload.meta.projectAddress || "未填寫"}`,
      `- 參照附件：${payload.meta.referenceLabel || "未填寫"}`,
      `- 附件版次：${payload.meta.attachmentVersion || "未填寫"}`,
      `- 合約總額：${formatCurrency(payload.meta.contractAmount || 0)}`,
      `- 中期款查驗里程碑：${payload.meta.midpointMilestone || "未填寫"}`,
      `- 簽約日期：${payload.meta.contractDate || "未填寫"}`,
      `- 預計開工：${payload.meta.plannedStartDate || "未填寫"}`,
      `- 預計完工：${payload.meta.plannedEndDate || "未填寫"}`,
      `- 一般裝修保固：${payload.meta.generalWarrantyYears || "未填寫"}`,
      `- 防水工程保固：${payload.meta.waterproofWarrantyYears || "未填寫"}`,
      `- 約定通知管道：${payload.meta.notificationChannel || "未填寫"} / ${payload.meta.notificationAccount || "未填寫"}`,
      `- 爭議處理：${payload.meta.disputeVenue || "未填寫"}`,
      `- 逾期違約金：${payload.meta.delayPenaltyRate || "未填寫"}；上限：${payload.meta.delayPenaltyCap || "未填寫"}`,
      `- 終止結算標準：${payload.meta.settlementMethod || "未填寫"}`,
      `- 退款帳戶戶名：${payload.meta.refundAccountName || "未填寫"}`,
      `- 退款 / 結算指定帳戶：${payload.meta.refundAccount || "未填寫"}`,
      `- 提前入住風險條款：已納入預設核心條款與簽署確認`,
      `- 合法專業單位切換條款：已納入預設核心條款與簽署確認`,
      `- 合約摘要：${payload.meta.contractSummary || "未填寫"}`,
      `- 簽署完成提醒：${payload.meta.signNotice || "未填寫"}`,
      "",
      "【付款節點】",
      paymentLines || "- 未填寫",
      "- 提醒：中期款是否合理，應以『查驗里程碑是否具體』為主，而不只看比例本身。",
      "",
      "【核心條款】",
      sectionLines || "- 未填寫",
      "",
      "【材料規格確認表】",
      materialSpecLines || "- 未填寫",
      "",
      "【客戶簽署前確認】",
      checklistLines || "- 未填寫",
      "",
      "【目前簽署模組特性】",
      "- 客戶可於手機或平板手寫簽名",
      "- 簽署頁可列印或另存 PDF",
      "- 目前會留存簽署姓名、電話、Email、身分、簽署時間、語系、時區、裝置摘要與簽名圖像",
      "- 目前尚未可靠取得真實 IP，也尚未加入 OTP 驗證、CA 憑證或後端不可竄改時間戳",
      "- 尚未加入雙方分流簽署、自動寄送定稿副本與後端不可竄改存證",
      "",
      "請直接輸出：",
      "S. 架構總分（滿分 10 分，請以目前版本可用度為主）",
      "S2. 若以高證據力電子簽署標準評估，目前大約落在幾分",
      "A. 主要問題",
      "B. 風險提醒",
      "C. 建議補問客戶或補簽的資訊",
      "D. 建議改寫文案",
      "E. 目前做得不錯的地方",
    ].join("\n");
  }

  function renderPaymentStages() {
    const amount = parseNumber(state.meta.contractAmount);
    document.getElementById("payment-stage-list").innerHTML = state.paymentStages
      .map((stage) => {
        const computedAmount = Math.round((amount * parseNumber(stage.percent)) / 100);
        return `
          <article class="payment-stage-card">
            <label class="field">
              <span>節點名稱</span>
              <input data-payment-id="${stage.id}" data-payment-field="label" type="text" value="${stage.label}" />
            </label>
            <label class="field">
              <span>比例</span>
              <div class="input-with-suffix">
                <input data-payment-id="${stage.id}" data-payment-field="percent" type="number" min="0" max="100" step="1" value="${stage.percent}" />
                <span>%</span>
              </div>
            </label>
            <label class="field field-full">
              <span>說明</span>
              <textarea data-payment-id="${stage.id}" data-payment-field="note" rows="3">${stage.note}</textarea>
            </label>
            <div class="stage-amount">${formatCurrency(computedAmount)}</div>
          </article>
        `;
      })
      .join("");
  }

  function renderSections() {
    document.getElementById("contract-section-list").innerHTML = state.sections
      .map(
        (section) => `
          <article class="contract-section-card">
            <h3>${section.title}</h3>
            <textarea data-section-id="${section.id}" rows="5">${section.body}</textarea>
          </article>
        `,
      )
      .join("");
  }

  function renderMaterialSpecs() {
    document.getElementById("material-spec-list").innerHTML = state.materialSpecs
      .map(
        (section) => `
          <article class="material-spec-card">
            <div class="material-spec-header">
              <div>
                <h3>${section.title}</h3>
                <p>${section.description || ""}</p>
              </div>
            </div>
            <div class="form-grid">
              <label class="field">
                <span>基準 / 做法</span>
                <textarea data-material-id="${section.id}" data-material-field="baseline" rows="3">${section.baseline || ""}</textarea>
              </label>
              <label class="field">
                <span>品牌 / 型號 / 等級</span>
                <textarea data-material-id="${section.id}" data-material-field="selection" rows="3">${section.selection || ""}</textarea>
              </label>
              <label class="field">
                <span>顏色 / 完成面 / 範圍</span>
                <textarea data-material-id="${section.id}" data-material-field="finishScope" rows="3">${section.finishScope || ""}</textarea>
              </label>
              <label class="field">
                <span>補充說明</span>
                <textarea data-material-id="${section.id}" data-material-field="note" rows="3">${section.note || ""}</textarea>
              </label>
            </div>
          </article>
        `,
      )
      .join("");
  }

  function renderChecklist() {
    document.getElementById("checklist-list").innerHTML = contractChecklist
      .map((item) => `<li>${item}</li>`)
      .join("");
  }

  function renderSummary() {
    const amount = parseNumber(state.meta.contractAmount);
    const totalPercent = state.paymentStages.reduce((sum, stage) => sum + parseNumber(stage.percent), 0);

    document.getElementById("summary-content").innerHTML = `
      <div class="summary-row">
        <span>合約總額</span>
        <strong>${formatCurrency(amount)}</strong>
      </div>
      <div class="summary-row">
        <span>付款比例總和</span>
        <strong class="${totalPercent === 100 ? "is-good" : "is-warning"}">${totalPercent}%</strong>
      </div>
      <div class="summary-row">
        <span>條款段落</span>
        <strong>${state.sections.length} 段</strong>
      </div>
      <div class="summary-row">
        <span>材料規格附件</span>
        <strong>${state.materialSpecs.length} 區塊</strong>
      </div>
      <div class="summary-row">
        <span>一般 / 防水保固</span>
        <strong>${state.meta.generalWarrantyYears || "未填寫"} / ${state.meta.waterproofWarrantyYears || "未填寫"}</strong>
      </div>
      <div class="summary-row">
        <span>約定通知管道</span>
        <strong>${state.meta.notificationChannel || "未填寫"}</strong>
      </div>
      <div class="summary-row">
        <span>中期款里程碑</span>
        <strong>${state.meta.midpointMilestone || "未填寫"}</strong>
      </div>
      <div class="summary-row">
        <span>違約金 / 上限</span>
        <strong>${state.meta.delayPenaltyRate || "未填寫"} / ${state.meta.delayPenaltyCap || "未填寫"}</strong>
      </div>
      <div class="summary-row">
        <span>簽署方式</span>
        <strong>手機手寫簽名</strong>
      </div>
      <div class="summary-row">
        <span>退款帳戶</span>
        <strong>${state.meta.refundAccount && state.meta.refundAccountName ? "已填寫" : "未填寫"}</strong>
      </div>
      <div class="summary-row">
        <span>先入住風險條款</span>
        <strong>已納入</strong>
      </div>
      <div class="summary-row">
        <span>指定代理人</span>
        <strong>${state.meta.projectAgentName || "未填寫"}</strong>
      </div>
      <p class="summary-note">
        若付款比例未滿 100%，或身分識別、退款帳戶、材料規格仍未補齊，簽署頁雖可開啟，但建議先補正後再分享給客戶。
      </p>
    `;
  }

  function renderLlmReviewOutput() {
    document.getElementById("llm-review-output").value = buildContractLlmReviewText();
  }

  function syncMetaInputs() {
    document.querySelectorAll("[data-field]").forEach((input) => {
      const key = input.dataset.field;
      if (!key) return;
      input.value = state.meta[key] ?? "";
    });
  }

  function syncActions() {
    const signUrl = buildInlineSignUrl();
    document.getElementById("open-sign-link").href = signUrl;
  }

  function renderAll() {
    syncMetaInputs();
    renderPaymentStages();
    renderSections();
    renderMaterialSpecs();
    renderChecklist();
    renderSummary();
    renderLlmReviewOutput();
    syncActions();
    renderShareLinkStatus();
  }

  function resetState() {
    state = createInitialState();
    saveDraft();
    renderAll();
  }

  loadDraft();
  renderAll();

  document.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement)) return;

    if (target.dataset.field) {
      state.meta[target.dataset.field] = target.type === "number" ? parseNumber(target.value) : target.value;
      saveDraft();
      renderSummary();
      renderLlmReviewOutput();
      syncActions();
      renderPaymentStages();
      return;
    }
  });

  document.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement)) return;

    if (target.dataset.paymentId && target.dataset.paymentField) {
      state.paymentStages = state.paymentStages.map((stage) =>
        stage.id === target.dataset.paymentId
          ? {
              ...stage,
              [target.dataset.paymentField]:
                target.dataset.paymentField === "percent" ? parseNumber(target.value) : target.value,
            }
          : stage,
      );
      saveDraft();
      renderPaymentStages();
      renderSummary();
      renderLlmReviewOutput();
      syncActions();
      return;
    }

    if (target.dataset.sectionId) {
      state.sections = state.sections.map((section) =>
        section.id === target.dataset.sectionId ? { ...section, body: target.value } : section,
      );
      saveDraft();
      renderSummary();
      renderLlmReviewOutput();
      syncActions();
      return;
    }

    if (target.dataset.materialId && target.dataset.materialField) {
      state.materialSpecs = state.materialSpecs.map((section) =>
        section.id === target.dataset.materialId ? { ...section, [target.dataset.materialField]: target.value } : section,
      );
      saveDraft();
      renderSummary();
      renderLlmReviewOutput();
      syncActions();
    }
  });

  document.getElementById("open-sign-link").addEventListener("click", async (event) => {
    event.preventDefault();
    const result = await createShareLink();
    renderShareLinkStatus(result);
    const feedback = document.getElementById("share-link-feedback");
    if (feedback) {
      feedback.className = `share-link-feedback ${result.mode === "short" ? "is-ready" : "is-warning"}`;
      feedback.textContent = result.mode === "short" ? "已在新分頁開啟短簽約連結。" : "已在新分頁開啟完整長連結。";
    }
    window.open(result.url, "_blank", "noopener,noreferrer");
  });

  document.getElementById("copy-sign-link").addEventListener("click", async (event) => {
    const target = event.currentTarget;
    if (!(target instanceof HTMLButtonElement)) return;

    try {
      const result = await createShareLink();
      renderShareLinkStatus(result);
      await navigator.clipboard.writeText(result.url);
      const originalText = target.textContent;
      target.textContent = result.mode === "short" ? "短簽約連結已複製" : "已複製完整長連結";
      window.setTimeout(() => {
        target.textContent = originalText;
      }, 1400);
    } catch (error) {
      console.error("無法複製簽署連結：", error);
    }
  });

  document.getElementById("copy-contract-llm-review").addEventListener("click", async (event) => {
    const target = event.currentTarget;
    if (!(target instanceof HTMLButtonElement)) return;

    try {
      await navigator.clipboard.writeText(buildContractLlmReviewText());
      const originalText = target.textContent;
      target.textContent = "LLM 合約覆核文字已複製";
      window.setTimeout(() => {
        target.textContent = originalText;
      }, 1400);
    } catch (error) {
      console.error("無法複製 LLM 合約覆核文字：", error);
    }
  });

  document.getElementById("reset-contract").addEventListener("click", () => {
    resetState();
  });
</script>

<style>
  .contract-studio-page {
    padding: 8rem 0 5rem;
    background: linear-gradient(180deg, rgba(246, 242, 236, 0.94), rgba(255, 255, 255, 0.98));
