  .payment-stage-card,
  .contract-section-card,
  .material-spec-card,
  .checklist-shell {
    border: 1px solid rgba(93, 67, 44, 0.1);
    border-radius: 18px;
    padding: 1rem;
    background: rgba(250, 247, 242, 0.7);
  }

