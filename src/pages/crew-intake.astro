---
import BaseLayout from "../layouts/BaseLayout.astro";

const vendorTradeOptions = [
  "木作",
  "系統櫃",
  "泥作",
  "水電",
  "油漆",
  "燈光",
  "窗簾",
  "地板",
  "鐵件",
  "玻璃",
  "軟裝",
  "清潔",
  "其他",
];
---

<BaseLayout
  title="合作工班資料登錄 - 青曦空間設計"
  description="青曦空間設計合作工班資料登錄頁，留下必要聯絡資訊並上傳常用收費標準或報價單。"
  noindex={true}
>
  <section class="crew-intake-page">
    <div class="crew-intake-shell">
      <div class="crew-intake-hero">
        <div class="crew-intake-copy">
          <p class="crew-intake-eyebrow">QINGXI CREW INTAKE</p>
          <h1>合作工班資料登錄</h1>
          <p class="crew-intake-description">
            若你有穩定承接相關工種，歡迎先留下必要資料。
            若方便，也可直接附上常用單價表、報價單範例或去識別後的報價樣本，後續若案件方向適合，青曦會再主動聯繫。
          </p>
          <div class="crew-intake-points">
            <span>只填必要欄位</span>
            <span>可附去識別報價樣本</span>
            <span>資料僅供青曦內部篩選</span>
          </div>
        </div>

        <aside class="crew-intake-aside">
          <p class="crew-intake-aside-label">你會需要準備</p>
          <ul>
            <li>可聯絡的主要窗口</li>
            <li>擅長案型與工法傾向</li>
            <li>服務工種與區域</li>
            <li>常用單價表、報價單或去識別樣本</li>
          </ul>
        </aside>
      </div>

      <div class="crew-intake-card">
        <div class="crew-intake-card-head">
          <p class="crew-intake-section-label">STEP 01</p>
          <h2>先完成核心必填資料，再補附件即可</h2>
          <p>這份表單分成核心必填區、補充資料區與附件區；青曦會先看最影響合作判斷的項目。</p>
        </div>

        <form id="crew-intake-form" class="crew-intake-form" enctype="multipart/form-data">
          <input type="hidden" name="source_label" id="crew-source-label" />
          <input type="hidden" name="source_detail" id="crew-source-detail" />
          <input type="hidden" name="utm_source" id="crew-utm-source" />
          <input type="hidden" name="utm_medium" id="crew-utm-medium" />
          <input type="hidden" name="utm_campaign" id="crew-utm-campaign" />
          <input type="hidden" name="utm_term" id="crew-utm-term" />
          <input type="hidden" name="utm_content" id="crew-utm-content" />
          <input type="hidden" name="landing_page" id="crew-landing-page" />
          <input type="hidden" name="referrer" id="crew-referrer" />

          <section class="crew-intake-form-section crew-intake-form-section-emphasis">
            <div class="crew-intake-form-section-head">
              <div>
                <p class="crew-intake-form-section-tag">核心必填區</p>
                <h3>這幾題會直接影響青曦是否能快速判斷合作方向</h3>
              </div>
              <p>請優先完成工種、區域、聯絡方式、擅長案型、工法傾向與報價資料提供方式。</p>
            </div>

            <div class="crew-intake-grid">
              <label class="crew-intake-field crew-intake-field-key">
                <span class="crew-intake-field-title"><strong>姓名</strong><em>必填</em></span>
                <input type="text" name="name" placeholder="請填主要聯絡人姓名" required />
              </label>

              <label class="crew-intake-field">
                <span class="crew-intake-field-title"><strong>團隊 / 公司名稱</strong><small>選填</small></span>
                <input type="text" name="team_name" placeholder="可填工作室或公司名稱" />
              </label>

              <label class="crew-intake-field crew-intake-field-key">
                <span class="crew-intake-field-title"><strong>工種</strong><em>必填</em></span>
                <select name="trade" id="crew-trade" required>
                  <option value="">請選擇工種</option>
                  {vendorTradeOptions.map((trade) => (
                    <option value={trade}>{trade}</option>
                  ))}
                </select>
              </label>

              <label class="crew-intake-field crew-intake-field-key">
                <span class="crew-intake-field-title"><strong>服務區域</strong><em>必填</em></span>
                <input type="text" name="service_area" placeholder="例如：台北 / 新北 / 基隆" required />
              </label>

              <label class="crew-intake-field crew-intake-field-key">
                <span class="crew-intake-field-title"><strong>聯絡方式類型</strong><em>必填</em></span>
                <select name="contact_method" required>
                  <option value="">請選擇</option>
                  <option value="phone">手機</option>
                  <option value="line">LINE</option>
                  <option value="email">Email</option>
                </select>
              </label>

              <label class="crew-intake-field crew-intake-field-key">
                <span class="crew-intake-field-title"><strong>聯絡方式</strong><em>必填</em></span>
                <input type="text" name="contact_value" placeholder="請填主要聯絡方式" required />
              </label>

              <label class="crew-intake-field crew-intake-field-key">
                <span class="crew-intake-field-title"><strong>擅長案型</strong><em>必填</em></span>
                <select name="project_focus" required>
                  <option value="">請選擇</option>
                  <option value="商空 / 武場為主">商空 / 武場為主</option>
                  <option value="住宅裝潢為主">住宅裝潢為主</option>
                  <option value="兩者都有">兩者都有</option>
                  <option value="其他特殊案型">其他特殊案型</option>
                </select>
                <small>例如較常承接商空、武場、住宅裝潢，或兩者皆有。</small>
              </label>

              <label class="crew-intake-field crew-intake-field-key">
                <span class="crew-intake-field-title"><strong>工法細緻度</strong><em>必填</em></span>
                <select name="craft_approach" required>
                  <option value="">請選擇</option>
                  <option value="偏效率施工">偏效率施工</option>
                  <option value="標準住宅施工">標準住宅施工</option>
                  <option value="偏細緻收邊">偏細緻收邊</option>
                  <option value="依案型調整">依案型調整</option>
                </select>
                <small>若你會依案型調整施工節奏與收邊方式，可直接選最後一項。</small>
              </label>

              <label class="crew-intake-field crew-intake-field-key">
                <span class="crew-intake-field-title"><strong>報價資料提供方式</strong><em>必填</em></span>
                <select name="pricing_disclosure" id="crew-pricing-disclosure" required>
                  <option value="">請選擇</option>
                  <option value="direct">可直接提供單價表 / 報價單</option>
                  <option value="sanitized">可提供去識別版本</option>
                  <option value="later">接洽後再提供</option>
                  <option value="not-now">目前暫不提供</option>
                </select>
                <small>即使目前不方便附檔，也建議先選擇現在可配合的方式。</small>
              </label>
            </div>
          </section>

          <section class="crew-intake-form-section">
            <div class="crew-intake-form-section-head">
              <div>
                <p class="crew-intake-form-section-tag">補充資料區</p>
                <h3>這些欄位會幫青曦更快判斷合作條件，但可稍後再補</h3>
              </div>
              <p>若願意先提供，後續在整理合作名單時會更有效率。</p>
            </div>

            <div class="crew-intake-grid">
              <label class="crew-intake-field">
                <span class="crew-intake-field-title"><strong>是否可開發票</strong><small>選填</small></span>
                <select name="invoice_status">
                  <option value="">先不填也可以</option>
                  <option value="yes">可開發票</option>
                  <option value="no">不可開發票</option>
                  <option value="discuss">可再討論</option>
                </select>
              </label>

              <label class="crew-intake-field">
                <span class="crew-intake-field-title"><strong>目前報價方式</strong><small>選填</small></span>
                <select name="pricing_mode">
                  <option value="">先不填也可以</option>
                  <option value="unit-price">常用單價表</option>
                  <option value="quote-sheet">常用報價單</option>
                  <option value="both">兩者都有</option>
                  <option value="custom">依案件另報</option>
                </select>
              </label>

              <label class="crew-intake-field">
                <span class="crew-intake-field-title"><strong>是否可接受簽約</strong><small>選填</small></span>
                <select name="accepts_contract">
                  <option value="">先不填也可以</option>
                  <option value="yes">可接受簽約</option>
                  <option value="no">暫不接受簽約</option>
                  <option value="discuss">可再討論</option>
                </select>
              </label>

              <label class="crew-intake-field crew-intake-field-full">
                <span class="crew-intake-field-title"><strong>補充說明</strong><small>選填</small></span>
                <textarea
                  name="note"
                  rows="4"
                  placeholder="可補充擅長案型、合作方式、常接案型，或其他想先說明的內容"
                ></textarea>
              </label>
            </div>
          </section>

          <section class="crew-intake-form-section">
            <div class="crew-intake-form-section-head">
              <div>
                <p class="crew-intake-form-section-tag">附件區</p>
                <h3>若方便，請附單價表、報價單或去識別樣本</h3>
              </div>
              <p>若你選了可直接提供或可提供去識別版本，附件會列為必附；若目前不方便，也可先送出基本資料。</p>
            </div>

            <div class="crew-intake-grid">
              <label class="crew-intake-field">
                <span class="crew-intake-field-title"><strong>附件類型</strong><small>條件必填</small></span>
                <select name="attachment_kind" id="crew-attachment-kind">
                  <option value="">若未附檔可先略過</option>
                  <option value="pricing-sheet">收費標準</option>
                  <option value="quote-sheet">報價單</option>
                  <option value="both-mixed">綜合資料</option>
                </select>
              </label>

              <div class="crew-intake-field crew-intake-field-full crew-intake-field-key">
                <span class="crew-intake-field-title"><strong>上傳單價表、報價單或去識別報價樣本</strong><small>條件必填</small></span>
                <input
                  type="file"
                  id="crew-pricing-file"
                  name="pricing_file"
                  accept=".pdf,.jpg,.jpeg,.png,.webp,.xls,.xlsx,application/pdf,image/jpeg,image/png,image/webp,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                />
                <small id="crew-pricing-file-hint">若方便，可直接上傳單價表、既有報價單，或去識別後的報價樣本其一即可；資料僅供青曦內部評估，不會對外公開。</small>
              </div>
            </div>
          </section>

          <div class="crew-intake-actions">
            <button type="submit" id="crew-intake-submit">送出資料</button>
            <p id="crew-intake-feedback" class="crew-intake-feedback" aria-live="polite">
              送出後資料只供青曦內部篩選，不會公開顯示。
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .crew-intake-page {
    padding: 5rem 1.5rem 5.5rem;
    background:
      radial-gradient(circle at top, rgba(164, 171, 160, 0.12), transparent 26%),
      linear-gradient(180deg, rgba(250, 247, 242, 1) 0%, rgba(239, 234, 228, 1) 100%);
  }

  .crew-intake-shell {
    width: min(100%, 1120px);
    margin: 0 auto;
    display: grid;
    gap: 1.6rem;
  }

  .crew-intake-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(280px, 340px);
    gap: 1.4rem;
    align-items: stretch;
  }

  .crew-intake-copy,
  .crew-intake-aside,
  .crew-intake-card {
    border-radius: 30px;
    border: 1px solid rgba(124, 131, 122, 0.14);
    background: rgba(255, 253, 249, 0.9);
    box-shadow: 0 22px 48px rgba(58, 52, 46, 0.07);
  }

  .crew-intake-copy {
    padding: 2.4rem;
    background:
      radial-gradient(circle at top right, rgba(164, 171, 160, 0.12), transparent 34%),
      linear-gradient(180deg, rgba(255, 254, 251, 0.94) 0%, rgba(246, 242, 237, 0.94) 100%);
  }

  .crew-intake-eyebrow,
  .crew-intake-section-label,
  .crew-intake-aside-label {
    margin: 0 0 0.85rem;
    color: #69736c;
    font-size: 0.74rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .crew-intake-copy h1,
  .crew-intake-card-head h2 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #332e29;
  }

  .crew-intake-copy h1 {
    font-size: clamp(2.2rem, 4vw, 4rem);
    line-height: 1.24;
  }

  .crew-intake-description,
  .crew-intake-card-head p,
  .crew-intake-aside li,
  .crew-intake-feedback,
  .crew-intake-field small {
    color: #6a645d;
    line-height: 1.8;
  }

  .crew-intake-description {
    margin: 1.2rem 0 0;
    max-width: 42rem;
  }

  .crew-intake-points {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.6rem;
  }

  .crew-intake-points span {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: rgba(255, 252, 248, 0.78);
    border: 1px solid rgba(124, 131, 122, 0.14);
    color: #4a4a4a;
    font-size: 0.88rem;
  }

  .crew-intake-aside {
    padding: 1.8rem;
    display: grid;
    gap: 0.75rem;
    background:
      radial-gradient(circle at top right, rgba(164, 171, 160, 0.12), transparent 34%),
      linear-gradient(180deg, rgba(247, 243, 238, 1) 0%, rgba(255, 253, 249, 0.96) 100%);
  }

  .crew-intake-aside ul {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.7rem;
  }

  .crew-intake-card {
    padding: 2rem;
  }

  .crew-intake-card-head {
    display: grid;
    gap: 0.55rem;
    margin-bottom: 1.4rem;
  }

  .crew-intake-form-section {
    display: grid;
    gap: 1rem;
    padding: 1.1rem 1.15rem 1.2rem;
    border-radius: 24px;
    border: 1px solid rgba(124, 131, 122, 0.12);
    background: rgba(255, 252, 248, 0.76);
  }

  .crew-intake-form-section + .crew-intake-form-section {
    margin-top: 0.95rem;
  }

  .crew-intake-form-section-emphasis {
    border-color: rgba(105, 115, 108, 0.2);
    background:
      radial-gradient(circle at top right, rgba(164, 171, 160, 0.12), transparent 38%),
      linear-gradient(180deg, rgba(255, 254, 251, 0.96) 0%, rgba(247, 242, 237, 0.94) 100%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .crew-intake-form-section-head {
    display: grid;
    gap: 0.45rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(124, 131, 122, 0.12);
  }

  .crew-intake-form-section-head h3,
  .crew-intake-form-section-head p {
    margin: 0;
  }

  .crew-intake-form-section-head h3 {
    color: #332e29;
    font-size: 1.02rem;
    line-height: 1.65;
    font-weight: 600;
  }

  .crew-intake-form-section-head p {
    color: #766f68;
    line-height: 1.75;
  }

  .crew-intake-form-section-tag {
    margin: 0 0 0.3rem;
    color: #69736c;
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .crew-intake-form,
  .crew-intake-grid,
  .crew-intake-field {
    display: grid;
    gap: 0.85rem;
  }

  .crew-intake-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .crew-intake-field-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    color: #332e29;
    font-size: 0.94rem;
  }

  .crew-intake-field-title strong,
  .crew-intake-field-title em,
  .crew-intake-field-title small {
    margin: 0;
    font-style: normal;
  }

  .crew-intake-field-title strong {
    font-weight: 600;
  }

  .crew-intake-field-title em,
  .crew-intake-field-title small {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    font-size: 0.76rem;
    letter-spacing: 0.02em;
  }

  .crew-intake-field-title em {
    background: rgba(74, 89, 78, 0.1);
    border: 1px solid rgba(74, 89, 78, 0.12);
    color: #475347;
  }

  .crew-intake-field-title small {
    background: rgba(124, 131, 122, 0.08);
    border: 1px solid rgba(124, 131, 122, 0.1);
    color: #746d66;
  }

  .crew-intake-field-key {
    padding: 0.15rem;
    border-radius: 22px;
    background: rgba(247, 243, 238, 0.62);
  }

  .crew-intake-field input,
  .crew-intake-field select,
  .crew-intake-field textarea {
    width: 100%;
    border-radius: 18px;
    border: 1px solid rgba(124, 131, 122, 0.18);
    background: rgba(255, 253, 250, 0.96);
    padding: 0.95rem 1rem;
    color: #332e29;
    font: inherit;
    line-height: 1.6;
    box-sizing: border-box;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .crew-intake-field input:focus,
  .crew-intake-field select:focus,
  .crew-intake-field textarea:focus {
    outline: none;
    border-color: rgba(124, 131, 122, 0.3);
    box-shadow: 0 0 0 4px rgba(124, 131, 122, 0.12);
  }

  .crew-intake-field textarea {
    resize: vertical;
    min-height: 130px;
  }

  .crew-intake-field-full {
    grid-column: 1 / -1;
  }

  .crew-intake-actions {
    display: grid;
    gap: 0.8rem;
    margin-top: 0.35rem;
  }

  .crew-intake-actions button {
    width: fit-content;
    min-height: 50px;
    padding: 0.9rem 1.5rem;
    border-radius: 999px;
    border: 1px solid rgba(44, 39, 35, 0.96);
    background: linear-gradient(135deg, rgba(44, 39, 35, 1) 0%, rgba(97, 89, 80, 1) 100%);
    color: #ffffff;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 14px 24px rgba(58, 52, 46, 0.16);
  }

  .crew-intake-actions button:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 28px rgba(58, 52, 46, 0.2);
  }

  .crew-intake-actions button:disabled {
    opacity: 0.72;
    cursor: wait;
  }

  .crew-intake-feedback {
    margin: 0;
    min-height: 1.5rem;
    font-size: 0.92rem;
  }

  .crew-intake-feedback.is-success {
    color: #4d5b51;
  }

  .crew-intake-feedback.is-warning {
    color: #8a5b44;
  }

  @media (max-width: 900px) {
    .crew-intake-hero,
    .crew-intake-grid {
      grid-template-columns: 1fr;
    }

    .crew-intake-copy,
    .crew-intake-aside,
    .crew-intake-card {
      padding: 1.5rem;
    }

    .crew-intake-actions button {
      width: 100%;
    }
  }
</style>

<script is:inline>
  const crewIntakeForm = document.getElementById("crew-intake-form");
  const feedbackNode = document.getElementById("crew-intake-feedback");
  const submitButton = document.getElementById("crew-intake-submit");
  const tradeField = document.getElementById("crew-trade");
  const pricingDisclosureField = document.getElementById("crew-pricing-disclosure");
  const pricingFileField = document.getElementById("crew-pricing-file");
  const attachmentKindField = document.getElementById("crew-attachment-kind");
  const pricingFileHint = document.getElementById("crew-pricing-file-hint");

  function setCrewFeedback(message, mode = "") {
    if (!(feedbackNode instanceof HTMLElement)) return;
    feedbackNode.className = `crew-intake-feedback ${mode}`.trim();
    feedbackNode.textContent = message;
  }

  function syncPricingDisclosureRequirement() {
    const disclosure = pricingDisclosureField instanceof HTMLSelectElement ? pricingDisclosureField.value : "";
    const requiresAttachment = disclosure === "direct" || disclosure === "sanitized";

    if (pricingFileField instanceof HTMLInputElement) {
      pricingFileField.required = requiresAttachment;
    }
    if (attachmentKindField instanceof HTMLSelectElement) {
      attachmentKindField.required = requiresAttachment;
    }
    if (pricingFileHint instanceof HTMLElement) {
      pricingFileHint.textContent = requiresAttachment
        ? "你選擇了可提供報價資料，請一併上傳單價表、既有報價單，或去識別後的報價樣本其一即可；資料僅供青曦內部評估，不會對外公開。"
        : "若目前不方便附檔，也可先留下資料；若願意提供，建議上傳單價表、既有報價單，或去識別後的報價樣本其一即可。";
    }
  }

  if (crewIntakeForm instanceof HTMLFormElement) {
    const searchParams = new URLSearchParams(window.location.search);
    const sourceLabel = document.getElementById("crew-source-label");
    const sourceDetail = document.getElementById("crew-source-detail");
    const utmSource = document.getElementById("crew-utm-source");
    const utmMedium = document.getElementById("crew-utm-medium");
    const utmCampaign = document.getElementById("crew-utm-campaign");
    const utmTerm = document.getElementById("crew-utm-term");
    const utmContent = document.getElementById("crew-utm-content");
    const landingPage = document.getElementById("crew-landing-page");
    const referrer = document.getElementById("crew-referrer");

    if (sourceLabel instanceof HTMLInputElement) {
      sourceLabel.value = searchParams.get("source") || "social-comment";
    }
    if (sourceDetail instanceof HTMLInputElement) {
      sourceDetail.value = searchParams.get("source_detail") || "";
    }
    if (utmSource instanceof HTMLInputElement) utmSource.value = searchParams.get("utm_source") || "";
    if (utmMedium instanceof HTMLInputElement) utmMedium.value = searchParams.get("utm_medium") || "";
    if (utmCampaign instanceof HTMLInputElement) utmCampaign.value = searchParams.get("utm_campaign") || "";
    if (utmTerm instanceof HTMLInputElement) utmTerm.value = searchParams.get("utm_term") || "";
    if (utmContent instanceof HTMLInputElement) utmContent.value = searchParams.get("utm_content") || "";
    if (landingPage instanceof HTMLInputElement) landingPage.value = window.location.href;
    if (referrer instanceof HTMLInputElement) referrer.value = document.referrer || "";

    const tradeParam = searchParams.get("trade") || "";
    if (tradeField instanceof HTMLSelectElement && tradeParam) {
      const matchingOption = Array.from(tradeField.options).find(
        (option) => option.value === tradeParam,
      );
      if (matchingOption) {
        tradeField.value = tradeParam;
      }
    }

    syncPricingDisclosureRequirement();
    pricingDisclosureField?.addEventListener("change", syncPricingDisclosureRequirement);

    crewIntakeForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!(submitButton instanceof HTMLButtonElement)) return;

      submitButton.disabled = true;
      setCrewFeedback("資料送出中，請稍候。");

      try {
        const response = await fetch("/api/vendor-intake", {
          method: "POST",
          body: new FormData(crewIntakeForm),
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok || result?.status !== "ok") {
          throw new Error(result?.note || "資料送出失敗，請稍後再試。");
        }

        crewIntakeForm.reset();
        if (tradeField instanceof HTMLSelectElement && tradeParam) {
          tradeField.value = tradeParam;
        }
        setCrewFeedback(
          result?.note || "資料已送出，若案件適合，青曦會再主動聯繫。",
          "is-success",
        );
      } catch (error) {
        setCrewFeedback(
          error instanceof Error ? error.message : "資料送出失敗，請稍後再試。",
          "is-warning",
        );
      } finally {
        submitButton.disabled = false;
      }
    });
  }
</script>
