      }

      .brand-smart-home {
        margin-top: 1.1rem;
        padding: 1rem;
        border-radius: 18px;
      }

      .brand-smart-home-actions,
      .smart-case-actions {
        gap: 0.6rem;
      }

      .brand-smart-home-link,
      .smart-case-link,
      .consult-button {
        width: 100%;
        padding: 0.85rem 1rem;
        letter-spacing: 0.04em;
      }

      .brand-credential {
        margin-top: 1.1rem;
        padding: 1rem;
      }

      .site-proof-section {
        padding: 0 1.25rem 4rem;
      }

      .site-proof-copy,
      .site-proof-photo {
        border-radius: 18px;
      }

      .site-proof-copy {
        padding: 1.2rem;
      }

      .site-proof-photo img {
        min-height: 240px;
      }

      .about-section,
      .testimonial-section,
      .faq-section,
      .consult-section,
      .service-section,
      .smart-case-section,
      .workflow-section {
        min-height: auto;
        padding-left: 1.25rem;
        padding-right: 1.25rem;
      }

      .stats-section {
        padding: 2.6rem 1.25rem;
      }

      .section-header,
      .workflow-header,
      .smart-case-header {
        margin-bottom: 2rem;
      }

      .smart-case-summary,
      .smart-case-card,
      .workflow-content,
      .consult-shell {
        border-radius: 20px;
      }

      .smart-case-summary,
      .smart-case-card {
        padding: 1.2rem;
      }

      .smart-case-tags {
        gap: 0.55rem;
        margin-top: 1rem;
      }

      .smart-case-tags span {
        padding: 0.5rem 0.7rem;
        font-size: 0.82rem;
      }

      .faq-section,
      .consult-section {
        padding: 3rem 1.5rem;
      }

      .stats-container {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .stat-item {
        padding: 1.35rem 1.05rem;
        border-radius: 18px;
      }

      .stat-number {
        font-size: 1.2rem;
      }

      .faq-question {
        padding: 1.25rem 1.5rem;
        font-size: 1rem;
      }

      .faq-answer p {
        padding: 0 1.5rem 1.25rem 1.5rem;
      }

      .faq-actions {
        flex-direction: column;
      }

      .workflow-list::before {
        display: none;
      }

      .smart-case-mobile-note,
      .workflow-mobile-note {
        display: none;
        margin: 0.9rem 0 0;
        color: var(--gray-medium);
        font-size: 0.9rem;
        line-height: 1.7;
      }

      .workflow-mobile-note {
        text-align: center;
        max-width: 32rem;
        margin: 0.9rem auto 0;
      }

      .workflow-actions {
        margin-top: 1rem;
      }

      .workflow-link {
        width: 100%;
      }

      .consult-shell {
        grid-template-columns: 1fr;
        padding: 1.5rem;
        gap: 1.4rem;
      }

      .consult-title {
        max-width: none;
        font-size: clamp(2.5rem, 11vw, 3.7rem);
        line-height: 1.12;
        letter-spacing: 0.06em;
      }

      .consult-note {
        padding: 1.25rem 1.2rem;
        border-radius: 22px;
      }

      .consult-actions {
        min-width: 0;
        max-width: none;
        width: 100%;
      }
    }

    .service-section {
      padding: clamp(5rem, 9vw, 7.5rem) 2rem;
      background:
        radial-gradient(circle at top right, rgba(159, 147, 136, 0.05), transparent 24%),
        linear-gradient(180deg, rgba(250, 250, 250, 1) 0%, rgba(245, 240, 234, 1) 100%);
    }

    .service-container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-header {
      text-align: center;
      max-width: 920px;
      margin: 0 auto 5rem;
    }

    .service-intro {
      max-width: 34rem;
      margin: 1.35rem auto 0;
      color: color-mix(in srgb, var(--gray-darkest) 60%, transparent);
      line-height: var(--type-body-line-height);
      letter-spacing: 0.01em;
    }

    .section-subtitle {
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      color: color-mix(in srgb, var(--gray-darkest) 54%, transparent);
      margin-bottom: 1rem;
      text-transform: uppercase;
    }

    .section-title {
      margin: 0;
      font-size: clamp(3.6rem, 8vw, 6.8rem);
      font-family: var(--font-display);
      font-weight: 400;
      line-height: 1.04;
      color: var(--gray-darkest);
      letter-spacing: 0.1em;
    }

    .service-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 1.25rem;
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .service-item {
      opacity: 0;
      transform: scale(0.8);
      transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .service-item.animate-in {
      opacity: 1;
      transform: scale(1);
    }

    .service-card {
      display: block;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(250, 250, 250, 1) 100%);
      border: 1px solid rgba(115, 103, 94, 0.14);
      border-radius: 24px;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      transition: all 0.3s ease;
      height: 100%;
      position: relative;
      box-shadow: 0 16px 34px rgba(47, 47, 47, 0.06);
    }

    .service-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        135deg,
        rgba(241, 234, 227, 1) 0%,
        rgba(214, 218, 222, 1) 100%
      );
      opacity: 0;
      transition: opacity 0.3s ease;
      z-index: 0;
    }

    .service-card:hover::before {
      opacity: 0.15;
    }

    .service-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 18px 34px rgba(47, 47, 47, 0.08);
      border-color: rgba(47, 47, 47, 0.14);
    }

    .service-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2.5rem 1.5rem;
      margin: 0;
      position: relative;
      z-index: 1;
      min-height: 250px;
    }

    .service-text {
      min-height: 4.1rem;
      margin-bottom: 1.5rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.2rem;
    }

    .service-title {
      margin: 0;
      letter-spacing: 0.04em;
    }

    .service-title {
      font-size: 1.28rem;
      font-family: var(--font-display);
      font-weight: 500;
      color: var(--gray-darkest);
      line-height: 1.28;
      letter-spacing: 0.06em;
    }

    .service-title-compact {
      font-size: 1.14rem;
      line-height: 1.4;
    }

    .service-icon {
      width: 72px;
      height: 72px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
    }

    .service-icon svg {
      width: 100%;
      height: 100%;
      color: var(--gray-medium);
      transition: all 0.3s ease;
    }

    .service-card:hover .service-icon {
      transform: scale(1.1) rotate(5deg);
    }

    .service-card:hover .service-icon svg {
      color: var(--tiffany-primary);
    }

    @media (max-width: 1200px) {
      .service-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 768px) {
      .service-section {
        padding: 3rem 1.5rem;
      }

      .section-title {
        font-size: 2rem;
      }

      .service-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.5rem;
      }

      .service-content {
        padding: 2rem 1.5rem;
        min-height: 220px;
      }

      .service-text {
        min-height: 3.7rem;
      }

      .service-title {
        font-size: 1.14rem;
      }

      .service-title-compact {
        font-size: 1rem;
        white-space: normal;
      }

      .service-icon {
        width: 60px;
        height: 60px;
      }
    }

    @media (max-width: 480px) {
      .service-grid {
        grid-template-columns: 1fr;
      }
    }

    .smart-case-section {
