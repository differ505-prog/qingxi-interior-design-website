    }

    .testimonial-card:nth-child(3) {
      grid-column: 9 / -1;
      margin-top: 1rem;
    }

    .testimonial-card.animate-in {
      opacity: 1;
      transform: scale(1);
    }

    .testimonial-card:hover {
      transform: translateY(-4px);
    }

    .testimonial-label {
      margin: 0 0 0.8rem;
      font-size: 0.76rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gray-medium);
    }

    .promise-title {
      font-size: clamp(1.5rem, 2vw, 2.2rem);
      font-weight: 500;
      color: var(--gray-dark);
      margin-bottom: 1rem;
      text-align: left;
      font-family: var(--font-display);
      line-height: 1.22;
      letter-spacing: 0.06em;
    }

    .testimonial-text {
      font-size: 1rem;
      line-height: var(--type-body-line-height);
      color: var(--gray-medium);
      margin-bottom: 0;
      text-align: left;
      letter-spacing: var(--type-body-tracking);
    }

    /* FAQ Section Styles */
    .faq-section {
      padding: clamp(5rem, 9vw, 7.5rem) 2rem;
      background:
        radial-gradient(circle at top right, rgba(159, 147, 136, 0.04), transparent 24%),
        linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(246, 241, 236, 1) 100%);
    }

    .faq-container {
      max-width: 1180px;
      margin: 0 auto;
    }

    .faq-header {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 1.5rem;
      align-items: end;
      margin-bottom: 2.2rem;
    }

    .faq-header-main {
      grid-column: 1 / span 7;
    }

    .faq-header-main.section-header {
      text-align: left;
      max-width: none;
      margin: 0;
    }

    .faq-home-note {
      grid-column: 9 / -1;
      padding: 1.1rem 0 0 1.35rem;
      border-left: 1px solid rgba(164, 171, 160, 0.2);
    }

    .faq-home-note-label {
      margin: 0 0 0.65rem;
      font-size: 0.76rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gray-medium);
    }

    .faq-home-note p:last-child {
      margin: 0;
      color: color-mix(in srgb, var(--gray-darkest) 60%, transparent);
      line-height: var(--type-body-line-height);
      letter-spacing: var(--type-body-tracking);
    }

    .faq-list {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 1.35rem 1.15rem;
    }

    .faq-intro {
      max-width: 38rem;
      margin: 1rem 0 0;
      color: var(--gray-medium);
      line-height: var(--type-body-line-height);
      letter-spacing: var(--type-body-tracking);
    }

    .faq-curation {
      margin: 0 0 1.9rem;
      max-width: 32rem;
    }

    .faq-curation-label {
      margin: 0 0 0.55rem;
      font-size: 0.76rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gray-medium);
    }

    .faq-curation p:last-child {
      margin: 0;
      color: color-mix(in srgb, var(--gray-darkest) 58%, transparent);
      line-height: var(--type-body-line-height);
      letter-spacing: var(--type-body-tracking);
    }

    .faq-item {
      position: relative;
      grid-column: span 12;
      padding: 1.15rem 0 0;
      background: transparent;
      border-radius: 0;
      overflow: visible;
      border: 0;
      box-shadow: none;
      backdrop-filter: none;
      opacity: 0;
      transition:
        opacity 0.8s ease,
        transform 0.8s ease;
    }

    .faq-item::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: min(180px, 48%);
      height: 1px;
      background: linear-gradient(90deg, rgba(115, 103, 94, 0.46), rgba(115, 103, 94, 0.08));
    }

    .faq-item:nth-child(2),
    .faq-item:nth-child(3) {
      grid-column: span 6;
    }

    .faq-item:nth-child(2) {
      margin-top: 1.2rem;
    }

    .faq-item[data-animate="left"] {
      transform: translateX(-30px);
    }

    .faq-item[data-animate="right"] {
      transform: translateX(30px);
    }

    .faq-item.animate-in {
      opacity: 1;
      transform: translateX(0);
    }

    .faq-item:hover {
      transform: translateY(-2px);
    }

    .faq-item.active {
      transform: translateX(0);
    }

    .faq-item.active::before {
      background: linear-gradient(90deg, rgba(79, 72, 66, 0.7), rgba(115, 103, 94, 0.14));
    }

    .faq-item-label {
      margin: 0 0 0.75rem;
      font-size: 0.76rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gray-medium);
    }

    .faq-question {
      width: 100%;
      padding: 0 0 1rem;
      background: none;
      border: none;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      cursor: pointer;
      font-size: clamp(1.3rem, 2vw, 1.8rem);
      font-weight: 500;
      color: var(--gray-dark);
      text-align: left;
      transition: all 0.3s ease;
      font-family: var(--font-display);
      line-height: 1.24;
      letter-spacing: 0.05em;
    }

    .faq-question-text {
      display: block;
      max-width: 26ch;
    }

    .faq-question:hover {
      color: var(--gray-darkest);
    }

    .faq-icon {
      width: 24px;
      height: 24px;
      flex-shrink: 0;
      transition: transform 0.3s ease;
      color: var(--gray-medium);
    }

    .faq-item.active .faq-icon {
      transform: rotate(180deg);
      color: var(--gray-darkest);
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }

    .faq-item.active .faq-answer {
      max-height: 300px;
    }

    .faq-answer p {
      padding: 0 2rem 0 0;
      color: var(--gray-medium);
      line-height: var(--type-body-line-height);
      letter-spacing: var(--type-body-tracking);
      margin: 0;
    }

    .faq-actions {
      margin-top: 2.3rem;
      display: flex;
      justify-content: flex-start;
      flex-wrap: wrap;
      gap: 0.85rem;
    }

    .faq-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.9rem 1.3rem;
      border-radius: 999px;
      text-decoration: none;
      letter-spacing: 0.06em;
      transition:
        transform 0.25s ease,
        background-color 0.25s ease;
    }

    .faq-link:hover {
      transform: translateY(-2px);
    }

    .faq-link-primary {
      background: var(--gray-darkest);
      color: var(--white);
    }

    .faq-link-secondary {
      background: rgba(255, 255, 255, 0.96);
      color: var(--gray-darkest);
      box-shadow: inset 0 0 0 1px rgba(115, 103, 94, 0.14);
    }

    /* Responsive Styles */
    @media (max-width: 1024px) {
      .brand-strip-inner {
        grid-template-columns: 1fr;
      }

      .about-container {
        gap: 3rem;
      }

      .stats-container {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
      }

      .testimonial-grid {
        grid-template-columns: 1fr;
      }

      .faq-header {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .faq-header-main,
      .faq-home-note {
        grid-column: auto;
      }

      .faq-home-note,
      .workflow-editor-note {
        padding: 0.9rem 0 0 0;
        border-left: 0;
        border-top: 1px solid rgba(164, 171, 160, 0.2);
      }

      .testimonial-card,
      .testimonial-card:nth-child(1),
      .testimonial-card:nth-child(2),
      .testimonial-card:nth-child(3),
      .faq-item,
      .faq-item:nth-child(2),
      .faq-item:nth-child(3) {
        grid-column: auto;
        margin-top: 0;
      }

      .site-proof-shell {
        grid-template-columns: 1fr;
      }

      .workflow-header {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .workflow-header-main,
      .workflow-editor-note {
        grid-column: auto;
      }

      .consult-shell {
        grid-template-columns: 1fr;
      }

      .faq-list {
        grid-template-columns: 1fr;
      }

      .consult-actions {
        min-width: 0;
        max-width: 340px;
      }
    }

    @media (max-width: 768px) {
      .brand-strip {
        padding: 0 1.25rem;
