---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroCarousel from "../components/HeroCarousel.astro";

const homeDescription =
  "青曦空間設計提供大台北住宅、商業空間與智能家居整合服務，從設計提案、工程管理到裝修估價與需求整理，協助你把理想空間落地。";
const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "設計費用如何計算？",
        acceptedAnswer: {
          "@type": "Answer",
          text: "一般住宅設計費約為每坪 NT$ 3,000-6,000 元。初步諮詢免費，了解需求後會提供詳細報價。",
        },
      },
      {
        "@type": "Question",
        name: "從設計到完工需要多久時間？",
        acceptedAnswer: {
          "@type": "Answer",
          text: "整體時程約 3 到 6 個月，依空間大小與工程內容而定。",
        },
      },
      {
        "@type": "Question",
        name: "可以只做設計不做工程嗎？",
        acceptedAnswer: {
          "@type": "Answer",
          text: "可以，青曦提供純設計服務；若採設計加工程統包，整體品質與時程會更有保障。",
        },
      },
    ],
  },
];
---

<BaseLayout
  title="首頁 - 青曦空間設計"
  description={homeDescription}
  ogImage="/images/portfolio/xizhi-1.jpg"
  structuredData={homeStructuredData}
>
  <HeroCarousel />

  <section class="brand-strip">
    <div class="brand-strip-inner">
      <div class="brand-strip-copy">
        <p class="brand-strip-label">BRAND VISION</p>
        <h2>從設計到工程，給你好住的空間</h2>
        <p class="brand-strip-intro">
          不只追求視覺美感，更在意入住後的耐用與舒適。
          我們讓預算透明、工序清晰，每一次決策都安心。
        </p>
        <div class="brand-smart-home">
          <p class="brand-smart-home-label">SMART LIVING</p>
          <h3>智能家居 Smart Home，不只是配設備，而是把科技真正住進生活</h3>
          <p>
            青曦可協助規劃與設定 Home Assistant、NAS 與跨品牌設備整合，
            讓燈光、窗簾、空調、門鎖、監控、備份與情境控制在入住後更直覺、更穩定。
          </p>
          <div class="brand-smart-home-actions">
            <a href="/smart-home" class="brand-smart-home-link">查看智能家居專區</a>
          <a href="/smart-home-quiz" class="brand-smart-home-link brand-smart-home-link-secondary">
            智能家居快篩
          </a>
          </div>
        </div>
        <div class="brand-credential">
          <p class="brand-credential-label">PROFESSIONAL CREDENTIAL</p>
          <p class="brand-credential-title">具建築物室內裝修工程管理乙級技術士資格</p>
          <p class="brand-credential-description">
            在設計美感之外，也重視工程管理、施工節點與實際落地品質。
          </p>
        </div>
      </div>
      <div class="brand-strip-metrics">
        <article class="brand-metric">
          <strong>住宅與商空</strong>
          <span>整合規劃與工程落地</span>
        </article>
        <article class="brand-metric">
          <strong>透明報價</strong>
          <span>從需求到估算都有清楚節點</span>
        </article>
        <article class="brand-metric">
          <strong>大台北服務</strong>
          <span>專注區域，回應更即時</span>
        </article>
      </div>
    </div>
  </section>

  <!-- 關於我們 Section -->
  <section class="about-section">
    <div class="about-container">
      <div class="about-header" data-animate="left">
        <h6 class="section-subtitle">ABOUT US</h6>
        <h2 class="section-title">青曦空間設計</h2>
        <p class="about-tagline">讓生活理念與美學完美結合</p>
        <p class="about-intro">深耕大台北地區，提供從毛胚到成屋的完整空間對策</p>
      </div>

      <div class="core-philosophy" data-animate="right">
        <div class="philosophy-quote">
          <span class="quote-mark">"</span>
          <p>用心傾聽、用設計說話</p>
          <span class="quote-dash">——</span>
          <p class="quote-detail">少一點空話，多一點專業，為你打造真正適合久住的空間。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 核心優勢 Section -->
  <section class="stats-section">
    <div class="stats-container">
      <div class="stat-item" data-animate="scale">
        <div class="stat-number">100%</div>
        <div class="stat-label">客製化設計</div>
      </div>
      <div class="stat-item" data-animate="scale">
        <div class="stat-number">1年</div>
        <div class="stat-label">工程保固</div>
      </div>
      <div class="stat-item" data-animate="scale">
        <div class="stat-number">免費</div>
        <div class="stat-label">初步諮詢</div>
      </div>
      <div class="stat-item" data-animate="scale">
        <div class="stat-number">透明</div>
        <div class="stat-label">報價流程</div>
      </div>
    </div>
  </section>

  <section class="public-ready-section">
    <div class="public-ready-container">
      <div class="section-header public-ready-header">
        <h6 class="section-subtitle">COOPERATION GUIDE</h6>
        <h2 class="section-title">合作資訊</h2>
        <p class="public-ready-intro">
          如果你是第一次接觸青曦，這裡先幫你快速理解目前的服務範圍、合作方式與適合的案型。
        </p>
      </div>

      <div class="public-ready-shell">
        <article class="public-ready-highlight" data-animate="left">
          <p class="public-ready-label">QINGXI FIT</p>
          <h3>適合想把設計、美感與工程執行一起整理清楚的屋主</h3>
          <p>
            不論是預售屋客變、新成屋整理、老屋翻新，或希望將智能家居一起納入規劃，
            青曦都以「好住、耐看、可落地」為核心，協助你把需求與預算對齊。
          </p>
          <div class="public-ready-tags">
            <span>預售屋客變</span>
            <span>住宅翻新</span>
            <span>新成屋規劃</span>
            <span>智能家居整合</span>
          </div>
          <div class="public-ready-actions">
            <a href="/portfolio" class="public-ready-link public-ready-link-primary">先看作品</a>
            <a href="/contact" class="public-ready-link public-ready-link-secondary">直接諮詢</a>
          </div>
        </article>

        <div class="public-ready-grid">
          <article class="public-ready-card" data-animate="scale">
            <p class="public-ready-card-label">SERVICE AREA</p>
            <h3>服務範圍</h3>
            <p>以大台北住宅與商業空間為主，著重溝通效率、現場掌握與工程整合。</p>
          </article>

          <article class="public-ready-card" data-animate="scale">
            <p class="public-ready-card-label">WORKING METHOD</p>
            <h3>合作方式</h3>
            <p>可先透過 LINE 或需求表初談，再依空間條件安排丈量、提案與後續設計流程。</p>
          </article>

          <article class="public-ready-card" data-animate="scale">
            <p class="public-ready-card-label">PORTFOLIO VIEW</p>
            <h3>案例呈現方式</h3>
            <p>目前可從作品案例、工程前後對比與設計圖紙，更完整了解青曦的規劃與落地能力。</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- 服務項目 Section -->
  <section class="service-section">
    <div class="service-container">
      <div class="section-header">
        <h6 class="section-subtitle">SERVICE</h6>
        <h2 class="section-title">服務項目</h2>
        <p class="service-intro">以住宅空間為主軸，延伸整合商業空間、智能家居與社區公共空間規劃。</p>
      </div>

      <ul class="service-grid">
        <li class="service-item" data-animate="scale">
          <a href="/portfolio?category=residential" class="service-card">
            <figure class="service-content">
              <div class="service-text">
                <p class="service-title">住宅</p>
              </div>
              <div class="service-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                  ></path>
                  <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
              </div>
            </figure>
          </a>
        </li>

        <li class="service-item" data-animate="scale">
          <a href="/portfolio?category=commercial" class="service-card">
            <figure class="service-content">
              <div class="service-text">
                <p class="service-title">商業空間</p>
              </div>
              <div class="service-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                  <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                </svg>
              </div>
            </figure>
          </a>
        </li>

        <li class="service-item" data-animate="scale">
          <a href="/contact" class="service-card">
            <figure class="service-content">
              <div class="service-text">
                <p class="service-title">室內設計</p>
                <p class="service-title">工程施作</p>
              </div>
              <div class="service-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
                  ></path>
                </svg>
              </div>
            </figure>
          </a>
        </li>

        <li class="service-item" data-animate="scale">
          <a href="/smart-home" class="service-card">
            <figure class="service-content">
              <div class="service-text">
                <p class="service-title service-title-compact">智能家居 Smart Home</p>
              </div>
              <div class="service-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <rect x="4" y="4" width="16" height="16" rx="3"></rect>
                  <path d="M9 9h.01"></path>
                  <path d="M15 9h.01"></path>
                  <path d="M9 15h6"></path>
                  <path d="M12 4v-2"></path>
                  <path d="M12 22v-2"></path>
                  <path d="M4 12h-2"></path>
                  <path d="M22 12h-2"></path>
                </svg>
              </div>
            </figure>
          </a>
        </li>

        <li class="service-item" data-animate="scale">
          <a href="/portfolio?category=community" class="service-card">
            <figure class="service-content">
              <div class="service-text">
                <p class="service-title">社區公設</p>
              </div>
              <div class="service-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
              </div>
            </figure>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="smart-case-section">
    <div class="smart-case-container">
      <div class="section-header smart-case-header">
        <h6 class="section-subtitle">SMART HOME CASE</h6>
        <h2 class="section-title">懂科技的設計師，能把智能家居做得更完整</h2>
        <p class="smart-case-intro">
          不只規劃空間與動線，也能把 Home Assistant 設定、NAS、
          弱電配置與跨品牌設備整合納入同一套設計思考。
        </p>
      </div>

      <div class="smart-case-shell">
        <article class="smart-case-summary">
          <p class="smart-case-label">SMART HOME POSITIONING</p>
          <h3>從裝修前期就把智慧控制、資料備份與家庭網路一起想清楚</h3>
          <p class="smart-case-description">
            青曦不只做設備清單，而是把空間設計、弱電架構、HA 自動化邏輯與 NAS 應用
            一起規劃，讓家更順手，也保留後續升級彈性。
          </p>
          <div class="smart-case-tags">
            <span>系統設定整合</span>
            <span>Home Assistant</span>
            <span>NAS</span>
            <span>跨品牌整合</span>
          </div>
          <div class="smart-case-actions">
            <a href="/smart-home" class="smart-case-link">查看完整專區</a>
            <a href="/smart-home-quiz" class="smart-case-link smart-case-link-secondary">智能家居快篩</a>
          </div>
        </article>

        <div class="smart-case-grid">
          <article class="smart-case-card">
            <p class="smart-case-card-label">HA 設定</p>
            <h3>協助整理與設定 Home Assistant，讓自動化更快進入可用狀態</h3>
            <p>
              協助整理需求、撰寫規則、調整儀表板與排查整合問題，
              讓回家、離家、睡眠與節能模式更快落地。
            </p>
          </article>

          <article class="smart-case-card">
            <p class="smart-case-card-label">NAS 規劃</p>
            <h3>把備份、媒體、監控與遠端存取納入居家系統的一部分</h3>
            <p>
              從網路節點、主機位置、散熱與權限管理一起規劃，
              避免 NAS 變成裝好卻不好用的孤島設備。
            </p>
          </article>

          <article class="smart-case-card">
            <p class="smart-case-card-label">整合能力</p>
            <h3>燈光、窗簾、空調、門鎖、感測與監控整合成同一套邏輯</h3>
            <p>
              不被單一品牌綁死，能依實際生活情境規劃控制介面、
              情境切換與擴充路線。
            </p>
          </article>

          <article class="smart-case-card">
            <p class="smart-case-card-label">設計視角</p>
            <h3>因為懂空間設計，所以科技不會破壞日常使用感</h3>
            <p>
              從開關位置、收納、弱電箱、機櫃、布線到操作流程，
              都能和整體空間一起思考，這就是懂科技的設計師的差別。
            </p>
          </article>
        </div>
        <p class="smart-case-mobile-note">手機版先整理兩個重點能力，更多整合內容可進入智能家居專區查看。</p>
      </div>
    </div>
  </section>

  <!-- 服務流程 Section -->
  <section id="workflow" class="workflow-section">
    <div class="workflow-container">
      <div class="workflow-header">
        <h6 class="section-subtitle">WORKFLOW</h6>
        <h2 class="section-title">服務流程</h2>
        <p class="workflow-mobile-note">手機版先看前四個關鍵節點，完整流程會在諮詢後依案型進一步說明。</p>
      </div>

      <ul class="workflow-list">
        <li class="workflow-item" data-animate="left">
          <div class="workflow-number">01</div>
          <div class="workflow-content">
            <h3>初步接洽</h3>
            <p>了解需求與預算，釐清設計方向。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="right">
          <div class="workflow-number">02</div>
          <div class="workflow-content">
            <h3>現場丈量</h3>
            <p>專業團隊到場，完整記錄空間現況。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="left">
          <div class="workflow-number">03</div>
          <div class="workflow-content">
            <h3>平面提案</h3>
            <p>規劃平面圖，提供風格與初步預算。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="right">
          <div class="workflow-number">04</div>
          <div class="workflow-content">
            <h3>設計委任</h3>
            <p>簽訂合約，進入深入規劃階段。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="left">
          <div class="workflow-number">05</div>
          <div class="workflow-content">
            <h3>細部設計</h3>
            <p>繪製 3D 與施工圖，確認每個細節。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="right">
          <div class="workflow-number">06</div>
          <div class="workflow-content">
            <h3>工程報價</h3>
            <p>依最終設計與選材，提出透明報價。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="left">
          <div class="workflow-number">07</div>
          <div class="workflow-content">
            <h3>工程施作</h3>
            <p>安排進度，嚴格控管施工品質。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="right">
          <div class="workflow-number">08</div>
          <div class="workflow-content">
            <h3>完工交屋</h3>
            <p>陪同驗收，確認細節後交屋。</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- 服務承諾 Section -->
  <section class="testimonial-section">
    <div class="testimonial-container">
      <div class="section-header">
        <h6 class="section-subtitle">OUR PROMISE</h6>
        <h2 class="section-title">我們的承諾</h2>
      </div>

      <div class="testimonial-grid">
        <div class="testimonial-card" data-animate="scale">
          <div class="promise-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3 class="promise-title">用心傾聽</h3>
          <p class="testimonial-text">
            仔細聆聽生活需求，將想法化為真正可執行的設計方案。
          </p>
        </div>

        <div class="testimonial-card" data-animate="scale">
          <div class="promise-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <h3 class="promise-title">品質保證</h3>
          <p class="testimonial-text">
            從材料到施工嚴格把關，並提供完整一年工程保固。
          </p>
        </div>

        <div class="testimonial-card" data-animate="scale">
          <div class="promise-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <h3 class="promise-title">準時交付</h3>
          <p class="testimonial-text">
            重視時程與落地品質，透過前期規劃確保如期完工。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="consult-section">
    <div class="consult-shell">
      <div class="consult-copy">
        <p class="section-subtitle consult-subtitle">NEXT STEP</p>
        <h2 class="consult-title">正在整理新家需求？現在就從諮詢開始</h2>
        <p class="consult-description">
