  <script>
    // Intersection Observer for scroll animations
    document.addEventListener("DOMContentLoaded", () => {
      const observerOptions = {
        threshold: 0.2,
        rootMargin: "0px 0px -50px 0px",
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const delay = Number(entry.target.getAttribute("data-animate-delay") || 0);
            setTimeout(() => {
              entry.target.classList.add("animate-in");
              observer.unobserve(entry.target);
            }, delay);
          }
        });
      }, observerOptions);

      function observeElements(
        elements: NodeListOf<HTMLElement> | (Element | null)[],
        delayStep = 0,
      ) {
        Array.from(elements).forEach((element, index) => {
          if (!(element instanceof HTMLElement)) return;
          element.setAttribute("data-animate-delay", String(index * delayStep));
          observer.observe(element);
        });
      }

      // Observe about section
      const aboutHeader = document.querySelector(".about-header");
      const corePhilosophy = document.querySelector(".core-philosophy");
      observeElements([aboutHeader, corePhilosophy]);

      // Observe stats
      const statItems = document.querySelectorAll<HTMLElement>(".stat-item");
      observeElements(statItems, 100);

      // Observe public-ready section
      const publicReadyItems = document.querySelectorAll<HTMLElement>(".public-ready-highlight, .public-ready-card");
      observeElements(publicReadyItems, 120);

      // Observe service items
      const serviceItems = document.querySelectorAll<HTMLElement>(".service-item");
      observeElements(serviceItems, 100);

      // Observe workflow items
      const workflowItems = document.querySelectorAll<HTMLElement>(".workflow-item");
      observeElements(workflowItems, 150);

      // Observe testimonials
      const testimonialCards = document.querySelectorAll<HTMLElement>(".testimonial-card");
      observeElements(testimonialCards, 150);

      // Observe FAQ items
      const faqItems = document.querySelectorAll<HTMLElement>(".faq-item");
      observeElements(faqItems, 100);

      // FAQ Toggle
      const faqQuestions = document.querySelectorAll(".faq-question");
      faqQuestions.forEach((question) => {
        question.addEventListener("click", () => {
          const faqItem = question.parentElement;

          // Add null check to fix TypeScript error
          if (!faqItem) return;

          const isActive = faqItem.classList.contains("active");

          // Close all FAQ items
          document.querySelectorAll(".faq-item").forEach((item) => {
            item.classList.remove("active");
          });

          // Toggle current item
          if (!isActive) {
            faqItem.classList.add("active");
          }
        });
      });
    });
  </script>
