---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroCarousel from "../components/HeroCarousel.astro";

const homeDescription =
  "青曦空間設計專注大台北住宅、商空與智能整合，把需求、預算與施工安排整理成真正能落地的空間。";
const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "設計費用如何計算？",
        acceptedAnswer: {
          "@type": "Answer",
          text: "一般住宅設計費約為每坪 NT$ 3,000-6,000 元。先聊需求後，才會給你對得上的報價。",
        },
      },
      {
        "@type": "Question",
        name: "從設計到完工需要多久時間？",
        acceptedAnswer: {
          "@type": "Answer",
          text: "多數案子約 3 到 6 個月，還是會依空間大小與工程內容微調。",
        },
      },
      {
        "@type": "Question",
        name: "可以只做設計不做工程嗎？",
        acceptedAnswer: {
          "@type": "Answer",
          text: "可以。若一起做設計加工程，整體品質與時程通常更好掌握。",
        },
      },
    ],
  },
];
---

<BaseLayout
  title="首頁 - 青曦空間設計"
  description={homeDescription}
  ogImage="/images/portfolio/xizhi-1.jpg"
  structuredData={homeStructuredData}
>
  <HeroCarousel />

  <section class="brand-strip">
    <div class="brand-strip-inner">
      <div class="brand-strip-copy">
        <p class="brand-strip-label">品牌概念</p>
        <h2>設計與工程，一起想清楚</h2>
        <p class="brand-strip-intro">
          先對齊需求與預算，再把空間做好。
        </p>
        <div class="brand-smart-home">
          <p class="brand-smart-home-label">智能家居</p>
          <h3>先把科技放對位置</h3>
          <p>
            Home Assistant、NAS 與跨品牌整合可一起規劃。
          </p>
          <div class="brand-smart-home-actions">
            <a href="/smart-home" class="brand-smart-home-link">查看智能家居專區</a>
          <a href="/smart-home-quiz" class="brand-smart-home-link brand-smart-home-link-secondary">
            智能家居快篩
          </a>
          </div>
        </div>
        <div class="brand-credential">
          <p class="brand-credential-label">專業資格</p>
          <p class="brand-credential-title">具室內裝修工程管理乙級證照</p>
          <p class="brand-credential-description">
            設計與落地一起看。
          </p>
        </div>
      </div>
      <div class="brand-strip-metrics">
        <article class="brand-metric">
          <strong>住宅、商空、智能整合</strong>
          <span>一起規劃</span>
        </article>
        <article class="brand-metric">
          <strong>大台北服務</strong>
          <span>回應更快</span>
        </article>
      </div>
    </div>
  </section>

  <!-- 關於我們 Section -->
  <section class="about-section">
    <div class="about-container">
      <div class="about-header" data-animate="left">
        <h6 class="section-subtitle">品牌介紹</h6>
        <h2 class="section-title">青曦空間設計</h2>
        <p class="about-tagline">把美感做成能久住的日常</p>
        <p class="about-intro">深耕大台北，專注住宅、商空與智能整合。</p>
      </div>

      <div class="core-philosophy" data-animate="right">
        <div class="philosophy-quote">
          <span class="quote-mark">"</span>
          <p>少一點空話，多一點真的適合</p>
          <span class="quote-dash">——</span>
          <p class="quote-detail">設計不是堆漂亮詞，而是把生活整理得更好住。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 核心優勢 Section -->
  <section class="stats-section">
    <div class="stats-container">
      <div class="stat-item" data-animate="scale">
        <div class="stat-kicker">設計</div>
        <div class="stat-number">客製化設計</div>
        <div class="stat-label">依空間、預算與使用習慣調整</div>
      </div>
      <div class="stat-item" data-animate="scale">
        <div class="stat-kicker">保固</div>
        <div class="stat-number">1 年工程保固</div>
        <div class="stat-label">完工後仍有清楚的售後承接</div>
      </div>
      <div class="stat-item" data-animate="scale">
        <div class="stat-kicker">諮詢</div>
        <div class="stat-number">初步諮詢免費</div>
        <div class="stat-label">先把方向、預算與條件對清楚</div>
      </div>
      <div class="stat-item" data-animate="scale">
        <div class="stat-kicker">報價</div>
        <div class="stat-number">報價流程透明</div>
        <div class="stat-label">每一步怎麼估、怎麼走都說清楚</div>
      </div>
    </div>
  </section>

  <!-- 服務項目 Section -->
  <section class="service-section">
    <div class="service-container">
      <div class="section-header">
        <h6 class="section-subtitle">服務內容</h6>
        <h2 class="section-title">服務項目</h2>
        <p class="service-intro">住宅、商空、智能整合。</p>
      </div>

      <ul class="service-grid">
        <li class="service-item" data-animate="scale">
          <a href="/portfolio?category=residential" class="service-card">
            <figure class="service-content">
              <div class="service-text">
                <p class="service-title">住宅</p>
              </div>
              <div class="service-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                  ></path>
                  <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
              </div>
            </figure>
          </a>
        </li>

        <li class="service-item" data-animate="scale">
          <a href="/portfolio?category=commercial" class="service-card">
            <figure class="service-content">
              <div class="service-text">
                <p class="service-title">商業空間</p>
              </div>
              <div class="service-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                  <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                </svg>
              </div>
            </figure>
          </a>
        </li>

        <li class="service-item" data-animate="scale">
          <a href="/contact" class="service-card">
            <figure class="service-content">
              <div class="service-text">
                <p class="service-title">室內設計</p>
                <p class="service-title">工程施作</p>
              </div>
              <div class="service-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
                  ></path>
                </svg>
              </div>
            </figure>
          </a>
        </li>

        <li class="service-item" data-animate="scale">
          <a href="/smart-home" class="service-card">
            <figure class="service-content">
              <div class="service-text">
                <p class="service-title service-title-compact">智能家居 Smart Home</p>
              </div>
              <div class="service-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <rect x="4" y="4" width="16" height="16" rx="3"></rect>
                  <path d="M9 9h.01"></path>
                  <path d="M15 9h.01"></path>
                  <path d="M9 15h6"></path>
                  <path d="M12 4v-2"></path>
                  <path d="M12 22v-2"></path>
                  <path d="M4 12h-2"></path>
                  <path d="M22 12h-2"></path>
                </svg>
              </div>
            </figure>
          </a>
        </li>

        <li class="service-item" data-animate="scale">
          <a href="/portfolio?category=community" class="service-card">
            <figure class="service-content">
              <div class="service-text">
                <p class="service-title">社區公設</p>
              </div>
              <div class="service-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
              </div>
            </figure>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="smart-case-section">
    <div class="smart-case-container">
      <div class="section-header smart-case-header">
        <h6 class="section-subtitle">智能家居</h6>
        <h2 class="section-title">把智能、空間與使用感一起規劃</h2>
        <p class="smart-case-intro">
          智能、弱電與空間一次規劃。
        </p>
      </div>

      <div class="smart-case-shell">
        <article class="smart-case-summary">
          <p class="smart-case-label">整合定位</p>
          <h3>從裝修前期就把控制、備份與家庭網路一起規劃好</h3>
          <p class="smart-case-description">
            先定控制邏輯與弱電配置，再選設備。
          </p>
          <div class="smart-case-tags">
            <span>系統設定整合</span>
            <span>Home Assistant</span>
            <span>NAS</span>
            <span>跨品牌整合</span>
          </div>
          <div class="smart-case-actions">
            <a href="/smart-home" class="smart-case-link">查看完整專區</a>
            <a href="/smart-home-quiz" class="smart-case-link smart-case-link-secondary">智能家居快篩</a>
          </div>
        </article>

        <div class="smart-case-grid">
          <article class="smart-case-card">
            <p class="smart-case-card-label">HA 設定</p>
            <h3>協助整理與設定 Home Assistant，讓自動化更快能用</h3>
            <p>
              協助整理需求、撰寫規則與排查整合問題，
              讓回家、離家、睡眠與節能模式更快落地。
            </p>
          </article>

          <article class="smart-case-card">
            <p class="smart-case-card-label">NAS 規劃</p>
            <h3>把備份、媒體、監控與遠端存取整理成同一套系統</h3>
            <p>
              從網路節點、主機位置到散熱與權限一起規劃，
              避免 NAS 變成裝好卻不好用的孤島設備。
            </p>
          </article>

          <article class="smart-case-card">
            <p class="smart-case-card-label">整合能力</p>
            <h3>燈光、窗簾、空調與門鎖整合成同一套邏輯</h3>
            <p>
              不被單一品牌綁死，能依實際生活情境規劃控制介面、
              情境切換與擴充路線。
            </p>
          </article>

          <article class="smart-case-card">
            <p class="smart-case-card-label">設計視角</p>
            <h3>懂空間設計，所以科技不會破壞日常使用感</h3>
            <p>
              從開關位置、收納、弱電箱到操作流程，
              都能和整體空間一起思考。
            </p>
          </article>
        </div>
        <p class="smart-case-mobile-note">手機版先看重點能力，更多內容可進入智能家居專區。</p>
      </div>
    </div>
  </section>

  <!-- 服務流程 Section -->
  <section id="workflow" class="workflow-section">
    <div class="workflow-container">
      <div class="workflow-header">
        <h6 class="section-subtitle">合作流程</h6>
        <h2 class="section-title">怎麼開始</h2>
        <p class="workflow-mobile-note">8 個節點，一眼看完。</p>
      </div>

      <ul class="workflow-list">
        <li class="workflow-item" data-animate="left">
          <div class="workflow-number">01</div>
          <div class="workflow-content">
            <h3>初步接洽</h3>
            <p>了解需求與預算，釐清設計方向。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="right">
          <div class="workflow-number">02</div>
          <div class="workflow-content">
            <h3>現場丈量</h3>
            <p>專業團隊到場，完整記錄空間現況。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="left">
          <div class="workflow-number">03</div>
          <div class="workflow-content">
            <h3>平面提案</h3>
            <p>規劃平面圖，提供風格與初步預算。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="right">
          <div class="workflow-number">04</div>
          <div class="workflow-content">
            <h3>設計委任</h3>
            <p>簽訂合約，進入深入規劃階段。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="left">
          <div class="workflow-number">05</div>
          <div class="workflow-content">
            <h3>細部設計</h3>
            <p>繪製 3D 與施工圖，確認每個細節。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="right">
          <div class="workflow-number">06</div>
          <div class="workflow-content">
            <h3>工程報價</h3>
            <p>依最終設計與選材，提出透明報價。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="left">
          <div class="workflow-number">07</div>
          <div class="workflow-content">
            <h3>工程施作</h3>
            <p>安排進度，嚴格控管施工品質。</p>
          </div>
        </li>

        <li class="workflow-item" data-animate="right">
          <div class="workflow-number">08</div>
          <div class="workflow-content">
            <h3>完工交屋</h3>
            <p>陪同驗收，確認細節後交屋。</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <section class="site-proof-section">
    <div class="site-proof-shell">
      <div class="site-proof-copy">
        <p class="site-proof-label">現場與落地</p>
        <h2>不只看圖，也看現場</h2>
        <p>
          從丈量、拆改到施工安排，都以現場條件為基礎。
        </p>
      </div>
      <figure class="site-proof-photo">
        <img
          src="/images/home/site-process-1.jpg"
          alt="青曦空間設計工地現場拆改與丈量紀錄"
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <!-- 服務承諾 Section -->
  <section class="testimonial-section">
    <div class="testimonial-container">
      <div class="section-header">
        <h6 class="section-subtitle">服務承諾</h6>
        <h2 class="section-title">我們的承諾</h2>
      </div>

      <div class="testimonial-grid">
        <div class="testimonial-card" data-animate="scale">
          <div class="promise-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3 class="promise-title">用心傾聽</h3>
          <p class="testimonial-text">
            把生活需求整理成可執行的方案。
          </p>
        </div>

        <div class="testimonial-card" data-animate="scale">
          <div class="promise-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <h3 class="promise-title">品質保證</h3>
          <p class="testimonial-text">
            從材料到施工都確實把關，並提供一年工程保固。
          </p>
        </div>

        <div class="testimonial-card" data-animate="scale">
          <div class="promise-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <h3 class="promise-title">準時交付</h3>
          <p class="testimonial-text">
            重視時程，也重視交付品質。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="consult-section">
    <div class="consult-shell">
      <div class="consult-copy">
        <p class="section-subtitle consult-subtitle">下一步</p>
        <h2 class="consult-title">準備開始，就直接留下需求。</h2>
        <p class="consult-description">
          需求、預算、時程一次整理。
        </p>
      </div>
      <div class="consult-actions">
        <a href="/contact" class="consult-button consult-button-primary">預約諮詢</a>
        <a href="/tools" class="consult-button consult-button-secondary">開始估價</a>
        <a href="/smart-home-quiz" class="consult-button consult-button-secondary">智能家居快篩</a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="faq-container">
      <div class="section-header">
        <h6 class="section-subtitle">FAQ</h6>
        <h2 class="section-title">常見問題</h2>
        <p class="faq-intro">先看 3 個常見問題。</p>
      </div>

      <div class="faq-list">
        <div class="faq-item" data-animate="left">
          <button class="faq-question">
            <span>設計費用如何計算？</span>
            <svg
              class="faq-icon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <p>
              一般住宅設計費約為每坪 NT$ 3,000-6,000 元。先聊需求後，才會給你對得上的報價。
            </p>
          </div>
        </div>

        <div class="faq-item" data-animate="right">
          <button class="faq-question">
            <span>從設計到完工需要多久時間？</span>
            <svg
              class="faq-icon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <p>
              多數案子約 3 到 6 個月，還是會依空間大小與工程內容微調。
            </p>
          </div>
        </div>

        <div class="faq-item" data-animate="left">
          <button class="faq-question">
            <span>可以只做設計不做工程嗎？</span>
            <svg
              class="faq-icon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <p>
              可以。若一起做設計加工程，整體品質與時程通常更好掌握。
            </p>
          </div>
        </div>
      </div>
      <div class="faq-actions">
        <a href="/faq" class="faq-link faq-link-primary">查看完整 FAQ</a>
        <a href="/contact" class="faq-link faq-link-secondary">直接諮詢</a>
      </div>
    </div>
  </section>

  <style>
    .brand-strip {
      padding: 0 2rem;
      margin-top: -2.5rem;
      position: relative;
      z-index: 4;
    }

    .brand-strip-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem;
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(320px, 440px);
      gap: 2rem;
      border-radius: 28px;
      background:
        radial-gradient(circle at top right, rgba(159, 147, 136, 0.07), transparent 30%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, rgba(246, 241, 236, 0.96) 100%);
      border: 1px solid rgba(115, 103, 94, 0.16);
      box-shadow: 0 20px 44px rgba(47, 47, 47, 0.06);
      backdrop-filter: blur(14px);
    }

    .brand-strip-label {
      margin: 0 0 0.9rem;
      color: var(--gray-medium);
      letter-spacing: 0.18em;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .brand-strip-copy h2 {
      margin: 0;
      font-size: clamp(1.9rem, 3vw, 2.8rem);
      line-height: 1.24;
      font-family: var(--font-serif);
      font-weight: 600;
      letter-spacing: 0.022em;
      color: var(--gray-darkest);
    }

    .brand-strip-intro {
      margin: 1.1rem 0 0;
      color: var(--gray-medium);
      line-height: 1.84;
      letter-spacing: 0.008em;
      font-size: 1.01rem;
    }

    .brand-smart-home {
      margin-top: 1.35rem;
      padding: 1.2rem 1.25rem;
      border-radius: 20px;
      background:
        radial-gradient(circle at top right, rgba(159, 147, 136, 0.07), transparent 34%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(245, 240, 234, 1) 100%);
      border: 1px solid rgba(115, 103, 94, 0.16);
      box-shadow: 0 16px 30px rgba(47, 47, 47, 0.05);
    }

    .brand-smart-home-label {
      margin: 0;
      color: var(--gray-medium);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .brand-smart-home h3 {
      margin: 0.65rem 0 0;
      font-family: var(--font-serif);
      font-size: 1.3rem;
      font-weight: 600;
      line-height: 1.48;
      color: var(--gray-darkest);
      letter-spacing: 0.02em;
    }

    .brand-smart-home > p:last-child {
      margin: 0.65rem 0 0;
      color: var(--gray-medium);
      line-height: 1.78;
      letter-spacing: 0.008em;
      font-size: 0.96rem;
    }

    .brand-smart-home-actions {
      margin-top: 1rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .brand-smart-home-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.8rem 1.2rem;
      border-radius: 999px;
      background: var(--gray-darkest);
      color: var(--white);
      text-decoration: none;
      letter-spacing: 0.08em;
      transition: transform 0.25s ease, background-color 0.25s ease;
    }

    .brand-smart-home-link:hover {
      transform: translateY(-2px);
      background: var(--gray-dark);
    }

    .brand-smart-home-link-secondary {
      background: rgba(255, 255, 255, 0.9);
      color: var(--gray-darkest);
      border: 1px solid rgba(115, 103, 94, 0.18);
    }

    .brand-smart-home-link-secondary:hover {
      background: rgba(244, 246, 247, 1);
    }

    .brand-credential {
      margin-top: 1.4rem;
      padding: 1.15rem 1.25rem;
      border-radius: 20px;
      background:
        radial-gradient(circle at top right, rgba(159, 147, 136, 0.05), transparent 34%),
        linear-gradient(135deg, rgba(31, 31, 31, 1) 0%, rgba(73, 64, 57, 1) 100%);
      border: 1px solid rgba(115, 103, 94, 0.14);
      box-shadow: 0 22px 42px rgba(17, 17, 17, 0.16);
    }

    .brand-credential-label {
      margin: 0;
      color: rgba(255, 255, 255, 0.54);
      font-size: 0.74rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .brand-credential-title {
      margin: 0.65rem 0 0;
      color: var(--white);
      font-size: 1.05rem;
      line-height: 1.58;
      letter-spacing: 0.02em;
      font-weight: 600;
    }

    .brand-credential-description {
      margin: 0.55rem 0 0;
      color: rgba(255, 255, 255, 0.72);
      font-size: 0.94rem;
      line-height: 1.74;
      letter-spacing: 0.008em;
    }

    .brand-strip-metrics {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .brand-metric {
      padding: 1.2rem 1.25rem;
      border-radius: 20px;
      background:
        radial-gradient(circle at top right, rgba(159, 147, 136, 0.06), transparent 36%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 241, 236, 1) 100%);
      border: 1px solid rgba(115, 103, 94, 0.14);
      box-shadow: 0 12px 24px rgba(47, 47, 47, 0.04);
    }

    .brand-metric strong {
      display: block;
      color: var(--gray-darkest);
      font-size: 1.05rem;
      margin-bottom: 0.35rem;
      letter-spacing: 0.05em;
    }

    .brand-metric span {
      color: rgba(71, 71, 71, 0.84);
      line-height: 1.7;
      font-size: 0.95rem;
    }

    /* Smooth scrolling */
    html {
      scroll-behavior: smooth;
    }

    /* Adjust scroll position for fixed header */
    section[id] {
      scroll-margin-top: 80px;
    }

    /* About Section Styles */
    .about-section {
      padding: 6rem 2rem 5rem;
      background:
        radial-gradient(circle at top left, rgba(159, 147, 136, 0.06), transparent 26%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(247, 242, 237, 1) 100%);
    }

    .about-container {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 2.2rem;
    }

    .about-header {
      text-align: center;
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s ease;
    }

    .about-header.animate-in {
      opacity: 1;
      transform: translateY(0);
    }

    .about-tagline {
      font-size: 1.3rem;
      color: var(--gray-dark);
      margin: 0.5rem 0 1rem;
      font-weight: 500;
      letter-spacing: 0.08em;
    }

    .about-intro {
      font-size: 1.05rem;
      color: var(--gray-medium);
      margin: 0;
      line-height: 1.8;
    }

    /* Core Philosophy */
    .core-philosophy {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s ease;
    }

    .core-philosophy.animate-in {
      opacity: 1;
      transform: translateY(0);
    }

    .philosophy-quote {
      text-align: center;
      padding: 2.5rem 2rem;
      background:
        radial-gradient(circle at top left, rgba(159, 147, 136, 0.04), transparent 30%),
        linear-gradient(135deg, #342f2b 0%, #292521 100%);
      border-radius: 26px;
      color: var(--white);
      position: relative;
      overflow: hidden;
    }

    .quote-mark {
      font-size: 4rem;
      color: rgba(255, 255, 255, 0.68);
      line-height: 1;
      display: block;
      font-family: 'Noto Serif TC', serif;
    }

    .philosophy-quote > p:first-of-type {
      font-size: 1.4rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      margin: 0.5rem 0;
      font-family: 'Noto Serif TC', serif;
    }

    .quote-dash {
      color: rgba(255, 255, 255, 0.52);
      display: block;
      margin: 0.5rem 0;
    }

    .quote-detail {
      font-size: 0.95rem;
      color: var(--gray-light);
      margin: 0;
      line-height: 1.7;
    }

    /* Stats Section Styles */
    .stats-section {
      padding: 4rem 2rem;
      background:
        radial-gradient(circle at top left, rgba(159, 147, 136, 0.06), transparent 26%),
        linear-gradient(135deg, rgba(31, 31, 31, 1) 0%, rgba(73, 64, 57, 1) 100%);
      color: var(--white);
    }

    .stats-container {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 3rem;
    }

    .stat-item {
      text-align: left;
      padding: 1.5rem 1.35rem;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(10px);
      opacity: 0;
      transform: scale(0.8);
      transition: all 0.6s ease;
    }

    .stat-item.animate-in {
      opacity: 1;
      transform: scale(1);
    }

    .stat-kicker {
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      color: rgba(255, 255, 255, 0.58);
      margin-bottom: 0.8rem;
    }

    .stat-number {
      font-size: 1.45rem;
      font-weight: 500;
      color: var(--white);
      margin-bottom: 0.7rem;
      font-family: "Noto Serif TC", serif;
      line-height: 1.45;
      letter-spacing: 0.04em;
    }

    .stat-label {
      font-size: 0.95rem;
      color: rgba(255, 255, 255, 0.72);
      line-height: 1.75;
    }

    /* Testimonial Section Styles */
    .testimonial-section {
      padding: 5rem 2rem;
      background:
        radial-gradient(circle at top right, rgba(159, 147, 136, 0.04), transparent 24%),
        linear-gradient(180deg, rgba(247, 242, 237, 1) 0%, rgba(243, 245, 246, 1) 100%);
    }

    .site-proof-section {
      padding: 0 2rem 5rem;
      background:
        radial-gradient(circle at top left, rgba(159, 147, 136, 0.04), transparent 22%),
        linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(245, 240, 234, 0.96) 100%);
    }

    .site-proof-shell {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
      gap: 1.4rem;
      align-items: stretch;
    }

    .site-proof-copy,
    .site-proof-photo {
      border-radius: 24px;
      overflow: hidden;
      border: 1px solid rgba(47, 47, 47, 0.08);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 241, 236, 0.98) 100%);
      box-shadow: 0 14px 30px rgba(47, 47, 47, 0.06);
    }

    .site-proof-copy {
      padding: 2rem 2.1rem;
      display: grid;
      align-content: center;
      gap: 0.8rem;
    }

    .site-proof-label {
      margin: 0;
      color: var(--gray-medium);
      font-size: 0.76rem;
      font-weight: 600;
      letter-spacing: 0.16em;
    }

    .site-proof-copy h2 {
      margin: 0;
      color: var(--gray-darkest);
      font-family: 'Noto Serif TC', serif;
      font-size: clamp(1.5rem, 2.5vw, 2rem);
      line-height: 1.55;
      letter-spacing: 0.03em;
      font-weight: 500;
    }

    .site-proof-copy p:last-child {
      margin: 0;
      color: rgba(79, 79, 79, 0.82);
      font-size: 0.98rem;
      line-height: 1.9;
    }

    .site-proof-photo {
      margin: 0;
      min-height: 100%;
    }

    .site-proof-photo img {
      display: block;
      width: 100%;
      height: 100%;
      min-height: 320px;
      object-fit: cover;
      object-position: center;
      background: #f3f3f3;
    }

    .testimonial-container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .testimonial-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .testimonial-card {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(249, 249, 249, 1) 100%);
      padding: 2rem;
      border-radius: 22px;
      box-shadow: 0 14px 28px rgba(47, 47, 47, 0.06);
      border: 1px solid rgba(47, 47, 47, 0.08);
      transition: all 0.3s ease;
      opacity: 0;
      transform: scale(0.9);
    }

    .testimonial-card.animate-in {
      opacity: 1;
      transform: scale(1);
    }

    .testimonial-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(115, 103, 94, 0.12);
      border-color: rgba(115, 103, 94, 0.2);
    }

    .promise-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(241, 234, 227, 1);
      border-radius: 50%;
      color: var(--gray-dark);
      transition: all 0.3s ease;
    }

    .testimonial-card:hover .promise-icon {
      background: var(--gray-darkest);
      color: var(--white);
      transform: scale(1.1) rotate(5deg);
    }

    .promise-icon svg {
      width: 32px;
      height: 32px;
    }

    .promise-title {
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--gray-dark);
      margin-bottom: 1rem;
      text-align: center;
    }

    .testimonial-text {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--gray-medium);
      margin-bottom: 0;
      text-align: center;
    }

    /* FAQ Section Styles */
    .faq-section {
      padding: 5rem 2rem;
      background:
        radial-gradient(circle at top right, rgba(159, 147, 136, 0.04), transparent 24%),
        linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(246, 241, 236, 1) 100%);
    }

    .faq-container {
      max-width: 900px;
      margin: 0 auto;
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .faq-intro {
      max-width: 38rem;
      margin: 1rem auto 0;
      color: var(--gray-medium);
      line-height: 1.85;
    }

    .faq-item {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(250, 250, 250, 1) 100%);
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(115, 103, 94, 0.14);
      box-shadow: 0 12px 26px rgba(47, 47, 47, 0.05);
      transition: all 0.3s ease;
      opacity: 0;
      transition:
        opacity 0.8s ease,
        transform 0.8s ease;
    }

    .faq-item[data-animate="left"] {
      transform: translateX(-30px);
    }

    .faq-item[data-animate="right"] {
      transform: translateX(30px);
    }

    .faq-item.animate-in {
      opacity: 1;
      transform: translateX(0);
    }

    .faq-item:hover {
      border-color: rgba(115, 103, 94, 0.2);
    }

    .faq-item.active {
      border-color: var(--gray-darkest);
    }

    .faq-question {
      width: 100%;
      padding: 1.5rem 2rem;
      background: none;
      border: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      font-size: 1.1rem;
      font-weight: 500;
      color: var(--gray-dark);
      text-align: left;
      transition: all 0.3s ease;
    }

    .faq-question:hover {
      color: var(--gray-darkest);
    }

    .faq-icon {
      width: 24px;
      height: 24px;
      flex-shrink: 0;
      transition: transform 0.3s ease;
      color: var(--gray-medium);
    }

    .faq-item.active .faq-icon {
      transform: rotate(180deg);
      color: var(--gray-darkest);
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }

    .faq-item.active .faq-answer {
      max-height: 300px;
    }

    .faq-answer p {
      padding: 0 2rem 1.5rem 2rem;
      color: var(--gray-medium);
      line-height: 1.7;
      margin: 0;
    }

    .faq-actions {
      margin-top: 1.5rem;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.85rem;
    }

    .faq-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.9rem 1.3rem;
      border-radius: 999px;
      text-decoration: none;
      letter-spacing: 0.06em;
      transition:
        transform 0.25s ease,
        background-color 0.25s ease,
        border-color 0.25s ease;
    }

    .faq-link:hover {
      transform: translateY(-2px);
    }

    .faq-link-primary {
      background: var(--gray-darkest);
      color: var(--white);
      border: 1px solid var(--gray-darkest);
    }

    .faq-link-secondary {
      background: rgba(255, 255, 255, 0.96);
      color: var(--gray-darkest);
      border: 1px solid rgba(115, 103, 94, 0.18);
    }

    /* Responsive Styles */
    @media (max-width: 1024px) {
      .brand-strip-inner {
        grid-template-columns: 1fr;
      }

      .about-container {
        gap: 3rem;
      }

      .stats-container {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
      }

      .testimonial-grid {
        grid-template-columns: 1fr;
      }

      .site-proof-shell {
        grid-template-columns: 1fr;
      }

      .consult-shell {
        grid-template-columns: 1fr;
      }

      .consult-actions {
        min-width: 0;
        max-width: 340px;
      }
    }

    @media (max-width: 768px) {
      .about-section,
      .stats-section,
      .testimonial-section {
        display: none;
      }

      .brand-strip {
        padding: 0 1.25rem;
        margin-top: -1.5rem;
      }

      .brand-strip-inner {
        padding: 1.5rem;
        border-radius: 22px;
      }

      .brand-strip-label,
      .brand-smart-home-label,
      .brand-credential-label,
      .smart-case-label,
      .smart-case-card-label,
      .section-subtitle,
      .consult-subtitle {
        letter-spacing: 0.16em;
        font-size: 0.72rem;
      }

      .brand-strip-copy h2,
      .smart-case-summary h3,
      .consult-title {
        line-height: 1.38;
      }

      .brand-strip-copy h2 {
        font-size: clamp(2rem, 9vw, 2.6rem);
      }

      .brand-strip-intro,
      .brand-smart-home > p:last-child,
      .smart-case-intro,
      .smart-case-description,
      .smart-case-card p:last-child,
      .consult-description {
        font-size: 0.95rem;
        line-height: 1.75;
      }

      .brand-smart-home {
        margin-top: 1.1rem;
        padding: 1rem;
        border-radius: 18px;
      }

      .brand-smart-home-actions,
      .smart-case-actions {
        gap: 0.6rem;
      }

      .brand-smart-home-link,
      .smart-case-link,
      .consult-button {
        width: 100%;
        padding: 0.85rem 1rem;
        letter-spacing: 0.04em;
      }

      .brand-credential {
        margin-top: 1.1rem;
        padding: 1rem;
      }

      .site-proof-section {
        padding: 0 1.25rem 4rem;
      }

      .site-proof-copy,
      .site-proof-photo {
        border-radius: 18px;
      }

      .site-proof-copy {
        padding: 1.2rem;
      }

      .site-proof-photo img {
        min-height: 240px;
      }

      .about-section,
      .testimonial-section,
      .faq-section,
      .consult-section,
      .service-section,
      .smart-case-section,
      .workflow-section {
        padding-left: 1.25rem;
        padding-right: 1.25rem;
      }

      .stats-section {
        padding: 2.6rem 1.25rem;
      }

      .section-header,
      .workflow-header,
      .smart-case-header {
        margin-bottom: 2rem;
      }

      .smart-case-summary,
      .smart-case-card,
      .workflow-content,
      .consult-shell {
        border-radius: 20px;
      }

      .smart-case-summary,
      .smart-case-card {
        padding: 1.2rem;
      }

      .smart-case-tags {
        gap: 0.55rem;
        margin-top: 1rem;
      }

      .smart-case-tags span {
        padding: 0.5rem 0.7rem;
        font-size: 0.82rem;
      }

      .faq-section,
      .consult-section {
        padding: 3rem 1.5rem;
      }

      .stats-container {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .stat-item {
        padding: 1.35rem 1.05rem;
        border-radius: 18px;
      }

      .stat-number {
        font-size: 1.2rem;
      }

      .faq-question {
        padding: 1.25rem 1.5rem;
        font-size: 1rem;
      }

      .faq-answer p {
        padding: 0 1.5rem 1.25rem 1.5rem;
      }

      .faq-actions {
        flex-direction: column;
      }

      .workflow-list::before {
        display: none;
      }

      .smart-case-card:nth-child(n + 3),
      .workflow-item:nth-child(n + 5) {
        display: none;
      }

      .smart-case-mobile-note,
      .workflow-mobile-note {
        display: block;
        margin: 0.9rem 0 0;
        color: var(--gray-medium);
        font-size: 0.9rem;
        line-height: 1.7;
      }

      .workflow-mobile-note {
        text-align: center;
        max-width: 32rem;
        margin: 0.9rem auto 0;
      }

      .consult-shell {
        padding: 1.5rem;
        gap: 1.4rem;
      }

      .consult-actions {
        min-width: 0;
        max-width: none;
        width: 100%;
      }
    }

    .service-section {
      padding: 5rem 2rem;
      background:
        radial-gradient(circle at top right, rgba(159, 147, 136, 0.05), transparent 24%),
        linear-gradient(180deg, rgba(250, 250, 250, 1) 0%, rgba(245, 240, 234, 1) 100%);
    }

    .service-container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-header {
      text-align: center;
      margin-bottom: 4rem;
    }

    .service-intro {
      max-width: 44rem;
      margin: 1rem auto 0;
      color: var(--gray-medium);
      line-height: 1.85;
    }

    .section-subtitle {
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      color: var(--gray-medium);
      margin-bottom: 0.75rem;
      text-transform: uppercase;
    }

    .section-title {
      font-size: 2.5rem;
      font-weight: 400;
      color: var(--gray-dark);
      letter-spacing: 0.05em;
    }

    .service-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
