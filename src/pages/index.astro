      background:
        radial-gradient(circle at top right, rgba(159, 147, 136, 0.06), transparent 22%),
        linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(246, 241, 236, 1) 100%);
      display: grid;
      align-items: center;
