---
import BaseLayout from "../layouts/BaseLayout.astro";

const capabilities = [
  {
    label: "系統整理",
    title: "協助設定與整理 Home Assistant",
    description:
      "協助整理需求、建立自動化邏輯與排查整合問題，讓 HA 更快進入可用狀態。",
  },
  {
    label: "NAS 規劃",
    title: "把 NAS 變成家庭數位中樞",
    description:
      "整合備份、媒體庫、監控錄影與遠端存取，不讓 NAS 只是擺在角落的主機。",
  },
  {
    label: "設計整合",
    title: "從空間設計階段就一起規劃",
    description:
      "弱電箱、機櫃位置、網路節點與日後擴充一起思考，避免入住後才發現設備不好放也不好用。",
  },
];

const scenarios = [
  "回家模式：進門後燈光、冷氣、窗簾與背景音樂自動切換",
  "離家模式：一鍵關閉指定設備，同步確認門鎖與監控狀態",
  "日照調節：依日照角度、西曬強度與戶外溫度，自動調整電動蜂巢簾開合",
  "夜間模式：走道感應微亮照明，不打擾家人休息",
  "NAS 支援：照片備份、監視錄影、媒體串流與遠端檔案存取",
];

const visualPlaceholders = [
  {
    tag: "SCENE 01",
    title: "回家模式情境照",
    description: "以暖光、窗簾與冷氣一起啟動的客廳情境，讓回家這件事從進門第一秒就有被接住的感覺。",
    note: "情境重點：回家後的燈光、溫度與氛圍同步切換",
    image: "/images/smart-home/arrival-scene.png",
    alt: "智能家居回家模式情境照",
    frameLabel: "ARRIVE HOME",
  },
  {
    tag: "SCENE 02",
    title: "手機控制畫面",
    description: "把常用功能整理成一眼看懂的操作介面，讓燈光、情境與設備控制回到真正順手的狀態。",
    note: "情境重點：把常用控制集中在日常最常打開的畫面",
    image: "/images/smart-home/mobile-control.jpg",
    alt: "智能家居手機控制畫面",
    frameLabel: "CONTROL VIEW",
  },
  {
    tag: "SCENE 03",
    title: "室內控制中樞",
    description: "把常用情境、燈光與設備控制集中在牆面中控，讓住宅裡最常觸碰的操作也維持乾淨、直覺與一致。",
    note: "情境重點：固定中控把常用操作留在最順手的位置",
    image: "/images/smart-home/wall-control-hub.jpg",
    alt: "智能家居室內控制中樞畫面",
    frameLabel: "WALL HUB",
  },
  {
    tag: "SCENE 04",
    title: "蜂巢簾與日照聯動",
    description: "把窗簾盒間接照明與電動蜂巢簾一起整合，讓遮光、採光與室內溫感可依日照角度、西曬強度與戶外溫度自動切換。",
    note: "情境重點：遮陽、採光與溫度控制不必每次手動調整",
    image: "/images/smart-home/honeycomb-shade.jpg",
    alt: "窗簾盒間接照明與電動蜂巢簾情境",
    frameLabel: "SMART SHADE",
  },
  {
    tag: "SCENE 05",
    title: "弱電與設備整合",
    description: "把 NAS、網路設備與收納整合進住宅尺度中，讓技術配置清楚可維護，視覺上也不破壞空間質感。",
    note: "情境重點：設備、佈線與收納一起被整理到位",
    image: "/images/smart-home/equipment-cabinet.png",
    alt: "智能家居弱電與設備整合畫面",
    frameLabel: "TECH CORE",
  },
  {
    tag: "SCENE 06",
    title: "夜間動線與感應",
    description: "用低照度感應燈光建立安靜夜間動線，讓半夜起身時不刺眼、不驚擾，也更有安全感。",
    note: "情境重點：感應照明只在需要時輕柔亮起",
    image: "/images/smart-home/night-path.png",
    alt: "智能家居夜間動線與感應畫面",
    frameLabel: "QUIET NIGHT",
  },
];

const workflow = [
  {
    step: "01",
    title: "需求盤點",
    description: "先釐清屋主生活習慣、設備清單、品牌偏好與預算範圍。",
  },
  {
    step: "02",
    title: "弱電與設備規劃",
    description: "在裝修前確認網路、電源、控制節點、機櫃與散熱配置。",
  },
  {
    step: "03",
    title: "設定整合與情境調校",
    description: "協助整理 HA 規則、場景設定與除錯流程，讓系統更快進入穩定可用狀態。",
  },
  {
    step: "04",
    title: "交付與後續擴充",
    description: "保留可維護與可升級架構，讓之後新增設備不必整套重來。",
  },
];
---

<BaseLayout
  title="智能家居 Smart Home - 青曦空間設計"
  description="青曦提供智能家居規劃，整合 Home Assistant、NAS 與跨品牌設備，讓科技真正變成好用的日常。"
  ogImage="/images/portfolio/xizhi-2.jpg"
  pageType="service"
>
  <div class="smart-home-page">
    <section class="smart-home-hero">
      <div class="smart-home-shell">
        <div class="hero-copy reveal-up" data-reveal-delay="0">
          <p class="section-subtitle">智能家居</p>
          <h1>把智能家居做成真正好用的生活系統</h1>
          <p class="hero-intro">
            青曦不只做空間設計，也協助設定 Home Assistant、規劃 NAS 與跨品牌整合。
            從弱電配置到入住後的自動化，一起整理清楚。
          </p>
          <div class="hero-actions">
            <a href="/smart-home-quiz" class="primary-link">先做智能家居需求快篩</a>
            <a href="/contact?intent=smart-home-studio-visit&source=smart-home" class="secondary-link">預約工作室體驗</a>
          </div>
        </div>

        <aside class="hero-panel reveal-up" data-reveal-delay="120">
          <p class="hero-panel-label">為什麼是青曦</p>
          <ul>
            <li>懂空間，也懂系統整合與設備落地</li>
            <li>可協助 Home Assistant、NAS 與跨品牌串聯</li>
            <li>協助需求整理、設定與除錯</li>
            <li>從一開始就把布線、機櫃與操作流程想進去</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="capability-section">
      <div class="section-shell">
        <div class="section-heading reveal-up" data-reveal-delay="0">
          <p class="section-subtitle">核心能力</p>
          <h2>不只是裝設備，而是把 HA、NAS 與空間一起整合好</h2>
        </div>

        <div class="capability-grid">
          {capabilities.map((item) => (
            <article class="capability-card reveal-up" data-reveal-delay="80">
              <p class="capability-label">{item.label}</p>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="visual-section">
      <div class="section-shell">
        <div class="section-heading reveal-up" data-reveal-delay="0">
          <p class="section-subtitle">情境畫面</p>
          <h2>把智能家居的使用感與空間感一起看見</h2>
          <p>
            不是單純展示設備，而是直接看見入住後的使用感。
          </p>
        </div>

        <div class="visual-grid">
          {visualPlaceholders.map((item) => (
            <article class="visual-card reveal-up" data-reveal-delay="90">
              {item.image ? (
                <div
                  class="visual-frame visual-frame-photo"
                  style={`background-image: linear-gradient(180deg, rgba(12, 12, 12, 0.08) 0%, rgba(12, 12, 12, 0.22) 100%), url('${item.image}');`}
                  aria-label={item.alt || item.title}
                  role="img"
                >
                  <span>{item.tag}</span>
                  <strong>{item.frameLabel || "LIVE PREVIEW"}</strong>
                </div>
              ) : (
                <div class="visual-frame">
                  <span>{item.tag}</span>
                  <strong>IMAGE PLACEHOLDER</strong>
                </div>
              )}
              <div class="visual-copy">
                <p class="visual-tag">{item.tag}</p>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
                <small>{item.note}</small>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="positioning-section">
      <div class="section-shell positioning-shell">
        <article class="positioning-card positioning-card-dark reveal-up" data-reveal-delay="0">
          <p class="section-subtitle muted">設計與科技</p>
          <h2>科技應該在入住前就規劃到位</h2>
          <p>
            很多智能家居不好用，不是設備不夠新，而是空間、佈線與控制邏輯沒有一起規劃。
            青曦會在設計階段先整合這些條件，讓系統更順手。
          </p>
        </article>

        <article class="positioning-card positioning-card-light reveal-up" data-reveal-delay="120">
          <p class="section-subtitle">使用情境</p>
          <ul class="scenario-list">
            {scenarios.map((scenario) => (
              <li>{scenario}</li>
            ))}
          </ul>
        </article>
      </div>
    </section>

    <section class="workflow-section">
      <div class="section-shell">
        <div class="section-heading reveal-up" data-reveal-delay="0">
          <p class="section-subtitle">合作流程</p>
          <h2>智能家居怎麼開始</h2>
        </div>

        <div class="workflow-grid">
          {workflow.map((item) => (
            <article class="workflow-card reveal-up" data-reveal-delay="80">
              <span class="workflow-step">{item.step}</span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="section-shell cta-shell reveal-up" data-reveal-delay="0">
        <div class="reveal-up" data-reveal-delay="40">
          <p class="section-subtitle">下一步</p>
          <h2>如果你要的是好用，不是堆設備，就從這裡開始</h2>
          <p>
            先把需求、預算與想要的使用情境講清楚，就知道適不適合開始。
          </p>
        </div>
        <div class="cta-actions reveal-up" data-reveal-delay="120">
          <a href="/smart-home-quiz" class="cta-link">先做需求快篩</a>
          <a href="/contact?intent=smart-home-studio-visit&source=smart-home" class="secondary-link">預約工作室體驗</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const revealTargets = Array.from(document.querySelectorAll(".reveal-up"));

  if (reducedMotion.matches) {
    revealTargets.forEach((node) => node.classList.add("is-visible"));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const element = entry.target;
          const delay = Number(element.getAttribute("data-reveal-delay") || "0");
          window.setTimeout(() => {
            element.classList.add("is-visible");
          }, delay);
          observer.unobserve(element);
        });
      },
      {
        threshold: 0.16,
        rootMargin: "0px 0px -8% 0px",
      },
    );

    revealTargets.forEach((node) => observer.observe(node));
  }
</script>

<style>
  .smart-home-page {
    background:
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.06), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(246, 241, 236, 1) 100%);
  }

  .smart-home-hero,
  .capability-section,
  .visual-section,
  .positioning-section,
  .workflow-section,
  .cta-section {
    padding: clamp(5.5rem, 8vw, 8.5rem) 2rem;
  }

  .smart-home-hero {
    padding-top: clamp(6.75rem, 10vw, 8.75rem);
  }

  .smart-home-shell,
  .section-shell {
    max-width: 1280px;
    margin: 0 auto;
  }

  .smart-home-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: clamp(1.5rem, 3vw, 2.8rem);
    align-items: center;
    min-height: calc(100vh - 9rem);
  }

  .section-subtitle {
    margin: 0 0 0.8rem;
    color: var(--tiffany-dark);
    font-size: 0.8rem;
    letter-spacing: var(--type-overline-spacing);
    font-weight: 600;
  }

  .section-subtitle.muted {
    color: rgba(255, 255, 255, 0.62);
  }

  .hero-copy h1 {
    margin: 0;
    max-width: 8ch;
    font-family: var(--font-sans);
    font-size: clamp(4.2rem, 8vw, 7rem);
    font-weight: 780;
    line-height: 0.92;
    letter-spacing: -0.065em;
    color: var(--gray-darkest);
  }

  .hero-intro,
  .capability-card p,
  .positioning-card p,
  .workflow-card p,
  .cta-shell p {
    color: color-mix(in srgb, var(--gray-darkest) 62%, transparent);
    line-height: 1.86;
    letter-spacing: 0.01em;
  }

  .hero-intro {
    margin: 1.5rem 0 0;
    max-width: 42rem;
    font-size: clamp(1.02rem, 1.8vw, 1.14rem);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.95rem;
    margin-top: 2rem;
  }

  .primary-link,
  .secondary-link,
  .cta-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 500;
    letter-spacing: var(--type-cta-tracking);
    transition:
      transform var(--motion-duration-fast) var(--motion-standard),
      background-color var(--motion-duration-fast) var(--motion-standard),
      color var(--motion-duration-fast) var(--motion-standard),
      border-color var(--motion-duration-fast) var(--motion-standard),
      box-shadow var(--motion-duration-fast) var(--motion-standard);
  }

  .primary-link,
  .cta-link {
    background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--tiffany-dark) 100%);
    color: var(--white);
    border: 1px solid rgba(170, 159, 149, 0.24);
  }

  .secondary-link {
    background: rgba(255, 255, 255, 0.72);
    color: var(--gray-darkest);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 16px 36px rgba(var(--brand-dark-rgb), 0.08);
    backdrop-filter: blur(20px) saturate(135%);
  }

  .hero-actions .secondary-link:last-child {
    background: rgba(255, 255, 255, 0.96);
    border-color: rgba(101, 91, 84, 0.22);
  }

  .primary-link:hover,
  .secondary-link:hover,
  .cta-link:hover {
    transform: translateY(-2px);
  }

  .primary-link:hover,
  .cta-link:hover {
    background: linear-gradient(135deg, rgba(52, 47, 43, 1) 0%, rgba(103, 92, 84, 1) 100%);
  }

  .secondary-link:hover {
    background: rgba(243, 237, 231, 0.96);
    border-color: rgba(255, 255, 255, 0.22);
    box-shadow: 0 22px 46px rgba(var(--brand-dark-rgb), 0.1);
  }

  .hero-panel {
    padding: clamp(1.9rem, 3vw, 2.6rem);
    border-radius: 32px;
    background:
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.12), transparent 32%),
      linear-gradient(135deg, rgba(31, 31, 31, 0.94) 0%, rgba(73, 64, 57, 0.96) 100%);
    color: var(--white);
    box-shadow: 0 34px 88px rgba(var(--brand-dark-rgb), 0.2);
    border: 1px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(28px) saturate(140%);
  }

  .hero-panel-label,
  .capability-label,
  .workflow-step {
    display: inline-flex;
    font-weight: 600;
    letter-spacing: var(--type-overline-spacing);
    font-size: 0.78rem;
  }

  .hero-panel-label {
    color: rgba(255, 255, 255, 0.62);
  }

  .hero-panel ul {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: grid;
    gap: 0.95rem;
  }

  .hero-panel li {
    padding-bottom: 0.95rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.8;
  }

  .hero-panel li:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .section-heading {
    max-width: 820px;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .section-heading h2,
  .positioning-card h2,
  .cta-shell h2 {
    margin: 0;
    font-family: var(--font-sans);
    color: var(--gray-darkest);
    font-weight: 780;
    line-height: 0.94;
    letter-spacing: -0.06em;
  }

  .section-heading h2 {
    max-width: 10ch;
    font-size: clamp(3rem, 6vw, 5.6rem);
  }

  .section-heading > p:last-child {
    margin: 1.2rem 0 0;
    max-width: 34rem;
    color: color-mix(in srgb, var(--gray-darkest) 60%, transparent);
    line-height: 1.82;
  }

  .reveal-up {
    opacity: 0;
    transform: translate3d(0, 28px, 0);
    transition:
      opacity 1s var(--motion-standard),
      transform 1s var(--motion-standard);
    will-change: opacity, transform;
  }

  .reveal-up.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .capability-grid,
  .visual-grid,
  .workflow-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .visual-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .capability-card,
  .visual-card,
  .workflow-card,
  .positioning-card {
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 24px 56px rgba(var(--brand-dark-rgb), 0.08);
  }

  .capability-card,
  .visual-card,
  .workflow-card {
    padding: clamp(1.8rem, 3vw, 2.25rem);
    background:
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.05), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.74) 0%, rgba(247, 244, 239, 0.62) 100%);
  }

  .visual-card {
    display: grid;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    transition:
      transform var(--motion-duration) var(--motion-standard),
      box-shadow var(--motion-duration) var(--motion-standard),
      border-color var(--motion-duration) var(--motion-standard),
      background-color var(--motion-duration) var(--motion-standard);
  }

  .visual-frame {
    aspect-ratio: 16 / 10;
    border-radius: 22px;
    border: 1px dashed rgba(27, 27, 27, 0.18);
    background:
      linear-gradient(135deg, rgba(19, 19, 19, 0.88) 0%, rgba(61, 89, 94, 0.88) 100%),
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.28), transparent 34%);
    display: grid;
    place-items: center;
    text-align: center;
    padding: 1rem;
    color: rgba(255, 255, 255, 0.9);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
    transition:
      transform 0.45s ease,
      box-shadow 0.45s ease,
      border-color 0.45s ease;
  }

  .visual-frame-photo {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-style: solid;
    border-color: rgba(27, 27, 27, 0.08);
    background-position: center;
    background-size: 102%;
    background-repeat: no-repeat;
    align-content: space-between;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      0 18px 30px rgba(17, 17, 17, 0.08);
    transition:
      background-size 0.6s ease,
      filter 0.45s ease,
      box-shadow 0.45s ease,
      border-color 0.45s ease;
  }

  .visual-frame-photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(12, 12, 12, 0.04) 0%, rgba(12, 12, 12, 0.28) 100%),
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.18), transparent 38%);
    opacity: 0.72;
    transition: opacity 0.45s ease;
    pointer-events: none;
  }

  .visual-frame span,
  .visual-tag {
    display: inline-flex;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: var(--type-overline-spacing);
    text-transform: uppercase;
    color: var(--tiffany-dark);
  }

