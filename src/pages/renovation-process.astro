---
import BaseLayout from "../layouts/BaseLayout.astro";

const ganttWeeks = Array.from({ length: 18 }, (_, index) => index + 1);
const processStages = [
  {
    id: "protection",
    stage: "01",
    category: "開工前置",
    title: "保護工程與現場放樣",
    summary: "開工後先做公共區域與室內保護，並依圖面確認基準線與施工位置。",
    start: 1,
    span: 1,
    durationLabel: "約 1 週",
    outputs: ["地坪與電梯保護", "施工基準線", "現場開工確認"],
  },
  {
    id: "demolition",
    stage: "02",
    category: "拆除清運",
    title: "拆除工程與廢棄物清運",
    summary: "依拆除範圍進行天花、牆面、舊櫃體、設備與既有裝修拆除，並同步清運。",
    start: 1,
    span: 2,
    durationLabel: "約 1-2 週",
    outputs: ["拆除完成面", "垃圾清運", "基底清空"],
  },
  {
    id: "plumbing-electric",
    stage: "03",
    category: "隱蔽工程",
    title: "水電定位、配管與弱電預埋",
    summary: "依照插座、燈具、設備與系統櫃位置，完成強弱電、給排水與必要預埋。",
    start: 2,
    span: 3,
    durationLabel: "約 2-3 週",
    outputs: ["水電配管", "插座開關定位", "弱電預留"],
  },
  {
    id: "masonry-base",
    stage: "04",
    category: "泥作基礎",
    title: "砌磚、回填、打底與粉光",
    summary: "處理新隔間、門洞調整、地坪修補與基礎打底，為後續防水與貼磚做準備。",
    start: 3,
    span: 3,
    durationLabel: "約 2-3 週",
    outputs: ["泥作打底", "砌築調整", "地坪修補"],
  },
  {
    id: "waterproofing",
    stage: "05",
    category: "防水工程",
    title: "浴室、陽台與濕區防水試水",
    summary: "在泥作與管線調整後完成防水施作，並安排試水確認滲漏風險。",
    start: 4,
    span: 2,
    durationLabel: "約 1-2 週",
    outputs: ["防水層", "試水紀錄", "濕區確認"],
  },
  {
    id: "windows-metal",
    stage: "06",
    category: "外部配合",
    title: "鋁窗、金屬件與外部修補",
    summary: "若案件涉及窗體更新、鐵件、外牆修補或門框調整，通常會在此階段穿插進行。",
    start: 5,
    span: 2,
    durationLabel: "約 1-2 週",
    outputs: ["窗框更新", "金屬件定位", "外部收邊"],
  },
  {
    id: "carpentry",
    stage: "07",
    category: "木作工程",
    title: "天花、隔間、包樑與木作基礎",
    summary: "依現場條件施作木作天花、包管包樑、局部隔間與櫃體基礎結構。",
    start: 5,
    span: 4,
    durationLabel: "約 3-4 週",
    outputs: ["木作骨架", "天花結構", "造型基礎"],
  },
  {
    id: "hvac-lowvoltage",
    stage: "08",
    category: "設備協作",
    title: "空調、消防、弱電與設備套管",
    summary: "配合木作與天花高度，把空調、消防、網路、監控與設備套管一起收進節點。",
    start: 5,
    span: 3,
    durationLabel: "約 2-3 週",
    outputs: ["空調配合", "弱電路徑", "設備預留"],
  },
  {
    id: "tiling",
    stage: "09",
    category: "表面工程",
    title: "貼磚、石材與濕區完成面",
    summary: "浴室、廚房、陽台與需要石材或磚材的區域，會在這段時間陸續成形。",
    start: 6,
    span: 3,
    durationLabel: "約 2-3 週",
    outputs: ["貼磚完成面", "石材安裝", "濕區定型"],
  },
  {
    id: "paint",
    stage: "10",
    category: "塗裝工程",
    title: "批土、研磨、底漆與面漆",
    summary: "木作與牆面基礎完成後，進行批土、修補、打磨與分階段上漆。",
    start: 8,
    span: 3,
    durationLabel: "約 2-3 週",
    outputs: ["牆面修飾", "油漆底面漆", "表面平整度"],
  },
  {
    id: "cabinet-factory",
    stage: "11",
    category: "櫃體製作",
    title: "系統櫃複丈、下單與工廠製作",
    summary: "現場尺寸穩定後安排複丈，系統櫃、門板與部分客製櫃體同步進入製作期。",
    start: 7,
    span: 4,
    durationLabel: "約 3-4 週",
    outputs: ["複丈完成", "櫃體下單", "工廠排程"],
  },
  {
    id: "flooring",
    stage: "12",
    category: "地坪工程",
    title: "地板、地坪收邊與保護更新",
    summary: "依材質不同安排 SPC、木地板或其他地坪施工，並同步做收邊與保護更新。",
    start: 10,
    span: 2,
    durationLabel: "約 1-2 週",
    outputs: ["地坪完成面", "收邊處理", "新保護更新"],
  },
  {
    id: "cabinet-install",
    stage: "13",
    category: "安裝階段",
    title: "系統櫃、門片、玻璃與固定家具安裝",
    summary: "櫃體到場後進行系統櫃、門片、玻璃、把手與固定家具安裝與校正。",
    start: 11,
    span: 3,
    durationLabel: "約 2-3 週",
    outputs: ["櫃體安裝", "玻璃門片", "五金校正"],
  },
  {
    id: "equipment-install",
    stage: "14",
    category: "設備安裝",
    title: "燈具、衛浴、廚具、插座與設備安裝",
    summary: "進入設備安裝期，把燈具、面板、衛浴五金、廚具與家電定位逐一完成。",
    start: 12,
    span: 3,
    durationLabel: "約 2-3 週",
    outputs: ["燈具面板", "衛浴廚具", "設備就位"],
  },
  {
    id: "finishing",
    stage: "15",
    category: "細部收尾",
    title: "矽利康、補漆、修飾與細節收尾",
    summary: "在大項安裝完成後，集中處理接縫、補漆、修口、調整與各種視覺細節。",
    start: 14,
    span: 2,
    durationLabel: "約 1-2 週",
    outputs: ["矽利康收邊", "補漆修口", "細節整理"],
  },
  {
    id: "cleaning",
    stage: "16",
    category: "驗收前整理",
    title: "細清、保護拆除與設備試運轉",
    summary: "拆除施工保護後進行細清，並測試燈具、插座、衛浴、空調與其他設備運作。",
    start: 16,
    span: 1,
    durationLabel: "約 1 週",
    outputs: ["細部清潔", "設備測試", "初驗準備"],
  },
  {
    id: "inspection",
    stage: "17",
    category: "驗收修正",
    title: "初驗、缺失修正與複驗",
    summary: "依現場驗收清單逐項確認，針對缺失安排修正，並在複驗後完成結案確認。",
    start: 17,
    span: 1,
    durationLabel: "約 1 週",
    outputs: ["驗收清單", "缺失修正", "複驗確認"],
  },
  {
    id: "handoff",
    stage: "18",
    category: "正式交付",
    title: "完工交屋與使用說明",
    summary: "確認現場交付狀態、設備操作方式、保固資訊與後續使用注意事項後正式交屋。",
    start: 18,
    span: 1,
    durationLabel: "約 1 週",
    outputs: ["正式交屋", "設備教學", "保固說明"],
  },
];

const stageHighlights = [
  {
    label: "拆除前後",
    title: "拆除不是第一刀下去就結束，而是整個工程節奏的起點",
    body: "拆除完成後，真正影響後面品質的，是保護、放樣、基底整理與隱蔽工程是否被提早處理乾淨。",
  },
  {
    label: "中段工序",
    title: "木作、泥作、水電、設備其實是交錯推進",
    body: "現場不會只剩單一工班。很多節點必須穿插銜接，像空調、弱電、木作與系統櫃就常常彼此卡位。",
  },
  {
    label: "交屋前",
    title: "真正決定質感的，常常是最後 20% 的收尾",
    body: "補漆、矽利康、設備校正、清潔、初驗與複驗，往往比前面的大工程更影響屋主最後的入住感受。",
  },
];

const processStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "拆除到交屋的裝修工程甘特圖",
    description:
      "青曦空間設計整理的裝修工程甘特圖，從拆除、保護、水電、泥作、木作、油漆、系統櫃安裝到驗收交屋，讓屋主快速掌握工程期節奏。",
    totalTime: "P18W",
    step: processStages.map((item, index) => ({
      "@type": "HowToStep",
      position: index + 1,
      name: item.title,
      text: item.summary,
    })),
  },
];
---

<BaseLayout
  title="裝修全流程 - 青曦空間設計"
  description="用甘特圖看懂青曦空間設計從拆除工程到完工交屋的主要工項，包含保護、水電、泥作、木作、油漆、系統櫃、設備安裝與驗收節點。"
  ogImage="/images/portfolio/xizhi-1.jpg"
  pageType="service"
  structuredData={processStructuredData}
>
  <section class="process-page">
    <div class="process-shell">
      <header class="process-hero">
        <p class="process-eyebrow">Renovation Roadmap</p>
        <h1>從拆除到交屋，工項節奏一次攤開。</h1>
        <p class="process-description">
          這張甘特圖聚焦在「開工後」的工程期，把拆除工程開始到驗收交屋的主要工項全部拉出來看。
          實際案場仍會依老屋狀況、格局改動幅度、系統櫃比例與設備複雜度調整先後順序。
        </p>
        <div class="process-actions">
          <a href="/contact" class="process-button process-button-primary">預約諮詢</a>
          <a href="/tools" class="process-button process-button-secondary">先做估價</a>
        </div>
      </header>

      <section class="process-highlights" aria-label="流程重點">
        {stageHighlights.map((item) => (
          <article class="highlight-card">
            <p class="highlight-label">{item.label}</p>
            <h2>{item.title}</h2>
            <p>{item.body}</p>
          </article>
        ))}
      </section>

      <section class="gantt-section" aria-labelledby="gantt-title">
        <div class="gantt-header">
          <div>
            <p class="gantt-label">甘特圖</p>
            <h2 id="gantt-title">以 18 週為基準的工程工項節奏</h2>
          </div>
          <p class="gantt-note">甘特圖顯示各工項常見的進場時機與重疊區，方便先看懂哪些環節會同時發生。</p>
        </div>

        <div class="gantt-board">
          <div class="gantt-axis" aria-hidden="true">
            <div class="gantt-axis-stage">階段</div>
            <div class="gantt-axis-grid">
              {ganttWeeks.map((week) => <span>W{week}</span>)}
            </div>
          </div>

          <div class="gantt-rows">
            {processStages.map((item) => (
              <article class="gantt-row">
                <div class="gantt-stage">
                  <span class="gantt-stage-number">{item.stage}</span>
                  <div>
                    <p class="gantt-stage-category">{item.category}</p>
                    <h3>{item.title}</h3>
                    <p class="gantt-stage-summary">{item.summary}</p>
                    <p class="gantt-stage-duration">{item.durationLabel}</p>
                  </div>
                </div>

                <div class="gantt-track">
                  <div class="gantt-track-grid" aria-hidden="true">
                    {ganttWeeks.map(() => <span></span>)}
                  </div>
                  <div
                    class="gantt-bar"
                    style={`--start:${item.start}; --span:${item.span};`}
                    aria-label={`${item.title}，${item.durationLabel}`}
                  >
                    <span>{item.durationLabel}</span>
                  </div>
                </div>

                <div class="gantt-output">
                  <p>常見產出</p>
                  <ul>
                    {item.outputs.map((output) => <li>{output}</li>)}
                  </ul>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="process-notes" aria-label="補充說明">
        <article class="notes-card notes-card-dark">
          <p class="notes-label">你會看到的真實差異</p>
          <h2>哪些因素最常讓時程變動？</h2>
          <ul class="notes-list">
            <li>老屋若拆除後才發現漏水、結構修補、電箱更新或管線重拉，後面所有工項都可能往後延。</li>
            <li>系統櫃、特殊門片、玻璃、石材或進口五金若製作週期較長，安裝與收尾階段會一起被拉長。</li>
            <li>若施工中段改動櫃體、燈具、空調或設備配置，最常受影響的是木作、配線、油漆與收尾節點。</li>
          </ul>
        </article>

        <article class="notes-card">
          <p class="notes-label">青曦的做法</p>
          <h2>把收納、系統櫃與日常使用感一起想清楚</h2>
          <p>
            青曦平常特別重視收納細節、櫃體整合與實際入住後的使用感。流程的目的不是把案子做快，
            而是把每個決策放在對的節點，避免後面一直補洞。
          </p>
          <div class="notes-actions">
            <a href="/portfolio" class="process-button process-button-secondary">先看作品</a>
            <a href="/contact" class="process-button process-button-primary">直接聊需求</a>
          </div>
        </article>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .process-page {
    padding: 5rem 1.5rem;
    background:
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.08), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(245, 240, 234, 1) 100%);
  }

  .process-shell {
    max-width: 1280px;
    margin: 0 auto;
  }

  .process-hero {
    max-width: 52rem;
    margin: 0 auto;
    text-align: center;
  }

  .process-eyebrow,
  .gantt-label,
  .highlight-label,
  .notes-label {
    margin: 0 0 0.85rem;
    color: var(--gray-medium);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .process-hero h1,
  .gantt-header h2,
  .notes-card h2 {
    margin: 0;
    font-family: var(--font-serif);
    color: var(--gray-darkest);
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.24;
  }

  .process-hero h1 {
    font-size: clamp(2.4rem, 4.6vw, 4.2rem);
  }

  .process-description {
    margin: 1.1rem auto 0;
    color: var(--gray-medium);
    line-height: 1.9;
    letter-spacing: 0.008em;
    max-width: 46rem;
  }

  .process-actions,
  .notes-actions {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .process-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0.92rem 1.4rem;
    border-radius: 999px;
    text-decoration: none;
    letter-spacing: 0.06em;
    transition:
      transform 0.25s ease,
      background-color 0.25s ease,
      border-color 0.25s ease;
  }

  .process-button:hover {
    transform: translateY(-2px);
  }

  .process-button-primary {
    background: linear-gradient(135deg, var(--gray-darkest) 0%, #6a5f57 100%);
    color: var(--white);
    border: 1px solid rgba(115, 103, 94, 0.18);
    box-shadow: 0 16px 26px rgba(20, 20, 20, 0.14);
  }

  .process-button-secondary {
    background: rgba(255, 255, 255, 0.96);
    color: var(--gray-darkest);
    border: 1px solid rgba(101, 91, 84, 0.22);
    box-shadow: 0 12px 22px rgba(47, 47, 47, 0.05);
  }

  .process-highlights {
    margin-top: 2.6rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .highlight-card,
  .notes-card {
    border-radius: 26px;
    border: 1px solid rgba(115, 103, 94, 0.14);
    box-shadow: 0 18px 34px rgba(47, 47, 47, 0.05);
  }

  .highlight-card {
    padding: 1.5rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(249, 250, 250, 1) 100%);
  }

  .highlight-card h2 {
    margin: 0;
    font-family: var(--font-serif);
    color: var(--gray-darkest);
    font-size: 1.25rem;
    line-height: 1.42;
    font-weight: 600;
  }

  .highlight-card p:last-child {
    margin: 0.8rem 0 0;
    color: var(--gray-medium);
    line-height: 1.82;
    letter-spacing: 0.008em;
  }

  .gantt-section {
    margin-top: 2rem;
    padding: 1.4rem;
    border-radius: 32px;
    background:
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.06), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, rgba(247, 243, 238, 0.98) 100%);
    border: 1px solid rgba(115, 103, 94, 0.14);
    box-shadow: 0 22px 42px rgba(47, 47, 47, 0.06);
  }

  .gantt-header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    padding: 0.4rem 0.4rem 1.2rem;
  }

  .gantt-header h2 {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
  }

  .gantt-note {
    max-width: 22rem;
    margin: 0;
    color: var(--gray-medium);
    line-height: 1.8;
    letter-spacing: 0.008em;
  }

  .gantt-board {
    overflow-x: auto;
    padding-bottom: 0.3rem;
  }

  .gantt-axis,
  .gantt-row {
    min-width: 1120px;
    display: grid;
    grid-template-columns: minmax(280px, 320px) minmax(500px, 1fr) minmax(220px, 260px);
    gap: 1rem;
    align-items: stretch;
  }

  .gantt-axis {
    margin-bottom: 0.9rem;
  }

  .gantt-axis-stage,
  .gantt-axis-grid span {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--gray-medium);
    letter-spacing: 0.08em;
  }

  .gantt-axis-stage {
    padding: 0 0.75rem;
    display: flex;
    align-items: center;
  }

  .gantt-axis-grid,
  .gantt-track-grid {
    display: grid;
    grid-template-columns: repeat(18, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .gantt-axis-grid span {
    text-align: center;
  }

  .gantt-rows {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .gantt-row {
    padding: 1rem;
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(115, 103, 94, 0.12);
    box-shadow: 0 14px 30px rgba(47, 47, 47, 0.04);
  }

  .gantt-stage {
    display: flex;
    gap: 1rem;
  }

  .gantt-stage-number {
    flex: 0 0 52px;
    width: 52px;
    height: 52px;
    border-radius: 18px;
    display: inline-flex;
    align-items: center;
