    .gantt-axis,
    .gantt-row {
      min-width: 1320px;
      grid-template-columns: minmax(268px, 308px) minmax(392px, 0.9fr) minmax(220px, 256px);
      gap: 0.75rem;
    }

    .gantt-board {
      padding-top: 1.1rem;
    }

    .legend-items,
