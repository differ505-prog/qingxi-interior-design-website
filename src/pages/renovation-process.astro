    riskNote: "材質、櫃體與設備整合越多，往往越需要反覆確認。",
    bufferDays: 4,
  },
  "quote-contract": {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "報價增減與付款條件協調常讓時間拉長。",
    bufferDays: 3,
  },
  "procurement-prep": {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "主材到貨與工班排程常在這裡開始出現落差。",
    bufferDays: 4,
  },
  protection: {
    riskLevel: "low",
    riskLabel: "低變動",
    riskNote: "通常為開工既定流程。",
    bufferDays: 0,
  },
  demolition: {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "拆除後最容易發現漏水、結構或管線隱藏問題。",
    bufferDays: 7,
  },
  "plumbing-electric": {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "常因點位調整、現場條件與協作卡位延後。",
    bufferDays: 6,
  },
  "masonry-base": {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "濕作與修補類工序最常受基底與養護時間影響。",
    bufferDays: 7,
  },
  waterproofing: {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "需保留試水與修正時間，不能壓太滿。",
    bufferDays: 5,
  },
  "windows-metal": {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "外部條件、訂製尺寸與金屬加工交期波動較大。",
    bufferDays: 5,
  },
  carpentry: {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "常與空調、弱電和現場誤差互相牽動。",
    bufferDays: 4,
  },
  "hvac-lowvoltage": {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "設備整合與多工班交錯最容易延長工期。",
    bufferDays: 6,
  },
  tiling: {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "對基底、排版與材料到貨都較敏感。",
    bufferDays: 4,
  },
  paint: {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "常受前面木作修補與現場保護品質影響。",
    bufferDays: 3,
  },
  "cabinet-factory": {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "系統櫃與門片製作最常受工廠排程與五金交期影響。",
    bufferDays: 7,
  },
  flooring: {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "會受濕作完成度與交叉施工影響。",
    bufferDays: 3,
  },
  "cabinet-install": {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "若現場誤差或完成面有問題，安裝會被連動延後。",
    bufferDays: 4,
  },
  "equipment-install": {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "型號更換、到貨延誤或設備測試都會影響節點。",
    bufferDays: 4,
  },
  finishing: {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "最後修口與補漆最常被前面累積問題壓縮。",
    bufferDays: 5,
  },
  cleaning: {
    riskLevel: "low",
    riskLabel: "低變動",
    riskNote: "主要受前一階段是否真正收尾完成影響。",
    bufferDays: 1,
  },
  inspection: {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "驗收後若有缺失修正，通常會直接往後推。",
    bufferDays: 5,
  },
  handoff: {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "點交通常受複驗結果與屋主時間影響。",
    bufferDays: 3,
  },
};

const processStages = rawProcessStages.map((item) => ({
  ...item,
  ...stageRiskConfig[item.id],
}));

const totalWeeks = Math.max(...processStages.map((item) => item.start + item.span - 1));
const highRiskCount = processStages.filter((item) => item.riskLevel === "high").length;
const keyFlexStageIds = ["demolition", "plumbing-electric", "cabinet-factory", "inspection"];
const keyFlexStages = keyFlexStageIds
  .map((id) => processStages.find((item) => item.id === id))
  .filter((item): item is (typeof processStages)[number] => Boolean(item));

const stageHighlights = [
  {
    label: "全流程",
    title: "從提案、簽約、設計到交屋都放進同一張圖",
    body: "現在不是只看施工期，而是把前期提案與後段工程整合成一套完整時程。",
  },
  {
    label: "判讀方式",
    title: "顏色看工項類型，標籤看必做或視案況",
    body: "不需要長篇說明，也能快速分辨哪些是固定節點、哪些會依案況增減。",
  },
  {
    label: "日期推算",
    title: "輸入起算日後，節點就能直接換算成大概日期",
    body: "很適合屋主先抓搬家、家具進場、設備到貨與請假驗收的大致時點。",
  },
];

const processStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "提案到交屋的裝修全流程甘特圖",
    description:
      "青曦空間設計整理的裝修全流程甘特圖，涵蓋初談、丈量、提案、設計、報價簽約、拆除施工到驗收交屋，讓屋主快速掌握整體節奏。",
    totalTime: "P28W",
    step: processStages.map((item, index) => ({
      "@type": "HowToStep",
      position: index + 1,
      name: item.title,
      text: item.summary,
    })),
  },
];
---

<BaseLayout
  title="裝修全流程 - 青曦空間設計"
  description="用甘特圖看懂青曦空間設計從初談、提案、簽約設計到拆除施工與完工交屋的完整流程，並提供兩種更貼近真實溝通情境的日期視角。"
  ogImage="/images/portfolio/xizhi-1.jpg"
  pageType="service"
  structuredData={processStructuredData}
>
  <section class="process-page" data-total-weeks={totalWeeks}>
    <div class="process-shell">
      <header class="process-hero">
        <p class="process-eyebrow">Renovation Roadmap</p>
        <h1>從接洽到交屋，整套時程一次看懂。</h1>
        <p class="process-description">
          把前期提案、設計簽約、開工準備、拆除施工到驗收交屋全部放進同一張甘特圖，
          也能直接用日期去推算每個節點大約落在何時。
        </p>
        <div class="process-actions">
          <a href="/contact" class="process-button process-button-primary">預約諮詢</a>
          <a href="/tools" class="process-button process-button-secondary">先做估價</a>
        </div>
      </header>

      <section class="process-highlights" aria-label="流程重點">
        {stageHighlights.map((item) => (
          <article class="highlight-card">
            <p class="highlight-label">{item.label}</p>
            <h2>{item.title}</h2>
            <p>{item.body}</p>
          </article>
        ))}
      </section>

      <section class="schedule-tools" aria-label="日期換算工具">
        <article class="schedule-card schedule-card-primary">
          <p class="schedule-eyebrow">時程視角</p>
          <h2>輸入起算日期，用兩種方式看這份排程</h2>
          <div class="schedule-form">
            <label class="schedule-field">
              <span>起算日期</span>
              <input id="schedule-start-date" type="date" />
            </label>
            <div class="schedule-form-actions">
              <button type="button" id="schedule-fill-today" class="schedule-action schedule-action-primary">今天</button>
              <button type="button" id="schedule-clear" class="schedule-action">清除</button>
            </div>
          </div>
          <div class="schedule-mode-switch" role="tablist" aria-label="排程模式">
            {scheduleViews.map((view, index) => (
              <button
                type="button"
                class={`schedule-mode-button ${index === 0 ? "is-active" : ""}`}
                data-schedule-mode={view.key}
                data-mode-label={view.label}
                data-mode-description={view.description}
                data-mode-note={view.note}
              >
                {view.label}
              </button>
            ))}
          </div>
          <div class="schedule-mode-copy" id="schedule-mode-copy" aria-live="polite">
            <p class="schedule-mode-title">{scheduleViews[0].label}</p>
            <p class="schedule-mode-description">{scheduleViews[0].description}</p>
            <p class="schedule-mode-note">{scheduleViews[0].note}</p>
          </div>
          <p id="schedule-summary" class="schedule-summary" aria-live="polite">
            輸入日期後，會先看到較貼近真實溝通情境的交付視角。
          </p>
          <p class="schedule-helper">
            這份排程是拿來對齊節奏，不是拿來把交屋時間講死。
          </p>
        </article>

        <article class="schedule-card schedule-card-secondary">
          <p class="schedule-eyebrow">閱讀建議</p>
          <div class="schedule-metrics schedule-metrics-compact">
            <div class="schedule-metric">
              <strong>{processStages.length}</strong>
              <span>主要節點</span>
            </div>
            <div class="schedule-metric">
              <strong>{totalWeeks}</strong>
              <span>基準週數</span>
            </div>
            <div class="schedule-metric">
              <strong>{highRiskCount}</strong>
              <span>高變動工項</span>
            </div>
          </div>
          <ul class="schedule-reading-list">
            <li>第一次看這頁，先用「日常節奏」理解整體先後順序。</li>
            <li>如果你已有搬家、家具進場或租約銜接壓力，再切到「安心安排」。</li>
            <li>看到高變動工項時，代表那一段最需要保留談調整的空間。</li>
          </ul>
          <p class="schedule-description">
            以下日期是排程推算，不是交屋承諾。若遇到缺工、材料交期、現場突發狀況、社區施工限制或中途變更，實際進度仍可能延後，建議至少預留 10%-20% 彈性。
          </p>
        </article>
      </section>

      <section class="process-brief" aria-label="重點摘要">
        <article class="brief-card brief-card-primary">
          <p class="notes-label">交付視窗</p>
          <h2>先看兩種時間視角，再決定你要抓得多保守。</h2>
          <div class="brief-window-grid">
            <div class="brief-window-item">
              <span>日常節奏</span>
              <strong id="brief-baseline-window">輸入日期後，這裡會先出現日常節奏下的交付視窗。</strong>
              <small>先用來理解整體推進感</small>
            </div>
            <div class="brief-window-item">
              <span>安心安排</span>
              <strong id="brief-conservative-window">如果你手上已有固定時程，這裡會同步給你更保守的抓法。</strong>
              <small>更適合拿來安排實際決策</small>
            </div>
          </div>
        </article>

        <article class="brief-card">
          <p class="notes-label">最需留白</p>
          <h2>真正該保留彈性的，通常不是全部工項，而是幾個關鍵轉折。</h2>
          <div class="brief-tag-list">
            {keyFlexStages.map((item) => <span class="brief-tag">{item.title}</span>)}
          </div>
          <p>
            這幾段最常牽動後面的節奏，所以比起把每一天算得很準，更重要的是替這些轉折預留空間。
          </p>
        </article>
      </section>

      <section class="gantt-section" aria-labelledby="gantt-title">
        <div class="gantt-header">
          <div>
            <p class="gantt-label">甘特圖</p>
            <h2 id="gantt-title">以 28 週為基準的全流程節奏</h2>
          </div>
          <p class="gantt-note">把它當成一份溝通底稿會最剛好，既能先看節奏，也不會把現場變化講得太死。</p>
        </div>

        <div class="gantt-legend-grid">
          <div class="legend-group">
            <p>工項分類</p>
            <div class="legend-items">
              {toneLegend.map((item) => (
                <div class="legend-item">
                  <span class={`legend-dot legend-dot-${item.key}`}></span>
                  <div>
                    <strong>{item.label}</strong>
                    <small>{item.note}</small>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="legend-group">
            <p>工項性質</p>
            <div class="legend-items legend-items-compact">
              {scopeLegend.map((item) => (
                <div class="legend-item">
                  <span class={`legend-badge legend-badge-${item.key}`}>{item.label}</span>
                  <div>
                    <small>{item.note}</small>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="legend-group">
            <p>變動程度</p>
            <div class="legend-items legend-items-compact">
              {riskLegend.map((item) => (
                <div class="legend-item">
                  <span class={`risk-pill risk-pill-${item.key}`}>{item.label}</span>
                  <div>
                    <small>{item.note}</small>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="gantt-board">
          <div class="gantt-axis" aria-hidden="true">
            <div class="gantt-axis-stage">工項</div>
            <div class="gantt-axis-grid">
              {ganttWeeks.map((week) => <span>W{week}</span>)}
            </div>
            <div class="gantt-axis-detail">前置與產出</div>
          </div>

          <div class="gantt-rows">
            {processStages.map((item) => (
              <article
                class={`gantt-row gantt-row-${item.tone} gantt-row-${item.scopeType}`}
                data-stage-id={item.id}
                data-stage-title={item.title}
                data-start-week={item.start}
                data-span-weeks={item.span}
                data-buffer-days={item.bufferDays}
                data-risk-level={item.riskLevel}
              >
                <div class="gantt-stage">
                  <span class={`gantt-stage-number gantt-stage-number-${item.tone}`}>{item.stage}</span>
                  <div class="gantt-stage-body">
                    <div class="gantt-stage-topline">
                      <p class="gantt-stage-category">{item.category}</p>
                      <span class={`legend-badge legend-badge-${item.scopeType}`}>{item.scopeLabel}</span>
                    </div>
                    <h3>{item.title}</h3>
                    <p class="gantt-stage-summary">{item.summary}</p>
                    <div class="gantt-stage-meta">
                      <span class={`tone-pill tone-pill-${item.tone}`}>{item.toneLabel}</span>
                      <span class={`risk-pill risk-pill-${item.riskLevel}`}>{item.riskLabel}</span>
                      <span class="gantt-stage-duration">{item.durationLabel}</span>
                    </div>
                    <p class="gantt-date-range gantt-date-range-empty" data-stage-date={item.id}>
                      輸入日期後，這段流程的時間感會出現在這裡。
                    </p>
                  </div>
                </div>

                <div class="gantt-track">
                  <div class="gantt-track-grid" aria-hidden="true">
                    {ganttWeeks.map(() => <span></span>)}
                  </div>
                  <div
                    class={`gantt-bar gantt-bar-${item.tone} gantt-bar-${item.scopeType}`}
                    style={`--start:${item.start}; --span:${item.span};`}
                    aria-label={`${item.title}，${item.durationLabel}`}
                  >
                    <span>{item.durationLabel}</span>
                  </div>
                </div>

                <div class="gantt-detail">
                  <div class="gantt-detail-block">
                    <p>前置條件</p>
                    <ul>
                      {item.prerequisites.map((condition) => <li>{condition}</li>)}
                    </ul>
                  </div>
                  <div class="gantt-detail-block">
                    <p>變動提醒</p>
                    <p class="gantt-risk-note">{item.riskNote}</p>
                  </div>
                  <div class="gantt-detail-block">
                    <p>常見產出</p>
                    <ul>
                      {item.outputs.map((output) => <li>{output}</li>)}
                    </ul>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="process-notes" aria-label="補充說明">
        <article class="notes-card notes-card-dark">
          <p class="notes-label">排程現實</p>
          <h2>哪些情況最常把時程往後推？</h2>
          <ul class="notes-list">
            <li>老屋若拆除後才發現漏水、結構修補、電箱更新或管線重拉，後面所有工項都可能往後延。</li>
            <li>系統櫃、特殊門片、玻璃、石材或進口五金若製作週期較長，安裝與收尾階段會一起被拉長。</li>
            <li>若施工中段改動櫃體、燈具、空調或設備配置，最常受影響的是木作、配線、油漆與收尾節點。</li>
          </ul>
        </article>

        <article class="notes-card">
          <p class="notes-label">建議</p>
          <h2>如果有搬家或租約壓力，請直接看保守版</h2>
          <p>
            若你手上有搬家、家具進場、租約到期或入厝日安排，不建議把基準版最後一天當成唯一決策點。
          </p>
          <div class="notes-actions">
            <a href="/portfolio" class="process-button process-button-secondary">先看作品</a>
            <a href="/contact" class="process-button process-button-primary">直接聊需求</a>
          </div>
        </article>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .process-page {
    padding: 5rem 1.5rem;
    background:
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.08), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(245, 240, 234, 1) 100%);
  }

  .process-shell {
    max-width: 1320px;
    margin: 0 auto;
  }

  .process-hero {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
  }

  .process-eyebrow,
  .gantt-label,
  .highlight-label,
  .notes-label,
  .schedule-eyebrow {
    margin: 0 0 0.85rem;
    color: var(--gray-medium);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .process-hero h1,
  .gantt-header h2,
  .notes-card h2,
  .schedule-card h2 {
    margin: 0;
    font-family: var(--font-serif);
    color: var(--gray-darkest);
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.24;
  }

  .process-hero h1 {
    font-size: clamp(2.3rem, 4.4vw, 4rem);
  }

  .process-description,
  .schedule-description {
    margin: 1.1rem auto 0;
    color: var(--gray-medium);
    line-height: 1.9;
    letter-spacing: 0.008em;
  }

  .process-description {
    max-width: 48rem;
  }

  .process-actions,
  .notes-actions {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .process-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0.92rem 1.4rem;
    border-radius: 999px;
    text-decoration: none;
    letter-spacing: 0.06em;
    transition:
      transform 0.25s ease,
      background-color 0.25s ease,
      border-color 0.25s ease;
  }

  .process-button:hover,
  .schedule-action:hover {
    transform: translateY(-2px);
  }

  .process-button-primary,
  .schedule-action-primary {
    background: linear-gradient(135deg, var(--gray-darkest) 0%, #6a5f57 100%);
    color: var(--white);
    border: 1px solid rgba(115, 103, 94, 0.18);
    box-shadow: 0 16px 26px rgba(20, 20, 20, 0.14);
  }

  .process-button-secondary,
  .schedule-action {
    background: rgba(255, 255, 255, 0.96);
    color: var(--gray-darkest);
    border: 1px solid rgba(101, 91, 84, 0.22);
    box-shadow: 0 12px 22px rgba(47, 47, 47, 0.05);
  }

  .process-highlights,
  .schedule-tools,
  .process-brief,
  .process-notes {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .schedule-tools,
  .process-brief,
  .process-notes {
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.9fr);
  }

  .highlight-card,
  .brief-card,
  .notes-card,
  .schedule-card {
    border-radius: 26px;
    border: 1px solid rgba(115, 103, 94, 0.14);
    box-shadow: 0 18px 34px rgba(47, 47, 47, 0.05);
  }

  .highlight-card,
  .brief-card,
  .notes-card,
  .schedule-card-secondary {
    padding: 1.5rem;
