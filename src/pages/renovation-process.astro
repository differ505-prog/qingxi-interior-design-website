</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const startDateInput = document.getElementById("schedule-start-date");
    const fillTodayButton = document.getElementById("schedule-fill-today");
    const clearButton = document.getElementById("schedule-clear");
    const summaryNode = document.getElementById("schedule-summary");
    const modeCopy = document.getElementById("schedule-mode-copy");
    const baselineWindowNode = document.getElementById("brief-baseline-window");
    const conservativeWindowNode = document.getElementById("brief-conservative-window");
    const projectTypeCopyNode = document.getElementById("project-type-copy");
    const briefProjectTypeCopyNode = document.getElementById("brief-project-type-copy");
    const briefFlexTagsNode = document.getElementById("brief-flex-tags");
    const metricTotalWeeksNode = document.getElementById("metric-total-weeks");
    const metricHighRiskCountNode = document.getElementById("metric-high-risk-count");
    const ganttTitleNode = document.getElementById("gantt-title");
    const processPage = document.querySelector(".process-page");
    const projectTypeConfig = JSON.parse(processPage?.getAttribute("data-project-config") || "{}");
    const stageRows = Array.from(document.querySelectorAll("[data-stage-id]"));
    const modeButtons = Array.from(document.querySelectorAll("[data-schedule-mode]"));
    const projectTypeButtons = Array.from(document.querySelectorAll(".project-type-button"));
    const axisWeekNodes = Array.from(document.querySelectorAll("[data-axis-week]"));
    const trackWeekNodes = Array.from(document.querySelectorAll("[data-track-week]"));
    const defaultSummary = summaryNode?.textContent || "";
    let scheduleMode = "baseline";
    let projectType = processPage?.getAttribute("data-project-type") || "old-house";

    function toInputDateValue(date) {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    }

    function parseLocalDate(value) {
      if (!value) return null;
      const [year, month, day] = value.split("-").map(Number);
      if (!year || !month || !day) return null;
      return new Date(year, month - 1, day, 12, 0, 0, 0);
    }

    function addDays(date, days) {
      const next = new Date(date);
      next.setDate(next.getDate() + days);
      return next;
    }

    function formatDate(date) {
      return new Intl.DateTimeFormat("zh-TW", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
      }).format(date);
    }

    function getPhaseLabel(date) {
      const day = date.getDate();
      if (day <= 10) return "上旬";
      if (day <= 20) return "中旬";
      return "下旬";
    }

    function formatNaturalWindow(startDate, endDate) {
      const startYear = startDate.getFullYear();
      const endYear = endDate.getFullYear();
      const startMonth = startDate.getMonth() + 1;
      const endMonth = endDate.getMonth() + 1;
      const startPhase = getPhaseLabel(startDate);
      const endPhase = getPhaseLabel(endDate);

      if (startYear === endYear && startMonth === endMonth) {
        if (startPhase === endPhase) {
          return `${startYear} 年 ${startMonth} 月${startPhase}`;
        }
        return `${startYear} 年 ${startMonth} 月${startPhase}至${endPhase}`;
      }

      return `${startYear} 年 ${startMonth} 月${startPhase}至 ${endYear} 年 ${endMonth} 月${endPhase}`;
    }

    function setBriefFlexTags(titles) {
      if (!briefFlexTagsNode) return;

      briefFlexTagsNode.innerHTML = "";
      titles.forEach((title) => {
        const tag = document.createElement("span");
        tag.className = "brief-tag";
        tag.textContent = title;
        briefFlexTagsNode.appendChild(tag);
      });
    }

    function setScheduleMode(nextMode) {
      scheduleMode = nextMode;
      modeButtons.forEach((button) => {
        const isActive = button.getAttribute("data-schedule-mode") === nextMode;
        button.classList.toggle("is-active", isActive);
      });

      const activeButton = modeButtons.find((button) => button.getAttribute("data-schedule-mode") === nextMode);
      const modeTitle = modeCopy?.querySelector(".schedule-mode-title");
      const modeDescription = modeCopy?.querySelector(".schedule-mode-description");

      if (activeButton && modeTitle && modeDescription) {
        modeTitle.textContent = activeButton.getAttribute("data-mode-label") || "";
        modeDescription.textContent = activeButton.getAttribute("data-mode-description") || "";
      }
    }

    function applyProjectType(nextType) {
      const config = projectTypeConfig[nextType];
      if (!config) return;

      projectType = nextType;
      processPage?.setAttribute("data-project-type", nextType);
      processPage?.setAttribute("data-total-weeks", String(config.totalWeeks));

      projectTypeButtons.forEach((button) => {
        const isActive = button.getAttribute("data-project-type") === nextType;
        button.classList.toggle("is-active", isActive);
      });

      if (projectTypeCopyNode) {
        projectTypeCopyNode.textContent = config.description;
      }

      if (briefProjectTypeCopyNode) {
        briefProjectTypeCopyNode.textContent = config.briefCopy;
      }

      if (metricTotalWeeksNode) {
        metricTotalWeeksNode.textContent = String(config.totalWeeks);
      }

      if (metricHighRiskCountNode) {
        metricHighRiskCountNode.textContent = String(config.highRiskCount);
      }

      if (ganttTitleNode) {
        ganttTitleNode.textContent = config.ganttTitle;
      }

      setBriefFlexTags(config.flexStageTitles);

      axisWeekNodes.forEach((node) => {
        const week = Number(node.getAttribute("data-axis-week") || 0);
        node.classList.toggle("is-outside-range", week > config.totalWeeks);
      });

      trackWeekNodes.forEach((node) => {
        const week = Number(node.getAttribute("data-track-week") || 0);
        node.classList.toggle("is-outside-range", week > config.totalWeeks);
      });

      stageRows.forEach((row) => {
        const startWeek = row.getAttribute(`data-${nextType}-start-week`) || row.getAttribute("data-start-week") || "";
        const spanWeeks = row.getAttribute(`data-${nextType}-span-weeks`) || row.getAttribute("data-span-weeks") || "";
        const bufferDays = row.getAttribute(`data-${nextType}-buffer-days`) || row.getAttribute("data-buffer-days") || "";
        const riskLevel = row.getAttribute(`data-${nextType}-risk-level`) || row.getAttribute("data-risk-level") || "low";
        const riskLabel = row.getAttribute(`data-${nextType}-risk-label`) || "";
        const riskNote = row.getAttribute(`data-${nextType}-risk-note`) || "";
        const durationLabel = row.getAttribute(`data-${nextType}-duration-label`) || "";
        const stageTitle = row.getAttribute("data-stage-title") || "此節點";

        row.setAttribute("data-start-week", startWeek);
        row.setAttribute("data-span-weeks", spanWeeks);
        row.setAttribute("data-buffer-days", bufferDays);
        row.setAttribute("data-risk-level", riskLevel);

        const riskPill = row.querySelector("[data-stage-risk-pill]");
        if (riskPill) {
          riskPill.className = `risk-pill risk-pill-${riskLevel}`;
          riskPill.textContent = riskLabel;
        }

        const durationNode = row.querySelector("[data-stage-duration]");
        if (durationNode) {
          durationNode.textContent = durationLabel;
        }

        const riskNoteNode = row.querySelector("[data-stage-risk-note]");
        if (riskNoteNode) {
          riskNoteNode.textContent = riskNote;
        }

        const barNode = row.querySelector("[data-stage-bar]");
        if (barNode instanceof HTMLElement) {
          barNode.style.setProperty("--start", startWeek);
          barNode.style.setProperty("--span", spanWeeks);
          barNode.setAttribute("aria-label", `${stageTitle}，${durationLabel}`);
          const labelNode = barNode.querySelector("span");
          if (labelNode) {
            labelNode.textContent = durationLabel;
          }
        }
      });
    }

    function updateSchedule() {
      const baseDate = parseLocalDate(startDateInput instanceof HTMLInputElement ? startDateInput.value : "");
      const dateNodes = Array.from(document.querySelectorAll("[data-stage-date]"));
      const totalWeeks = projectTypeConfig[projectType]?.totalWeeks || 0;

      if (!baseDate) {
        dateNodes.forEach((node) => {
          node.textContent = "輸入日期後，這段流程的時間感會出現在這裡。";
          node.classList.add("gantt-date-range-empty");
        });
        if (summaryNode) {
          summaryNode.textContent = defaultSummary;
        }
        if (baselineWindowNode) {
          baselineWindowNode.textContent = "輸入日期後，這裡會先出現日常節奏下的交付視窗。";
        }
        if (conservativeWindowNode) {
          conservativeWindowNode.textContent = "如果你手上已有固定時程，這裡會同步給你更保守的抓法。";
        }
        return;
      }

      let conservativeOffsetDays = 0;

      stageRows.forEach((row) => {
        const stageId = row.getAttribute("data-stage-id");
        const startWeek = Number(row.getAttribute("data-start-week") || 0);
        const spanWeeks = Number(row.getAttribute("data-span-weeks") || 0);
        const bufferDays = Number(row.getAttribute("data-buffer-days") || 0);
        const riskLevel = row.getAttribute("data-risk-level") || "low";
        const title = row.getAttribute("data-stage-title") || "此節點";
        const targetNode = document.querySelector(`[data-stage-date="${stageId}"]`);
        if (!targetNode || !startWeek || !spanWeeks) return;

        const baselineStart = addDays(baseDate, (startWeek - 1) * 7);
        const baselineEnd = addDays(baseDate, (startWeek + spanWeeks - 1) * 7 - 1);
        const conservativeStart = addDays(baselineStart, conservativeOffsetDays);
        const conservativeEnd = addDays(baselineEnd, conservativeOffsetDays + bufferDays);

        if (scheduleMode === "conservative") {
          const bufferText =
            riskLevel === "high" || riskLevel === "medium" ? `，已含約 ${bufferDays} 天緩衝` : "";
          targetNode.textContent =
            `${title}在安心安排裡，通常會落在 ${formatNaturalWindow(conservativeStart, conservativeEnd)}左右${bufferText}`;
        } else {
          targetNode.textContent =
            `${title}在日常節奏裡，通常會落在 ${formatNaturalWindow(baselineStart, baselineEnd)}左右`;
        }
        targetNode.classList.remove("gantt-date-range-empty");

        conservativeOffsetDays += bufferDays;
      });

      if (summaryNode && totalWeeks) {
        const baselineEnd = addDays(baseDate, totalWeeks * 7 - 1);
        const conservativeEnd = addDays(baselineEnd, conservativeOffsetDays);

        if (baselineWindowNode) {
          baselineWindowNode.textContent =
            `${formatNaturalWindow(baseDate, baselineEnd)}交付機率最高`;
        }

        if (conservativeWindowNode) {
          conservativeWindowNode.textContent =
            `${formatNaturalWindow(baseDate, conservativeEnd)}會更從容`;
        }

        if (scheduleMode === "conservative") {
          summaryNode.textContent =
            `若從 ${formatDate(baseDate)} 開始往後看，安心安排會把中高變動工項的緩衝一起算進去，整體交付多半會落在 ${formatNaturalWindow(baseDate, conservativeEnd)}。`;
        } else {
          summaryNode.textContent =
            `若從 ${formatDate(baseDate)} 開始往後看，依日常節奏推進，整體交付通常會落在 ${formatNaturalWindow(baseDate, baselineEnd)}；若你手上已有固定時程，建議再多看安心安排。`;
        }
      }
    }

    if (fillTodayButton instanceof HTMLButtonElement && startDateInput instanceof HTMLInputElement) {
      fillTodayButton.addEventListener("click", () => {
        startDateInput.value = toInputDateValue(new Date());
        updateSchedule();
      });
    }

    if (clearButton instanceof HTMLButtonElement && startDateInput instanceof HTMLInputElement) {
      clearButton.addEventListener("click", () => {
        startDateInput.value = "";
        updateSchedule();
      });
    }

    if (startDateInput instanceof HTMLInputElement) {
      startDateInput.addEventListener("input", updateSchedule);
      startDateInput.addEventListener("change", updateSchedule);
    }

    modeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextMode = button.getAttribute("data-schedule-mode");
        if (!nextMode) return;
        setScheduleMode(nextMode);
        updateSchedule();
      });
    });

    projectTypeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextType = button.getAttribute("data-project-type");
        if (!nextType || nextType === projectType) return;
        applyProjectType(nextType);
        updateSchedule();
      });
    });

    applyProjectType(projectType);
    setScheduleMode(scheduleMode);
    updateSchedule();
  });
</script>
