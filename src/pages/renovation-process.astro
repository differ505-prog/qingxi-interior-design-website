  "detailed-design": {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "材質、櫃體與設備整合越多，往往越需要反覆確認。",
    bufferDays: 4,
  },
  "quote-contract": {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "報價增減與付款條件協調常讓時間拉長。",
    bufferDays: 3,
  },
  "procurement-prep": {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "主材到貨與工班排程常在這裡開始出現落差。",
    bufferDays: 4,
  },
  protection: {
    riskLevel: "low",
    riskLabel: "低變動",
    riskNote: "通常為開工既定流程。",
    bufferDays: 0,
  },
  demolition: {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "拆除後最容易發現漏水、結構或管線隱藏問題。",
    bufferDays: 7,
  },
  "plumbing-electric": {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "常因點位調整、現場條件與協作卡位延後。",
    bufferDays: 6,
  },
  "masonry-base": {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "濕作與修補類工序最常受基底與養護時間影響。",
    bufferDays: 7,
  },
  waterproofing: {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "需保留試水與修正時間，不能壓太滿。",
    bufferDays: 5,
  },
  "windows-metal": {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "外部條件、訂製尺寸與金屬加工交期波動較大。",
    bufferDays: 5,
  },
  carpentry: {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "常與空調、弱電和現場誤差互相牽動。",
    bufferDays: 4,
  },
  "hvac-lowvoltage": {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "設備整合與多工班交錯最容易延長工期。",
    bufferDays: 6,
  },
  tiling: {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "對基底、排版與材料到貨都較敏感。",
    bufferDays: 4,
  },
  paint: {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "常受前面木作修補與現場保護品質影響。",
    bufferDays: 3,
  },
  "cabinet-factory": {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "系統櫃與門片製作最常受工廠排程與五金交期影響。",
    bufferDays: 7,
  },
  flooring: {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "會受濕作完成度與交叉施工影響。",
    bufferDays: 3,
  },
  "cabinet-install": {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "若現場誤差或完成面有問題，安裝會被連動延後。",
    bufferDays: 4,
  },
  "equipment-install": {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "型號更換、到貨延誤或設備測試都會影響節點。",
    bufferDays: 4,
  },
  finishing: {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "最後修口與補漆最常被前面累積問題壓縮。",
    bufferDays: 5,
  },
  cleaning: {
    riskLevel: "low",
    riskLabel: "低變動",
    riskNote: "主要受前一階段是否真正收尾完成影響。",
    bufferDays: 1,
  },
  inspection: {
    riskLevel: "high",
    riskLabel: "高變動",
    riskNote: "驗收後若有缺失修正，通常會直接往後推。",
    bufferDays: 5,
  },
  handoff: {
    riskLevel: "medium",
    riskLabel: "中變動",
    riskNote: "點交通常受複驗結果與屋主時間影響。",
    bufferDays: 3,
  },
};

const processStages = rawProcessStages.map((item) => ({
  ...item,
  ...stageRiskConfig[item.id],
}));

type ProcessStage = (typeof processStages)[number];
type StageProfileOverride = Partial<
  Pick<ProcessStage, "start" | "span" | "durationLabel" | "bufferDays" | "riskLevel" | "riskLabel" | "riskNote">
>;

const projectTypeStageOverrides: Record<ProjectTypeKey, Record<string, StageProfileOverride>> = {
  "old-house": {},
  "new-home": {
    "detailed-design": { span: 3, durationLabel: "約 2-3 週", bufferDays: 3 },
    "quote-contract": { span: 1, durationLabel: "約 1 週", bufferDays: 2 },
    "procurement-prep": { start: 8, span: 2, durationLabel: "約 1-2 週", bufferDays: 3 },
    protection: { start: 10 },
    demolition: {
      start: 10,
      span: 1,
      durationLabel: "約 3-5 天",
      bufferDays: 3,
      riskLevel: "medium",
      riskLabel: "中變動",
      riskNote: "新成屋通常拆除較少，但若有客變調整仍會影響後續工序。",
    },
    "plumbing-electric": {
      start: 11,
      span: 2,
      durationLabel: "約 1-2 週",
      bufferDays: 4,
      riskLevel: "medium",
      riskLabel: "中變動",
      riskNote: "新成屋多半以點位整合為主，但設備與櫃體配合仍會牽動進度。",
    },
    "masonry-base": {
      start: 12,
      span: 2,
      durationLabel: "約 1-2 週",
      bufferDays: 4,
      riskLevel: "medium",
      riskLabel: "中變動",
      riskNote: "若浴室、防水或局部格局調整介入，才會明顯拉長時程。",
    },
    waterproofing: {
      start: 13,
      span: 1,
      durationLabel: "約 3-5 天",
      bufferDays: 3,
      riskLevel: "medium",
      riskLabel: "中變動",
      riskNote: "新成屋通常只有局部濕區會影響這段節奏。",
    },
    "windows-metal": {
      start: 14,
      span: 1,
      durationLabel: "約 3-5 天",
      bufferDays: 3,
      riskLevel: "medium",
      riskLabel: "中變動",
      riskNote: "若沒有窗體或金屬追加，這段通常只會輕微穿插。",
    },
    carpentry: { start: 14, span: 3, durationLabel: "約 2-3 週", bufferDays: 3 },
    "hvac-lowvoltage": {
      start: 14,
      span: 2,
      durationLabel: "約 1-2 週",
      bufferDays: 4,
      riskLevel: "medium",
      riskLabel: "中變動",
      riskNote: "新成屋常見的是空調與弱電整合，而不是大規模修復。",
    },
    tiling: { start: 15, span: 2, durationLabel: "約 1-2 週", bufferDays: 3 },
    paint: { start: 17, span: 2, durationLabel: "約 1-2 週", bufferDays: 2 },
    "cabinet-factory": { start: 15, span: 4, bufferDays: 6 },
    flooring: { start: 18, span: 1, durationLabel: "約 3-5 天", bufferDays: 2 },
    "cabinet-install": { start: 19, span: 2, durationLabel: "約 1-2 週", bufferDays: 3 },
    "equipment-install": { start: 20, span: 2, durationLabel: "約 1-2 週", bufferDays: 3 },
    finishing: { start: 21, span: 2, durationLabel: "約 1-2 週", bufferDays: 3 },
    cleaning: { start: 23 },
    inspection: { start: 24, bufferDays: 4 },
    handoff: { start: 25 },
  },
};

const projectTypeStages = {
  "old-house": processStages,
  "new-home": processStages.map((item) => ({
    ...item,
    ...(projectTypeStageOverrides["new-home"][item.id] ?? {}),
  })),
} satisfies Record<ProjectTypeKey, ProcessStage[]>;

const projectTypeMetrics = {
  "old-house": {
    totalWeeks: Math.max(...projectTypeStages["old-house"].map((item) => item.start + item.span - 1)),
    highRiskCount: projectTypeStages["old-house"].filter((item) => item.riskLevel === "high").length,
    flexStageTitles: ["拆除工程與廢棄物清運", "水電定位、配管與弱電預埋", "系統櫃複丈、下單與工廠製作", "初驗、缺失修正與複驗"],
  },
  "new-home": {
    totalWeeks: Math.max(...projectTypeStages["new-home"].map((item) => item.start + item.span - 1)),
    highRiskCount: projectTypeStages["new-home"].filter((item) => item.riskLevel === "high").length,
    flexStageTitles: ["水電定位、配管與弱電預埋", "系統櫃複丈、下單與工廠製作", "燈具、衛浴、廚具、插座與設備安裝", "初驗、缺失修正與複驗"],
  },
} satisfies Record<ProjectTypeKey, { totalWeeks: number; highRiskCount: number; flexStageTitles: string[] }>;

const projectTypeClientConfig = {
  "old-house": {
    label: "老屋翻新",
    description: "會預留較多拆除後修補、管線調整與現場變數。",
    briefCopy: "目前以老屋翻新為基準，會把拆除後修補與現場調整一起算進來。",
    ganttTitle: `以老屋翻新 ${projectTypeMetrics["old-house"].totalWeeks} 週為基準的全流程節奏`,
  },
  "new-home": {
    label: "新成屋全戶",
    description: "基礎修復較少，重點多在設計整合與櫃體設備進場。",
    briefCopy: "切到新成屋全戶後，重點會轉成櫃體、設備與整合進場的節奏。",
    ganttTitle: `以新成屋全戶 ${projectTypeMetrics["new-home"].totalWeeks} 週為基準的全流程節奏`,
  },
} satisfies Record<ProjectTypeKey, { label: string; description: string; briefCopy: string; ganttTitle: string }>;

const projectTypeRuntimeConfig = {
  "old-house": {
    ...projectTypeClientConfig["old-house"],
    ...projectTypeMetrics["old-house"],
  },
  "new-home": {
    ...projectTypeClientConfig["new-home"],
    ...projectTypeMetrics["new-home"],
  },
} satisfies Record<
  ProjectTypeKey,
  {
    label: string;
    description: string;
    briefCopy: string;
    ganttTitle: string;
    totalWeeks: number;
    highRiskCount: number;
    flexStageTitles: string[];
  }
>;

const totalWeeks = projectTypeMetrics["old-house"].totalWeeks;
const highRiskCount = projectTypeMetrics["old-house"].highRiskCount;
const keyFlexStages = projectTypeMetrics["old-house"].flexStageTitles;

const processStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "提案到交屋的裝修全流程甘特圖",
    description:
      "青曦空間設計整理的裝修全流程甘特圖，涵蓋初談、丈量、提案、設計、報價簽約、拆除施工到驗收交屋，讓屋主快速掌握整體節奏。",
    totalTime: "P28W",
    step: processStages.map((item, index) => ({
      "@type": "HowToStep",
      position: index + 1,
      name: item.title,
      text: item.summary,
    })),
  },
];
---

<BaseLayout
  title="裝修全流程 - 青曦空間設計"
  description="用甘特圖看懂青曦空間設計從初談、提案、簽約設計到拆除施工與完工交屋的完整流程，並提供兩種更貼近真實溝通情境的日期視角。"
  ogImage="/images/portfolio/xizhi-1.jpg"
  pageType="service"
  structuredData={processStructuredData}
>
  <section
    class="process-page"
    data-total-weeks={totalWeeks}
    data-project-type="old-house"
    data-project-config={JSON.stringify(projectTypeRuntimeConfig)}
  >
    <div class="process-shell">
      <header class="process-hero">
        <p class="process-eyebrow">Renovation Roadmap</p>
        <h1>從接洽到交屋，整套時程一次看懂。</h1>
        <p class="process-description">
          把前期提案到完工交屋全部放進同一張甘特圖，也能依屋況基準換算每個節點的大致時間。
        </p>
        <div class="process-actions">
          <a href="/contact" class="process-button process-button-primary">預約諮詢</a>
          <a href="/tools" class="process-button process-button-secondary">先做估價</a>
          <a href="/standard-sop" class="process-button process-button-secondary">看青曦標準 SOP</a>
        </div>
      </header>

      <section class="process-stage-overview" aria-label="流程階段總覽">
        <div class="section-heading">
          <p class="section-eyebrow">Flow Overview</p>
          <h2>從接洽到交屋的 6 大階段</h2>
          <p>先理解整體階段的脈絡，再進入甘特圖看細節時程。</p>
        </div>
        <div class="flow-grid">
          {toneLegend.map((item, index) => (
            <article class="flow-card">
              <div class="flow-stage-row">
                <span class="flow-stage">{`0${index + 1}`}</span>
                <span class="flow-tag">{item.label}</span>
              </div>
              <h3>{item.label}</h3>
              <p>{item.note}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="schedule-tools" aria-label="日期換算工具">
        <article class="schedule-card schedule-card-primary">
          <p class="schedule-eyebrow">時程視角</p>
          <h2>輸入起算日期，用兩種方式看這份排程</h2>
          <div class="project-type-picker">
            <p class="project-type-label">屋況基準</p>
            <div class="project-type-switch" role="tablist" aria-label="屋況基準">
              {projectTypeViews.map((view, index) => (
                <button
                  type="button"
                  class={`project-type-button ${index === 0 ? "is-active" : ""}`}
                  data-project-type={view.key}
                  data-type-label={view.label}
                  data-type-description={view.description}
                >
                  {view.label}
                </button>
              ))}
            </div>
            <p class="project-type-copy" id="project-type-copy" aria-live="polite">
              {projectTypeViews[0].description}
            </p>
          </div>
          <div class="schedule-form">
            <label class="schedule-field">
              <span>起算日期</span>
              <input id="schedule-start-date" type="date" />
            </label>
            <div class="schedule-form-actions">
              <button type="button" id="schedule-fill-today" class="schedule-action schedule-action-primary">今天</button>
              <button type="button" id="schedule-clear" class="schedule-action">清除</button>
            </div>
          </div>
          <div class="schedule-mode-switch" role="tablist" aria-label="排程模式">
            {scheduleViews.map((view, index) => (
              <button
                type="button"
                class={`schedule-mode-button ${index === 0 ? "is-active" : ""}`}
                data-schedule-mode={view.key}
                data-mode-label={view.label}
                data-mode-description={view.description}
              >
                {view.label}
              </button>
            ))}
          </div>
          <div class="schedule-mode-copy" id="schedule-mode-copy" aria-live="polite">
            <p class="schedule-mode-title">{scheduleViews[0].label}</p>
            <p class="schedule-mode-description">{scheduleViews[0].description}</p>
          </div>
          <p id="schedule-summary" class="schedule-summary" aria-live="polite">
            輸入日期後，會先看到較貼近真實溝通情境的交付視角。
          </p>
        </article>

        <article class="schedule-card schedule-card-secondary">
          <p class="schedule-eyebrow">閱讀建議</p>
          <div class="schedule-metrics schedule-metrics-compact">
            <div class="schedule-metric">
              <strong>{processStages.length}</strong>
              <span>主要節點</span>
            </div>
            <div class="schedule-metric">
              <strong id="metric-total-weeks">{totalWeeks}</strong>
              <span>基準週數</span>
            </div>
            <div class="schedule-metric">
              <strong id="metric-high-risk-count">{highRiskCount}</strong>
              <span>高變動工項</span>
            </div>
          </div>
          <p class="schedule-description">
            以下日期是排程推算，不是交屋承諾，建議至少預留 10%-20% 彈性。
          </p>
        </article>
      </section>

      <section class="process-brief" aria-label="重點摘要">
        <article class="brief-card brief-card-primary">
          <p class="notes-label">交付視窗</p>
          <h2>先看兩種時間視角，再決定你要抓得多保守。</h2>
          <p class="brief-inline-copy" id="brief-project-type-copy">
            目前以老屋翻新為基準，會把拆除後修補與現場調整一起算進來。
          </p>
          <div class="brief-window-grid">
            <div class="brief-window-item">
              <span>日常節奏</span>
              <strong id="brief-baseline-window">輸入日期後，這裡會先出現日常節奏下的交付視窗。</strong>
              <small>先用來理解整體推進感</small>
            </div>
            <div class="brief-window-item">
              <span>安心安排</span>
              <strong id="brief-conservative-window">如果你手上已有固定時程，這裡會同步給你更保守的抓法。</strong>
              <small>更適合拿來安排實際決策</small>
            </div>
          </div>
        </article>

        <article class="brief-card">
          <p class="notes-label">最需留白</p>
          <h2>真正該保留彈性的，通常不是全部工項，而是幾個關鍵轉折。</h2>
          <div class="brief-tag-list" id="brief-flex-tags">
            {keyFlexStages.map((item) => <span class="brief-tag">{item}</span>)}
          </div>
        </article>
      </section>

      <section class="gantt-section" aria-labelledby="gantt-title">
        <div class="gantt-header">
          <div>
            <p class="gantt-label">甘特圖</p>
            <h2 id="gantt-title">以老屋翻新 28 週為基準的全流程節奏</h2>
          </div>
        </div>

        <div class="gantt-legend-grid">
          <div class="legend-group">
            <p>工項分類</p>
            <div class="legend-items">
              {toneLegend.map((item) => (
                <div class="legend-item">
                  <span class={`legend-dot legend-dot-${item.key}`}></span>
                  <div>
                    <strong>{item.label}</strong>
                    <small>{item.note}</small>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="legend-group">
            <p>工項性質</p>
            <div class="legend-items legend-items-compact">
              {scopeLegend.map((item) => (
                <div class="legend-item">
                  <span class={`legend-badge legend-badge-${item.key}`}>{item.label}</span>
                  <div>
                    <small>{item.note}</small>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="legend-group">
            <p>變動程度</p>
            <div class="legend-items legend-items-compact">
              {riskLegend.map((item) => (
                <div class="legend-item">
                  <span class={`risk-pill risk-pill-${item.key}`}>{item.label}</span>
                  <div>
                    <small>{item.note}</small>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="gantt-board">
          <div class="gantt-axis" aria-hidden="true">
            <div class="gantt-axis-stage">工項</div>
            <div class="gantt-axis-grid">
              {ganttWeeks.map((week) => <span data-axis-week={week}>W{week}</span>)}
            </div>
            <div class="gantt-axis-detail">前置與產出</div>
          </div>

          <div class="gantt-rows">
            {processStages.map((item, index) => {
              const newHomeStage = projectTypeStages["new-home"][index];

              return (
              <article
                class={`gantt-row gantt-row-${item.tone} gantt-row-${item.scopeType}`}
                data-stage-id={item.id}
                data-stage-title={item.title}
                data-start-week={item.start}
                data-span-weeks={item.span}
                data-buffer-days={item.bufferDays}
                data-risk-level={item.riskLevel}
                data-old-house-start-week={item.start}
                data-old-house-span-weeks={item.span}
                data-old-house-buffer-days={item.bufferDays}
                data-old-house-risk-level={item.riskLevel}
                data-old-house-risk-label={item.riskLabel}
                data-old-house-risk-note={item.riskNote}
                data-old-house-duration-label={item.durationLabel}
                data-new-home-start-week={newHomeStage.start}
                data-new-home-span-weeks={newHomeStage.span}
                data-new-home-buffer-days={newHomeStage.bufferDays}
                data-new-home-risk-level={newHomeStage.riskLevel}
                data-new-home-risk-label={newHomeStage.riskLabel}
                data-new-home-risk-note={newHomeStage.riskNote}
                data-new-home-duration-label={newHomeStage.durationLabel}
              >
                <div class="gantt-stage">
                  <span class={`gantt-stage-number gantt-stage-number-${item.tone}`}>{item.stage}</span>
                  <div class="gantt-stage-body">
                    <div class="gantt-stage-topline">
                      <p class="gantt-stage-category">{item.category}</p>
                      <span class={`legend-badge legend-badge-${item.scopeType}`}>{item.scopeLabel}</span>
                    </div>
                    <h3>{item.title}</h3>
                    <p class="gantt-stage-summary">{item.summary}</p>
                    <div class="gantt-stage-meta">
                      <span class={`tone-pill tone-pill-${item.tone}`}>{item.toneLabel}</span>
                      <span class={`risk-pill risk-pill-${item.riskLevel}`} data-stage-risk-pill>{item.riskLabel}</span>
                      <span class="gantt-stage-duration" data-stage-duration>{item.durationLabel}</span>
                    </div>
