                    <p>前置條件</p>
                    <ul>
                      {item.prerequisites.map((condition) => <li>{condition}</li>)}
                    </ul>
                  </div>
                  <div class="gantt-detail-block">
                    <p>變動提醒</p>
                    <p class="gantt-risk-note" data-stage-risk-note>{item.riskNote}</p>
                  </div>
                  <div class="gantt-detail-block">
                    <p>常見產出</p>
                    <ul>
                      {item.outputs.map((output) => <li>{output}</li>)}
                    </ul>
                  </div>
                </div>
              </article>
