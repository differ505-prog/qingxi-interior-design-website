---
import EditorialArticleLayout from "../../components/blog/EditorialArticleLayout.astro";
import * as contentful from "contentful";
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";

// getStaticPaths 函數 - 告訴 Astro 有哪些路徑
export async function getStaticPaths() {
  // 檢查是否有 Contentful 配置
  if (
    !import.meta.env.CONTENTFUL_SPACE_ID ||
    !import.meta.env.CONTENTFUL_ACCESS_TOKEN
  ) {
    return []; // 沒有配置時返回空數組
  }

  try {
    const client = contentful.createClient({
      space: import.meta.env.CONTENTFUL_SPACE_ID,
      accessToken: import.meta.env.CONTENTFUL_ACCESS_TOKEN,
      environment: "master",
    });

    const response = await client.getEntries({
      content_type: "blogPost",
    });

    return response.items.map((item: any) => ({
      params: { slug: item.fields.slug },
    }));
  } catch (error) {
    console.error("Contentful 連接錯誤:", error);
    return []; // 連接失敗時返回空數組
  }
}

// 獲取 URL 參數
const { slug } = Astro.params;

// 檢查是否有 Contentful 配置
if (
  !import.meta.env.CONTENTFUL_SPACE_ID ||
  !import.meta.env.CONTENTFUL_ACCESS_TOKEN
) {
  return Astro.redirect("/blog");
}

// 連接 Contentful
const client = contentful.createClient({
  space: import.meta.env.CONTENTFUL_SPACE_ID,
  accessToken: import.meta.env.CONTENTFUL_ACCESS_TOKEN,
  environment: "master",
});

// 根據 slug 獲取文章
let response;
try {
  response = await client.getEntries({
    content_type: "blogPost",
    "fields.slug": slug,
    limit: 1,
  });
} catch (error) {
  console.error("Contentful 連接錯誤:", error);
  return Astro.redirect("/blog");
}

if (response.items.length === 0) {
  return Astro.redirect("/404");
}

const item = response.items[0];
const fields = item.fields as Record<string, any>;
const postTitle = String(fields.title ?? "");
const postSlug = String(fields.slug ?? slug ?? "");
const postDateSource = String(fields.date ?? "");
const postSummary = String(fields.summary ?? "");
const postCategory = String(fields.category ?? "");
const postContent = fields.content as any;
const coverImageUrl = fields.coverImage?.fields?.file?.url;

const post = {
  title: postTitle,
  slug: postSlug,
  date: new Date(postDateSource).toISOString().split("T")[0],
  summary: postSummary,
  category: postCategory,
  content: postContent,
  coverImage: coverImageUrl
    ? `https:${coverImageUrl}`
    : "https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=1200",
};

// 將 Rich Text 轉換為 HTML
const contentHtml = documentToHtmlString(post.content);
const publishedTime = new Date(postDateSource).toISOString();
const modifiedTime = item.sys?.updatedAt ? new Date(item.sys.updatedAt).toISOString() : publishedTime;
const articleStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: post.title,
    description: post.summary,
    image: [post.coverImage],
    datePublished: publishedTime,
    dateModified: modifiedTime,
    author: {
      "@type": "Organization",
      name: "青曦空間設計",
    },
    publisher: {
      "@type": "Organization",
      name: "青曦空間設計",
    },
    articleSection: post.category,
    mainEntityOfPage: `https://qingxidesign.tw/blog/${post.slug}`,
  },
];
---
<EditorialArticleLayout
  title={post.title}
  description={post.summary}
  ogImage={post.coverImage}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  structuredData={articleStructuredData}
  category={post.category}
  dateLabel={post.date}
  htmlContent={contentHtml}
/>
