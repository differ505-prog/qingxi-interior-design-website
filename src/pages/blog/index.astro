---
import BaseLayout from "../../layouts/BaseLayout.astro";
import * as contentful from "contentful";
import {
  type BlogCatalogPost,
  mapContentfulBlogPosts,
  mergeBlogPosts,
  staticBlogPosts,
} from "../../lib/blog-catalog";
import { bookshelfTracks } from "../../lib/content-taxonomy";

// 獲取所有文章（帶錯誤處理）
let posts: BlogCatalogPost[] = [];
let errorMessage = "";

try {
  // 連接 Contentful（恢復原來的邏輯，不檢查環境變數是否存在）
  const client = contentful.createClient({
    space: import.meta.env.CONTENTFUL_SPACE_ID,
    accessToken: import.meta.env.CONTENTFUL_ACCESS_TOKEN,
    environment: "master",
  });

  // 獲取所有文章
  const response = await client.getEntries({
    content_type: "blogPost",
    order: ["-fields.date"],
  });

  posts = mapContentfulBlogPosts(response.items);
} catch (error: any) {
  console.error("Contentful 連接錯誤:", error);
  console.error(
    "CONTENTFUL_SPACE_ID:",
    import.meta.env.CONTENTFUL_SPACE_ID ? "已設置" : "未設置",
  );
  console.error(
    "CONTENTFUL_ACCESS_TOKEN:",
    import.meta.env.CONTENTFUL_ACCESS_TOKEN ? "已設置" : "未設置",
  );

  // 如果沒有配置或連接失敗，顯示友好提示
  if (error.message && error.message.includes("Expected parameter")) {
    errorMessage =
      "缺少 Contentful 配置。請在 .env 文件中設置 CONTENTFUL_SPACE_ID 和 CONTENTFUL_ACCESS_TOKEN。如果配置在 Vercel 上，請複製到本地 .env 文件。";
  } else {
    errorMessage = `連接 Contentful 時發生錯誤: ${error.message || "未知錯誤"}`;
  }
  // 如果連接失敗，posts 保持為空數組
}

const mergedPosts = mergeBlogPosts([...posts, ...staticBlogPosts]);
const blogTrackFilters = bookshelfTracks;
---

<style>
  .blog-page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 4.5rem 1.5rem 5rem;
  }

  .blog-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 360px);
    gap: 2rem;
    align-items: end;
    margin-bottom: 3rem;
  }

  .hero-eyebrow,
  .panel-label {
    margin: 0 0 0.9rem;
    color: var(--tiffany-dark);
    font-size: 0.82rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .blog-hero h1 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(2.4rem, 4vw, 4rem);
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: 0.05em;
    color: var(--gray-darkest);
  }

  .hero-description {
    margin: 1.2rem 0 0;
    max-width: 44rem;
    color: var(--gray-medium);
    line-height: 1.95;
    font-size: 1.03rem;
  }

  .blog-panel {
    padding: 1.6rem;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(128, 146, 142, 0.05), transparent 30%),
      linear-gradient(135deg, rgba(31, 31, 31, 1) 0%, rgba(47, 47, 47, 1) 100%);
    color: var(--white);
    box-shadow: 0 26px 60px rgba(17, 17, 17, 0.16);
  }

  .blog-panel .panel-label {
    color: rgba(255, 255, 255, 0.62);
  }

  .blog-panel p {
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.8;
  }

  .blog-panel strong {
    display: block;
    margin-top: 1rem;
    font-size: 1.2rem;
    font-weight: 500;
    font-family: "Noto Serif TC", serif;
  }

  .category-filters {
    display: flex;
    gap: 0.75rem;
    margin: 1.5rem 0 0;
    flex-wrap: wrap;
  }

  .blog-library {
    padding: 2rem;
    border-radius: 32px;
    background:
      radial-gradient(circle at top right, rgba(128, 146, 142, 0.06), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(246, 249, 249, 0.96));
    border: 1px solid rgba(108, 120, 118, 0.14);
    box-shadow: 0 24px 55px rgba(47, 47, 47, 0.05);
  }

  .library-header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1.5rem;
    margin-bottom: 2.4rem;
    padding-bottom: 1.4rem;
    border-bottom: 1px solid rgba(108, 120, 118, 0.18);
  }

  .library-kicker {
    margin: 0 0 0.85rem;
    color: var(--tiffany-dark);
    font-size: 0.78rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .library-title {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(1.8rem, 2.8vw, 2.5rem);
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0.03em;
    color: var(--gray-darkest);
  }

  .library-description {
    margin: 0.75rem 0 0;
    max-width: 40rem;
    color: var(--gray-medium);
    line-height: 1.9;
  }

  .library-count {
    margin: 0;
    color: var(--gray-light);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .category-btn {
    padding: 0.65rem 1.15rem;
    border: 1px solid rgba(108, 120, 118, 0.18);
    background: rgba(255, 255, 255, 0.82);
    color: var(--gray-dark);
    border-radius: 999px;
    font-size: 0.92rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      transform 0.25s ease,
      background-color 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease,
      box-shadow 0.25s ease;
    box-shadow: 0 10px 20px rgba(47, 47, 47, 0.04);
  }

  .category-btn:hover {
    transform: translateY(-2px);
    background: var(--tiffany-pale);
    border-color: rgba(108, 120, 118, 0.4);
  }

  .category-btn.active {
    background: var(--gray-darkest);
    color: var(--white);
    border-color: var(--gray-darkest);
    box-shadow: 0 14px 24px rgba(47, 47, 47, 0.14);
  }

  .blog-list {
    display: grid;
    gap: 1.5rem;
  }

  .post-card {
    display: grid;
    grid-template-columns: minmax(260px, 0.95fr) minmax(0, 1.05fr);
    gap: 0;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 28px;
    border: 1px solid rgba(108, 120, 118, 0.14);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 22px 45px rgba(47, 47, 47, 0.05);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .post-card:hover {
    transform: translateY(-6px);
    border-color: rgba(108, 120, 118, 0.32);
    box-shadow: 0 30px 60px rgba(108, 120, 118, 0.12);
  }

  .post-image {
    position: relative;
    overflow: hidden;
    min-height: 260px;
    background: var(--gray-bg);
  }

  .post-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20, 20, 20, 0.04) 0%, rgba(20, 20, 20, 0.18) 100%);
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .post-card:hover .post-image img {
    transform: scale(1.05);
  }

  .post-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-category {
    display: inline-flex;
    width: fit-content;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(108, 120, 118, 0.12);
    color: var(--tiffany-dark);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    margin-bottom: 0.85rem;
  }

  .post-title {
    margin: 0;
    font-family: "Noto Serif TC", serif !important;
    font-size: clamp(1.55rem, 2.4vw, 2.15rem);
    font-weight: 500;
    color: var(--gray-darkest);
    line-height: 1.55;
    letter-spacing: 0.03em;
  }

  .post-taxonomy {
    margin: 0 0 0.95rem;
    color: var(--gray-light);
    font-size: 0.86rem;
    letter-spacing: 0.08em;
  }

  .post-summary {
    margin: 1rem 0 0;
    font-size: 1rem;
    color: var(--gray-medium);
    line-height: 1.9;
  }

  .post-link {
    margin-top: 1.35rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--tiffany-dark);
    letter-spacing: 0.08em;
  }

  .post-link::after {
    content: "→";
    transition: transform 0.25s ease;
  }

  .post-card:hover .post-link::after {
    transform: translateX(4px);
  }

  .empty-state {
    padding: 4rem 2rem;
    border-radius: 28px;
    text-align: center;
    color: var(--gray-medium);
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(108, 120, 118, 0.14);
    box-shadow: 0 18px 40px rgba(47, 47, 47, 0.04);
  }

  .empty-state strong {
    display: block;
    margin-bottom: 0.8rem;
    font-family: "Noto Serif TC", serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--gray-darkest);
  }

  .empty-state p {
    margin: 0.5rem 0 0;
    line-height: 1.8;
  }

  .blog-filter-empty[hidden] {
    display: none;
  }

  @media (max-width: 900px) {
    .blog-hero,
    .library-header,
    .post-card {
      grid-template-columns: 1fr;
    }

    .library-header {
      align-items: start;
    }
  }

  @media (max-width: 768px) {
    .blog-page {
      padding: 4rem 1.25rem 4.5rem;
    }

    .post-content,
    .blog-panel,
    .blog-library {
      padding: 1.5rem;
    }

    .post-image {
      min-height: 220px;
    }
  }
</style>

<BaseLayout
  title="知識分享 - 青曦空間設計"
  description="閱讀青曦空間設計的裝修與空間知識分享，包含插座定位、生活動線、工程思考與智能家居整合觀點。"
  ogImage="/images/blog/插座被沙發遮蓋住.png"
  pageType="collection"
>
  <section class="blog-page">
    <div class="blog-hero">
      <div>
        <p class="hero-eyebrow">KNOWLEDGE GUIDE</p>
        <h1>把裝修知識整理得更清楚、更好懂。</h1>
        <p class="hero-description">
          從老屋翻新、預售屋客變到格局動線與水電照明，青曦把裝修知識整理成可慢慢累積的書系內容，
          讓你在做決策之前，先找到自己正在面對的那一本。
        </p>
      </div>

      <aside class="blog-panel">
        <p class="panel-label">READING GUIDE</p>
        <p>先依主書系整理，再往下延伸章節與標籤，讓每篇文章都能回到同一套知識骨架。</p>
        <strong>{mergedPosts.length} 篇文章持續整理中</strong>
      </aside>
    </div>

    <section class="blog-library">
      <div class="library-header">
        <div>
          <p class="library-kicker">Editorial Archive</p>
          <h2 class="library-title">以設計判斷為核心，整理可慢慢閱讀的裝修知識。</h2>
          <p class="library-description">
            內容先依主書系分流，再透過章節定位與標籤往下細分，讓零散問題也能被放回完整的知識地圖。
          </p>
        </div>
        <p class="library-count">{mergedPosts.length} articles</p>
      </div>

      <div class="category-filters">
        <button class="category-btn active" data-track="全部">全部</button>
        {blogTrackFilters.map((track) => (
          <button class="category-btn" data-track={track.title}>{track.title}</button>
        ))}
      </div>

      <div class="blog-list">
        {
          mergedPosts.length > 0 ? (
            <>
              {mergedPosts.map((post) => (
                <a
                  href={`/blog/${post.slug}`}
                  class="post-card"
                  data-post-track={post.track}
                >
                  <div class="post-image">
                    <img src={post.coverImage} alt={post.title} />
                  </div>
                  <div class="post-content">
                    <span class="post-category">{post.track}</span>
                    <p class="post-taxonomy">{post.chapter} / {post.siteCategory}</p>
                    <h2 class="post-title">{post.title}</h2>
                    <p class="post-summary">{post.summary}</p>
                    <span class="post-link">閱讀文章</span>
                  </div>
                </a>
              ))}
              <div class="empty-state blog-filter-empty" hidden>
                <strong>這個主書系還在整理中</strong>
                <p>目前這一書系尚未上線文章，之後會沿著既定章節陸續補齊。</p>
              </div>
            </>
          ) : (
            <div class="empty-state">
              <strong>知識內容正在整理中</strong>
              {errorMessage ? (
                <>
                  <p>{errorMessage}</p>
                  <p>請檢查 `.env` 文件或部署環境中的 Contentful 設定。</p>
                </>
              ) : (
                <>
                  <p>請在 `.env` 中配置 Contentful 環境變數以連接內容管理系統。</p>
                  <p>需要設置：`CONTENTFUL_SPACE_ID` 與 `CONTENTFUL_ACCESS_TOKEN`。</p>
                </>
              )}
            </div>
          )
        }
      </div>
    </section>
  </section>

  <script>
    const categoryButtons =
      document.querySelectorAll<HTMLButtonElement>(".category-btn");
    const postCards = document.querySelectorAll<HTMLElement>(".post-card");
    const emptyState = document.querySelector<HTMLElement>(".blog-filter-empty");

    function updateTrackFilter(selectedTrack: string) {
      let visibleCount = 0;

      postCards.forEach((card) => {
        const postTrack = card.dataset.postTrack;

        if (
          selectedTrack === "全部" ||
          postTrack === selectedTrack
        ) {
          card.style.display = "flex";
          visibleCount += 1;
        } else {
          card.style.display = "none";
        }
      });

      if (emptyState) {
        emptyState.hidden = visibleCount > 0 || selectedTrack === "全部";
      }
    }

    categoryButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const selectedTrack = button.dataset.track;

        categoryButtons.forEach((btn) => btn.classList.remove("active"));
        button.classList.add("active");
        updateTrackFilter(selectedTrack || "全部");
      });
    });
  </script>
</BaseLayout>
