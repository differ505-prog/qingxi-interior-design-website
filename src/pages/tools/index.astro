<script>
  // @ts-nocheck
  // Calculator logic
  const estimatorConfig = JSON.parse(
    document.getElementById("estimator-config")?.textContent || "{}",
  );
  const renovationItems = JSON.parse(
    document.getElementById("renovation-items")?.textContent || "[]",
  );
  const areaInput = document.getElementById("area") as HTMLInputElement;
  const projectType = document.getElementById(
    "project-type",
  ) as HTMLSelectElement;
  const qualityLevel = document.getElementById(
    "quality-level",
  ) as HTMLSelectElement;
  const houseCondition = document.getElementById(
    "house-condition",
  ) as HTMLSelectElement;
  const residenceType = document.getElementById(
    "residence-type",
  ) as HTMLSelectElement;
  const marketBenchmark = document.getElementById(
    "market-benchmark",
  ) as HTMLSelectElement;
  const usePurpose = document.getElementById(
    "use-purpose",
  ) as HTMLSelectElement;
  const timeline = document.getElementById(
    "timeline",
  ) as HTMLSelectElement;
  const bathroomCount = document.getElementById(
    "bathroom-count",
  ) as HTMLSelectElement;
  const utilityScope = document.getElementById(
    "utility-scope",
  ) as HTMLSelectElement;
  const storageKitchenGroup = document.getElementById(
    "storage-kitchen-group",
  ) as HTMLDivElement | null;
  const storageKitchenScope = document.getElementById(
    "storage-kitchen-scope",
  ) as HTMLSelectElement;
  const selectedItems = Array.from(
    document.querySelectorAll('.checkbox-item input[type="checkbox"]'),
  ) as HTMLInputElement[];
  const recommendedTotal = document.getElementById("recommended-total");
  const totalPrice = document.getElementById("total-price");
  const designFee = document.getElementById("design-fee");
  const constructionFee = document.getElementById("construction-fee");
  const reserveBudget = document.getElementById("reserve-budget");
  const perPingRange = document.getElementById("per-ping-range");
  const scopeSummary = document.getElementById("scope-summary");
  const resultSubtitle = document.getElementById("result-subtitle");
  const logicSummary = document.getElementById("logic-summary");
  const costDriverSummary = document.getElementById("cost-driver-summary");
  const marketBenchmarkSummary = document.getElementById("market-benchmark-summary");
  const changeSummary = document.getElementById("change-summary");
  const breakdownNote = document.getElementById("breakdown-note");
  const breakdownList = document.getElementById("breakdown-list");
  const adviceList = document.getElementById("advice-list");
  const nextStepIntro = document.getElementById("next-step-intro");
  const nextStepPoints = document.getElementById("next-step-points");
  const reportContext = document.getElementById("report-context");
  const estimatorHandoffTitle = document.getElementById("estimator-handoff-title");
  const estimatorHandoffDescription = document.getElementById("estimator-handoff-description");
  const estimatorHandoffPointTitle = document.getElementById("estimator-handoff-point-title");
  const estimatorHandoffPointDescription = document.getElementById("estimator-handoff-point-description");
  const requirementFormLinks = Array.from(
    document.querySelectorAll('[data-estimator-cta="requirement-form"]'),
  );
  const estimatorLeadForm = document.getElementById(
    "estimator-lead-form",
  ) as HTMLFormElement | null;
  const estimatorLeadIntent = document.getElementById(
    "estimator-lead-intent",
  ) as HTMLInputElement | null;
  const estimatorSummaryInput = document.getElementById(
    "estimator-summary-input",
  ) as HTMLInputElement | null;
  const estimatorLeadFocus = document.getElementById(
    "estimator-lead-focus",
  ) as HTMLTextAreaElement | null;
  const estimatorUtmSource = document.getElementById(
    "estimator-utm-source",
  ) as HTMLInputElement | null;
  const estimatorUtmMedium = document.getElementById(
    "estimator-utm-medium",
  ) as HTMLInputElement | null;
  const estimatorUtmCampaign = document.getElementById(
    "estimator-utm-campaign",
  ) as HTMLInputElement | null;
  const estimatorUtmTerm = document.getElementById(
    "estimator-utm-term",
  ) as HTMLInputElement | null;
  const estimatorUtmContent = document.getElementById(
    "estimator-utm-content",
  ) as HTMLInputElement | null;
  const estimatorLandingPage = document.getElementById(
    "estimator-landing-page",
  ) as HTMLInputElement | null;
  const estimatorPageReferrer = document.getElementById(
    "estimator-page-referrer",
  ) as HTMLInputElement | null;
  const estimatorCtaLinks = Array.from(
    document.querySelectorAll("[data-estimator-cta]"),
  );

  const projectTypeMeta = {
    full: {
      label: "全屋裝修",
      constructionMultiplier: estimatorConfig.projectTypeMultipliers?.full ?? 1,
      designMultiplier: 1,
      baseScopeFactor: 0.62,
      variableScopeFactor: 0.38,
    },
    partial: {
      label: "局部裝修",
      constructionMultiplier: estimatorConfig.projectTypeMultipliers?.partial ?? 0.6,
      designMultiplier: 0.65,
      baseScopeFactor: 0.18,
      variableScopeFactor: 0.82,
    },
    "design-only": {
      label: "純設計",
      constructionMultiplier: 0,
      designMultiplier: 1,
      baseScopeFactor: 0,
      variableScopeFactor: 0,
    },
  };

  const houseConditionMeta = {
    new: { label: "新成屋 / 屋況佳", multiplier: 0.92 },
    standard: { label: "中古屋 / 一般整理", multiplier: 1 },
    old: { label: "老屋翻新", multiplier: 1.18 },
    rough: { label: "毛胚屋 / 大幅改造", multiplier: 1.28 },
  };

  const residenceTypeMeta = {
    tower: { label: "電梯大樓", multiplier: 1 },
    walkup: { label: "公寓 / 華廈", multiplier: 1.06 },
    townhouse: { label: "透天 / 樓中樓", multiplier: 1.12 },
  };

  const marketBenchmarkMeta = {
    "taipei-metro": {
      label: "北北基住宅市場",
      constructionMultiplier: 1.06,
      designMultiplier: 1.08,
      summary:
        "目前以北北基住宅裝修前期行情帶校準，會比全台都會中位帶略高一些，較貼近雙北住宅常見報價節奏。",
    },
    "urban-taiwan": {
      label: "全台都會住宅中位帶",
      constructionMultiplier: 1,
      designMultiplier: 1,
      summary:
        "目前以全台都會住宅常見中位行情帶校準，適合先抓較通用的前期估價範圍。",
    },
    "central-south": {
      label: "中南部都會住宅帶",
      constructionMultiplier: 0.94,
      designMultiplier: 0.95,
      summary:
        "目前以中南部都會住宅帶校準，會比雙北市場帶更收斂一些，適合先抓在地較常見的前期預算。",
    },
  };

  const usePurposeMeta = {
    self: { label: "自住", multiplier: 1.02 },
    family: { label: "家庭長住", multiplier: 1.05 },
    rental: { label: "出租 / 轉售整理", multiplier: 0.9 },
  };

  const timelineMeta = {
    flexible: { label: "半年以上，可彈性安排", multiplier: 1, reserve: 1 },
    planned: { label: "三到六個月內，希望開始", multiplier: 1.02, reserve: 1.05 },
    urgent: { label: "三個月內，希望盡快進場", multiplier: 1.08, reserve: 1.15 },
  };

  const bathroomCountMeta = {
    1: { label: "1 間衛浴", multiplier: 1 },
    2: { label: "2 間衛浴", multiplier: 1.06 },
    "3plus": { label: "3 間以上衛浴", multiplier: 1.12 },
  };

  const utilityScopeMeta = {
    none: { label: "不重拉水電", multiplier: 1, reserve: 1 },
    partial: { label: "局部調整 / 局部換新", multiplier: 1.08, reserve: 1.04 },
    full: { label: "全室重拉水電", multiplier: 1.16, reserve: 1.12 },
  };

  const storageKitchenScopeMeta = {
    none: { label: "先不另外放大系統櫃 / 廚具預算" },
    storage: { label: "已知會做系統櫃" },
    kitchen: { label: "已知會更新廚具" },
    both: { label: "系統櫃與廚具都會做" },
  };

  function formatRange(min, max) {
    return `${min}萬 - ${max}萬`;
  }

  function getStorageKitchenMultiplier(scopeValue, selectedConfigs) {
    const hasKitchen = selectedConfigs.some((item) => item.value === "kitchen");
    const hasFurniture = selectedConfigs.some((item) => item.value === "furniture");

    switch (scopeValue) {
      case "storage":
        return hasFurniture ? 1.06 : 1.03;
      case "kitchen":
        return hasKitchen ? 1.07 : 1.03;
      case "both":
        if (hasKitchen && hasFurniture) return 1.12;
        if (hasKitchen || hasFurniture) return 1.08;
        return 1.04;
      default:
        return 1;
    }
  }

  function saveEstimateSnapshot(snapshot) {
    try {
      window.sessionStorage.setItem(
        "renovationEstimateSnapshot",
        JSON.stringify(snapshot),
      );
    } catch (error) {
      console.warn("Unable to persist renovation estimate snapshot.", error);
    }
  }

  function fillEstimatorLeadAttribution() {
    const searchParams = new URLSearchParams(window.location.search);

    if (estimatorUtmSource) estimatorUtmSource.value = searchParams.get("utm_source") || "";
    if (estimatorUtmMedium) estimatorUtmMedium.value = searchParams.get("utm_medium") || "";
    if (estimatorUtmCampaign) estimatorUtmCampaign.value = searchParams.get("utm_campaign") || "";
    if (estimatorUtmTerm) estimatorUtmTerm.value = searchParams.get("utm_term") || "";
    if (estimatorUtmContent) estimatorUtmContent.value = searchParams.get("utm_content") || "";
    if (estimatorLandingPage) estimatorLandingPage.value = window.location.href;
    if (estimatorPageReferrer) estimatorPageReferrer.value = document.referrer || "";
  }

  let lastTrackedSignature = "";
  let lastChangeReason = "";
  let previousEstimateState = null;

  function toggleStorageKitchenField(selectedConfigs) {
    const shouldShow = selectedConfigs.some(
      (item) => item.value === "kitchen" || item.value === "furniture",
    );
    if (storageKitchenGroup) {
      storageKitchenGroup.hidden = !shouldShow;
    }
    if (!shouldShow && storageKitchenScope.value !== "none") {
      storageKitchenScope.value = "none";
    }
    return shouldShow;
  }

  function buildCostDrivers({
    qualityLabel,
    conditionMeta,
    residenceMeta,
    marketInfo,
    timelineInfo,
    utilityInfo,
    bathroomInfo,
    storageKitchenInfo,
    selectedConfigs,
    bathroomMultiplier,
    storageKitchenMultiplier,
    projectMeta,
  }) {
    const drivers = [];

    if (qualityLevel.value === "premium" || qualityLevel.value === "luxury") {
      drivers.push(`${qualityLabel} 單價帶較高`);
    }
    if (conditionMeta.multiplier > 1) {
      drivers.push(`${conditionMeta.label} 需要較多基礎工程`);
    }
    if (utilityInfo.multiplier > 1) {
      drivers.push(`${utilityInfo.label} 會拉高水電與預備金`);
    }
    if (bathroomMultiplier > 1 && selectedConfigs.some((item) => item.value === "bathroom")) {
      drivers.push(`${bathroomInfo.label} 會增加衛浴相關工程`);
    }
    if (storageKitchenMultiplier > 1 && storageKitchenInfo.label) {
      drivers.push(`${storageKitchenInfo.label} 會放大櫃體或廚具預算`);
    }
    if (residenceMeta.multiplier > 1) {
      drivers.push(`${residenceMeta.label} 的施工條件較複雜`);
    }
    if (marketInfo.constructionMultiplier > 1) {
      drivers.push(`${marketInfo.label} 本身的市場帶較高`);
    }
    if (timelineInfo.multiplier > 1) {
      drivers.push(`${timelineInfo.label} 會提高時程壓力`);
    }
    if (projectMeta.label === "全屋裝修") {
      drivers.push("全屋裝修本身包含較完整的基礎底盤");
    }

    return drivers.slice(0, 4);
  }

  function buildChangeSummary({
    hasValidScope,
    minRecommendedTotal,
    costDrivers,
  }) {
    if (!hasValidScope) {
      return "請先勾選至少 1 項裝修項目，系統才會建立有效估價。";
    }

    if (!previousEstimateState) {
      return costDrivers.length
        ? `目前主要由 ${costDrivers.slice(0, 2).join("、")} 影響這次估價。`
        : "目前條件已套入，接著可再微調工項與高影響因子。";
    }

    const delta = minRecommendedTotal - previousEstimateState.minRecommendedTotal;
    const absDelta = Math.abs(delta);

    if (!absDelta) {
      return lastChangeReason
        ? `你剛調整了「${lastChangeReason}」，但目前仍落在同一個預算帶。`
        : "目前條件變動不大，整體預算帶維持不變。";
    }

    const direction = delta > 0 ? "上升" : "下降";
    const reasonPrefix = lastChangeReason ? `你剛調整了「${lastChangeReason}」，` : "";
    const topDriver = costDrivers[0] ? `主因多半是 ${costDrivers[0]}。` : "";

    return `${reasonPrefix}這次建議準備總預算約${direction} ${absDelta} 萬起。${topDriver}`;
  }

  function calculate() {
    const area = Math.min(200, Math.max(1, parseFloat(areaInput.value) || 30));
    const pricePerPing =
      estimatorConfig.qualityLevels?.[qualityLevel.value] ||
      estimatorConfig.qualityLevels?.standard || { min: 6, max: 10 };
    const designFeePerPing = estimatorConfig.designFeePerPing || {
      min: 0.6,
      max: 1,
    };
    const selected = selectedItems.filter((item) => item.checked);
    const selectedConfigs = renovationItems.filter((item) =>
      selected.some((selectedItem) => selectedItem.value === item.value),
    );
    const projectMeta =
      projectTypeMeta[projectType.value as keyof typeof projectTypeMeta] ||
      projectTypeMeta.full;
    const conditionMeta =
      houseConditionMeta[houseCondition.value as keyof typeof houseConditionMeta] ||
      houseConditionMeta.standard;
    const residenceMeta =
      residenceTypeMeta[residenceType.value as keyof typeof residenceTypeMeta] ||
      residenceTypeMeta.tower;
    const marketInfo =
      marketBenchmarkMeta[marketBenchmark.value as keyof typeof marketBenchmarkMeta] ||
      marketBenchmarkMeta["taipei-metro"];
    const usePurposeInfo =
      usePurposeMeta[usePurpose.value as keyof typeof usePurposeMeta] ||
      usePurposeMeta.self;
    const timelineInfo =
      timelineMeta[timeline.value as keyof typeof timelineMeta] ||
      timelineMeta.planned;
    const bathroomInfo =
      bathroomCountMeta[bathroomCount.value as keyof typeof bathroomCountMeta] ||
      bathroomCountMeta[2];
    const utilityInfo =
      utilityScopeMeta[utilityScope.value as keyof typeof utilityScopeMeta] ||
      utilityScopeMeta.partial;
    const shouldShowStorageKitchen = toggleStorageKitchenField(selectedConfigs);
    const storageKitchenInfo =
      storageKitchenScopeMeta[
        (shouldShowStorageKitchen ? storageKitchenScope.value : "none") as keyof typeof storageKitchenScopeMeta
      ] || storageKitchenScopeMeta.none;
    const totalWeight = renovationItems.reduce(
      (sum, item) => sum + item.weight,
      0,
    );
    const selectedWeight = selectedConfigs.reduce(
      (sum, item) => sum + item.weight,
      0,
    );
    const hasSelectedItems = selectedConfigs.length > 0;
    const hasValidScope =
      projectType.value === "design-only" ? true : hasSelectedItems;
    const selectedScopeRatio = selectedWeight / totalWeight || 0;
    const scopeFactor =
      projectType.value === "design-only"
        ? 0
        : projectMeta.baseScopeFactor +
          projectMeta.variableScopeFactor * selectedScopeRatio;
    const bathroomMultiplier = selectedConfigs.some((item) => item.value === "bathroom")
      ? bathroomInfo.multiplier
      : 1;
    const storageKitchenMultiplier =
      projectType.value === "design-only"
        ? 1
        : getStorageKitchenMultiplier(
            shouldShowStorageKitchen ? storageKitchenScope.value : "none",
            selectedConfigs,
          );

    const minConstruction =
      projectType.value === "design-only"
        ? 0
        : Math.round(
            area *
              pricePerPing.min *
              marketInfo.constructionMultiplier *
              projectMeta.constructionMultiplier *
              conditionMeta.multiplier *
              residenceMeta.multiplier *
              usePurposeInfo.multiplier *
              timelineInfo.multiplier *
              bathroomMultiplier *
              utilityInfo.multiplier *
              storageKitchenMultiplier *
              scopeFactor,
          );
    const maxConstruction =
      projectType.value === "design-only"
        ? 0
        : Math.round(
            area *
              pricePerPing.max *
              marketInfo.constructionMultiplier *
              projectMeta.constructionMultiplier *
              conditionMeta.multiplier *
              residenceMeta.multiplier *
              usePurposeInfo.multiplier *
              timelineInfo.multiplier *
              bathroomMultiplier *
              utilityInfo.multiplier *
              storageKitchenMultiplier *
              scopeFactor,
          );

    const minDesign = Math.round(
      area * designFeePerPing.min * projectMeta.designMultiplier * marketInfo.designMultiplier,
    );
    const maxDesign = Math.round(
      area * designFeePerPing.max * projectMeta.designMultiplier * marketInfo.designMultiplier,
    );

    const minReserve =
      projectType.value === "design-only"
        ? 0
        : Math.round(
            minConstruction *
              (conditionMeta.multiplier > 1 ? 0.1 : 0.06) *
              timelineInfo.reserve *
              utilityInfo.reserve *
              (bathroomMultiplier > 1 ? 1.03 : 1),
          );
    const maxReserve =
      projectType.value === "design-only"
        ? 0
        : Math.round(
            maxConstruction *
              (conditionMeta.multiplier > 1 ? 0.14 : 0.08) *
              timelineInfo.reserve *
              utilityInfo.reserve *
              (bathroomMultiplier > 1 ? 1.05 : 1),
          );

    const minTotal = minConstruction + minDesign;
    const maxTotal = maxConstruction + maxDesign;
    const minRecommendedTotal = minTotal + minReserve;
    const maxRecommendedTotal = maxTotal + maxReserve;
    const minPerPing = (minTotal / area).toFixed(1);
    const maxPerPing = (maxTotal / area).toFixed(1);
    const qualityLabel =
      qualityLevel.options[qualityLevel.selectedIndex]?.textContent || "";
    const costDrivers = buildCostDrivers({
      qualityLabel,
      conditionMeta,
      residenceMeta,
      marketInfo,
      timelineInfo,
      utilityInfo,
      bathroomInfo,
      storageKitchenInfo,
      selectedConfigs,
      bathroomMultiplier,
      storageKitchenMultiplier,
      projectMeta,
    });
    const dynamicChangeSummary = buildChangeSummary({
      hasValidScope,
      minRecommendedTotal,
      costDrivers,
    });
    const breakdownItems =
      projectType.value === "design-only"
        ? [
            {
              label: "設計規劃",
              description: "依坪數與設計深度估算，尚未包含實際工程發包與選材差異。",
              min: minDesign,
              max: maxDesign,
            },
          ]
        : selectedConfigs.map((item) => {
            const share = item.weight / (selectedWeight || 1);
            return {
              label: item.label,
              description: item.description,
              min: Math.round(minConstruction * share),
              max: Math.round(maxConstruction * share),
            };
          });
    const trackingSignature = JSON.stringify({
      area,
      projectType: projectType.value,
      qualityLevel: qualityLevel.value,
      houseCondition: houseCondition.value,
      residenceType: residenceType.value,
      marketBenchmark: marketBenchmark.value,
      usePurpose: usePurpose.value,
      timeline: timeline.value,
      bathroomCount: bathroomCount.value,
      utilityScope: utilityScope.value,
      storageKitchenScope: storageKitchenScope.value,
      selectedItems: selectedConfigs.map((item) => item.value),
    });

    if (
      recommendedTotal &&
      totalPrice &&
      designFee &&
      constructionFee &&
      reserveBudget &&
      perPingRange &&
      scopeSummary &&
      resultSubtitle &&
      logicSummary &&
      costDriverSummary &&
      marketBenchmarkSummary &&
      changeSummary &&
      nextStepIntro &&
      reportContext &&
      breakdownNote
    ) {
      if (!hasValidScope) {
        recommendedTotal.textContent = "--";
        totalPrice.textContent = "--";
        designFee.textContent = "--";
        constructionFee.textContent = "--";
        reserveBudget.textContent = "--";
        perPingRange.textContent = "--";
        scopeSummary.textContent = `${projectMeta.label} / 尚未勾選工項 / ${residenceMeta.label}`;
        logicSummary.textContent = "請至少勾選 1 項裝修項目，估價結果才有參考意義。";
        costDriverSummary.textContent = "尚未形成有效估價條件，因此暫不整理高價因子。";
        marketBenchmarkSummary.textContent = `${marketInfo.label}：${marketInfo.summary}`;
        changeSummary.textContent = "先勾選至少 1 項裝修項目，系統才會開始解釋預算如何變動。";
        resultSubtitle.textContent = "目前未勾選任何裝修項目，因此不顯示正式預算帶，避免誤導。";
        nextStepIntro.textContent = "先勾選實際要做的項目，再看預算帶。";
        reportContext.textContent = "先確定至少一項實際裝修項目，後續的拆解報告與需求表判讀才會更準。";
        breakdownNote.textContent = "目前尚未形成有效工項範圍，因此先不提供工程比例拆解。";
      } else {
        recommendedTotal.textContent = formatRange(minRecommendedTotal, maxRecommendedTotal);
        totalPrice.textContent = formatRange(minTotal, maxTotal);
        designFee.textContent = formatRange(minDesign, maxDesign);
        constructionFee.textContent = formatRange(minConstruction, maxConstruction);
        reserveBudget.textContent = formatRange(minReserve, maxReserve);
        perPingRange.textContent = `每坪約 ${minPerPing}萬 - ${maxPerPing}萬`;
        scopeSummary.textContent = `${projectMeta.label} / ${selectedConfigs.length} 項工種 / ${residenceMeta.label}`;
        logicSummary.textContent =
          projectType.value === "design-only"
            ? `坪數 x 設計費單價 x 條件係數（${[projectMeta.label, marketInfo.label, conditionMeta.label, residenceMeta.label, usePurposeInfo.label, timelineInfo.label].join(" / ")}）`
            : `坪數 x 等級單價 x 條件係數（${[projectMeta.label, marketInfo.label, conditionMeta.label, residenceMeta.label, usePurposeInfo.label, timelineInfo.label, selectedConfigs.some((item) => item.value === "bathroom") ? bathroomInfo.label : null, utilityInfo.label, storageKitchenInfo.label].filter(Boolean).join(" / ")}）`;
        costDriverSummary.textContent = costDrivers.length
          ? `目前主要拉高預算的條件：${costDrivers.join("、")}。`
          : "目前條件相對單純，估價主要由坪數、等級單價與基本工項組成。";
        marketBenchmarkSummary.textContent = `${marketInfo.label}：${marketInfo.summary}`;
        changeSummary.textContent = dynamicChangeSummary;
        resultSubtitle.textContent =
          projectType.value === "design-only"
            ? "目前以設計規劃費為主，工程費用需依圖面、工法與發包範圍另行確認。"
            : projectType.value === "full" &&
                selectedScopeRatio < 0.7
              ? "全屋裝修仍保留基礎工程底盤，但工項勾選越多，估算會越接近完整裝修規模。"
              : "依目前輸入條件，先整理出適合討論的預算帶、主要工項與建議預備金。";
        nextStepIntro.textContent =
          projectType.value === "design-only"
            ? "你現在更接近設計規劃前期。"
            : "你現在已經有可討論的預算帶。";
        reportContext.textContent =
          projectType.value === "design-only"
            ? `目前較適合先整理 ${projectMeta.label} 的需求重點與設計深度，再進一步確認交付方向。`
            : `目前這組 ${projectMeta.label} / ${residenceMeta.label} 條件，可先用拆解報告判讀 ${formatRange(minTotal, maxTotal)} 的主要預算落點。`;
        breakdownNote.textContent =
          projectType.value === "design-only"
            ? "目前為設計規劃費試算，尚未進入工程比例拆解。"
            : "目前為前期比例拆解，先依勾選工項與權重估出落點；實際報價仍會再看尺寸、材質、點位與現場條件。";
      }
    }

    if (
      estimatorHandoffTitle &&
      estimatorHandoffDescription &&
      estimatorHandoffPointTitle &&
      estimatorHandoffPointDescription
    ) {
      if (projectType.value === "design-only") {
        estimatorHandoffTitle.textContent = "下一步：把這次空間方向整理成可討論的設計需求";
        estimatorHandoffDescription.textContent =
          "把需求、空間痛點與參考風格補進需求表，第一次討論就能更快對齊生活畫面與設計深度。";
        estimatorHandoffPointTitle.textContent = "先把方向說清楚";
        estimatorHandoffPointDescription.textContent =
          "你只需要先整理想像中的生活感、參考圖與期待交付，青曦就能順著這份初步方向往下接。";
      } else {
        estimatorHandoffTitle.textContent = "下一步：把這份初估延伸成完整空間需求";
        estimatorHandoffDescription.textContent =
          "再補需求、照片與時程，青曦就能更快把預算帶、空間條件與後續方向一起判讀。";
        estimatorHandoffPointTitle.textContent = "先把條件接續下去";
        estimatorHandoffPointDescription.textContent =
          "如果你已經抓到大致預算方向，現在最有效率的做法就是直接把需求與現場資訊補完整。";
      }
    }

    const adviceItems = [];
    if (!hasValidScope) {
      adviceItems.push("目前沒有勾選任何裝修項目，因此系統不提供正式預算，避免把基礎底盤誤認成實際報價。");
      adviceItems.push("先勾選至少 1 項實際要做的工程，例如衛浴、廚房、地板或系統家具，估價結果才有參考價值。");
    } else {
      if (conditionMeta.multiplier >= 1.18) {
        adviceItems.push("屋況偏複雜，建議預留較高比例的拆除、基礎工程與預備金。");
      } else {
        adviceItems.push("屋況相對單純，較適合先把預算重點放在機能、材質與收納整合。");
      }

      if (utilityScope.value === "full") {
        adviceItems.push("這次估算已把全室重拉水電算進去，若現場原始管線老舊，實際費用通常會更接近區間上緣。");
      } else if (utilityScope.value === "partial") {
        adviceItems.push("目前以局部水電調整估算，若後續確認要全室重拉，總價通常會再上修。");
      }

      if (projectType.value === "full" && selectedScopeRatio < 0.7) {
        adviceItems.push("你目前選的是全屋裝修，因此估算仍保留基礎工程底盤；但每次增減工項，總價都會同步調整，不會再完全卡住。");
      }

      if (
        selectedConfigs.some((item) => item.value === "bathroom") &&
        bathroomCount.value !== "1"
      ) {
        adviceItems.push(`這次已把 ${bathroomInfo.label} 的條件納入，衛浴數量越多，泥作、防水、設備與收邊費用通常越明顯。`);
      }

      if (usePurpose.value === "rental") {
        adviceItems.push("若以出租或轉售為主，建議優先聚焦耐用、易維護與高感知更新項目。");
      } else {
        adviceItems.push("若以自住為主，可優先盤點真正影響日常使用的動線、收納與生活情境。");
      }

      if (timeline.value === "urgent") {
        adviceItems.push("預計時程較趕，建議盡快整理現場照片、尺寸與交屋時間，避免後續排程壓縮。");
      } else {
        adviceItems.push("時程仍有彈性，可先把需求表填完整，讓設計討論更聚焦也更容易抓準預算。");
      }
    }

    const compactAdviceItems =
      !hasValidScope
        ? adviceItems
        : projectType.value === "design-only"
          ? adviceItems.slice(0, 2)
          : [adviceItems[0], adviceItems[2] || adviceItems[1]].filter(Boolean);

    if (adviceList) {
      adviceList.innerHTML = compactAdviceItems.map((item) => `<li>${item}</li>`).join("");
    }

    if (nextStepPoints) {
      const stepItem =
        !hasValidScope
          ? {
              title: "先勾選至少 1 項裝修項目",
              description: "先把這次實際要做的工程圈出來，系統才會顯示有參考價值的預算帶。",
            }
          : projectType.value === "design-only"
          ? {
              title: "先整理需求與參考圖",
              description: "把需求、風格與空間痛點帶進需求表，第一次設計討論會更容易對焦。",
            }
          : {
              title: "帶著估價摘要填需求表",
              description: "你現在的試算會一起帶進需求表，再補照片與時程就能直接往下討論。",
            };

      nextStepPoints.innerHTML = `
        <div class="next-step-item">
          <strong>${stepItem.title}</strong>
          <span>${stepItem.description}</span>
        </div>
      `;
    }

    if (estimatorLeadIntent) {
      estimatorLeadIntent.value =
        projectType.value === "design-only"
          ? "design-planning-report"
          : "budget-breakdown-report";
    }

    const estimatorSummaryText = [
      `估價摘要：${hasValidScope ? formatRange(minTotal, maxTotal) : "尚未形成有效估價"}`,
      `每坪抓法：${hasValidScope ? `每坪約 ${minPerPing}萬 - ${maxPerPing}萬` : "--"}`,
      `專案條件：${[projectMeta.label, qualityLevel.options[qualityLevel.selectedIndex]?.textContent, conditionMeta.label, residenceMeta.label, marketInfo.label].filter(Boolean).join(" / ")}`,
      `高影響因子：${[selectedConfigs.some((item) => item.value === "bathroom") ? bathroomInfo.label : null, utilityInfo.label, storageKitchenInfo.label].filter(Boolean).join(" / ")}`,
      `使用目的 / 時程：${[usePurposeInfo.label, timelineInfo.label].filter(Boolean).join(" / ")}`,
      `工項：${selectedConfigs.length ? selectedConfigs.map((item) => item.label).join("、") : "尚未勾選"}`,
    ].join(" ｜ ");

    if (estimatorSummaryInput) {
      estimatorSummaryInput.value = estimatorSummaryText;
    }

    const defaultLeadFocus =
      projectType.value === "design-only"
        ? `我想先索取這次設計規劃的初步判讀，目前估價結果約為 ${formatRange(minTotal, maxTotal)}，想進一步了解空間方向、設計深度與下一步建議。`
        : !hasValidScope
          ? "我目前還在整理實際裝修範圍，想先確認哪些工項與條件最該先釐清，才能得到更有參考價值的前期估價。"
        : `我想索取這次估價的費用拆解判讀，目前估價結果約為 ${formatRange(minTotal, maxTotal)}，想先了解主要預算落點、影響比例與是否適合安排後續諮詢。`;

    if (
      estimatorLeadFocus &&
      (!estimatorLeadFocus.value.trim() || estimatorLeadFocus.dataset.autofilled === "true")
    ) {
      estimatorLeadFocus.value = defaultLeadFocus;
      estimatorLeadFocus.dataset.autofilled = "true";
    }

    saveEstimateSnapshot({
      area,
      projectType: projectType.value,
      projectTypeLabel: projectMeta.label,
      qualityLevel: qualityLevel.value,
      qualityLevelLabel:
        qualityLevel.options[qualityLevel.selectedIndex]?.textContent || "",
      houseCondition: houseCondition.value,
      houseConditionLabel: conditionMeta.label,
      residenceType: residenceType.value,
      residenceTypeLabel: residenceMeta.label,
      marketBenchmark: marketBenchmark.value,
      marketBenchmarkLabel: marketInfo.label,
      marketBenchmarkSummary: marketInfo.summary,
      usePurpose: usePurpose.value,
      usePurposeLabel: usePurposeInfo.label,
      timeline: timeline.value,
      timelineLabel: timelineInfo.label,
      bathroomCount: bathroomCount.value,
      bathroomCountLabel: bathroomInfo.label,
      utilityScope: utilityScope.value,
      utilityScopeLabel: utilityInfo.label,
      storageKitchenScope: shouldShowStorageKitchen ? storageKitchenScope.value : "none",
      storageKitchenScopeLabel: storageKitchenInfo.label,
      hasValidScope,
      selectedItems: selectedConfigs.map((item) => item.label),
      totalRange: hasValidScope ? formatRange(minTotal, maxTotal) : "--",
      designRange: hasValidScope ? formatRange(minDesign, maxDesign) : "--",
      constructionRange: hasValidScope ? formatRange(minConstruction, maxConstruction) : "--",
      reserveRange: hasValidScope ? formatRange(minReserve, maxReserve) : "--",
      recommendedTotalRange: hasValidScope ? formatRange(minRecommendedTotal, maxRecommendedTotal) : "--",
      perPingRange: hasValidScope ? `每坪約 ${minPerPing}萬 - ${maxPerPing}萬` : "--",
      costDrivers,
      reportIntent:
        projectType.value === "design-only"
          ? "design-planning-report"
          : "budget-breakdown-report",
      breakdownItems,
      updatedAt: new Date().toISOString(),
    });

    previousEstimateState = {
      minRecommendedTotal,
      maxRecommendedTotal,
      hasValidScope,
    };
    lastChangeReason = "";

    if (hasValidScope && trackingSignature !== lastTrackedSignature) {
      lastTrackedSignature = trackingSignature;
      window.trackLeadEvent?.("renovation_estimate_generated", {
        project_type: projectType.value,
        quality_level: qualityLevel.value,
        house_condition: houseCondition.value,
        residence_type: residenceType.value,
        market_benchmark: marketBenchmark.value,
        use_purpose: usePurpose.value,
        timeline: timeline.value,
        bathroom_count: bathroomCount.value,
        utility_scope: utilityScope.value,
        storage_kitchen_scope: storageKitchenScope.value,
        selected_item_count: selectedConfigs.length,
        estimated_total_min: minTotal,
        estimated_total_max: maxTotal,
      });
    }

    if (breakdownList) {
      if (projectType.value === "design-only") {
        breakdownList.innerHTML = `
          <div class="breakdown-item">
            <div class="breakdown-copy">
              <strong>設計規劃</strong>
              <span>依坪數與設計深度估算，尚未包含實際工程發包與選材差異。</span>
            </div>
            <span class="breakdown-value">${formatRange(minDesign, maxDesign)}</span>
          </div>
        `;
        return;
      }

      if (!selectedConfigs.length) {
        breakdownList.innerHTML = `
          <div class="breakdown-item">
            <div class="breakdown-copy">
              <strong>請至少勾選一項裝修工種</strong>
              <span>勾選越接近實際需求，結果越能作為後續討論的預算帶參考。</span>
            </div>
            <span class="breakdown-value">--</span>
          </div>
        `;
        return;
      }

      breakdownList.innerHTML = selectedConfigs
        .map((item) => {
          const share = item.weight / selectedWeight;
          const minItem = Math.round(minConstruction * share);
          const maxItem = Math.round(maxConstruction * share);

          return `
            <div class="breakdown-item">
              <div class="breakdown-copy">
                <strong>${item.label}</strong>
                <span>${item.description}</span>
              </div>
              <span class="breakdown-value">${formatRange(minItem, maxItem)}</span>
            </div>
          `;
        })
        .join("");
    }
  }

  // Add event listeners
  if (
    areaInput &&
    projectType &&
    qualityLevel &&
    houseCondition &&
    residenceType &&
    usePurpose &&
    timeline &&
    bathroomCount &&
    utilityScope &&
    storageKitchenScope
  ) {
    areaInput.addEventListener("input", () => {
      lastChangeReason = "室內坪數";
      calculate();
    });
    projectType.addEventListener("change", () => {
      lastChangeReason = "項目類型";
      calculate();
    });
    qualityLevel.addEventListener("change", () => {
      lastChangeReason = "裝修等級";
      calculate();
    });
    houseCondition.addEventListener("change", () => {
      lastChangeReason = "屋況條件";
      calculate();
    });
    residenceType.addEventListener("change", () => {
      lastChangeReason = "住宅型態";
      calculate();
    });
    marketBenchmark.addEventListener("change", () => {
      lastChangeReason = "市場行情基準";
      calculate();
    });
    usePurpose.addEventListener("change", () => {
      lastChangeReason = "使用目的";
      calculate();
    });
    timeline.addEventListener("change", () => {
      lastChangeReason = "開始時程";
      calculate();
    });
    bathroomCount.addEventListener("change", () => {
      lastChangeReason = "衛浴數量";
      calculate();
    });
    utilityScope.addEventListener("change", () => {
      lastChangeReason = "水電更新程度";
      calculate();
    });
    storageKitchenScope.addEventListener("change", () => {
      lastChangeReason = "系統櫃 / 廚具納入程度";
      calculate();
    });
    selectedItems.forEach((checkbox) => {
      checkbox.addEventListener("change", () => {
        const label = checkbox.closest(".checkbox-item")?.querySelector("strong")?.textContent || "裝修項目";
        lastChangeReason = checkbox.checked ? `新增 ${label}` : `取消 ${label}`;
        calculate();
      });
    });
    requirementFormLinks.forEach((link) => {
      link.addEventListener("click", calculate);
    });
    estimatorCtaLinks.forEach((link) => {
      link.addEventListener("click", () => {
        calculate();
        window.trackLeadEvent?.("renovation_estimate_cta_click", {
          destination: link.getAttribute("data-estimator-cta") || "unknown",
        });
      });
    });

    fillEstimatorLeadAttribution();

    estimatorLeadForm?.addEventListener("submit", () => {
      calculate();
      window.trackLeadEvent?.("estimator_inline_lead_submit", {
        lead_intent: estimatorLeadIntent?.value || "budget-breakdown-report",
      });
    });

    estimatorLeadFocus?.addEventListener("input", () => {
      estimatorLeadFocus.dataset.autofilled = "false";
    });

    // Initial calculation
    calculate();
  }
</script>
