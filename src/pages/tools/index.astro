  const usePurposeMeta = {
    self: { label: "自住", multiplier: 1.02 },
    family: { label: "家庭長住", multiplier: 1.05 },
    rental: { label: "出租 / 轉售整理", multiplier: 0.9 },
  };

  const timelineMeta = {
    flexible: { label: "半年以上，可彈性安排", multiplier: 1, reserve: 1 },
    planned: { label: "三到六個月內，希望開始", multiplier: 1.02, reserve: 1.05 },
    urgent: { label: "三個月內，希望盡快進場", multiplier: 1.08, reserve: 1.15 },
  };

  const bathroomCountMeta = {
    one: { label: "1 間衛浴", multiplier: 1 },
    two: { label: "2 間衛浴", multiplier: 1.45 },
    "three-plus": { label: "3 間以上", multiplier: 1.85 },
  };

  const bathroomScopeMeta = {
    fixtures: { label: "以設備更新為主", multiplier: 0.72 },
    standard: { label: "標準整間翻新", multiplier: 1 },
    relocate: { label: "含格局 / 管線移位", multiplier: 1.24 },
  };

  const kitchenLevelMeta = {
    cosmetic: { label: "局部更新，盡量保留格局", multiplier: 0.82 },
    full: { label: "整套翻新，不大改管線", multiplier: 1 },
    relocate: { label: "含管線 / 泥作與設備移位", multiplier: 1.22 },
  };

  const floorMethodMeta = {
    overlay: { label: "直鋪或表層更新", multiplier: 0.82 },
    replace: { label: "拆舊換新，含基礎處理", multiplier: 1 },
    rebuild: { label: "含整平或基底重做", multiplier: 1.18 },
  };

  const furnitureScaleMeta = {
    partial: { label: "局部收納補強", multiplier: 0.78 },
    wall: { label: "單面牆或單一主櫃體", multiplier: 1 },
    "multi-zone": { label: "多區櫃體整合", multiplier: 1.28 },
  };

  const surfaceCoverageMeta = {
    local: { label: "局部單區", multiplier: 0.82 },
    "main-zone": { label: "主要公區 / 主空間", multiplier: 1 },
    "whole-home": { label: "接近全室", multiplier: 1.24 },
  };

  function formatRange(min, max) {
    return `${min}萬 - ${max}萬`;
  }

  function saveEstimateSnapshot(snapshot) {
    try {
      window.sessionStorage.setItem(
        "renovationEstimateSnapshot",
        JSON.stringify(snapshot),
      );
    } catch (error) {
      console.warn("Unable to persist renovation estimate snapshot.", error);
    }
  }

  function fillEstimatorLeadAttribution() {
    const searchParams = new URLSearchParams(window.location.search);

    if (estimatorUtmSource) estimatorUtmSource.value = searchParams.get("utm_source") || "";
    if (estimatorUtmMedium) estimatorUtmMedium.value = searchParams.get("utm_medium") || "";
    if (estimatorUtmCampaign) estimatorUtmCampaign.value = searchParams.get("utm_campaign") || "";
    if (estimatorUtmTerm) estimatorUtmTerm.value = searchParams.get("utm_term") || "";
    if (estimatorUtmContent) estimatorUtmContent.value = searchParams.get("utm_content") || "";
    if (estimatorLandingPage) estimatorLandingPage.value = window.location.href;
    if (estimatorPageReferrer) estimatorPageReferrer.value = document.referrer || "";
    if (feedbackLandingPage) feedbackLandingPage.value = window.location.href;
    if (feedbackPageReferrer) feedbackPageReferrer.value = document.referrer || "";
  }

  let lastTrackedSignature = "";

  function hasSelectedItem(value) {
    return selectedItems.some((item) => item.value === value && item.checked);
  }

  function hasSelectedAnyItem(values = []) {
    return values.some((value) => hasSelectedItem(value));
  }

  function syncDetailControls() {
    detailGroups.forEach((group) => {
      const select = group.querySelector("select");
      const singleTarget = group.dataset.detailFor || "";
      const multiTargets = (group.dataset.detailTargets || "")
        .split(",")
        .map((value) => value.trim())
        .filter(Boolean);
      const enabled = singleTarget
        ? hasSelectedItem(singleTarget)
        : hasSelectedAnyItem(multiTargets);

      if (select) {
        select.disabled = !enabled;
      }

      group.classList.toggle("is-disabled", !enabled);
    });
  }

  function getItemDetailMeta(itemValue) {
    if (itemValue === "bathroom") {
      const countMeta =
        bathroomCountMeta[bathroomCount?.value as keyof typeof bathroomCountMeta] ||
        bathroomCountMeta.one;
      const scopeMeta =
        bathroomScopeMeta[bathroomScope?.value as keyof typeof bathroomScopeMeta] ||
        bathroomScopeMeta.standard;

      return {
        label: `${countMeta.label} / ${scopeMeta.label}`,
        multiplier: countMeta.multiplier * scopeMeta.multiplier,
      };
    }

    if (itemValue === "kitchen") {
      return kitchenLevelMeta[kitchenLevel?.value as keyof typeof kitchenLevelMeta] || kitchenLevelMeta.full;
    }

    if (itemValue === "floor") {
      const floorMeta =
        floorMethodMeta[floorMethod?.value as keyof typeof floorMethodMeta] ||
        floorMethodMeta.replace;
      const coverageMeta =
        surfaceCoverageMeta[surfaceCoverage?.value as keyof typeof surfaceCoverageMeta] ||
        surfaceCoverageMeta["main-zone"];

      return {
        label: `${floorMeta.label} / ${coverageMeta.label}`,
        multiplier: floorMeta.multiplier * coverageMeta.multiplier,
      };
    }

    if (itemValue === "ceiling" || itemValue === "wall") {
      return surfaceCoverageMeta[surfaceCoverage?.value as keyof typeof surfaceCoverageMeta] ||
        surfaceCoverageMeta["main-zone"];
    }

    if (itemValue === "furniture") {
      return furnitureScaleMeta[furnitureScale?.value as keyof typeof furnitureScaleMeta] || furnitureScaleMeta.wall;
    }

    return { label: "", multiplier: 1 };
  }

  function syncQualityLevelNote() {
    if (!qualityLevelNote) return;
    const meta =
      qualityLevelMeta[qualityLevel?.value as keyof typeof qualityLevelMeta] ||
      qualityLevelMeta.standard;
    qualityLevelNote.textContent = meta.helper;
  }

  function buildBreakdownSummary(breakdownItems = []) {
    if (!breakdownItems.length) return "";
    return breakdownItems
      .map((item) => `${item.label}：${formatRange(item.min, item.max)}｜${item.description}`)
      .join("\n");
  }

  function syncFeedbackStatusFromUrl() {
    const feedbackParam = new URLSearchParams(window.location.search).get("feedback");
    feedbackStatusSuccess?.classList.toggle("is-hidden", feedbackParam !== "success");
    feedbackStatusError?.classList.toggle("is-hidden", feedbackParam !== "error");
    if (feedbackParam === "success" || feedbackParam === "error") {
      setExpandableSection(feedbackPanel, feedbackToggle, true, "回報這次試算", "收起回報表單");
    }
  }

  function setExpandableSection(
    panel,
    button,
    isExpanded,
    expandLabel,
    collapseLabel,
  ) {
    if (!panel || !button) return;
    panel.classList.toggle("is-hidden", !isExpanded);
    button.setAttribute("aria-expanded", String(isExpanded));
    button.textContent = isExpanded ? collapseLabel : expandLabel;
  }

  function syncExpandableSectionsFromUrl() {
    syncFeedbackStatusFromUrl();

    const shouldOpenFaq =
      window.location.hash === "#faq-panel" ||
      window.location.hash === "#faq-list" ||
      new URLSearchParams(window.location.search).get("faq") === "open";

    if (shouldOpenFaq) {
      setExpandableSection(faqList, faqToggle, true, "查看常見問題", "收起常見問題");
    }
  }

  function calculate() {
    syncDetailControls();
    syncQualityLevelNote();
    const area = Math.min(200, Math.max(1, parseFloat(areaInput.value) || 30));
    const pricePerPing =
      estimatorConfig.qualityLevels?.[qualityLevel.value] ||
      estimatorConfig.qualityLevels?.standard || { min: 6, max: 10 };
    const designFeePerPing = estimatorConfig.designFeePerPing || {
      min: 0.6,
      max: 1,
    };
    const selected = selectedItems.filter((item) => item.checked);
    const selectedConfigs = renovationItems.filter((item) =>
      selected.some((selectedItem) => selectedItem.value === item.value),
    );
    const projectMeta =
      projectTypeMeta[projectType.value as keyof typeof projectTypeMeta] ||
      projectTypeMeta.full;
    const conditionMeta =
      houseConditionMeta[houseCondition.value as keyof typeof houseConditionMeta] ||
      houseConditionMeta.standard;
    const residenceMeta =
      residenceTypeMeta[residenceType.value as keyof typeof residenceTypeMeta] ||
      residenceTypeMeta.tower;
    const usePurposeInfo =
      usePurposeMeta[usePurpose.value as keyof typeof usePurposeMeta] ||
      usePurposeMeta.self;
    const timelineInfo =
      timelineMeta[timeline.value as keyof typeof timelineMeta] ||
      timelineMeta.planned;
    const totalWeight = renovationItems.reduce(
      (sum, item) => sum + item.weight,
      0,
    );
    const selectedDetailConfigs = selectedConfigs.map((item) => ({
      ...item,
      detail: getItemDetailMeta(item.value),
    }));
    const getConstructionRangeForConfigs = (configs) => {
      const configWeight = configs.reduce((sum, item) => sum + item.weight, 0);
      const configScopeRatio = configWeight / totalWeight || 0;
      const weightedConfigDetailMultiplier = configWeight
        ? configs.reduce(
            (sum, item) => sum + item.weight * item.detail.multiplier,
            0,
          ) / configWeight
        : 1;
      const configScopeFactor =
        projectType.value === "design-only"
          ? 0
          : Math.min(
              1,
              projectMeta.baseScopeFactor +
                projectMeta.variableScopeFactor * configScopeRatio,
            );
      const configDetailFactor =
        projectType.value === "design-only" ? 1 : weightedConfigDetailMultiplier;

      return {
        selectedWeight: configWeight,
        selectedScopeRatio: configScopeRatio,
        detailFactor: configDetailFactor,
        min:
          projectType.value === "design-only"
            ? 0
            : Math.round(
                area *
                  pricePerPing.min *
                  projectMeta.constructionMultiplier *
                  conditionMeta.multiplier *
                  residenceMeta.multiplier *
                  usePurposeInfo.multiplier *
                  timelineInfo.multiplier *
                  configScopeFactor *
                  configDetailFactor,
              ),
        max:
          projectType.value === "design-only"
            ? 0
            : Math.round(
                area *
                  pricePerPing.max *
                  projectMeta.constructionMultiplier *
                  conditionMeta.multiplier *
                  residenceMeta.multiplier *
                  usePurposeInfo.multiplier *
                  timelineInfo.multiplier *
                  configScopeFactor *
                  configDetailFactor,
              ),
      };
    };
    const constructionRange = getConstructionRangeForConfigs(selectedDetailConfigs);
    const selectedWeight = constructionRange.selectedWeight;
    const selectedScopeRatio = constructionRange.selectedScopeRatio;
    const baselineNoticeRatio = projectMeta.baselineNoticeRatio ?? 0;
    const detailFactor = constructionRange.detailFactor;
    const minConstruction = constructionRange.min;
    const maxConstruction = constructionRange.max;

    const minDesign = Math.round(
      area * designFeePerPing.min * projectMeta.designMultiplier,
    );
    const maxDesign = Math.round(
      area * designFeePerPing.max * projectMeta.designMultiplier,
    );

    const minReserve =
      projectType.value === "design-only"
        ? 0
        : Math.round(
            minConstruction *
              (conditionMeta.multiplier > 1 ? 0.1 : 0.06) *
              timelineInfo.reserve,
          );
    const maxReserve =
      projectType.value === "design-only"
        ? 0
        : Math.round(
            maxConstruction *
              (conditionMeta.multiplier > 1 ? 0.14 : 0.08) *
              timelineInfo.reserve,
          );

    const minTotal = minConstruction + minDesign;
    const maxTotal = maxConstruction + maxDesign;
    const minPerPing = (minTotal / area).toFixed(1);
    const maxPerPing = (maxTotal / area).toFixed(1);
    const breakdownItems =
      projectType.value === "design-only"
        ? [
            {
              label: "設計規劃",
              description: "依坪數與設計深度估算，尚未包含實際工程發包與選材差異。",
              min: minDesign,
              max: maxDesign,
            },
          ]
        : (() => {
            const itemBreakdowns = selectedDetailConfigs.map((item) => {
              const configsWithoutCurrentItem = selectedDetailConfigs.filter(
                (config) => config.value !== item.value,
              );
              const rangeWithoutCurrentItem = getConstructionRangeForConfigs(
                configsWithoutCurrentItem,
              );

              return {
                label: item.label,
                description: item.detail.label
                  ? `${item.description}｜目前條件：${item.detail.label}`
                  : item.description,
                min: Math.max(0, minConstruction - rangeWithoutCurrentItem.min),
                max: Math.max(0, maxConstruction - rangeWithoutCurrentItem.max),
              };
            });

            const itemBreakdownTotal = itemBreakdowns.reduce(
              (sum, item) => sum + item.min,
              0,
            );
            const itemBreakdownTotalMax = itemBreakdowns.reduce(
              (sum, item) => sum + item.max,
              0,
            );
            const commonBaseMin = Math.max(0, minConstruction - itemBreakdownTotal);
            const commonBaseMax = Math.max(0, maxConstruction - itemBreakdownTotalMax);

            return commonBaseMin > 0 || commonBaseMax > 0
              ? [
                  {
                    label: "拆除保護與共通整合成本",
                    description: "含全案共通的保護、拆除前後銜接、基礎收尾與難以切回單一工項的共同成本。",
                    min: commonBaseMin,
                    max: commonBaseMax,
                  },
                  ...itemBreakdowns,
                ]
              : itemBreakdowns;
          })();
    const trackingSignature = JSON.stringify({
      area,
      projectType: projectType.value,
      qualityLevel: qualityLevel.value,
      houseCondition: houseCondition.value,
      residenceType: residenceType.value,
      usePurpose: usePurpose.value,
      timeline: timeline.value,
      selectedItems: selectedConfigs.map((item) => item.value),
      bathroomCount: bathroomCount?.value || "",
      bathroomScope: bathroomScope?.value || "",
      kitchenLevel: kitchenLevel?.value || "",
      floorMethod: floorMethod?.value || "",
      furnitureScale: furnitureScale?.value || "",
      surfaceCoverage: surfaceCoverage?.value || "",
    });

    if (
      totalPrice &&
      designFee &&
      constructionFee &&
      reserveBudget &&
      perPingRange &&
      scopeSummary &&
      resultSubtitle &&
      nextStepIntro &&
      reportContext
    ) {
      totalPrice.textContent = formatRange(minTotal, maxTotal);
      designFee.textContent = formatRange(minDesign, maxDesign);
      constructionFee.textContent = formatRange(minConstruction, maxConstruction);
      reserveBudget.textContent = formatRange(minReserve, maxReserve);
      perPingRange.textContent = `每坪約 ${minPerPing}萬 - ${maxPerPing}萬`;
      scopeSummary.textContent = `${projectMeta.label} / ${selectedConfigs.length} 項工種 / ${residenceMeta.label}`;
      resultSubtitle.textContent =
        projectType.value === "design-only"
          ? "目前以設計規劃費為主，工程費用需另估。"
          : projectType.value === "full" &&
              selectedScopeRatio < baselineNoticeRatio
            ? "全屋裝修仍含基礎工程與共通工項，因此不會直接降成局部裝修。"
          : "先整理出可討論的預算帶、主要工項與預備金。";
      nextStepIntro.textContent =
        projectType.value === "design-only"
          ? "先整理設計需求。"
          : "你已經有可討論的預算帶。";
      reportContext.textContent =
        projectType.value === "design-only"
          ? `目前較適合先整理 ${projectMeta.label} 的需求重點與交付方向。`
          : `這組 ${projectMeta.label} / ${residenceMeta.label} 條件，可先用拆解報告判讀 ${formatRange(minTotal, maxTotal)} 的預算落點。`;
    }

    if (
      estimatorHandoffTitle &&
      estimatorHandoffDescription &&
      estimatorHandoffPointTitle &&
      estimatorHandoffPointDescription
    ) {
      if (projectType.value === "design-only") {
        estimatorHandoffTitle.textContent = "需求表（含估算試算）";
        estimatorHandoffDescription.textContent =
          "備齊需求、照片與時程，齊備後即可評估";
        estimatorHandoffPointTitle.textContent = "這一步最有效率";
        estimatorHandoffPointDescription.textContent =
          "把需求、參考圖與交付內容先講清楚。";
      } else {
        estimatorHandoffTitle.textContent = "需求表（含估算試算）";
        estimatorHandoffDescription.textContent =
          "備齊需求、照片與時程，齊備後即可評估";
        estimatorHandoffPointTitle.textContent = "這一步最有效率";
        estimatorHandoffPointDescription.textContent =
          "有預算方向後，直接整理需求。";
      }
    }

    const adviceItems = [];
    if (conditionMeta.multiplier >= 1.18) {
      adviceItems.push("屋況偏複雜，建議預留較高比例的拆除、基礎工程與預備金。");
    } else {
      adviceItems.push("屋況相對單純，較適合先把預算重點放在機能、材質與收納整合。");
    }

    if (projectType.value === "full" && selectedScopeRatio < baselineNoticeRatio) {
      adviceItems.push("你目前選的是全屋裝修，因此即使少勾幾項，估算仍會保留拆除、基礎工程與現場整合的基本成本。");
    }

    if (usePurpose.value === "rental") {
      adviceItems.push("若以出租或轉售為主，建議優先聚焦耐用、易維護與高感知更新項目。");
    } else {
      adviceItems.push("若以自住為主，可優先盤點真正影響日常使用的動線、收納與生活情境。");
    }

    if (timeline.value === "urgent") {
      adviceItems.push("預計時程較趕，須儘快整理現場照片、尺寸與交屋時間，避免後續排程壓縮。");
    } else {
      adviceItems.push("時程仍有彈性，填寫完整需求表可讓設計討論更聚焦。");
    }

    if (hasSelectedItem("bathroom") && bathroomCount?.value === "two") {
      adviceItems.push("兩間衛浴一起翻新時，防水、泥作與設備安裝通常會明顯拉高整體預算。");
    } else if (hasSelectedItem("bathroom") && bathroomCount?.value === "three-plus") {
      adviceItems.push("三間以上衛浴通常已接近整屋基礎工程量體，建議同步檢查排水、防水與設備等級。");
    }

    if (hasSelectedItem("bathroom") && bathroomScope?.value === "relocate") {
      adviceItems.push("衛浴若含格局或管線移位，費用通常不只增加設備，還會拉高泥作、防水與排水調整成本。");
    }

    if (hasSelectedItem("kitchen") && kitchenLevel?.value === "relocate") {
      adviceItems.push("廚房若涉及設備移位或重拉管線，預算差異通常不只在廚具本體，也會反映在泥作與水電。");
    }

    if (hasSelectedItem("floor") && floorMethod?.value === "rebuild") {
      adviceItems.push("地板若含整平或基底重做，通常要把拆除、乾燥與交界收口一併算進工期與預備金。");
    }

    if (hasSelectedAnyItem(["ceiling", "floor", "wall"]) && surfaceCoverage?.value === "whole-home") {
      adviceItems.push("表面工程若接近全室，雖然單項不一定最貴，但總面積累積後，常會把整體預算往上一級推。");
    }

    const detailAdviceItems = adviceItems.slice(4);
    const compactAdviceItems =
      projectType.value === "design-only"
        ? adviceItems.slice(0, 2)
        : [adviceItems[0], detailAdviceItems[0] || adviceItems[2] || adviceItems[1]].filter(Boolean);

    if (adviceList) {
      adviceList.innerHTML = compactAdviceItems.map((item) => `<li>${item}</li>`).join("");
    }

    if (nextStepPoints) {
      const stepItem =
        projectType.value === "design-only"
          ? {
              title: "先整理需求與參考圖",
              description: "把需求、風格與空間痛點帶進需求表，第一次設計討論會更容易對焦。",
            }
          : {
              title: "帶著估價摘要填需求表",
              description: "你現在的試算會一起帶進需求表，再補照片與時程就能直接往下討論。",
            };

      nextStepPoints.innerHTML = `
        <div class="next-step-item">
          <strong>${stepItem.title}</strong>
          <span>${stepItem.description}</span>
        </div>
      `;
    }

    if (estimatorLeadIntent) {
      estimatorLeadIntent.value =
        projectType.value === "design-only"
          ? "design-planning-report"
          : "budget-breakdown-report";
    }

    const estimatorSummaryText = [
      `估價摘要：${formatRange(minTotal, maxTotal)}`,
      `每坪抓法：每坪約 ${minPerPing}萬 - ${maxPerPing}萬`,
      `專案條件：${[projectMeta.label, qualityLevel.options[qualityLevel.selectedIndex]?.textContent, conditionMeta.label, residenceMeta.label].filter(Boolean).join(" / ")}`,
      `使用目的 / 時程：${[usePurposeInfo.label, timelineInfo.label].filter(Boolean).join(" / ")}`,
      `工項：${selectedConfigs.length ? selectedConfigs.map((item) => item.label).join("、") : "尚未勾選"}`,
      `細部條件：${[
        hasSelectedItem("bathroom") ? `衛浴 ${getItemDetailMeta("bathroom").label}` : "",
        hasSelectedItem("kitchen") ? `廚房 ${getItemDetailMeta("kitchen").label}` : "",
        hasSelectedItem("floor") ? `地板 ${getItemDetailMeta("floor").label}` : "",
        hasSelectedAnyItem(["ceiling", "wall"]) ? `表面工程 ${surfaceCoverageMeta[surfaceCoverage?.value as keyof typeof surfaceCoverageMeta]?.label || surfaceCoverageMeta["main-zone"].label}` : "",
        hasSelectedItem("furniture") ? `櫃體 ${getItemDetailMeta("furniture").label}` : "",
      ].filter(Boolean).join(" / ") || "未額外套用"}`,
    ].join(" ｜ ");

    if (estimatorSummaryInput) {
      estimatorSummaryInput.value = estimatorSummaryText;
    }
    if (feedbackEstimatorSummary) {
      feedbackEstimatorSummary.value = estimatorSummaryText;
    }
    if (feedbackEstimatorBreakdown) {
      feedbackEstimatorBreakdown.value = buildBreakdownSummary(breakdownItems);
    }

    const defaultLeadFocus =
      projectType.value === "design-only"
        ? `我想先索取這次設計規劃的拆解方向，目前估價結果約為 ${formatRange(minTotal, maxTotal)}，想了解設計深度與下一步建議。`
        : `我想索取這次估價的費用拆解報告，目前估價結果約為 ${formatRange(minTotal, maxTotal)}，想先了解主要預算落點與是否適合安排後續諮詢。`;

    if (
      estimatorLeadFocus &&
      (!estimatorLeadFocus.value.trim() || estimatorLeadFocus.dataset.autofilled === "true")
    ) {
      estimatorLeadFocus.value = defaultLeadFocus;
      estimatorLeadFocus.dataset.autofilled = "true";
    }

    saveEstimateSnapshot({
      area,
      projectType: projectType.value,
      projectTypeLabel: projectMeta.label,
      qualityLevel: qualityLevel.value,
      qualityLevelLabel:
        qualityLevel.options[qualityLevel.selectedIndex]?.textContent || "",
      houseCondition: houseCondition.value,
      houseConditionLabel: conditionMeta.label,
      residenceType: residenceType.value,
      residenceTypeLabel: residenceMeta.label,
      usePurpose: usePurpose.value,
      usePurposeLabel: usePurposeInfo.label,
      timeline: timeline.value,
      timelineLabel: timelineInfo.label,
      selectedItems: selectedConfigs.map((item) => item.label),
      detailSelections: [
        hasSelectedItem("bathroom") ? `衛浴：${getItemDetailMeta("bathroom").label}` : "",
        hasSelectedItem("kitchen") ? `廚房：${getItemDetailMeta("kitchen").label}` : "",
        hasSelectedItem("floor") ? `地板：${getItemDetailMeta("floor").label}` : "",
        hasSelectedAnyItem(["ceiling", "wall"]) ? `表面工程：${surfaceCoverageMeta[surfaceCoverage?.value as keyof typeof surfaceCoverageMeta]?.label || surfaceCoverageMeta["main-zone"].label}` : "",
        hasSelectedItem("furniture") ? `櫃體：${getItemDetailMeta("furniture").label}` : "",
      ].filter(Boolean),
      totalRange: formatRange(minTotal, maxTotal),
      designRange: formatRange(minDesign, maxDesign),
      constructionRange: formatRange(minConstruction, maxConstruction),
      reserveRange: formatRange(minReserve, maxReserve),
      perPingRange: `每坪約 ${minPerPing}萬 - ${maxPerPing}萬`,
      reportIntent:
        projectType.value === "design-only"
          ? "design-planning-report"
          : "budget-breakdown-report",
      breakdownItems,
      updatedAt: new Date().toISOString(),
    });

    if (feedbackEstimatorSnapshot) {
      feedbackEstimatorSnapshot.value = JSON.stringify(
        {
          area,
          projectType: projectMeta.label,
          qualityLevel:
            qualityLevel.options[qualityLevel.selectedIndex]?.textContent || "",
          houseCondition: conditionMeta.label,
          residenceType: residenceMeta.label,
          usePurpose: usePurposeInfo.label,
          timeline: timelineInfo.label,
          items: selectedConfigs.map((item) => ({
            label: item.label,
            detail: item.detail.label || "",
          })),
          totalRange: formatRange(minTotal, maxTotal),
          designRange: formatRange(minDesign, maxDesign),
          constructionRange: formatRange(minConstruction, maxConstruction),
          reserveRange: formatRange(minReserve, maxReserve),
          perPingRange: `每坪約 ${minPerPing}萬 - ${maxPerPing}萬`,
          breakdownItems,
          capturedAt: new Date().toISOString(),
        },
        null,
        2,
      );
    }

    if (trackingSignature !== lastTrackedSignature) {
      lastTrackedSignature = trackingSignature;
      window.trackLeadEvent?.("renovation_estimate_generated", {
        project_type: projectType.value,
        quality_level: qualityLevel.value,
        house_condition: houseCondition.value,
        residence_type: residenceType.value,
        use_purpose: usePurpose.value,
        timeline: timeline.value,
        selected_item_count: selectedConfigs.length,
        detail_factor: Number(detailFactor.toFixed(3)),
        estimated_total_min: minTotal,
        estimated_total_max: maxTotal,
      });
    }

    if (breakdownList) {
      if (projectType.value === "design-only") {
        breakdownList.innerHTML = `
          <div class="breakdown-item">
            <div class="breakdown-copy">
              <strong>設計規劃</strong>
              <span>依坪數與設計深度估算，尚未包含實際工程發包與選材差異。</span>
            </div>
            <span class="breakdown-value">${formatRange(minDesign, maxDesign)}</span>
          </div>
        `;
        return;
      }

      if (!selectedConfigs.length) {
        breakdownList.innerHTML = `
          <div class="breakdown-item">
            <div class="breakdown-copy">
              <strong>請至少勾選一項裝修工種</strong>
              <span>勾選越接近實際需求，結果越能作為後續討論的預算帶參考。</span>
            </div>
            <span class="breakdown-value">--</span>
          </div>
        `;
        return;
      }

      breakdownList.innerHTML = breakdownItems
        .map((item) => {
          return `
            <div class="breakdown-item">
              <div class="breakdown-copy">
                <strong>${item.label}</strong>
                <span>${item.description}</span>
              </div>
              <span class="breakdown-value">${formatRange(item.min, item.max)}</span>
            </div>
          `;
        })
        .join("");
    }
  }

  // Add event listeners
  if (
    areaInput &&
    projectType &&
    qualityLevel &&
    houseCondition &&
    residenceType &&
    usePurpose &&
    timeline
  ) {
    areaInput.addEventListener("input", calculate);
    projectType.addEventListener("change", calculate);
    qualityLevel.addEventListener("change", calculate);
    houseCondition.addEventListener("change", calculate);
    residenceType.addEventListener("change", calculate);
    usePurpose.addEventListener("change", calculate);
    timeline.addEventListener("change", calculate);
    bathroomCount?.addEventListener("change", calculate);
    bathroomScope?.addEventListener("change", calculate);
    kitchenLevel?.addEventListener("change", calculate);
    floorMethod?.addEventListener("change", calculate);
    furnitureScale?.addEventListener("change", calculate);
    surfaceCoverage?.addEventListener("change", calculate);
    selectedItems.forEach((checkbox) => {
      checkbox.addEventListener("change", calculate);
    });
    requirementFormLinks.forEach((link) => {
      link.addEventListener("click", calculate);
    });
    estimatorCtaLinks.forEach((link) => {
      link.addEventListener("click", () => {
        calculate();
        window.trackLeadEvent?.("renovation_estimate_cta_click", {
          destination: link.getAttribute("data-estimator-cta") || "unknown",
        });
      });
    });

    feedbackToggle?.addEventListener("click", () => {
      const isExpanded = feedbackToggle.getAttribute("aria-expanded") === "true";
      setExpandableSection(
        feedbackPanel,
        feedbackToggle,
        !isExpanded,
        "回報這次試算",
        "收起回報表單",
      );
    });

    faqToggle?.addEventListener("click", () => {
      const isExpanded = faqToggle.getAttribute("aria-expanded") === "true";
      setExpandableSection(
        faqList,
        faqToggle,
        !isExpanded,
        "查看常見問題",
        "收起常見問題",
      );
    });

    fillEstimatorLeadAttribution();
    syncExpandableSectionsFromUrl();

    estimatorLeadForm?.addEventListener("submit", () => {
      calculate();
      window.trackLeadEvent?.("estimator_inline_lead_submit", {
        lead_intent: estimatorLeadIntent?.value || "budget-breakdown-report",
      });
    });

    estimatorFeedbackForm?.addEventListener("submit", () => {
      calculate();
      window.trackLeadEvent?.("estimator_feedback_submit", {
        project_type: projectType.value,
        quality_level: qualityLevel.value,
      });
    });

    estimatorLeadFocus?.addEventListener("input", () => {
      estimatorLeadFocus.dataset.autofilled = "false";
    });

    // Initial calculation
    calculate();
  }
</script>
