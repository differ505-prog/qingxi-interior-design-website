---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getRenovationEstimatorConfig } from "../../lib/contentful.js";

const estimatorConfig = await getRenovationEstimatorConfig();

const houseConditionOptions = [
  { value: "new", label: "新成屋 / 屋況佳" },
  { value: "standard", label: "中古屋 / 一般整理" },
  { value: "old", label: "老屋翻新" },
  { value: "rough", label: "毛胚屋 / 大幅改造" },
];

const residenceTypeOptions = [
  { value: "tower", label: "電梯大樓" },
  { value: "walkup", label: "公寓 / 華廈" },
  { value: "townhouse", label: "透天 / 樓中樓" },
];

const usePurposeOptions = [
  { value: "self", label: "自住" },
  { value: "family", label: "家庭長住" },
  { value: "rental", label: "出租 / 轉售整理" },
];

const timelineOptions = [
  { value: "flexible", label: "半年以上，可彈性安排" },
  { value: "planned", label: "三到六個月內，希望開始" },
  { value: "urgent", label: "三個月內，希望盡快進場" },
];

const renovationItems = [
  {
    value: "ceiling",
    label: "天花板工程",
    description: "含平頂、包樑與基礎造型整理",
    weight: 0.14,
  },
  {
    value: "floor",
    label: "地板工程",
    description: "木地板、磁磚與基礎地坪更新",
    weight: 0.16,
  },
  {
    value: "wall",
    label: "牆面工程",
    description: "油漆、批土與牆面基礎修整",
    weight: 0.14,
  },
  {
    value: "kitchen",
    label: "廚房翻新",
    description: "廚具、檯面、設備與相關整修",
    weight: 0.22,
  },
  {
    value: "bathroom",
    label: "衛浴翻新",
    description: "防水、泥作、設備與配件更新",
    weight: 0.2,
  },
  {
    value: "furniture",
    label: "系統家具",
    description: "收納櫃體、立面與機能整合",
    weight: 0.18,
  },
];

const qualityLevelLabels = {
  basic: "經濟型",
  standard: "標準型",
  premium: "精緻型",
  luxury: "豪華型",
};

const qualityLevelOptions = Object.entries(qualityLevelLabels).map(
  ([value, label]) => {
    const typedValue = value as keyof typeof qualityLevelLabels;
    const range = estimatorConfig.qualityLevels[typedValue];
    const rangeLabel =
      value === "luxury"
        ? `每坪 ${range.min}萬以上`
        : `每坪 ${range.min}-${range.max}萬`;

    return {
      value,
      label: `${label} (${rangeLabel})`,
    };
  },
);

const estimatorConfigJson = JSON.stringify(estimatorConfig);
const renovationItemsJson = JSON.stringify(renovationItems);
---

<BaseLayout
  title="裝修估價器 - 青曦空間設計"
  description="簡單快速估算室內裝修預算，了解您的設計花費範圍"
>
  <div class="calculator-container">
    <div class="calculator-wrapper">
      <div class="calculator-header">
        <p class="eyebrow">RENOVATION ESTIMATOR</p>
        <h1>裝修估價器</h1>
        <p class="subtitle">先抓出預算帶與工程方向，讓你更快知道裝修規模的大致輪廓。</p>
        <div class="calculator-lead-note">
          <span>快速試算預算帶</span>
          <span>帶著結果進入需求表</span>
          <span>讓諮詢更快進入重點</span>
        </div>
      </div>

      <div class="calculator-form">
        <div class="form-section">
          <h2>基本資訊</h2>

          <div class="form-group">
            <label for="area">室內坪數</label>
            <div class="input-with-unit">
              <input
                type="number"
                id="area"
                min="1"
                max="200"
                value="30"
                step="0.5"
              />
              <span class="unit">坪</span>
            </div>
          </div>

          <div class="form-group">
            <label for="project-type">項目類型</label>
            <select id="project-type">
              <option value="full">全屋裝修</option>
              <option value="partial">局部裝修</option>
              <option value="design-only">純設計</option>
            </select>
          </div>

          <div class="form-group">
            <label for="quality-level">裝修等級</label>
            <select id="quality-level">
              {
                qualityLevelOptions.map(({ value, label }) => (
                  <option value={value} selected={value === "standard"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="form-group">
            <label for="house-condition">屋況條件</label>
            <select id="house-condition">
              {
                houseConditionOptions.map(({ value, label }) => (
                  <option value={value} selected={value === "standard"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="form-group">
            <label for="residence-type">住宅型態</label>
            <select id="residence-type">
              {
                residenceTypeOptions.map(({ value, label }) => (
                  <option value={value} selected={value === "tower"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="form-group">
            <label for="use-purpose">使用目的</label>
            <select id="use-purpose">
              {
                usePurposeOptions.map(({ value, label }) => (
                  <option value={value} selected={value === "self"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="form-group">
            <label for="timeline">預計時程</label>
            <select id="timeline">
              {
                timelineOptions.map(({ value, label }) => (
                  <option value={value} selected={value === "planned"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>
        </div>

        <div class="form-section">
          <h2>裝修項目</h2>

          <div class="checkbox-group">
            {
              renovationItems.map((item, index) => (
                <label class="checkbox-item">
                  <input
                    type="checkbox"
                    value={item.value}
                    checked={index <= 2}
                  />
                  <span class="checkbox-copy">
                    <strong>{item.label}</strong>
                    <small>{item.description}</small>
                  </span>
                </label>
              ))
            }
          </div>
        </div>

        <div class="result-section">
          <h2>預估結果</h2>
          <p class="result-subtitle" id="result-subtitle">
            依目前輸入條件，先整理出適合討論的預算帶與工程範圍。
          </p>

          <div class="result-card">
            <div class="result-row">
              <span class="result-label">預估總價</span>
              <span class="result-value" id="total-price">180萬 - 300萬</span>
            </div>
            <div class="result-row">
              <span class="result-label">設計費用</span>
              <span class="result-value" id="design-fee">9萬 - 15萬</span>
            </div>
            <div class="result-row">
              <span class="result-label">工程費用</span>
              <span class="result-value" id="construction-fee"
                >171萬 - 285萬</span
              >
            </div>
            <div class="result-row">
              <span class="result-label">建議預備金</span>
              <span class="result-value" id="reserve-budget">10萬 - 18萬</span>
            </div>
          </div>

          <div class="result-highlights">
            <div class="highlight-pill">
              <span>每坪抓法</span>
              <strong id="per-ping-range">每坪約 6萬 - 10萬</strong>
            </div>
            <div class="highlight-pill">
              <span>目前範圍</span>
              <strong id="scope-summary">全屋裝修 / 3 項工種</strong>
            </div>
          </div>

          <div class="breakdown-card">
            <div class="breakdown-header">
              <h3>工程拆解</h3>
              <p>以下為依目前勾選工項與條件拆出的粗略比例，方便你理解預算主要落點。</p>
            </div>
            <div class="breakdown-list" id="breakdown-list"></div>
          </div>

          <div class="advice-grid">
            <div class="advice-card">
              <div class="advice-header">
                <h3>估算判讀</h3>
                <p>根據你的住宅條件、使用方式與進場時程，整理討論重點。</p>
              </div>
              <ul class="advice-list" id="advice-list"></ul>
            </div>
            <div class="advice-card advice-card-accent">
              <div class="advice-header">
                <h3>建議下一步</h3>
                <p id="next-step-intro">若方向已接近，下一步最適合把需求與預算一起整理完整。</p>
              </div>
              <div class="next-step-points" id="next-step-points"></div>
            </div>
          </div>

          <div class="disclaimer">
            <p>{estimatorConfig.disclaimer}</p>
          </div>

          <div class="cta-buttons">
            <a href="/contact" class="btn btn-primary" data-estimator-cta="contact">帶著估算結果諮詢</a>
            <a href="/requirement-form" class="btn btn-secondary" data-estimator-cta="requirement-form">填寫完整需求表</a>
          </div>
          <p class="cta-note">若你已經有大致預算方向，下一步最有效的是帶著這份估算與需求一起討論。</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .calculator-container {
    padding: 4.75rem 1.5rem 5rem;
    background:
      radial-gradient(circle at top left, rgba(160, 217, 217, 0.1), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(244, 245, 244, 1) 100%);
  }

  .calculator-wrapper {
    max-width: 960px;
    margin: 0 auto;
  }

  .calculator-header {
    text-align: center;
    margin-bottom: 2.4rem;
  }

  .calculator-lead-note {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.25rem;
  }

  .calculator-lead-note span {
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(129, 199, 212, 0.16);
    color: var(--gray-dark);
    box-shadow: 0 10px 20px rgba(47, 47, 47, 0.04);
    font-size: 0.92rem;
  }

  .eyebrow {
    margin: 0 0 0.9rem;
    color: var(--tiffany-dark);
    font-size: 0.8rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .calculator-header h1 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(2.3rem, 4vw, 4rem);
    font-weight: 500;
    color: var(--gray-darkest);
    letter-spacing: 0.05em;
  }

  .subtitle {
    max-width: 40rem;
    margin: 1rem auto 0;
    color: var(--gray-medium);
    font-size: 1rem;
    line-height: 1.9;
  }

  .calculator-form {
    background: rgba(255, 255, 255, 0.9);
    border-radius: 32px;
    padding: 2.1rem;
    box-shadow: 0 28px 60px rgba(47, 47, 47, 0.06);
    border: 1px solid rgba(129, 199, 212, 0.16);
  }

  .form-section {
    margin-bottom: 1.5rem;
    padding: 1.6rem;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 249, 248, 1) 100%);
    border: 1px solid rgba(129, 199, 212, 0.12);
  }

  .form-section:last-child {
    margin-bottom: 0;
  }

  .form-section h2 {
    margin: 0 0 1.25rem;
    font-family: "Noto Serif TC", serif;
    font-size: 1.45rem;
    color: var(--gray-darkest);
    letter-spacing: 0.04em;
  }

  .form-group {
    margin-bottom: 1.1rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.55rem;
    font-weight: 500;
    color: var(--gray-dark);
  }

  .input-with-unit {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .input-with-unit input {
    flex: 1;
  }

  .unit {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--gray-medium);
  }

  input[type="number"],
  select {
    width: 100%;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(129, 199, 212, 0.18);
    border-radius: 16px;
    font-size: 1rem;
    color: var(--gray-darkest);
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
    background: rgba(255, 255, 255, 0.92);
  }

  input[type="number"]:focus,
  select:focus {
    outline: none;
    border-color: rgba(129, 199, 212, 0.46);
    box-shadow: 0 0 0 4px rgba(129, 199, 212, 0.12);
    transform: translateY(-1px);
  }

  .checkbox-group {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.85rem;
  }

  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 58px;
    padding: 0.9rem 1rem;
    border: 1px solid rgba(129, 199, 212, 0.16);
    border-radius: 18px;
    cursor: pointer;
    transition: transform 0.25s ease, border-color 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
    background: rgba(255, 255, 255, 0.82);
  }

  .checkbox-item:hover {
    background: rgba(245, 250, 250, 1);
    border-color: rgba(129, 199, 212, 0.34);
    box-shadow: 0 12px 22px rgba(47, 47, 47, 0.04);
    transform: translateY(-1px);
  }

  .checkbox-item input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: var(--tiffany-primary);
  }

  .checkbox-item input[type="checkbox"]:checked + span {
    color: var(--tiffany-dark);
  }

  .checkbox-copy {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
  }

  .checkbox-copy strong {
    font-size: 0.98rem;
    color: var(--gray-darkest);
  }

  .checkbox-copy small {
    color: var(--gray-medium);
    line-height: 1.55;
  }

  .checkbox-item input[type="checkbox"]:checked + .checkbox-copy strong {
    color: var(--tiffany-dark);
  }

  .result-section {
    margin-top: 1.5rem;
    padding: 2rem;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.14), transparent 28%),
      linear-gradient(135deg, rgba(247, 250, 250, 1) 0%, rgba(255, 255, 255, 1) 100%);
    border: 1px solid rgba(129, 199, 212, 0.16);
  }

  .result-section h2 {
    margin-bottom: 1.2rem;
  }

  .result-subtitle {
    margin: -0.4rem 0 1.25rem;
    color: var(--gray-medium);
    line-height: 1.8;
  }

  .result-card {
    background: rgba(255, 255, 255, 0.92);
    padding: 1.5rem;
    border-radius: 22px;
    margin-bottom: 1.5rem;
    box-shadow: 0 18px 32px rgba(47, 47, 47, 0.04);
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(47, 47, 47, 0.08);
  }

  .result-row:last-child {
    border-bottom: none;
  }

  .result-label {
    font-size: 1rem;
    color: var(--gray-medium);
  }

  .result-value {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--tiffany-dark);
  }

  .result-row:first-child .result-value {
    font-size: 1.5rem;
    color: var(--gray-darkest);
  }

  .result-highlights {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .highlight-pill {
    padding: 1rem 1.1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(129, 199, 212, 0.16);
  }

  .highlight-pill span,
  .highlight-pill strong {
    display: block;
  }

  .highlight-pill span {
    color: var(--gray-medium);
    font-size: 0.9rem;
  }

  .highlight-pill strong {
    margin-top: 0.35rem;
    color: var(--gray-darkest);
    line-height: 1.65;
  }

  .breakdown-card {
    margin-bottom: 1.5rem;
    padding: 1.4rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(129, 199, 212, 0.16);
    box-shadow: 0 18px 32px rgba(47, 47, 47, 0.04);
  }

  .breakdown-header h3 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: 1.2rem;
    color: var(--gray-darkest);
  }

  .breakdown-header p {
    margin: 0.55rem 0 0;
    color: var(--gray-medium);
    line-height: 1.75;
    font-size: 0.92rem;
  }

  .breakdown-list {
    display: grid;
    gap: 0.9rem;
    margin-top: 1.2rem;
  }

  .breakdown-item {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(47, 47, 47, 0.08);
  }

  .breakdown-item:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .breakdown-copy strong,
  .breakdown-copy span {
    display: block;
  }

  .breakdown-copy strong {
    color: var(--gray-darkest);
  }

  .breakdown-copy span {
    margin-top: 0.28rem;
    color: var(--gray-medium);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .breakdown-value {
    color: var(--tiffany-dark);
    font-weight: 600;
    white-space: nowrap;
  }

  .advice-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .advice-card {
    padding: 1.4rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(129, 199, 212, 0.16);
    box-shadow: 0 18px 32px rgba(47, 47, 47, 0.04);
  }

  .advice-card-accent {
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.18), transparent 35%),
      linear-gradient(135deg, rgba(247, 250, 250, 1) 0%, rgba(255, 255, 255, 1) 100%);
  }

  .advice-header h3 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: 1.2rem;
    color: var(--gray-darkest);
  }

  .advice-header p {
    margin: 0.55rem 0 0;
    color: var(--gray-medium);
    line-height: 1.75;
    font-size: 0.92rem;
  }

  .advice-list {
    margin: 1rem 0 0;
    padding-left: 1.15rem;
    color: var(--gray-dark);
    line-height: 1.8;
  }

  .advice-list li + li {
    margin-top: 0.5rem;
  }

  .next-step-points {
    display: grid;
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .next-step-item {
    padding: 0.9rem 1rem;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(129, 199, 212, 0.14);
  }

  .next-step-item strong,
  .next-step-item span {
    display: block;
  }

  .next-step-item strong {
    color: var(--gray-darkest);
  }

  .next-step-item span {
    margin-top: 0.24rem;
    color: var(--gray-medium);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .disclaimer {
    background: rgba(255, 255, 255, 0.92);
    padding: 1rem 1.1rem;
    border-radius: 18px;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(129, 199, 212, 0.16);
  }

  .disclaimer p {
    color: var(--gray-medium);
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.6;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .cta-note {
    margin: 1rem 0 0;
    color: var(--gray-medium);
    line-height: 1.75;
    font-size: 0.92rem;
  }

  .btn {
    flex: 1;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 500;
    text-align: center;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease, border-color 0.25s ease;
    font-size: 1rem;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--tiffany-dark) 100%);
    color: var(--white);
    border: 1px solid var(--gray-darkest);
  }

  .btn-primary:hover {
    border-color: var(--gray-darkest);
    transform: translateY(-2px);
    box-shadow: 0 18px 28px rgba(47, 47, 47, 0.18);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.92);
    color: var(--gray-darkest);
    border: 1px solid rgba(129, 199, 212, 0.22);
  }

  .btn-secondary:hover {
    background: rgba(245, 250, 250, 1);
    transform: translateY(-2px);
    box-shadow: 0 14px 24px rgba(129, 199, 212, 0.12);
  }

  @media (max-width: 768px) {
    .calculator-container {
      padding: 4rem 1.25rem 4rem;
    }

    .calculator-form {
      padding: 1.3rem;
      border-radius: 24px;
    }

    .form-section,
    .result-section,
    .result-card {
      padding: 1.25rem;
      border-radius: 20px;
    }

    .checkbox-group {
      grid-template-columns: 1fr;
    }

    .result-highlights {
      grid-template-columns: 1fr;
    }

    .advice-grid {
      grid-template-columns: 1fr;
    }

    .breakdown-item {
      flex-direction: column;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .result-value {
      font-size: 1.1rem;
    }

    .result-row:first-child .result-value {
      font-size: 1.3rem;
    }
  }
</style>

<script type="application/json" id="estimator-config" is:inline set:html={estimatorConfigJson}></script>
<script type="application/json" id="renovation-items" is:inline set:html={renovationItemsJson}></script>
<script>
  // @ts-nocheck
  // Calculator logic
  const estimatorConfig = JSON.parse(
    document.getElementById("estimator-config")?.textContent || "{}",
  );
  const renovationItems = JSON.parse(
    document.getElementById("renovation-items")?.textContent || "[]",
  );
  const areaInput = document.getElementById("area") as HTMLInputElement;
  const projectType = document.getElementById(
    "project-type",
  ) as HTMLSelectElement;
  const qualityLevel = document.getElementById(
    "quality-level",
  ) as HTMLSelectElement;
  const houseCondition = document.getElementById(
    "house-condition",
  ) as HTMLSelectElement;
  const residenceType = document.getElementById(
    "residence-type",
  ) as HTMLSelectElement;
  const usePurpose = document.getElementById(
    "use-purpose",
  ) as HTMLSelectElement;
  const timeline = document.getElementById(
    "timeline",
  ) as HTMLSelectElement;
  const selectedItems = Array.from(
    document.querySelectorAll('.checkbox-item input[type="checkbox"]'),
  ) as HTMLInputElement[];
  const totalPrice = document.getElementById("total-price");
  const designFee = document.getElementById("design-fee");
  const constructionFee = document.getElementById("construction-fee");
  const reserveBudget = document.getElementById("reserve-budget");
  const perPingRange = document.getElementById("per-ping-range");
  const scopeSummary = document.getElementById("scope-summary");
  const resultSubtitle = document.getElementById("result-subtitle");
  const breakdownList = document.getElementById("breakdown-list");
  const adviceList = document.getElementById("advice-list");
  const nextStepIntro = document.getElementById("next-step-intro");
  const nextStepPoints = document.getElementById("next-step-points");
  const requirementFormLink = document.querySelector(
    'a[href="/requirement-form"]',
  );
  const estimatorCtaLinks = Array.from(
    document.querySelectorAll("[data-estimator-cta]"),
  );

  const projectTypeMeta = {
    full: { label: "全屋裝修", constructionMultiplier: estimatorConfig.projectTypeMultipliers?.full ?? 1, designMultiplier: 1 },
    partial: { label: "局部裝修", constructionMultiplier: estimatorConfig.projectTypeMultipliers?.partial ?? 0.6, designMultiplier: 0.65 },
    "design-only": { label: "純設計", constructionMultiplier: 0, designMultiplier: 1 },
  };

  const houseConditionMeta = {
    new: { label: "新成屋 / 屋況佳", multiplier: 0.92 },
    standard: { label: "中古屋 / 一般整理", multiplier: 1 },
    old: { label: "老屋翻新", multiplier: 1.18 },
    rough: { label: "毛胚屋 / 大幅改造", multiplier: 1.28 },
  };

  const residenceTypeMeta = {
    tower: { label: "電梯大樓", multiplier: 1 },
    walkup: { label: "公寓 / 華廈", multiplier: 1.06 },
    townhouse: { label: "透天 / 樓中樓", multiplier: 1.12 },
  };

  const usePurposeMeta = {
    self: { label: "自住", multiplier: 1.02 },
    family: { label: "家庭長住", multiplier: 1.05 },
    rental: { label: "出租 / 轉售整理", multiplier: 0.9 },
  };

  const timelineMeta = {
    flexible: { label: "半年以上，可彈性安排", multiplier: 1, reserve: 1 },
    planned: { label: "三到六個月內，希望開始", multiplier: 1.02, reserve: 1.05 },
    urgent: { label: "三個月內，希望盡快進場", multiplier: 1.08, reserve: 1.15 },
  };

  function formatRange(min, max) {
    return `${min}萬 - ${max}萬`;
  }

  function saveEstimateSnapshot(snapshot) {
    try {
      window.sessionStorage.setItem(
        "renovationEstimateSnapshot",
        JSON.stringify(snapshot),
      );
    } catch (error) {
      console.warn("Unable to persist renovation estimate snapshot.", error);
    }
  }

  let lastTrackedSignature = "";

  function calculate() {
    const area = Math.min(200, Math.max(1, parseFloat(areaInput.value) || 30));
    const pricePerPing =
      estimatorConfig.qualityLevels?.[qualityLevel.value] ||
      estimatorConfig.qualityLevels?.standard || { min: 6, max: 10 };
    const designFeePerPing = estimatorConfig.designFeePerPing || {
      min: 3,
      max: 5,
    };
    const selected = selectedItems.filter((item) => item.checked);
    const selectedConfigs = renovationItems.filter((item) =>
      selected.some((selectedItem) => selectedItem.value === item.value),
    );
    const projectMeta =
      projectTypeMeta[projectType.value as keyof typeof projectTypeMeta] ||
      projectTypeMeta.full;
    const conditionMeta =
      houseConditionMeta[houseCondition.value as keyof typeof houseConditionMeta] ||
      houseConditionMeta.standard;
    const residenceMeta =
      residenceTypeMeta[residenceType.value as keyof typeof residenceTypeMeta] ||
      residenceTypeMeta.tower;
    const usePurposeInfo =
      usePurposeMeta[usePurpose.value as keyof typeof usePurposeMeta] ||
      usePurposeMeta.self;
    const timelineInfo =
      timelineMeta[timeline.value as keyof typeof timelineMeta] ||
      timelineMeta.planned;
    const totalWeight = renovationItems.reduce(
      (sum, item) => sum + item.weight,
      0,
    );
    const selectedWeight = selectedConfigs.reduce(
      (sum, item) => sum + item.weight,
      0,
    );
    const scopeFactor =
      projectType.value === "design-only"
        ? 0
        : Math.max(0.28, 0.45 + 0.55 * (selectedWeight / totalWeight || 0));

    const minConstruction =
      projectType.value === "design-only"
        ? 0
        : Math.round(
            area *
              pricePerPing.min *
              projectMeta.constructionMultiplier *
              conditionMeta.multiplier *
              residenceMeta.multiplier *
              usePurposeInfo.multiplier *
              timelineInfo.multiplier *
              scopeFactor,
          );
    const maxConstruction =
      projectType.value === "design-only"
        ? 0
        : Math.round(
            area *
              pricePerPing.max *
              projectMeta.constructionMultiplier *
              conditionMeta.multiplier *
              residenceMeta.multiplier *
              usePurposeInfo.multiplier *
              timelineInfo.multiplier *
              scopeFactor,
          );

    const minDesign = Math.round(
      area * designFeePerPing.min * projectMeta.designMultiplier,
    );
    const maxDesign = Math.round(
      area * designFeePerPing.max * projectMeta.designMultiplier,
    );

    const minReserve =
      projectType.value === "design-only"
        ? 0
        : Math.round(
            minConstruction *
              (conditionMeta.multiplier > 1 ? 0.1 : 0.06) *
              timelineInfo.reserve,
          );
    const maxReserve =
      projectType.value === "design-only"
        ? 0
        : Math.round(
            maxConstruction *
              (conditionMeta.multiplier > 1 ? 0.14 : 0.08) *
              timelineInfo.reserve,
          );

    const minTotal = minConstruction + minDesign;
    const maxTotal = maxConstruction + maxDesign;
    const minPerPing = (minTotal / area).toFixed(1);
    const maxPerPing = (maxTotal / area).toFixed(1);
    const breakdownItems =
      projectType.value === "design-only"
        ? [
            {
              label: "設計規劃",
              description: "依坪數與設計深度估算，尚未包含實際工程發包與選材差異。",
              min: minDesign,
              max: maxDesign,
            },
          ]
        : selectedConfigs.map((item) => {
            const share = item.weight / (selectedWeight || 1);
            return {
              label: item.label,
              description: item.description,
              min: Math.round(minConstruction * share),
              max: Math.round(maxConstruction * share),
            };
          });
    const trackingSignature = JSON.stringify({
      area,
      projectType: projectType.value,
      qualityLevel: qualityLevel.value,
      houseCondition: houseCondition.value,
      residenceType: residenceType.value,
      usePurpose: usePurpose.value,
      timeline: timeline.value,
      selectedItems: selectedConfigs.map((item) => item.value),
    });

    if (
      totalPrice &&
      designFee &&
      constructionFee &&
      reserveBudget &&
      perPingRange &&
      scopeSummary &&
      resultSubtitle &&
      nextStepIntro
    ) {
      totalPrice.textContent = formatRange(minTotal, maxTotal);
      designFee.textContent = formatRange(minDesign, maxDesign);
      constructionFee.textContent = formatRange(minConstruction, maxConstruction);
      reserveBudget.textContent = formatRange(minReserve, maxReserve);
      perPingRange.textContent = `每坪約 ${minPerPing}萬 - ${maxPerPing}萬`;
      scopeSummary.textContent = `${projectMeta.label} / ${selectedConfigs.length} 項工種 / ${residenceMeta.label}`;
      resultSubtitle.textContent =
        projectType.value === "design-only"
          ? "目前以設計規劃費為主，工程費用需依圖面、工法與發包範圍另行確認。"
          : "依目前輸入條件，先整理出適合討論的預算帶、主要工項與建議預備金。";
      nextStepIntro.textContent =
        projectType.value === "design-only"
          ? "你目前更接近設計規劃前期，適合先整理需求與生活方式，再確認圖面深度。"
          : "你目前已經有可討論的預算帶，下一步最適合把需求、照片與工程範圍一起整理。";
    }

    const adviceItems = [];
    if (conditionMeta.multiplier >= 1.18) {
      adviceItems.push("屋況偏複雜，建議預留較高比例的拆除、基礎工程與預備金。");
    } else {
      adviceItems.push("屋況相對單純，較適合先把預算重點放在機能、材質與收納整合。");
    }

    if (usePurpose.value === "rental") {
      adviceItems.push("若以出租或轉售為主，建議優先聚焦耐用、易維護與高感知更新項目。");
    } else {
      adviceItems.push("若以自住為主，可優先盤點真正影響日常使用的動線、收納與生活情境。");
    }

    if (timeline.value === "urgent") {
      adviceItems.push("預計時程較趕，建議盡快整理現場照片、尺寸與交屋時間，避免後續排程壓縮。");
    } else {
      adviceItems.push("時程仍有彈性，可先把需求表填完整，讓設計討論更聚焦也更容易抓準預算。");
    }

    if (adviceList) {
      adviceList.innerHTML = adviceItems.map((item) => `<li>${item}</li>`).join("");
    }

    if (nextStepPoints) {
      const stepItems =
        projectType.value === "design-only"
          ? [
              {
                title: "先整理需求與參考圖",
                description: "把生活需求、喜歡的風格與空間痛點一起帶進需求表，最能提高設計討論效率。",
              },
              {
                title: "確認設計深度與交付內容",
                description: "若你需要平面規劃、3D、施工圖或發包協助，建議在第一次諮詢就先說清楚。",
              },
            ]
          : [
              {
                title: "帶著估價摘要填需求表",
                description: "你現在的試算會一起帶進需求表，青曦能更快理解你的預算帶與工項範圍。",
              },
              {
                title: "準備現場照片與時程資訊",
                description: "若能同時提供現況照片、交屋時間與預計入住時間，初步判斷會更準確。",
              },
            ];

      nextStepPoints.innerHTML = stepItems
        .map(
          (item) => `
            <div class="next-step-item">
              <strong>${item.title}</strong>
              <span>${item.description}</span>
            </div>
          `,
        )
        .join("");
    }

    saveEstimateSnapshot({
      area,
      projectType: projectType.value,
      projectTypeLabel: projectMeta.label,
      qualityLevel: qualityLevel.value,
      qualityLevelLabel:
        qualityLevel.options[qualityLevel.selectedIndex]?.textContent || "",
      houseCondition: houseCondition.value,
      houseConditionLabel: conditionMeta.label,
      residenceType: residenceType.value,
      residenceTypeLabel: residenceMeta.label,
      usePurpose: usePurpose.value,
      usePurposeLabel: usePurposeInfo.label,
      timeline: timeline.value,
      timelineLabel: timelineInfo.label,
      selectedItems: selectedConfigs.map((item) => item.label),
      totalRange: formatRange(minTotal, maxTotal),
      designRange: formatRange(minDesign, maxDesign),
      constructionRange: formatRange(minConstruction, maxConstruction),
      reserveRange: formatRange(minReserve, maxReserve),
      perPingRange: `每坪約 ${minPerPing}萬 - ${maxPerPing}萬`,
      breakdownItems,
      updatedAt: new Date().toISOString(),
    });

    if (trackingSignature !== lastTrackedSignature) {
      lastTrackedSignature = trackingSignature;
      window.trackLeadEvent?.("renovation_estimate_generated", {
        project_type: projectType.value,
        quality_level: qualityLevel.value,
        house_condition: houseCondition.value,
        residence_type: residenceType.value,
        use_purpose: usePurpose.value,
        timeline: timeline.value,
        selected_item_count: selectedConfigs.length,
        estimated_total_min: minTotal,
        estimated_total_max: maxTotal,
      });
    }

    if (breakdownList) {
      if (projectType.value === "design-only") {
        breakdownList.innerHTML = `
          <div class="breakdown-item">
            <div class="breakdown-copy">
              <strong>設計規劃</strong>
              <span>依坪數與設計深度估算，尚未包含實際工程發包與選材差異。</span>
            </div>
            <span class="breakdown-value">${formatRange(minDesign, maxDesign)}</span>
          </div>
        `;
        return;
      }

      if (!selectedConfigs.length) {
        breakdownList.innerHTML = `
          <div class="breakdown-item">
            <div class="breakdown-copy">
              <strong>請至少勾選一項裝修工種</strong>
              <span>勾選越接近實際需求，結果越能作為後續討論的預算帶參考。</span>
            </div>
            <span class="breakdown-value">--</span>
          </div>
        `;
        return;
      }

      breakdownList.innerHTML = selectedConfigs
        .map((item) => {
          const share = item.weight / selectedWeight;
          const minItem = Math.round(minConstruction * share);
          const maxItem = Math.round(maxConstruction * share);

          return `
            <div class="breakdown-item">
              <div class="breakdown-copy">
                <strong>${item.label}</strong>
                <span>${item.description}</span>
              </div>
              <span class="breakdown-value">${formatRange(minItem, maxItem)}</span>
            </div>
          `;
        })
        .join("");
    }
  }

  // Add event listeners
  if (
    areaInput &&
    projectType &&
    qualityLevel &&
    houseCondition &&
    residenceType &&
    usePurpose &&
    timeline
  ) {
    areaInput.addEventListener("input", calculate);
    projectType.addEventListener("change", calculate);
    qualityLevel.addEventListener("change", calculate);
    houseCondition.addEventListener("change", calculate);
    residenceType.addEventListener("change", calculate);
    usePurpose.addEventListener("change", calculate);
    timeline.addEventListener("change", calculate);
    selectedItems.forEach((checkbox) => {
      checkbox.addEventListener("change", calculate);
    });
    requirementFormLink?.addEventListener("click", calculate);
    estimatorCtaLinks.forEach((link) => {
      link.addEventListener("click", () => {
        calculate();
        window.trackLeadEvent?.("renovation_estimate_cta_click", {
          destination: link.getAttribute("data-estimator-cta") || "unknown",
        });
      });
    });

    // Initial calculation
    calculate();
  }
</script>
