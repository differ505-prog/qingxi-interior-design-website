                    <label class="feedback-field">
                      <span>問題類型</span>
                      <select name="issue_type" required>
                        <option value="">請選擇</option>
                        <option value="pricing">估價數字不合理</option>
                        <option value="breakdown">工程拆解怪怪的</option>
                        <option value="interaction">勾選或互動有問題</option>
                        <option value="display">畫面顯示異常</option>
                        <option value="other">其他</option>
                      </select>
                    </label>
                    <label class="feedback-field">
                      <span>聯絡方式（可選）</span>
                      <input
                        type="text"
                        name="contact_method"
                        placeholder="Email、LINE ID 或電話"
                      />
                    </label>
                    <label class="feedback-field feedback-field-full">
                      <span>你覺得哪裡怪？</span>
                      <textarea
                        id="feedback-message"
                        name="issue_description"
                        rows="4"
                        placeholder="例如 30 坪、全勾時牆面工程反而下降，或切換精緻型後櫃體價格才正常"
                        required
                      ></textarea>
                    </label>
                  </div>

                  <div class="feedback-actions">
                    <button
                      type="submit"
                      class="btn btn-secondary feedback-submit"
                      disabled={!estimatorFeedbackEnabled}
                    >
                      送出問題回報
                    </button>
                    <p class="feedback-note">
                      送出後會一併附上本次試算內容，方便我們更快確認。
