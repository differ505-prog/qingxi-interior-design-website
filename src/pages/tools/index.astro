---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getRenovationEstimatorConfig } from "../../lib/contentful.js";

const estimatorConfig = await getRenovationEstimatorConfig();
const requirementFormId =
  import.meta.env.PUBLIC_FORMSPREE_REQUIREMENT_FORM_ID?.trim() || "";
const estimatorLeadAction = requirementFormId
  ? `https://formspree.io/f/${requirementFormId}`
  : "";
const estimatorLeadEnabled = Boolean(estimatorLeadAction);
const siteOrigin = (Astro.site || new URL("https://qingxidesign.tw")).toString();
const estimatorLeadSuccessURL = new URL("/consultation-thank-you", siteOrigin).toString();

const houseConditionOptions = [
  { value: "new", label: "新成屋 / 屋況佳" },
  { value: "standard", label: "中古屋 / 一般整理" },
  { value: "old", label: "老屋翻新" },
  { value: "rough", label: "毛胚屋 / 大幅改造" },
];

const residenceTypeOptions = [
  { value: "tower", label: "電梯大樓" },
  { value: "walkup", label: "公寓 / 華廈" },
  { value: "townhouse", label: "透天 / 樓中樓" },
];

const usePurposeOptions = [
  { value: "self", label: "自住" },
  { value: "family", label: "家庭長住" },
  { value: "rental", label: "出租 / 轉售整理" },
];

const timelineOptions = [
  { value: "flexible", label: "半年以上，可彈性安排" },
  { value: "planned", label: "三到六個月內，希望開始" },
  { value: "urgent", label: "三個月內，希望盡快進場" },
];

const renovationItems = [
  {
    value: "ceiling",
    label: "天花板工程",
    description: "含平頂、包樑與基礎造型整理",
    weight: 0.14,
  },
  {
    value: "floor",
    label: "地板工程",
    description: "木地板、磁磚與基礎地坪更新",
    weight: 0.16,
  },
  {
    value: "wall",
    label: "牆面工程",
    description: "油漆、批土與牆面基礎修整",
    weight: 0.14,
  },
  {
    value: "kitchen",
    label: "廚房翻新",
    description: "廚具、檯面、設備與相關整修",
    weight: 0.22,
  },
  {
    value: "bathroom",
    label: "衛浴翻新",
    description: "防水、泥作、設備與配件更新",
    weight: 0.2,
  },
  {
    value: "furniture",
    label: "系統家具",
    description: "收納櫃體、立面與機能整合",
    weight: 0.18,
  },
];

const qualityLevelLabels = {
  basic: "經濟型",
  standard: "標準型",
  premium: "精緻型",
  luxury: "豪華型",
};

const qualityLevelOptions = Object.entries(qualityLevelLabels).map(
  ([value, label]) => {
    const typedValue = value as keyof typeof qualityLevelLabels;
    const range = estimatorConfig.qualityLevels[typedValue];
    const rangeLabel =
      value === "luxury"
        ? `每坪 ${range.min}萬以上`
        : `每坪 ${range.min}-${range.max}萬`;

    return {
      value,
      label: `${label} (${rangeLabel})`,
    };
  },
);

const estimatorConfigJson = JSON.stringify(estimatorConfig);
const renovationItemsJson = JSON.stringify(renovationItems);
---

<BaseLayout
  title="裝修估價器 - 青曦空間設計"
  description="先抓出裝修預算帶，判斷要不要往下談。"
  ogImage="/images/portfolio/xizhi-3.jpg"
  pageType="service"
>
  <div class="calculator-container">
    <div class="calculator-wrapper">
      <div class="calculator-header">
        <p class="eyebrow">RENOVATION ESTIMATOR</p>
        <h1>裝修估價器</h1>
        <p class="subtitle">先用設計觀點整理預算帶，再判斷這個家要往哪一種生活感走。</p>
        <div class="calculator-lead-note">
          <span>前期預算判讀</span>
          <span>生活感與工項一起看</span>
          <span>結果可直接帶入需求表</span>
        </div>
        <div class="hero-actions">
          <a href="#estimator-form" class="btn btn-primary" data-estimator-cta="start-estimate">開始試算</a>
          <a href="/#workflow" class="btn btn-secondary">先看服務流程</a>
        </div>
      </div>

      <div class="landing-grid">
        <section class="landing-card">
          <div class="landing-card-header">
            <h2>這個工具比較像什麼</h2>
            <p>它不是快速喊價，而是先把空間尺度、工項比例與生活預算感整理出來。</p>
          </div>
          <div class="landing-points">
            <div class="landing-point">
              <strong>先看比例，再談風格</strong>
              <span>先知道哪些條件正在拉高預算，後續才更容易判斷收納、材質與機能如何取捨。</span>
            </div>
            <div class="landing-point">
              <strong>先判斷尺度，再進完整需求</strong>
              <span>還沒整理好所有細節也沒關係，這一層先幫你抓到可以對話的區間。</span>
            </div>
          </div>
        </section>

        <section class="landing-card landing-card-accent">
          <div class="landing-card-header">
            <h2>青曦想保留的感覺</h2>
            <p>即使是估價器，也希望它先傳達空間設計該有的安靜、比例與質地。</p>
          </div>
          <div class="landing-points">
            <div class="landing-point">
              <strong>極簡不是少做，而是少浪費</strong>
              <span>預算先放在真正影響生活感的工程與材質，而不是只堆滿表面裝飾。</span>
            </div>
            <div class="landing-point">
              <strong>質感來自秩序與克制</strong>
              <span>從工項、預備金到下一步，都希望維持清楚而不擁擠的節奏。</span>
            </div>
          </div>
        </section>
      </div>

      <section class="editorial-band" aria-label="青曦估價觀點">
        <div class="editorial-band-copy">
          <p class="editorial-band-eyebrow">QINGXI ESTIMATE NOTES</p>
          <h2>我們希望這份初估，不只是看數字，而是先讓你看見空間感的比例。</h2>
          <p>
            真正有質感的室內設計，往往不是把所有東西都加進去，而是知道哪些要留下、哪些該收斂，
            以及哪些地方值得為未來的生活多預留一點。
          </p>
        </div>
        <div class="editorial-band-points">
          <div class="editorial-band-point">
            <strong>先對齊生活畫面</strong>
            <span>估價之前，先確認這個家是要安靜、耐住、好整理，還是偏向展示與收納並重。</span>
          </div>
          <div class="editorial-band-point">
            <strong>先抓正確比例</strong>
            <span>拆除、水電、防水、櫃體、材質，先把比例抓對，後面的選擇才不容易失衡。</span>
          </div>
          <div class="editorial-band-point">
            <strong>再進完整需求</strong>
            <span>當你已經有預算帶與方向，第二層需求表就能更有效率地往下談。</span>
          </div>
        </div>
      </section>

      <div class="calculator-form" id="estimator-form">
        <div class="form-intro">
          <p class="form-intro-eyebrow">STEP 01</p>
          <h2>先把這次裝修的尺度與生活條件整理清楚。</h2>
          <p>這一頁先回答與預算最有關的條件，讓青曦用更接近設計討論的方式幫你抓到合理區間。</p>
        </div>
        <div class="form-section">
          <h2>基本資訊</h2>

          <div class="form-group">
            <label for="area">室內坪數</label>
            <div class="input-with-unit">
              <input
                type="number"
                id="area"
                min="1"
                max="200"
                value="30"
                step="0.5"
              />
              <span class="unit">坪</span>
            </div>
          </div>

          <div class="form-group">
            <label for="project-type">項目類型</label>
            <select id="project-type">
              <option value="full">全屋裝修</option>
              <option value="partial">局部裝修</option>
              <option value="design-only">純設計</option>
            </select>
          </div>

          <div class="form-group">
            <label for="quality-level">裝修等級</label>
            <select id="quality-level">
              {
                qualityLevelOptions.map(({ value, label }) => (
                  <option value={value} selected={value === "standard"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="form-group">
            <label for="house-condition">屋況條件</label>
            <select id="house-condition">
              {
                houseConditionOptions.map(({ value, label }) => (
                  <option value={value} selected={value === "standard"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="form-group">
            <label for="residence-type">住宅型態</label>
            <select id="residence-type">
              {
                residenceTypeOptions.map(({ value, label }) => (
                  <option value={value} selected={value === "tower"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="form-group">
            <label for="market-benchmark">市場行情基準</label>
            <p class="field-helper">
              這一層會把估價帶對齊你想參考的市場區域，讓前期預算更貼近實際行情。
            </p>
            <select id="market-benchmark">
              <option value="taipei-metro" selected>北北基住宅市場</option>
              <option value="urban-taiwan">全台都會住宅中位帶</option>
              <option value="central-south">中南部都會住宅帶</option>
            </select>
          </div>

          <div class="form-group">
            <label for="use-purpose">使用目的</label>
            <select id="use-purpose">
              {
                usePurposeOptions.map(({ value, label }) => (
                  <option value={value} selected={value === "self"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="form-group">
            <label for="timeline">大概什麼時候開始</label>
            <select id="timeline">
              {
                timelineOptions.map(({ value, label }) => (
                  <option value={value} selected={value === "planned"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="form-group">
            <label for="bathroom-count">衛浴數量</label>
            <select id="bathroom-count">
              <option value="1">1 間衛浴</option>
              <option value="2" selected>2 間衛浴</option>
              <option value="3plus">3 間以上衛浴</option>
            </select>
          </div>

          <div class="form-group">
            <label for="utility-scope">水電更新程度</label>
            <select id="utility-scope">
              <option value="none">不重拉，以局部整理為主</option>
              <option value="partial" selected>局部調整 / 局部換新</option>
              <option value="full">全室重拉水電</option>
            </select>
          </div>

          <div class="form-group" id="storage-kitchen-group" hidden>
            <label for="storage-kitchen-scope">系統櫃 / 廚具納入程度</label>
            <p class="field-helper">
              只有在你勾選 `系統家具` 或 `廚房翻新` 時，才需要補這個強度條件。
            </p>
            <select id="storage-kitchen-scope">
              <option value="none" selected>先不另外放大這兩項預算</option>
              <option value="storage">已知會做系統櫃</option>
              <option value="kitchen">已知會更新廚具</option>
              <option value="both">系統櫃與廚具都會做</option>
            </select>
          </div>
        </div>

        <div class="form-section">
          <h2>裝修項目</h2>

          <div class="checkbox-group">
            {
              renovationItems.map((item, index) => (
                <label class="checkbox-item">
                  <input
                    type="checkbox"
                    value={item.value}
                    checked={index <= 2}
                  />
                  <span class="checkbox-copy">
                    <strong>{item.label}</strong>
                    <small>{item.description}</small>
                  </span>
                </label>
              ))
            }
          </div>
        </div>

        <div class="result-section">
          <p class="result-eyebrow">ESTIMATE OVERVIEW</p>
          <h2>預估結果</h2>
          <p class="result-subtitle" id="result-subtitle">
            先看目前可討論的預算帶。
          </p>
          <div class="logic-summary-card">
            <span class="logic-summary-label">估算邏輯摘要</span>
            <p class="logic-summary-copy" id="logic-summary">
              坪數 x 等級單價 x 條件係數（項目類型、屋況、住宅型態、使用目的、時程與高影響因子）
            </p>
          </div>
          <div class="logic-summary-card logic-summary-card-soft">
            <span class="logic-summary-label">本次拉高預算的條件</span>
            <p class="logic-summary-copy" id="cost-driver-summary">
              目前先依你填入的條件整理主要影響因子。
            </p>
          </div>
          <div class="logic-summary-card logic-summary-card-soft">
            <span class="logic-summary-label">市場校準基準</span>
            <p class="logic-summary-copy" id="market-benchmark-summary">
              目前先以全台住宅裝修常見行情帶做前期校準。
            </p>
          </div>
          <div class="logic-summary-card logic-summary-card-accent">
            <span class="logic-summary-label">即時變動提示</span>
            <p class="logic-summary-copy" id="change-summary">
              調整條件後，系統會告訴你是哪個因素正在影響這次估價。
            </p>
          </div>

          <div class="result-card">
            <div class="result-row">
              <span class="result-label">建議準備總預算</span>
              <span class="result-value" id="recommended-total">190萬 - 318萬</span>
            </div>
            <div class="result-row">
              <span class="result-label">基礎估價</span>
              <span class="result-value" id="total-price">180萬 - 300萬</span>
            </div>
            <div class="result-row">
              <span class="result-label">設計費用</span>
              <span class="result-value" id="design-fee">9萬 - 15萬</span>
            </div>
            <div class="result-row">
              <span class="result-label">工程費用</span>
              <span class="result-value" id="construction-fee"
                >171萬 - 285萬</span
              >
            </div>
            <div class="result-row">
              <span class="result-label">建議預備金</span>
              <span class="result-value" id="reserve-budget">10萬 - 18萬</span>
            </div>
          </div>

          <div class="result-highlights">
            <div class="highlight-pill">
              <span>每坪抓法</span>
              <strong id="per-ping-range">每坪約 6萬 - 10萬</strong>
            </div>
            <div class="highlight-pill">
              <span>目前範圍</span>
              <strong id="scope-summary">全屋裝修 / 3 項工種</strong>
            </div>
          </div>

          <div class="breakdown-card">
            <div class="breakdown-header">
              <h3>工程拆解</h3>
                <p id="breakdown-note">目前為前期比例拆解，先用勾選工項與權重估出落點；實際報價仍會再看尺寸、材質、點位與現場條件。</p>
            </div>
            <div class="breakdown-list" id="breakdown-list"></div>
          </div>

          <div class="advice-grid">
            <div class="advice-card">
              <div class="advice-header">
                <h3>估算判讀</h3>
                <p>只留目前最值得先注意的 2 個重點。</p>
              </div>
              <ul class="advice-list" id="advice-list"></ul>
            </div>
            <div class="advice-card advice-card-accent">
              <div class="advice-header">
                <h3>建議下一步</h3>
                <p id="next-step-intro">先看最適合的下一步就好。</p>
              </div>
              <div class="next-step-points" id="next-step-points"></div>
            </div>
          </div>

          <div class="estimator-handoff-card">
            <div class="estimator-handoff-copy">
              <p class="estimator-handoff-eyebrow">BEST NEXT STEP</p>
              <h3 id="estimator-handoff-title">下一步：把這份初估延伸成完整空間需求</h3>
              <p id="estimator-handoff-description" class="estimator-handoff-description">
                再補需求、照片與時程，青曦就能更快判斷方向。
              </p>
              <div class="estimator-handoff-points">
                <div class="estimator-handoff-point">
                  <strong>不需要重填估算結果</strong>
                  <span>這次試算摘要會一起帶進需求表。</span>
                </div>
                <div class="estimator-handoff-point">
                  <strong id="estimator-handoff-point-title">這一步最有效率</strong>
                  <span id="estimator-handoff-point-description">如果你已經有大致預算方向，就直接往下整理需求。</span>
                </div>
              </div>
            </div>
            <div class="estimator-handoff-actions">
              <a
                href="/requirement-form"
                class="btn btn-primary"
                data-estimator-cta="requirement-form"
              >
                帶著估算結果填完整需求表
              </a>
              <a
                href="/contact?intent=budget-review&source=estimator"
                class="btn btn-secondary"
                data-estimator-cta="contact"
              >
                先帶著結果諮詢
              </a>
              <p class="estimator-handoff-note">若你只想先抓範圍，也可以先保留結果。</p>
            </div>
          </div>

          <div class="report-offer-card">
            <div class="report-offer-copy">
              <p class="report-offer-eyebrow">ESTIMATE FOLLOW-UP</p>
              <h3>如果你想看得更深一點，也可以直接索取這次的拆解判讀。</h3>
              <p class="report-offer-description">
                青曦會依這次條件整理初步拆解方向，幫你更快看懂預算落點。
              </p>
              <div class="report-offer-points">
                <div class="report-offer-point">
                  <strong>這份報告會帶到的重點</strong>
                  <span>預算帶、主要工項與初步判讀。</span>
                </div>
                <div class="report-offer-point">
                  <strong>適合目前這種前期階段</strong>
                  <span id="report-context">特別適合正在抓新成屋或住宅裝修預算方向的人。</span>
                </div>
              </div>
            </div>

            <div class="report-offer-actions">
              <div class="report-form-intro">
                <strong>想直接拿這次的拆解方向</strong>
                <p>留下姓名與 Line / Email，青曦會依這次試算內容接續整理。</p>
              </div>
              {
                !estimatorLeadEnabled && (
                  <div class="report-form-notice" role="status">
                    <p>表單收件尚未完成設定，目前請先透過下方按鈕前往聯絡頁或加入官方 LINE。</p>
                  </div>
                )
              }
              <form
                id="estimator-lead-form"
                action={estimatorLeadAction}
                method="POST"
                class="report-lead-form"
                data-form-enabled={String(estimatorLeadEnabled)}
              >
                <input type="hidden" name="_subject" value="青曦空間設計｜裝修估價器新名單" />
                <input type="hidden" name="_next" value={estimatorLeadSuccessURL} />
                <input type="hidden" name="form_type" value="estimator_inline_lead" />
                <input type="hidden" name="form_stage" value="stage_1_estimator_inline_lead" />
                <input type="hidden" name="lead_intent" id="estimator-lead-intent" value="budget-breakdown-report" />
                <input type="hidden" name="estimator_summary" id="estimator-summary-input" />
                <input type="hidden" name="utm_source" id="estimator-utm-source" />
                <input type="hidden" name="utm_medium" id="estimator-utm-medium" />
                <input type="hidden" name="utm_campaign" id="estimator-utm-campaign" />
                <input type="hidden" name="utm_term" id="estimator-utm-term" />
                <input type="hidden" name="utm_content" id="estimator-utm-content" />
                <input type="hidden" name="landing_page" id="estimator-landing-page" />
                <input type="hidden" name="page_referrer" id="estimator-page-referrer" />

                <div class="report-lead-grid">
                  <label class="report-lead-field">
                    <span>姓名</span>
                    <input type="text" name="name" placeholder="怎麼稱呼你" required />
                  </label>
                  <label class="report-lead-field">
                    <span>Line / Email</span>
                    <input
                      type="text"
                      name="contact_method"
                      placeholder="留下 Line ID 或 Email"
                      required
                    />
                  </label>
                  <label class="report-lead-field report-lead-field-full">
                    <span>想先確認的重點</span>
                    <textarea
                      id="estimator-lead-focus"
                      name="consultation_focus"
                      rows="3"
                      placeholder="例如想先知道預算主要會花在哪裡，或是否適合安排到工作室聊聊"
                      required
                    ></textarea>
                  </label>
                </div>

                <button
                  type="submit"
                  class="btn btn-primary report-lead-submit"
                  disabled={!estimatorLeadEnabled}
                >
                  送出並索取費用拆解報告
                </button>
              </form>
              <a
