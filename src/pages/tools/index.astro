---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getRenovationEstimatorConfig } from "../../lib/contentful.js";

const estimatorConfig = await getRenovationEstimatorConfig();

const qualityLevelLabels = {
  basic: "經濟型",
  standard: "標準型",
  premium: "精緻型",
  luxury: "豪華型",
};

const qualityLevelOptions = Object.entries(qualityLevelLabels).map(
  ([value, label]) => {
    const typedValue = value as keyof typeof qualityLevelLabels;
    const range = estimatorConfig.qualityLevels[typedValue];
    const rangeLabel =
      value === "luxury"
        ? `每坪 ${range.min}萬以上`
        : `每坪 ${range.min}-${range.max}萬`;

    return {
      value,
      label: `${label} (${rangeLabel})`,
    };
  },
);

const estimatorConfigJson = JSON.stringify(estimatorConfig);
---

<BaseLayout
  title="裝修估價器 - 青曦空間設計"
  description="簡單快速估算室內裝修預算，了解您的設計花費範圍"
>
  <div class="calculator-container">
    <div class="calculator-wrapper">
      <div class="calculator-header">
        <p class="eyebrow">RENOVATION ESTIMATOR</p>
        <h1>裝修估價器</h1>
        <p class="subtitle">先抓出預算帶與工程方向，讓你更快知道裝修規模的大致輪廓。</p>
      </div>

      <div class="calculator-form">
        <div class="form-section">
          <h2>基本資訊</h2>

          <div class="form-group">
            <label for="area">室內坪數</label>
            <div class="input-with-unit">
              <input
                type="number"
                id="area"
                min="1"
                max="200"
                value="30"
                step="0.5"
              />
              <span class="unit">坪</span>
            </div>
          </div>

          <div class="form-group">
            <label for="project-type">項目類型</label>
            <select id="project-type">
              <option value="full">全屋裝修</option>
              <option value="partial">局部裝修</option>
              <option value="design-only">純設計</option>
            </select>
          </div>

          <div class="form-group">
            <label for="quality-level">裝修等級</label>
            <select id="quality-level">
              {
                qualityLevelOptions.map(({ value, label }) => (
                  <option value={value} selected={value === "standard"}>
                    {label}
                  </option>
                ))
              }
            </select>
          </div>
        </div>

        <div class="form-section">
          <h2>裝修項目</h2>

          <div class="checkbox-group">
            <label class="checkbox-item">
              <input type="checkbox" value="ceiling" checked />
              <span>天花板工程</span>
            </label>
            <label class="checkbox-item">
              <input type="checkbox" value="floor" checked />
              <span>地板工程</span>
            </label>
            <label class="checkbox-item">
              <input type="checkbox" value="wall" checked />
              <span>牆面工程</span>
            </label>
            <label class="checkbox-item">
              <input type="checkbox" value="kitchen" />
              <span>廚房翻新</span>
            </label>
            <label class="checkbox-item">
              <input type="checkbox" value="bathroom" />
              <span>衛浴翻新</span>
            </label>
            <label class="checkbox-item">
              <input type="checkbox" value="furniture" />
              <span>系統家具</span>
            </label>
          </div>
        </div>

        <div class="result-section">
          <h2>預估結果</h2>

          <div class="result-card">
            <div class="result-row">
              <span class="result-label">預估總價</span>
              <span class="result-value" id="total-price">180萬 - 300萬</span>
            </div>
            <div class="result-row">
              <span class="result-label">設計費用</span>
              <span class="result-value" id="design-fee">9萬 - 15萬</span>
            </div>
            <div class="result-row">
              <span class="result-label">工程費用</span>
              <span class="result-value" id="construction-fee"
                >171萬 - 285萬</span
              >
            </div>
          </div>

          <div class="disclaimer">
            <p>{estimatorConfig.disclaimer}</p>
          </div>

          <div class="cta-buttons">
            <a href="/contact" class="btn btn-primary">聯絡我們</a>
            <a href="/requirement-form" class="btn btn-secondary">填寫需求表</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .calculator-container {
    padding: 4.75rem 1.5rem 5rem;
    background:
      radial-gradient(circle at top left, rgba(160, 217, 217, 0.1), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(244, 245, 244, 1) 100%);
  }

  .calculator-wrapper {
    max-width: 960px;
    margin: 0 auto;
  }

  .calculator-header {
    text-align: center;
    margin-bottom: 2.4rem;
  }

  .eyebrow {
    margin: 0 0 0.9rem;
    color: var(--tiffany-dark);
    font-size: 0.8rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .calculator-header h1 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(2.3rem, 4vw, 4rem);
    font-weight: 500;
    color: var(--gray-darkest);
    letter-spacing: 0.05em;
  }

  .subtitle {
    max-width: 40rem;
    margin: 1rem auto 0;
    color: var(--gray-medium);
    font-size: 1rem;
    line-height: 1.9;
  }

  .calculator-form {
    background: rgba(255, 255, 255, 0.9);
    border-radius: 32px;
    padding: 2.1rem;
    box-shadow: 0 28px 60px rgba(47, 47, 47, 0.06);
    border: 1px solid rgba(129, 199, 212, 0.16);
  }

  .form-section {
    margin-bottom: 1.5rem;
    padding: 1.6rem;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 249, 248, 1) 100%);
    border: 1px solid rgba(129, 199, 212, 0.12);
  }

  .form-section:last-child {
    margin-bottom: 0;
  }

  .form-section h2 {
    margin: 0 0 1.25rem;
    font-family: "Noto Serif TC", serif;
    font-size: 1.45rem;
    color: var(--gray-darkest);
    letter-spacing: 0.04em;
  }

  .form-group {
    margin-bottom: 1.1rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.55rem;
    font-weight: 500;
    color: var(--gray-dark);
  }

  .input-with-unit {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .input-with-unit input {
    flex: 1;
  }

  .unit {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--gray-medium);
  }

  input[type="number"],
  select {
    width: 100%;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(129, 199, 212, 0.18);
    border-radius: 16px;
    font-size: 1rem;
    color: var(--gray-darkest);
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
    background: rgba(255, 255, 255, 0.92);
  }

  input[type="number"]:focus,
  select:focus {
    outline: none;
    border-color: rgba(129, 199, 212, 0.46);
    box-shadow: 0 0 0 4px rgba(129, 199, 212, 0.12);
    transform: translateY(-1px);
  }

  .checkbox-group {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.85rem;
  }

  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 58px;
    padding: 0.9rem 1rem;
    border: 1px solid rgba(129, 199, 212, 0.16);
    border-radius: 18px;
    cursor: pointer;
    transition: transform 0.25s ease, border-color 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
    background: rgba(255, 255, 255, 0.82);
  }

  .checkbox-item:hover {
    background: rgba(245, 250, 250, 1);
    border-color: rgba(129, 199, 212, 0.34);
    box-shadow: 0 12px 22px rgba(47, 47, 47, 0.04);
    transform: translateY(-1px);
  }

  .checkbox-item input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: var(--tiffany-primary);
  }

  .checkbox-item input[type="checkbox"]:checked + span {
    color: var(--tiffany-dark);
    font-weight: 500;
  }

  .result-section {
    margin-top: 1.5rem;
    padding: 2rem;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.14), transparent 28%),
      linear-gradient(135deg, rgba(247, 250, 250, 1) 0%, rgba(255, 255, 255, 1) 100%);
    border: 1px solid rgba(129, 199, 212, 0.16);
  }

  .result-section h2 {
    margin-bottom: 1.2rem;
  }

  .result-card {
    background: rgba(255, 255, 255, 0.92);
    padding: 1.5rem;
    border-radius: 22px;
    margin-bottom: 1.5rem;
    box-shadow: 0 18px 32px rgba(47, 47, 47, 0.04);
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(47, 47, 47, 0.08);
  }

  .result-row:last-child {
    border-bottom: none;
  }

  .result-label {
    font-size: 1rem;
    color: var(--gray-medium);
  }

  .result-value {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--tiffany-dark);
  }

  .result-row:first-child .result-value {
    font-size: 1.5rem;
    color: var(--gray-darkest);
  }

  .disclaimer {
    background: rgba(255, 255, 255, 0.92);
    padding: 1rem 1.1rem;
    border-radius: 18px;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(129, 199, 212, 0.16);
  }

  .disclaimer p {
    color: var(--gray-medium);
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.6;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .btn {
    flex: 1;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 500;
    text-align: center;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease, border-color 0.25s ease;
    font-size: 1rem;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--tiffany-dark) 100%);
    color: var(--white);
    border: 1px solid var(--gray-darkest);
  }

  .btn-primary:hover {
    border-color: var(--gray-darkest);
    transform: translateY(-2px);
    box-shadow: 0 18px 28px rgba(47, 47, 47, 0.18);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.92);
    color: var(--gray-darkest);
    border: 1px solid rgba(129, 199, 212, 0.22);
  }

  .btn-secondary:hover {
    background: rgba(245, 250, 250, 1);
    transform: translateY(-2px);
    box-shadow: 0 14px 24px rgba(129, 199, 212, 0.12);
  }

  @media (max-width: 768px) {
    .calculator-container {
      padding: 4rem 1.25rem 4rem;
    }

    .calculator-form {
      padding: 1.3rem;
      border-radius: 24px;
    }

    .form-section,
    .result-section,
    .result-card {
      padding: 1.25rem;
      border-radius: 20px;
    }

    .checkbox-group {
      grid-template-columns: 1fr;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .result-value {
      font-size: 1.1rem;
    }

    .result-row:first-child .result-value {
      font-size: 1.3rem;
    }
  }
</style>

<script type="application/json" id="estimator-config" set:html={estimatorConfigJson}></script>
<script>
  // Calculator logic
  const estimatorConfig = JSON.parse(
    document.getElementById("estimator-config")?.textContent || "{}",
  );
  const areaInput = document.getElementById("area") as HTMLInputElement;
  const projectType = document.getElementById(
    "project-type",
  ) as HTMLSelectElement;
  const qualityLevel = document.getElementById(
    "quality-level",
  ) as HTMLSelectElement;
  const totalPrice = document.getElementById("total-price");
  const designFee = document.getElementById("design-fee");
  const constructionFee = document.getElementById("construction-fee");

  function calculate() {
    const area = parseFloat(areaInput.value) || 30;
    const pricePerPing =
      estimatorConfig.qualityLevels?.[qualityLevel.value] ||
      estimatorConfig.qualityLevels?.standard || { min: 6, max: 10 };
    const multiplier =
      estimatorConfig.projectTypeMultipliers?.[projectType.value] ?? 1;
    const designFeePerPing = estimatorConfig.designFeePerPing || {
      min: 3,
      max: 5,
    };

    const minTotal = Math.round(area * pricePerPing.min * multiplier);
    const maxTotal = Math.round(area * pricePerPing.max * multiplier);

    const minDesign = Math.round(area * designFeePerPing.min);
    const maxDesign = Math.round(area * designFeePerPing.max);

    const minConstruction = minTotal - minDesign;
    const maxConstruction = maxTotal - maxDesign;

    if (totalPrice && designFee && constructionFee) {
      totalPrice.textContent = `${minTotal}萬 - ${maxTotal}萬`;
      designFee.textContent = `${minDesign}萬 - ${maxDesign}萬`;
      constructionFee.textContent = `${minConstruction}萬 - ${maxConstruction}萬`;
    }
  }

  // Add event listeners
  if (areaInput && projectType && qualityLevel) {
    areaInput.addEventListener("input", calculate);
    projectType.addEventListener("change", calculate);
    qualityLevel.addEventListener("change", calculate);

    // Initial calculation
    calculate();
  }
</script>
