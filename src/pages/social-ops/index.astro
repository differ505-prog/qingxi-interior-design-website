  function buildVendorIntakeCannedReply(shareUrl) {
    return [
      "若您有穩定承接相關工種，歡迎填這個合作工班資料登錄頁，留下必要聯絡方式與服務資料。",
      "表單會請您簡單填寫工種、服務區域、較擅長商空 / 武場或住宅裝潢，以及工法傾向；若方便，也可附上常用單價表、報價單範例，或去識別後的報價樣本。",
      "資料僅供青曦內部評估與建立合作名單，不會對外公開；若案件方向適合，我們會再主動聯繫。",
      shareUrl,
