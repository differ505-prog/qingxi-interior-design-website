    const modeState = getCurrentTopicModeState(mode);
    const recommendation = getPrimaryReviewRecommendation(mode);
    if (!recommendation) return "";

    return [
      `決題模式：${modeState?.label || mode}`,
      `模式判斷：${modeState?.modeRationale || "尚未產生"}`,
      `主攻書系：${recommendation.focusTrackTitle}`,
      `這次補位：${recommendation.trackTitle}`,
      `章節：${recommendation.chapter}`,
      `子章節：${recommendation.subchapter}`,
      `網站分類：${recommendation.category}`,
      `統一標題：${getDisplayTitle(recommendation)}`,
      `備選 1：${recommendation.backupTitles?.[0] || "無"}`,
      `備選 2：${recommendation.backupTitles?.[1] || "無"}`,
      `推薦原因：${recommendation.reason}`,
      `補前完成度：${recommendation.coverageBefore}%`,
      `補後完成度：${recommendation.coverageAfter}%`,
