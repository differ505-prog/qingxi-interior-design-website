  function renderReviewNextTopicPanel(modeState = getCurrentTopicModeState(currentTopicMode)) {
    const panel = document.getElementById("review-next-topic-panel");
    const mode = document.getElementById("review-next-topic-mode");
    const title = document.getElementById("review-next-topic-title");
    const meta = document.getElementById("review-next-topic-meta");
    const riskBadge = document.getElementById("review-next-topic-risk-badge");
    const riskNote = document.getElementById("review-next-topic-risk-note");
    const similarList = document.getElementById("review-next-topic-similar-list");
    const blocker = document.getElementById("review-next-topic-blocker");
    if (
      !(panel instanceof HTMLElement) ||
      !(mode instanceof HTMLElement) ||
      !(title instanceof HTMLElement) ||
      !(meta instanceof HTMLElement) ||
      !(riskBadge instanceof HTMLElement) ||
      !(riskNote instanceof HTMLElement) ||
      !(similarList instanceof HTMLElement) ||
      !(blocker instanceof HTMLElement)
    ) {
      return;
    }

    const recommendation = getPrimaryReviewRecommendation(currentTopicMode);
    const focusTrack = modeState?.publishingDashboard?.focusTrack;
    if (!recommendation || !focusTrack) {
      title.textContent = "待 Gemini Pro 遞補";
      mode.textContent = "會跟內容書架同步";
      meta.textContent = "切換決題模式後，這裡會同步更新送審候選。";
      applyRiskBadge(riskBadge, "low", "規則初篩低相近");
      riskNote.textContent = "以下僅為規則層送審前初篩，最終以高階 LLM 覆核為準。";
      blocker.textContent = "";
      blocker.classList.remove("is-visible");
      renderSimilarArticleList(similarList, null);
      return;
    }

    mode.textContent = `${modeState?.label || currentTopicMode}｜${focusTrack.title} 尚差 ${focusTrack.remainingToBaseline} 篇`;
    title.textContent = getDisplayTitle(recommendation);
    meta.textContent = `${recommendation.chapter} / ${recommendation.subchapter} / ${recommendation.category}｜${recommendation.reason}`;
    applyRiskBadge(riskBadge, recommendation.collisionRisk, "規則初篩低相近");
    riskNote.textContent = recommendation.collisionReason;
    blocker.textContent =
      getChronologyWarningMessage(recommendation, focusTrack) ||
      getDependencyLockMessage(recommendation, focusTrack) ||
      getStateSyncWarningMessage(articleAiResult, currentTopicMode) ||
      getRecommendationBlockerMessage(recommendation);
    blocker.classList.toggle("is-visible", Boolean(blocker.textContent));
    renderSimilarArticleList(similarList, recommendation);
  }

  function savePublishingReviewFilter() {
    localStorage.setItem(
      PUBLISHING_REVIEW_FILTER_KEY,
      JSON.stringify({ showUnpublishedOnly: publishingReviewShowUnpublishedOnly }),
    );
  }

  function loadPublishingReviewFilter() {
    try {
      const raw = localStorage.getItem(PUBLISHING_REVIEW_FILTER_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      publishingReviewShowUnpublishedOnly = Boolean(parsed?.showUnpublishedOnly);
    } catch (error) {
      console.error("讀取出版閉環篩選失敗：", error);
      publishingReviewShowUnpublishedOnly = false;
    }
  }

