---
import BaseLayout from "../../layouts/BaseLayout.astro";

const defaultGroups = [
  {
    id: "group-1654316948220005",
    alias: "社團入口 A",
    groupId: "1654316948220005",
    url: "https://www.facebook.com/groups/1654316948220005/",
    note: "先掃在地修繕題。",
  },
  {
    id: "group-679286528824529",
    alias: "社團入口 B",
    groupId: "679286528824529",
    url: "https://www.facebook.com/groups/679286528824529",
    note: "補第二輪搜尋。",
  },
  {
    id: "group-163175389244849",
    alias: "社團入口 C",
    groupId: "163175389244849",
    url: "https://www.facebook.com/groups/163175389244849",
    note: "沒好題時補掃。",
  },
];

const defaultGroupsJson = JSON.stringify(defaultGroups);
---

<BaseLayout
  title="設計師工作面板 - 青曦空間設計"
  description="青曦內部使用的設計師工作面板，以遊戲化任務節奏管理社群導流行動。"
  noindex={true}
>
  <section class="social-ops-page">
    <div class="social-ops-shell">
      <header class="ops-hero">
        <div class="hero-copy">
          <p class="ops-eyebrow">DESIGNER WORK PANEL</p>
          <h1>設計師工作面板</h1>
          <p class="ops-description">
            開頁就做，做完就劃掉。
          </p>
          <div class="hero-actions">
            <a href="#quest-board" class="btn btn-primary">開始本週任務</a>
            <a href="#portal-grid" class="btn btn-secondary">前往社團傳送門</a>
            <button type="button" id="reset-social-ops" class="btn btn-secondary btn-muted">重設本週任務</button>
          </div>
          <p id="ops-feedback" class="ops-feedback" aria-live="polite"></p>
        </div>

        <div class="hero-command-panel">
          <div class="command-badge">
            <span>當前職階</span>
            <strong id="rank-title">Apprentice Operator</strong>
            <small id="level-value">Lv.1</small>
          </div>
          <div class="command-metrics">
            <article class="metric-card metric-card-primary">
              <span>本週主線</span>
              <strong id="weekly-progress-count">0 / 3</strong>
              <small id="weekly-progress-note">還差 3 個任務</small>
              <div class="progress-track">
                <div id="weekly-progress-bar" class="progress-bar"></div>
              </div>
            </article>
            <article class="metric-card">
              <span>總 XP</span>
              <strong id="xp-value">0 XP</strong>
              <small>完成任務自動累積</small>
            </article>
            <article class="metric-card">
              <span>連勝週數</span>
              <strong id="streak-value">0</strong>
              <small>每週達標才延續</small>
            </article>
            <article class="metric-card">
              <span>累積通關</span>
              <strong id="lifetime-runs-value">0</strong>
              <small>已完成任務數</small>
            </article>
          </div>
        </div>
      </header>

      <div class="ops-grid">
        <div class="ops-main">
          <section id="quest-board" class="ops-panel quest-board">
            <div class="panel-heading">
              <div>
                <p class="panel-tag">WEEKLY QUESTS</p>
                <h2>本週主線任務</h2>
              </div>
              <p>找到題目、回覆、導流。</p>
            </div>
            <div id="quest-grid" class="quest-grid"></div>
          </section>

          <section id="portal-grid" class="ops-panel portal-board">
            <div class="panel-heading">
              <div>
                <p class="panel-tag">GROUP PORTALS</p>
                <h2>社團傳送門</h2>
              </div>
              <p>只留直接可用入口。</p>
            </div>
            <div id="portal-card-grid" class="portal-card-grid"></div>
          </section>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ defaultGroupsJson }}>
  const STORAGE_KEY = "qingxi-social-ops-v2";
  const WEEKLY_TARGET = 3;
  const RUN_XP = 100;
  const WEEKLY_BONUS_XP = 50;
  const groupTemplate = JSON.parse(defaultGroupsJson);
  const rankTitles = [
    "Apprentice Operator",
    "Lead Hunter",
    "Signal Captain",
    "Market Commander",
    "Pipeline CEO",
    "Empire Architect",
  ];

  function getWeekKey(date = new Date()) {
    const target = new Date(date);
    const day = target.getDay() || 7;
    target.setHours(0, 0, 0, 0);
    target.setDate(target.getDate() + 4 - day);
    const yearStart = new Date(target.getFullYear(), 0, 1);
    const weekNo = Math.ceil((((target - yearStart) / 86400000) + 1) / 7);
    return `${target.getFullYear()}-W${String(weekNo).padStart(2, "0")}`;
  }

  function createRun(slot, keyword, title, guidance) {
    return {
      id: `run-${slot}`,
      slot,
      keyword,
      title,
      guidance,
      actionSearch: false,
      actionAdvice: false,
      actionArticle: false,
      rewardClaimed: false,
      completedAt: "",
    };
  }

  function createWeeklyRuns() {
    return [
      createRun(1, "南港", "Quest 01｜南港主線", "先解在地修繕問題，再附最貼近的痛點文。"),
      createRun(2, "汐止", "Quest 02｜汐止主線", "挑一題，快速完成。"),
      createRun(3, "自由掃場", "Quest 03｜自由補刀", "自由補一題。"),
    ];
  }

  function createInitialState() {
    return {
      weekly: {
        weekKey: getWeekKey(),
        bonusClaimed: false,
        runs: createWeeklyRuns(),
      },
      stats: {
        xp: 0,
        streak: 0,
        lifetimeRuns: 0,
      },
    };
  }

  let state = createInitialState();

  function saveState() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      state = {
        weekly: parsed.weekly || createInitialState().weekly,
        stats: {
          ...createInitialState().stats,
          ...(parsed.stats || {}),
        },
      };
    } catch (error) {
      console.error("讀取社群作戰台資料失敗：", error);
    }
  }

  function isRunComplete(run) {
    return run.actionSearch && run.actionAdvice && run.actionArticle;
  }

  function normalizeWeeklyState() {
    const currentWeekKey = getWeekKey();
    if (state.weekly.weekKey === currentWeekKey) return;

    const completedRuns = state.weekly.runs.filter(isRunComplete).length;
    state.stats.streak = completedRuns >= WEEKLY_TARGET ? state.stats.streak + 1 : 0;
    state.weekly = {
      weekKey: currentWeekKey,
      bonusClaimed: false,
      runs: createWeeklyRuns(),
    };
    saveState();
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function setFeedback(message, mode = "") {
    const shell = document.getElementById("ops-feedback");
    if (!shell) return;
    shell.className = `ops-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function getCompletedRunCount() {
    return state.weekly.runs.filter(isRunComplete).length;
  }

  function getLevel() {
    return Math.floor(state.stats.xp / 200) + 1;
  }

  function getRankTitle(level) {
    return rankTitles[Math.min(level - 1, rankTitles.length - 1)];
  }

  function maybeClaimRunReward(run) {
    if (!isRunComplete(run) || run.rewardClaimed) return;
    run.rewardClaimed = true;
    run.completedAt = new Date().toISOString();
    state.stats.xp += RUN_XP;
    state.stats.lifetimeRuns += 1;

    const completedRuns = getCompletedRunCount();
    if (completedRuns >= WEEKLY_TARGET && !state.weekly.bonusClaimed) {
      state.weekly.bonusClaimed = true;
      state.stats.xp += WEEKLY_BONUS_XP;
      setFeedback("本週三個任務已全清，已領取 +50 XP 額外獎勵。", "is-success");
    }
  }

  function renderHero() {
    const completedRuns = getCompletedRunCount();
    const remaining = Math.max(WEEKLY_TARGET - completedRuns, 0);
    const percent = Math.round((completedRuns / WEEKLY_TARGET) * 100);
    const level = getLevel();
    document.getElementById("weekly-progress-count").textContent = `${completedRuns} / ${WEEKLY_TARGET}`;
    document.getElementById("weekly-progress-note").textContent = remaining === 0
      ? "本週已清空。"
      : `還差 ${remaining} 個任務`;
    document.getElementById("weekly-progress-bar").style.width = `${percent}%`;
    document.getElementById("xp-value").textContent = `${state.stats.xp} XP`;
    document.getElementById("streak-value").textContent = String(state.stats.streak);
    document.getElementById("lifetime-runs-value").textContent = String(state.stats.lifetimeRuns);
    document.getElementById("level-value").textContent = `Lv.${level}`;
    document.getElementById("rank-title").textContent = getRankTitle(level);
  }

  function renderQuests() {
    const shell = document.getElementById("quest-grid");
    if (!shell) return;

    shell.innerHTML = state.weekly.runs
      .map((run, index) => {
        const complete = isRunComplete(run);

        return `
          <article class="quest-card ${complete ? "is-complete" : ""}">
            <div class="quest-topline">
              <span class="quest-slot">RUN ${run.slot}</span>
              <span class="quest-keyword">${escapeHtml(run.keyword)}</span>
            </div>
            <h3>${escapeHtml(run.title)}</h3>
            <p class="quest-guidance">${escapeHtml(run.guidance)}</p>
            <div class="quest-checklist">
              <label class="quest-check ${run.actionSearch ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionSearch" ${run.actionSearch ? "checked" : ""} />
                <span>已進場找題</span>
              </label>
              <label class="quest-check ${run.actionAdvice ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionAdvice" ${run.actionAdvice ? "checked" : ""} />
                <span>已給專業建議</span>
              </label>
              <label class="quest-check ${run.actionArticle ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionArticle" ${run.actionArticle ? "checked" : ""} />
                <span>已附痛點文導流</span>
              </label>
            </div>
            <div class="quest-footer">
              <small>${complete ? `CLEAR：${new Date(run.completedAt).toLocaleString("zh-TW")}` : "清空三格 +100 XP"}</small>
              <strong>${complete ? "Quest Cleared" : "Quest Active"}</strong>
            </div>
          </article>
        `;
      })
      .join("");
  }

  function renderPortals() {
    const shell = document.getElementById("portal-card-grid");
    if (!shell) return;

    shell.innerHTML = groupTemplate
      .map((group) => `
        <article class="portal-card">
          <div class="portal-card-top">
            <span class="portal-card-label">${escapeHtml(group.alias)}</span>
          </div>
          <p>${escapeHtml(group.note)}</p>
          <div class="portal-actions">
            <a class="portal-link primary-link" href="${escapeHtml(group.url)}" target="_blank" rel="noreferrer">開啟社團</a>
          </div>
        </article>
      `)
      .join("");
  }

  function rerender() {
    renderHero();
    renderQuests();
    renderPortals();
    saveState();
  }

  document.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    if (!target.dataset.runCheck) return;

    const index = Number(target.dataset.runIndex);
    const key = target.dataset.runCheck;
    const run = state.weekly.runs[index];
    if (!run || !key) return;

    run[key] = target.checked;
    maybeClaimRunReward(run);
    rerender();
  });

  document.getElementById("reset-social-ops")?.addEventListener("click", () => {
    state.weekly = {
      weekKey: getWeekKey(),
      bonusClaimed: false,
      runs: createWeeklyRuns(),
    };
    rerender();
    setFeedback("本週任務已重設，XP 與連勝保留。", "is-warning");
  });

  loadState();
  normalizeWeeklyState();
  rerender();
</script>

<style>
  .social-ops-page {
    padding: 5rem 1.25rem 6rem;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 22%),
      radial-gradient(circle at right top, rgba(196, 196, 188, 0.08), transparent 24%),
      linear-gradient(180deg, #121212 0%, #171717 44%, #1d1d1c 100%);
    color: #f0efeb;
    font-family: "Noto Sans TC", sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .social-ops-shell {
    max-width: 1220px;
    margin: 0 auto;
  }

  .social-ops-page a,
  .social-ops-page a:any-link,
  .social-ops-page a:link,
  .social-ops-page a:visited,
  .social-ops-page a:hover,
  .social-ops-page a:active {
    color: inherit;
    text-decoration: none;
  }

  .social-ops-shell {
    max-width: 1320px;
    margin: 0 auto;
    display: grid;
    gap: 1.5rem;
  }

  .ops-hero,
  .ops-panel {
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(44, 44, 44, 0.92), rgba(27, 27, 28, 0.94));
    box-shadow:
      0 28px 72px rgba(0, 0, 0, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(18px);
  }

  .ops-hero {
    padding: clamp(1.5rem, 3vw, 2.4rem);
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.9fr);
  }

  .ops-eyebrow,
  .panel-tag,
  .quest-slot,
  .portal-card-label,
  .article-state {
    margin: 0;
    letter-spacing: 0.22em;
    font-size: 0.74rem;
    color: rgba(215, 213, 206, 0.56);
  }

  .hero-copy h1 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(2.45rem, 4vw, 4rem);
    line-height: 1.04;
    letter-spacing: 0.02em;
    color: #f7f6f2;
  }

  .ops-description {
    margin: 0.85rem 0 0;
    max-width: 520px;
    color: rgba(233, 231, 225, 0.68);
    font-size: 0.98rem;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.95rem;
    margin-top: 1.55rem;
  }

  .hero-actions .btn {
    min-height: 52px;
    padding: 0.92rem 1.35rem;
    border-radius: 18px;
    border-width: 1px;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    box-shadow: 0 16px 28px rgba(0, 0, 0, 0.16);
  }

  .hero-actions .btn.btn-primary {
    background: linear-gradient(180deg, rgba(247, 246, 241, 0.18), rgba(201, 197, 188, 0.12));
    border-color: rgba(247, 246, 241, 0.18);
    color: #f7f6f2;
  }

  .hero-actions .btn.btn-secondary {
    background: linear-gradient(180deg, rgba(248, 247, 243, 0.12), rgba(255, 255, 255, 0.04));
    border-color: rgba(255, 255, 255, 0.1);
    color: #ece9e2;
  }

  .hero-actions .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 30px rgba(0, 0, 0, 0.18);
  }

  .ops-feedback {
    min-height: 1.5rem;
    margin: 0.95rem 0 0;
    color: rgba(233, 231, 225, 0.68);
    font-size: 0.92rem;
  }

  .ops-feedback.is-success {
    color: #e8e8e3;
  }

  .ops-feedback.is-warning {
    color: #d9d2c6;
  }

  .hero-command-panel,
  .command-metrics,
  .ops-grid,
  .ops-main,
  .quest-grid,
  .portal-card-grid {
    display: grid;
    gap: 1rem;
  }

  .command-badge,
  .metric-card,
  .quest-card,
  .portal-card {
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(64, 64, 63, 0.68), rgba(40, 40, 39, 0.8));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 14px 34px rgba(0, 0, 0, 0.14);
  }

  .command-badge {
    padding: 1.2rem 1.2rem 1rem;
    background:
      radial-gradient(circle at top left, rgba(244, 242, 236, 0.1), transparent 42%),
      linear-gradient(180deg, rgba(74, 74, 72, 0.96), rgba(41, 41, 40, 0.96));
  }

  .command-badge span,
  .metric-card span,
  .metric-card small,
  .quest-guidance,
  .quest-footer small,
  .portal-card p,
  .panel-heading p {
    color: rgba(230, 228, 222, 0.66);
  }

  .command-badge strong {
    display: block;
    margin-top: 0.45rem;
    font-size: 1.62rem;
    letter-spacing: 0.01em;
    color: #f7f6f2;
  }

  .command-badge small {
    display: inline-flex;
    margin-top: 0.45rem;
    color: rgba(215, 213, 206, 0.72);
  }

  .command-metrics {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .metric-card {
    padding: 1rem 1.05rem;
  }

  .metric-card strong {
    display: block;
    margin-top: 0.32rem;
    font-size: 1.62rem;
    letter-spacing: -0.01em;
    color: #f7f6f2;
  }

  .metric-card-primary {
    grid-column: 1 / -1;
    background:
      radial-gradient(circle at top right, rgba(236, 234, 228, 0.12), transparent 40%),
      linear-gradient(180deg, rgba(82, 82, 80, 0.98), rgba(44, 44, 43, 0.96));
  }

  .progress-track {
    margin-top: 0.85rem;
    height: 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.09);
    overflow: hidden;
  }

  .progress-bar {
    width: 0;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #e9e6df, #a9a59b);
    transition: width 0.35s ease;
  }

  .ops-grid {
    grid-template-columns: 1fr;
    align-items: start;
  }

  .ops-panel {
    padding: 1.35rem;
  }

  .panel-heading {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1.15rem;
  }

  .panel-heading h2 {
    margin: 0.2rem 0 0;
    font-family: "Noto Serif TC", serif;
    font-size: 1.5rem;
    letter-spacing: 0.02em;
    color: #f5f3ef;
  }

  .panel-heading p {
    margin: 0;
    max-width: 280px;
    line-height: 1.7;
    font-size: 0.92rem;
  }

  .quest-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .portal-card-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .quest-card,
  .portal-card {
    padding: 1.15rem;
  }

  .quest-card {
    position: relative;
    overflow: hidden;
  }

  .quest-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.08), transparent 30%);
    pointer-events: none;
  }

  .quest-card.is-complete {
    border-color: rgba(255, 255, 255, 0.18);
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.08), transparent 34%),
      linear-gradient(180deg, rgba(74, 74, 76, 0.84), rgba(49, 49, 51, 0.92));
  }

  .quest-topline,
  .portal-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .quest-topline {
    justify-content: space-between;
    align-items: center;
  }

  .quest-keyword {
    display: inline-flex;
    padding: 0.34rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(236, 234, 227, 0.74);
    font-size: 0.82rem;
  }

  .quest-card h3,
  .portal-card h3 {
    margin: 0.7rem 0 0;
    color: #f7f6f2;
    font-size: 1.16rem;
    letter-spacing: 0.015em;
  }

  .quest-guidance {
    margin: 0.72rem 0 0;
    line-height: 1.7;
    font-size: 0.93rem;
  }

  .quest-checklist {
    display: grid;
    gap: 0.7rem;
    margin-top: 1rem;
  }

  .quest-check {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.78rem 0.88rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.035);
    color: #f1efea;
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .quest-check.is-checked {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.09);
    color: rgba(244, 244, 242, 0.72);
  }

  .quest-check.is-checked span {
    text-decoration: line-through;
    text-decoration-thickness: 2px;
  }

  .quest-check input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: #dbdbd6;
  }

  .social-ops-page :global(.portal-link) {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    min-height: 54px;
    padding: 0.95rem 1.1rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: linear-gradient(180deg, rgba(249, 248, 244, 0.15), rgba(255, 255, 255, 0.045));
    color: #f1efea !important;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    box-shadow: 0 18px 28px rgba(0, 0, 0, 0.16);
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease, color 0.25s ease;
  }

