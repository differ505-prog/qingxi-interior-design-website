---
import BaseLayout from "../../layouts/BaseLayout.astro";
import * as contentful from "contentful";
import { geminiCanvasMaster } from "../../lib/gemini-canvas-master";

const defaultSources = [
  {
    id: "group-1654316948220005",
    alias: "汐止集團｜汐止人交流｜大小事",
    platform: "Facebook",
    url: "https://www.facebook.com/groups/1654316948220005/",
  },
  {
    id: "group-679286528824529",
    alias: "內湖 & 松山 & 南港 & 汐止 集團",
    platform: "Facebook",
    url: "https://www.facebook.com/groups/679286528824529",
  },
  {
    id: "group-163175389244849",
    alias: "汐止 南港 台北 新北 租屋 買賣網",
    platform: "Facebook",
    url: "https://www.facebook.com/groups/163175389244849",
  },
  {
    id: "line-community-1",
    alias: "南港人內湖人店家房市大小事",
    platform: "LINE",
    url: "https://line.me/ti/g2/PqRgmGp0TD6NdO_mU2Cp5NZEUCjU6UeE1hrrXw?utm_source=invitation&utm_medium=link_copy&utm_campaign=default",
  },
  {
    id: "line-community-2",
    alias: "南港內湖生活圈討論群",
    platform: "LINE",
    url: "https://line.me/ti/g2/hc7WHOLh4D5ZKYgSiA7cW1klztRTtza3CMK4PA?utm_source=invitation&utm_medium=link_copy&utm_campaign=default",
  },
  {
    id: "google-business",
    alias: "Google 商家編輯",
    platform: "Google",
    url: "https://www.google.com/search?q=%E9%9D%92%E6%9B%A6%E7%A9%BA%E9%96%93%E8%A8%AD%E8%A8%88&stick=H4sIAAAAAAAA_wE8AMP_CAYiIzB4Y2Y1NzIzYWQyN2I2OGVmOjB4MzMzYmU1YWI0ZDAxYjBiogUS6Z2S5pum56m66ZaT6Kit6KiI6b38AjwAAAA&hl=zh-TW&mat=CZzruPD9kuTbElcBa0lj_0QRxYoywBlV9k9DYHoy-VFRkTjl1IkHR0qufOOE0MNc1wkNSVfDEkXxAJyYs12m8HUMY9ODzhD28iMbxLDtTMqjl02vI5c77ni0KGBTZjiz2vc&authuser=9",
  },
];

const fallbackBlogPosts = [
  {
    title: "畫出家的神經系統——全屋開關與插座的最適定位",
    slug: "whole-house-switch-socket-positioning",
    date: "2025-11-12",
    summary: "整理全屋開關與插座定位原則，從生活動線、家具尺寸到常見錯誤，幫助裝修前先把隱蔽工程規劃清楚。",
    category: "水電篇",
  },
];

let blogPosts = [...fallbackBlogPosts];
let blogSyncLabel = "目前先顯示已存在文章。";

try {
  if (import.meta.env.CONTENTFUL_SPACE_ID && import.meta.env.CONTENTFUL_ACCESS_TOKEN) {
    const client = contentful.createClient({
      space: import.meta.env.CONTENTFUL_SPACE_ID,
      accessToken: import.meta.env.CONTENTFUL_ACCESS_TOKEN,
      environment: "master",
    });

    const response = await client.getEntries({
      content_type: "blogPost",
      order: ["-fields.date"],
    });

    const syncedPosts = response.items.map((item: any) => ({
      title: item.fields.title,
      slug: item.fields.slug,
      date: new Date(item.fields.date).toISOString().split("T")[0],
      summary: item.fields.summary,
      category: item.fields.category,
    }));

    if (syncedPosts.length > 0) {
      const postMap = new Map(
        [...fallbackBlogPosts, ...syncedPosts].map((post) => [post.slug, post]),
      );
      blogPosts = Array.from(postMap.values()).sort((a, b) => b.date.localeCompare(a.date));
      blogSyncLabel = `已同步 ${syncedPosts.length} 篇知識文章。`;
    } else {
      blogSyncLabel = "Contentful 目前無文章，先顯示已存在文章。";
    }
  } else {
    blogSyncLabel = "未連接 Contentful，先顯示已存在文章。";
  }
} catch (error) {
  console.error("讀取知識分享文章失敗：", error);
  blogSyncLabel = "同步失敗，先顯示已存在文章。";
}

const defaultSourcesJson = JSON.stringify(defaultSources);
const blogPostsJson = JSON.stringify(blogPosts);
const blogCategoryCount = new Set(blogPosts.map((post) => post.category)).size;
const geminiCanvasMasterJson = JSON.stringify(geminiCanvasMaster);
---

<BaseLayout
  title="設計師工作面板 - 青曦空間設計"
  description="青曦內部使用的設計師工作面板，只留必要任務、進度與來源入口。"
  noindex={true}
>
  <section class="social-ops-page">
    <div class="social-ops-shell">
      <header class="ops-hero">
        <div class="hero-copy">
          <p class="ops-eyebrow">青曦內部面板</p>
          <h1>設計師工作面板</h1>
          <p class="ops-description">
            一週任選三題，做完即可。
          </p>
          <div class="hero-actions">
            <a href="#quest-board" class="btn btn-primary">開始本週任務</a>
            <a href="#portal-grid" class="btn btn-secondary">前往來源入口</a>
            <button type="button" id="reset-social-ops" class="btn btn-tertiary">重設</button>
          </div>
          <p id="ops-feedback" class="ops-feedback" aria-live="polite"></p>
        </div>

        <div class="hero-command-panel">
          <div class="command-badge">
            <span>本週狀態</span>
            <strong id="rank-title">起稿中</strong>
            <small id="level-value">第 1 級</small>
          </div>
          <div class="command-metrics">
            <article class="metric-card metric-card-primary">
              <span>本週主線</span>
              <strong id="weekly-progress-count">0 / 3</strong>
              <small id="weekly-progress-note">還差 3 個任務</small>
              <div class="progress-track">
                <div id="weekly-progress-bar" class="progress-bar"></div>
              </div>
            </article>
            <article class="metric-card">
              <span>總進度</span>
              <strong id="xp-value">0 XP</strong>
            </article>
            <article class="metric-card">
              <span>連續達標</span>
              <strong id="streak-value">0</strong>
            </article>
            <article class="metric-card">
              <span>完成累積</span>
              <strong id="lifetime-runs-value">0</strong>
            </article>
          </div>
        </div>
      </header>

      <div class="ops-grid">
        <div class="ops-main">
          <section id="quest-board" class="ops-panel quest-board">
            <div class="panel-heading">
              <div>
                <p class="panel-tag">本週任務</p>
                <h2>本週主線任務</h2>
              </div>
            </div>
            <div id="quest-grid" class="quest-grid"></div>
          </section>

          <section id="portal-grid" class="ops-panel portal-board">
            <div class="panel-heading">
              <div>
                <p class="panel-tag">來源入口</p>
                <h2>來源入口</h2>
              </div>
            </div>
            <div class="portal-section">
              <div class="portal-section-heading">
                <p>Facebook 社團</p>
              </div>
              <div id="facebook-card-grid" class="portal-card-grid"></div>
            </div>
            <div class="portal-section">
              <div class="portal-section-heading">
                <p>LINE 社群</p>
              </div>
              <div id="line-card-grid" class="portal-card-grid"></div>
            </div>
            <div class="portal-section">
              <div class="portal-section-heading">
                <p>Google 商家</p>
              </div>
              <div id="google-card-grid" class="portal-card-grid"></div>
            </div>
          </section>

          <section id="bookshelf-board" class="ops-panel bookshelf-board">
            <div class="panel-heading">
              <div>
                <p class="panel-tag">內容書架</p>
                <h2>內容書架</h2>
              </div>
              <p>把既有文章慢慢整理成書。</p>
            </div>

            <div class="bookshelf-summary">
              <article class="bookshelf-stat">
                <span>現有文章</span>
                <strong>{blogPosts.length}</strong>
              </article>
              <article class="bookshelf-stat">
                <span>現有分類</span>
                <strong>{blogCategoryCount}</strong>
              </article>
              <article class="bookshelf-stat bookshelf-stat-wide">
                <span>同步狀態</span>
                <strong>{blogSyncLabel}</strong>
              </article>
            </div>

            <div class="bookshelf-actions">
              <button type="button" id="copy-book-plan" class="bookshelf-action bookshelp-action-primary">複製 LLM 書系整理稿</button>
              <button type="button" id="copy-book-titles" class="bookshelf-action">複製文章標題清單</button>
              <a href="/blog" class="bookshelf-action" target="_blank" rel="noreferrer">前往知識分享</a>
            </div>

            <div class="bookshelf-preview">
              <div class="bookshelf-preview-head">
                <p>目前文章</p>
                <span>{blogPosts.length} 篇</span>
              </div>
              <div class="bookshelf-title-list">
                {blogPosts.map((post, index) => (
                  <article class="bookshelf-entry">
                    <div class="bookshelf-entry-top">
                      <span>{String(index + 1).padStart(2, "0")}</span>
                      <p>{post.category}</p>
                    </div>
                    <h3>{post.title}</h3>
                    <div class="bookshelf-entry-meta">
                      <span>{post.date}</span>
                      <a href={`/blog/${post.slug}`} target="_blank" rel="noreferrer">查看文章</a>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </section>

          <section id="gemini-backup-board" class="ops-panel gemini-board">
            <div class="panel-heading">
              <div>
                <p class="panel-tag">Gemini 備份艙</p>
                <h2>Gemini Canvas 備份</h2>
              </div>
              <p>只留日期版本，點開才展開。</p>
            </div>

            <div class="gemini-actions gemini-actions-primary">
              <button type="button" id="run-gemini-backup" class="bookshelf-action bookshelp-action-primary">立即備份</button>
            </div>

            <p id="gemini-feedback" class="gemini-feedback" aria-live="polite"></p>

            <details class="gemini-composer" id="gemini-composer">
              <summary>
                <span>進階設定</span>
                <small>需要改連結、內容或下載時再展開</small>
              </summary>
              <div class="gemini-editor-grid">
                <label class="gemini-field">
                  <span>分享網址</span>
                  <input id="gemini-source-url" type="url" placeholder="貼上 Gemini 分享網址" />
                </label>
                <label class="gemini-field">
                  <span>備份標題</span>
                  <input id="gemini-title" type="text" placeholder="這次備份名稱" />
                </label>
                <label class="gemini-field gemini-field-full">
                  <span>內容</span>
                  <textarea id="gemini-content" rows="16" placeholder="把 Gemini Canvas 內容整段貼進來"></textarea>
                </label>
              </div>
              <div class="gemini-composer-actions">
                <button type="button" id="load-gemini-master" class="bookshelf-action">載入主檔</button>
                <button type="button" id="copy-gemini-markdown" class="bookshelf-action">複製 Markdown</button>
                <button type="button" id="download-gemini-json" class="bookshelf-action">下載 JSON</button>
              </div>
            </details>

            <div class="gemini-history">
              <div class="bookshelf-preview-head">
                <p>版本列表</p>
                <span id="gemini-history-count">0 版</span>
              </div>
              <div id="gemini-history-list" class="gemini-version-list"></div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ defaultSourcesJson, blogPostsJson, geminiCanvasMasterJson }}>
  const STORAGE_KEY = "qingxi-social-ops-v2";
  const GEMINI_DRAFT_KEY = "qingxi-gemini-canvas-draft-v1";
  const GEMINI_BACKUPS_KEY = "qingxi-gemini-canvas-backups-v1";
  const GEMINI_RECENT_LIMIT = 10;
  const WEEKLY_TARGET = 3;
  const RUN_XP = 100;
  const WEEKLY_BONUS_XP = 50;
  const sourceTemplate = JSON.parse(defaultSourcesJson);
  const articleLibrary = JSON.parse(blogPostsJson);
  const geminiCanvasMasterData = JSON.parse(geminiCanvasMasterJson);
  const rankTitles = [
    "起稿中",
    "構圖中",
    "提案中",
    "執行中",
    "定稿中",
    "主理中",
  ];
  let geminiDraft = null;
  let geminiBackups = [];

  function getWeekKey(date = new Date()) {
    const target = new Date(date);
    const day = target.getDay() || 7;
    target.setHours(0, 0, 0, 0);
    target.setDate(target.getDate() + 4 - day);
    const yearStart = new Date(target.getFullYear(), 0, 1);
    const weekNo = Math.ceil((((target - yearStart) / 86400000) + 1) / 7);
    return `${target.getFullYear()}-W${String(weekNo).padStart(2, "0")}`;
  }

  function createRun(slot) {
    return {
      id: `run-${slot}`,
      slot,
      actionSearch: false,
      actionAdvice: false,
      actionArticle: false,
      rewardClaimed: false,
      completedAt: "",
    };
  }

  function createWeeklyRuns() {
    return [
      createRun(1),
      createRun(2),
      createRun(3),
    ];
  }

  function createInitialState() {
    return {
      weekly: {
        weekKey: getWeekKey(),
        bonusClaimed: false,
        runs: createWeeklyRuns(),
      },
      stats: {
        xp: 0,
        streak: 0,
        lifetimeRuns: 0,
      },
    };
  }

  function syncRuns(savedRuns = []) {
    const templateRuns = createWeeklyRuns();
    return templateRuns.map((templateRun, index) => {
      const savedRun = savedRuns.find((run) => run?.id === templateRun.id) ?? savedRuns[index] ?? {};
      return {
        ...templateRun,
        ...savedRun,
      };
    });
  }

  let state = createInitialState();

  function saveState() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      const initialState = createInitialState();
      state = {
        weekly: {
          ...initialState.weekly,
          ...(parsed.weekly || {}),
          runs: syncRuns(parsed.weekly?.runs),
        },
        stats: {
          ...initialState.stats,
          ...(parsed.stats || {}),
        },
      };
    } catch (error) {
      console.error("讀取社群作戰台資料失敗：", error);
    }
  }

  function isRunComplete(run) {
    return run.actionSearch && run.actionAdvice && run.actionArticle;
  }

  function normalizeWeeklyState() {
    const currentWeekKey = getWeekKey();
    if (state.weekly.weekKey === currentWeekKey) return;

    const completedRuns = state.weekly.runs.filter(isRunComplete).length;
    state.stats.streak = completedRuns >= WEEKLY_TARGET ? state.stats.streak + 1 : 0;
    state.weekly = {
      weekKey: currentWeekKey,
      bonusClaimed: false,
      runs: createWeeklyRuns(),
    };
    saveState();
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function setFeedback(message, mode = "") {
    const shell = document.getElementById("ops-feedback");
    if (!shell) return;
    shell.className = `ops-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function setGeminiFeedback(message, mode = "") {
    const shell = document.getElementById("gemini-feedback");
    if (!shell) return;
    shell.className = `gemini-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function getCompletedRunCount() {
    return state.weekly.runs.filter(isRunComplete).length;
  }

  function getLevel() {
    return Math.floor(state.stats.xp / 200) + 1;
  }

  function getRankTitle(level) {
    return rankTitles[Math.min(level - 1, rankTitles.length - 1)];
  }

  function maybeClaimRunReward(run) {
    if (!isRunComplete(run) || run.rewardClaimed) return;
    run.rewardClaimed = true;
    run.completedAt = new Date().toISOString();
    state.stats.xp += RUN_XP;
    state.stats.lifetimeRuns += 1;

    const completedRuns = getCompletedRunCount();
    if (completedRuns >= WEEKLY_TARGET && !state.weekly.bonusClaimed) {
      state.weekly.bonusClaimed = true;
      state.stats.xp += WEEKLY_BONUS_XP;
      setFeedback("本週三個任務已全清，已領取 +50 XP 額外獎勵。", "is-success");
    }
  }

  function renderHero() {
    const completedRuns = getCompletedRunCount();
    const remaining = Math.max(WEEKLY_TARGET - completedRuns, 0);
    const percent = Math.round((completedRuns / WEEKLY_TARGET) * 100);
    const level = getLevel();
    document.getElementById("weekly-progress-count").textContent = `${completedRuns} / ${WEEKLY_TARGET}`;
    document.getElementById("weekly-progress-note").textContent = remaining === 0
      ? "本週已清空。"
      : `還差 ${remaining} 個任務`;
    document.getElementById("weekly-progress-bar").style.width = `${percent}%`;
    document.getElementById("xp-value").textContent = `${state.stats.xp} XP`;
    document.getElementById("streak-value").textContent = `${state.stats.streak} 週`;
    document.getElementById("lifetime-runs-value").textContent = `${state.stats.lifetimeRuns} 次`;
    document.getElementById("level-value").textContent = `第 ${level} 級`;
    document.getElementById("rank-title").textContent = getRankTitle(level);
  }

  function renderQuests() {
    const shell = document.getElementById("quest-grid");
    if (!shell) return;

    shell.innerHTML = state.weekly.runs
      .map((run, index) => {
        const complete = isRunComplete(run);

        return `
          <article class="quest-card ${complete ? "is-complete" : ""}">
            <div class="quest-topline">
              <span class="quest-slot">問題 ${run.slot}</span>
              <span class="quest-keyword">任選題</span>
            </div>
            <div class="quest-checklist">
              <label class="quest-check ${run.actionSearch ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionSearch" ${run.actionSearch ? "checked" : ""} />
                <span>已進場找題</span>
              </label>
              <label class="quest-check ${run.actionAdvice ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionAdvice" ${run.actionAdvice ? "checked" : ""} />
                <span>已給專業建議</span>
              </label>
              <label class="quest-check ${run.actionArticle ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionArticle" ${run.actionArticle ? "checked" : ""} />
                <span>已附痛點文導流</span>
              </label>
            </div>
          </article>
        `;
      })
      .join("");
  }

  function renderPortalCards(sources) {
    return sources
      .map((source) => `
        <article class="portal-card">
          <div class="portal-card-top">
            <strong>${escapeHtml(source.alias)}</strong>
          </div>
          <div class="portal-actions">
            ${source.url
              ? `<a class="portal-link primary-link" href="${escapeHtml(source.url)}" target="_blank" rel="noreferrer">開啟入口</a>`
              : `<span class="portal-link portal-link-muted">待補連結</span>`}
          </div>
        </article>
      `)
      .join("");
  }

  function renderPortals() {
    const facebookShell = document.getElementById("facebook-card-grid");
    const lineShell = document.getElementById("line-card-grid");
    const googleShell = document.getElementById("google-card-grid");
    if (!facebookShell || !lineShell || !googleShell) return;

    const facebookSources = sourceTemplate.filter((source) => source.platform === "Facebook");
    const lineSources = sourceTemplate.filter((source) => source.platform === "LINE");
    const googleSources = sourceTemplate.filter((source) => source.platform === "Google");

    facebookShell.innerHTML = renderPortalCards(facebookSources);
    lineShell.innerHTML = renderPortalCards(lineSources);
    googleShell.innerHTML = renderPortalCards(googleSources);
  }

  function buildArticleTitlesText() {
    return articleLibrary
      .map((post, index) => `${index + 1}. [${post.category}] ${post.title}`)
      .join("\n");
  }

  function buildBookshelfLlmPrompt() {
    const categories = Array.from(new Set(articleLibrary.map((post) => post.category))).join("、");

    return [
      "你是青曦空間設計的內容總編與出版策劃。",
      "以下是目前知識分享已存在的文章標題清單。請依照現有文章，幫我把內容整理成可持續完成與未來可出版的書系架構。",
      "",
      "工作目標：",
      "1. 把零散文章整理成一本一本可持續完成的書。",
      "2. 先用『書名 -> 章節 -> 已有文章 -> 還缺文章』的方式規劃。",
      "3. 優先找出最適合先完成的第一本書。",
      "",
      "請直接輸出：",
      "A. 建議先做的 3-5 本書名",
      "B. 每本書的定位與目標讀者",
      "C. 每本書的章節架構",
      "D. 目前文章應歸到哪一本到哪一章",
      "E. 每本書還缺哪些關鍵文章",
      "F. 最優先下一篇該補哪 3 篇，並說明原因",
      "G. 哪些現有標題適合改名，讓未來更像書稿章名",
      "",
      `目前文章數：${articleLibrary.length}`,
      `目前分類：${categories || "未分類"}`,
      "",
      "現有文章清單：",
      buildArticleTitlesText(),
    ].join("\n");
  }

  async function copyText(text, successMessage) {
    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
      } else {
        window.prompt("請手動複製以下內容", text);
      }
      setFeedback(successMessage, "is-success");
    } catch (error) {
      console.error("複製失敗：", error);
      setFeedback("複製失敗，請再試一次。", "is-warning");
    }
  }

  function createGeminiDraftFromMaster() {
    return {
      title: geminiCanvasMasterData.title,
      sourceUrl: geminiCanvasMasterData.sourceUrl,
      content: geminiCanvasMasterData.content,
    };
  }

  function normalizeGeminiBackups(backups = []) {
    if (!Array.isArray(backups)) return [];

    return backups
      .filter(Boolean)
      .map((backup) => ({
        id: backup.id || `gemini-backup-${Date.now()}-${Math.random().toString(16).slice(2)}`,
        title: backup.title || geminiCanvasMasterData.title,
        sourceUrl: backup.sourceUrl || geminiCanvasMasterData.sourceUrl,
        content: backup.content || "",
        savedAt: backup.savedAt || new Date().toISOString(),
        isPinned: Boolean(backup.isPinned),
      }))
      .sort((a, b) => new Date(b.savedAt).getTime() - new Date(a.savedAt).getTime());
  }

  function trimGeminiBackups(backups = geminiBackups) {
    return normalizeGeminiBackups(backups).slice(0, GEMINI_RECENT_LIMIT);
  }

  function getGeminiFieldElements() {
    return {
      title: document.getElementById("gemini-title"),
      sourceUrl: document.getElementById("gemini-source-url"),
      content: document.getElementById("gemini-content"),
    };
  }

  function applyGeminiDraftToFields() {
    const { title, sourceUrl, content } = getGeminiFieldElements();
    if (!(title instanceof HTMLInputElement) || !(sourceUrl instanceof HTMLInputElement) || !(content instanceof HTMLTextAreaElement)) {
      return;
    }

    title.value = geminiDraft?.title || "";
    sourceUrl.value = geminiDraft?.sourceUrl || "";
    content.value = geminiDraft?.content || "";
  }

  function persistGeminiDraftFromFields() {
    const { title, sourceUrl, content } = getGeminiFieldElements();
    if (!(title instanceof HTMLInputElement) || !(sourceUrl instanceof HTMLInputElement) || !(content instanceof HTMLTextAreaElement)) {
      return null;
    }

    geminiDraft = {
      title: title.value.trim() || geminiCanvasMasterData.title,
      sourceUrl: sourceUrl.value.trim() || geminiCanvasMasterData.sourceUrl,
      content: content.value.trim(),
    };
    localStorage.setItem(GEMINI_DRAFT_KEY, JSON.stringify(geminiDraft));
    return geminiDraft;
  }

  function loadGeminiBackupState() {
    try {
      const savedDraft = localStorage.getItem(GEMINI_DRAFT_KEY);
      geminiDraft = savedDraft ? JSON.parse(savedDraft) : createGeminiDraftFromMaster();
    } catch (error) {
      console.error("讀取 Gemini 草稿失敗：", error);
      geminiDraft = createGeminiDraftFromMaster();
    }

    try {
      const savedBackups = localStorage.getItem(GEMINI_BACKUPS_KEY);
      geminiBackups = trimGeminiBackups(savedBackups ? JSON.parse(savedBackups) : []);
    } catch (error) {
      console.error("讀取 Gemini 備份失敗：", error);
      geminiBackups = [];
    }
  }

  function saveGeminiBackups() {
    localStorage.setItem(GEMINI_BACKUPS_KEY, JSON.stringify(geminiBackups));
  }

  function formatTimestamp(value) {
    if (!value) return "未記錄";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;
    return new Intl.DateTimeFormat("zh-TW", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
    }).format(date);
  }

  function buildGeminiBackupMarkdown(payload) {
    return [
      `# ${payload.title || geminiCanvasMasterData.title}`,
      "",
      `- 備份時間：${formatTimestamp(payload.savedAt || new Date().toISOString())}`,
      `- 來源網址：${payload.sourceUrl || "未填寫"}`,
      "",
      "## 內容",
      "",
      payload.content || "",
      "",
    ].join("\n");
  }

  function downloadTextFile(fileName, text, mimeType = "text/plain;charset=utf-8") {
    const blob = new Blob([text], { type: mimeType });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = fileName;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  }

  function buildGeminiBackupPayload() {
    const draft = persistGeminiDraftFromFields();
    if (!draft?.content) {
      setFeedback("請先貼上 Gemini Canvas 內容，再建立備份。", "is-warning");
      setGeminiFeedback("請先貼上 Gemini Canvas 內容，再建立備份。", "is-warning");
      return null;
    }

    return {
      id: `gemini-backup-${Date.now()}`,
      title: draft.title,
      sourceUrl: draft.sourceUrl,
      content: draft.content,
      savedAt: new Date().toISOString(),
    };
  }

  function getGeminiVersionEntries() {
    if (geminiBackups.length) return geminiBackups;

    return [{
      id: "gemini-master-version",
      title: geminiCanvasMasterData.title,
      sourceUrl: geminiCanvasMasterData.sourceUrl,
      content: geminiCanvasMasterData.content,
      savedAt: geminiCanvasMasterData.updatedAt,
      isMaster: true,
    }];
  }

  function findGeminiBackupById(backupId) {
    return getGeminiVersionEntries().find((backup) => backup.id === backupId) || null;
  }

  function renderGeminiHistory() {
    const historyShell = document.getElementById("gemini-history-list");
    const historyCount = document.getElementById("gemini-history-count");
    if (!historyShell || !historyCount) return;

    const versions = getGeminiVersionEntries();
    historyCount.textContent = `${versions.length} 版`;

    historyShell.innerHTML = versions
      .map((backup) => `
        <details class="gemini-version-item">
          <summary class="gemini-version-summary">
            <strong>${escapeHtml(formatTimestamp(backup.savedAt))}</strong>
          </summary>
          <div class="gemini-version-body">
            <div class="gemini-version-meta">
              <p>${escapeHtml(backup.title || "未命名備份")}</p>
              <small>${escapeHtml(backup.sourceUrl || "未填寫來源網址")}</small>
            </div>
            <div class="gemini-history-actions">
              <button type="button" class="history-action-btn" data-backup-action="restore" data-backup-id="${escapeHtml(backup.id)}">${backup.isMaster ? "載入主檔" : "載入這版"}</button>
              <button type="button" class="history-action-btn" data-backup-action="copy" data-backup-id="${escapeHtml(backup.id)}">複製 Markdown</button>
            </div>
            <pre class="gemini-preview-content">${escapeHtml(backup.content || "")}</pre>
          </div>
        </details>
      `)
      .join("");
  }

  function loadGeminiMasterIntoEditor() {
    geminiDraft = createGeminiDraftFromMaster();
    localStorage.setItem(GEMINI_DRAFT_KEY, JSON.stringify(geminiDraft));
    applyGeminiDraftToFields();
    setFeedback("已載入目前主檔。", "is-success");
    setGeminiFeedback("已載入目前主檔。", "is-success");
  }

  function upsertGeminiBackup(payload) {
    const existing = geminiBackups.find((backup) => backup.content === payload.content);
    const nextPayload = existing
      ? {
          ...existing,
          title: payload.title,
          sourceUrl: payload.sourceUrl,
          content: payload.content,
          savedAt: payload.savedAt,
        }
      : payload;

    geminiBackups = trimGeminiBackups([
      nextPayload,
      ...geminiBackups.filter((backup) => backup.id !== existing?.id),
    ]);
    saveGeminiBackups();
    renderGeminiHistory();
    return { payload: nextPayload, updated: Boolean(existing) };
  }

  function rerender() {
    renderHero();
    renderQuests();
    renderPortals();
    renderGeminiHistory();
    saveState();
  }

  document.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    if (!target.dataset.runCheck) return;

    const index = Number(target.dataset.runIndex);
    const key = target.dataset.runCheck;
    const run = state.weekly.runs[index];
    if (!run || !key) return;

    run[key] = target.checked;
    maybeClaimRunReward(run);
    rerender();
  });

  document.getElementById("reset-social-ops")?.addEventListener("click", () => {
    state.weekly = {
      weekKey: getWeekKey(),
      bonusClaimed: false,
      runs: createWeeklyRuns(),
    };
    rerender();
    setFeedback("本週任務已重設，XP 與連勝保留。", "is-warning");
  });

  document.getElementById("copy-book-plan")?.addEventListener("click", async () => {
    await copyText(buildBookshelfLlmPrompt(), "已複製 LLM 書系整理稿。");
  });

  document.getElementById("copy-book-titles")?.addEventListener("click", async () => {
    await copyText(buildArticleTitlesText(), "已複製文章標題清單。");
  });

  document.getElementById("load-gemini-master")?.addEventListener("click", () => {
    loadGeminiMasterIntoEditor();
  });

  document.getElementById("run-gemini-backup")?.addEventListener("click", () => {
    const payload = buildGeminiBackupPayload();
    if (!payload) return;

    const result = upsertGeminiBackup(payload);
    const feedback = result.updated ? "已更新 Gemini 最新備份。" : "已建立 Gemini 備份版本。";
    setFeedback(feedback, "is-success");
    setGeminiFeedback(feedback, "is-success");
  });

  document.getElementById("copy-gemini-markdown")?.addEventListener("click", async () => {
    const payload = buildGeminiBackupPayload();
    if (!payload) return;
    await copyText(buildGeminiBackupMarkdown(payload), "已複製 Gemini Markdown 備份。");
    setGeminiFeedback("已複製 Gemini Markdown 備份。", "is-success");
  });

  document.getElementById("download-gemini-json")?.addEventListener("click", () => {
    const payload = buildGeminiBackupPayload();
    if (!payload) return;

    downloadTextFile(
      `qingxi-gemini-backup-${payload.savedAt.slice(0, 10)}.json`,
      JSON.stringify(
        {
          master: geminiCanvasMasterData,
          current: payload,
          history: geminiBackups,
        },
        null,
        2,
      ),
      "application/json;charset=utf-8",
    );
    setFeedback("已下載 Gemini JSON 備份。", "is-success");
    setGeminiFeedback("已下載 Gemini JSON 備份。", "is-success");
  });

  document.getElementById("gemini-backup-board")?.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const action = target.dataset.backupAction;
    const backupId = target.dataset.backupId;
    if (!action || !backupId) return;

    const backup = findGeminiBackupById(backupId);
    if (!backup) return;

    if (action === "restore") {
      geminiDraft = {
        title: backup.title,
        sourceUrl: backup.sourceUrl,
        content: backup.content,
      };
      localStorage.setItem(GEMINI_DRAFT_KEY, JSON.stringify(geminiDraft));
      applyGeminiDraftToFields();
      setFeedback("已載入指定備份版本。", "is-success");
      setGeminiFeedback("已載入指定備份版本。", "is-success");
      return;
    }

    if (action === "copy") {
      await copyText(buildGeminiBackupMarkdown(backup), "已複製該版本 Markdown。");
      setGeminiFeedback("已複製該版本 Markdown。", "is-success");
      return;
    }
  });

  document.getElementById("gemini-backup-board")?.addEventListener("input", (event) => {
    const target = event.target;
    if (
      target instanceof HTMLInputElement ||
      target instanceof HTMLTextAreaElement
    ) {
      persistGeminiDraftFromFields();
    }
  });

  loadGeminiBackupState();
  loadState();
  normalizeWeeklyState();
  applyGeminiDraftToFields();
  rerender();
</script>

