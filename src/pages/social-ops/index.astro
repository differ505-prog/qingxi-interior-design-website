                        <div class="bookshelf-outline-priority">
                          <p>{group.nextAction}</p>
                          {group.missingChapters.length > 0 ? (
                            <div class="bookshelf-outline-tags">
                              {group.missingChapters.slice(0, 3).map((chapter) => (
                                <span>{chapter}</span>
