---
import BaseLayout from "../../layouts/BaseLayout.astro";

const defaultGroups = [
  {
    id: "group-1654316948220005",
    alias: "主社團 01",
    groupId: "1654316948220005",
    url: "https://www.facebook.com/groups/1654316948220005/",
    note: "可先掃南港/汐止關鍵字，再挑最值得導流的貼文。",
  },
  {
    id: "group-679286528824529",
    alias: "主社團 02",
    groupId: "679286528824529",
    url: "https://www.facebook.com/groups/679286528824529",
    note: "適合補第二輪搜尋，避免只集中在單一社團。",
  },
  {
    id: "group-163175389244849",
    alias: "主社團 03",
    groupId: "163175389244849",
    url: "https://www.facebook.com/groups/163175389244849",
    note: "當日沒好題時，也可先去看留言區是否有待回答問題。",
  },
];

const defaultArticles = [
  {
    id: "soft-furnishing-sequence",
    title: "軟裝進場順序",
    status: "published",
    url: "",
    summary: "已完成的一篇痛點文，可補上正式文章連結後作為回覆導流素材。",
  },
  {
    id: "next-pain-point",
    title: "下一篇痛點文",
    status: "draft",
    url: "",
    summary: "先留一格給下一篇，例如老屋翻新踩雷、收納尺寸、預算分配。",
  },
];

const defaultGroupsJson = JSON.stringify(defaultGroups);
const defaultArticlesJson = JSON.stringify(defaultArticles);
---

<BaseLayout
  title="社群作戰台 - 青曦空間設計"
  description="青曦內部使用的社群誘餌式回覆與知識導流作戰頁，含每週任務、社團快捷入口與遊戲化追蹤。"
  noindex={true}
>
  <section class="social-ops-page">
    <div class="social-ops-shell">
      <header class="ops-hero">
        <div>
          <p class="ops-eyebrow">INTERNAL SOCIAL OPS</p>
          <h1>社群誘餌式回覆作戰台</h1>
          <p class="ops-description">
            把每週嚴格執行 3 次的社群導流，變成一個能直接開始、可累積戰果、像解任務一樣推進的內部工作流。
          </p>
          <div class="ops-actions">
            <button type="button" id="open-all-groups" class="btn btn-primary">開啟全部社團</button>
            <button type="button" id="open-nangang-pack" class="btn btn-secondary">開啟南港搜尋包</button>
            <button type="button" id="open-xizhi-pack" class="btn btn-secondary">開啟汐止搜尋包</button>
            <button type="button" id="reset-social-ops" class="btn btn-secondary btn-muted">重設本週任務</button>
          </div>
          <p id="ops-feedback" class="ops-feedback" aria-live="polite"></p>
        </div>

        <div class="hero-scoreboard">
          <div class="score-card score-card-highlight">
            <span>本週進度</span>
            <strong id="weekly-progress-count">0 / 3</strong>
            <small id="weekly-progress-note">距離本週達標還差 3 次出擊</small>
          </div>
          <div class="score-grid">
            <div class="score-card">
              <span>等級</span>
              <strong id="level-value">Lv.1</strong>
              <small id="xp-value">0 XP</small>
            </div>
            <div class="score-card">
              <span>連勝週數</span>
              <strong id="streak-value">0</strong>
              <small>每週達標 3 次才算延續</small>
            </div>
            <div class="score-card">
              <span>累積出擊</span>
              <strong id="lifetime-runs-value">0</strong>
              <small>完成一輪任務才計入</small>
            </div>
            <div class="score-card">
              <span>回覆紀錄</span>
              <strong id="log-count-value">0</strong>
              <small>可回頭追哪種題目最有回應</small>
            </div>
          </div>
        </div>
      </header>

      <div class="ops-grid">
        <div class="ops-main">
          <section class="ops-card">
            <div class="section-heading">
              <h2>任務 6｜本週主線</h2>
              <p>維持節奏比靈感更重要。這一區專注把每週 3 次出擊真的做完。</p>
            </div>
            <div class="mission-rules">
              <div class="rule-chip">行動 1：看到在地人發問修繕問題，給予專業建議</div>
              <div class="rule-chip">行動 2：用社團搜尋只掃南港 / 汐止貼文</div>
              <div class="rule-chip">行動 3：回覆時帶痛點文連結導流</div>
            </div>
            <div id="weekly-run-list" class="weekly-run-list"></div>
          </section>

          <section class="ops-card">
            <div class="section-heading">
              <h2>社團快捷入口</h2>
              <p>直接從這裡開始，不再浪費時間在找社團、切搜尋關鍵字與重複開頁。</p>
            </div>
            <div id="group-launcher-grid" class="group-launcher-grid"></div>
          </section>

          <section class="ops-card">
            <div class="section-heading">
              <h2>痛點文素材庫</h2>
              <p>先把可導流的素材放在手邊，回覆時就不需要臨場想連結。</p>
            </div>
            <div id="article-library" class="article-library"></div>
          </section>

          <section class="ops-card">
            <div class="section-heading">
              <h2>戰果紀錄</h2>
              <p>記錄今天回了什麼題、帶了哪篇、結果如何，才能慢慢找到最有效的導流模式。</p>
            </div>
            <form id="battle-log-form" class="battle-log-form">
              <div class="form-grid">
                <label class="field">
                  <span>日期</span>
                  <input id="log-date" type="date" />
                </label>
                <label class="field">
                  <span>社團</span>
                  <select id="log-group"></select>
                </label>
                <label class="field">
                  <span>地區關鍵字</span>
                  <select id="log-keyword">
                    <option value="南港">南港</option>
                    <option value="汐止">汐止</option>
                    <option value="其他">其他</option>
                  </select>
                </label>
                <label class="field">
                  <span>導流素材</span>
                  <select id="log-article"></select>
                </label>
                <label class="field field-full">
                  <span>問題主題</span>
                  <input id="log-topic" type="text" placeholder="例如：老屋壁癌、浴室漏水、插座位置、窗簾盒高度" />
                </label>
                <label class="field field-full">
                  <span>回覆策略簡述</span>
                  <textarea id="log-summary" rows="3" placeholder="例如：先回答抓預算與動線，再附上軟裝進場順序文章，引導去官網看完整內容。"></textarea>
                </label>
                <label class="field field-full">
                  <span>貼文網址 / 備註</span>
                  <input id="log-url" type="url" placeholder="可貼 Facebook 貼文網址，或寫後續私訊 / 加 LINE 狀態" />
                </label>
              </div>
              <div class="battle-log-actions">
                <button type="submit" class="btn btn-primary">記錄這次出擊</button>
                <small>每記錄一筆可加 15 XP，方便回頭看哪種主題最值得持續回答。</small>
              </div>
            </form>
            <div id="battle-log-list" class="battle-log-list"></div>
          </section>
        </div>

        <aside class="ops-sidebar">
          <section class="ops-card">
            <div class="section-heading">
              <h2>今日快速開始</h2>
              <p>如果現在只想先動起來，就照這個順序做。</p>
            </div>
            <ol class="quick-start-list">
              <li>先開南港或汐止搜尋包，找一篇最容易回的修繕問題。</li>
              <li>先給專業建議，再挑一篇最貼近的痛點文導流。</li>
              <li>回來勾任務、記戰果，讓 XP 和進度真的累積起來。</li>
            </ol>
          </section>

          <section class="ops-card">
            <div class="section-heading">
              <h2>本週獎勵規則</h2>
              <p>讓任務有一點遊戲感，但重點仍是穩定執行。</p>
            </div>
            <ul class="reward-list">
              <li>完成 1 次完整出擊：+100 XP</li>
              <li>新增 1 筆戰果紀錄：+15 XP</li>
              <li>每週達標 3 次：連勝週數 +1</li>
              <li>同週若 3 次全完成：額外獎勵 +50 XP</li>
            </ul>
          </section>

          <section class="ops-card">
            <div class="section-heading">
              <h2>戰略連動</h2>
              <p>這一區不是只有導流，也是在幫你累積下一階段素材。</p>
            </div>
            <div class="strategy-notes">
              <div class="strategy-note">
                <strong>短期</strong>
                <span>把每週固定曝光與官網導流做成習慣。</span>
              </div>
              <div class="strategy-note">
                <strong>中期</strong>
                <span>從高互動問題萃取成下一篇痛點文題材。</span>
              </div>
              <div class="strategy-note">
                <strong>長期</strong>
                <span>沉澱成你未來寫書、講內容與建立個人觀點的原始素材庫。</span>
              </div>
            </div>
          </section>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ defaultGroupsJson, defaultArticlesJson }}>
  const STORAGE_KEY = "qingxi-social-ops-v1";
  const groupTemplate = JSON.parse(defaultGroupsJson);
  const articleTemplate = JSON.parse(defaultArticlesJson);
  const WEEKLY_TARGET = 3;
  const RUN_XP = 100;
  const LOG_XP = 15;
  const WEEKLY_BONUS_XP = 50;

  function getCurrentDateString() {
    return new Date().toISOString().slice(0, 10);
  }

  function getWeekKey(date = new Date()) {
    const target = new Date(date);
    const day = target.getDay() || 7;
    target.setHours(0, 0, 0, 0);
    target.setDate(target.getDate() + 4 - day);
    const yearStart = new Date(target.getFullYear(), 0, 1);
    const weekNo = Math.ceil((((target - yearStart) / 86400000) + 1) / 7);
    return `${target.getFullYear()}-W${String(weekNo).padStart(2, "0")}`;
  }

  function createRun(slot) {
    return {
      id: `run-${slot}`,
      slot,
      title: `本週出擊 ${slot}`,
      keyword: slot === 1 ? "南港" : slot === 2 ? "汐止" : "南港",
      actionAdvice: false,
      actionSearch: false,
      actionArticle: false,
      notes: "",
      launchedAt: "",
      completedAt: "",
      rewardClaimed: false,
    };
  }

  function createInitialState() {
    return {
      groups: groupTemplate.map((group) => ({ ...group })),
      articles: articleTemplate.map((article) => ({ ...article })),
      weekly: {
        weekKey: getWeekKey(),
        bonusClaimed: false,
        runs: [createRun(1), createRun(2), createRun(3)],
      },
      logs: [],
      stats: {
        xp: 0,
        streak: 0,
        lifetimeRuns: 0,
      },
    };
  }

  let state = createInitialState();

  function saveState() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      state = {
        groups: Array.isArray(parsed.groups) && parsed.groups.length ? parsed.groups : createInitialState().groups,
        articles: Array.isArray(parsed.articles) && parsed.articles.length ? parsed.articles : createInitialState().articles,
        weekly: parsed.weekly || createInitialState().weekly,
        logs: Array.isArray(parsed.logs) ? parsed.logs : [],
        stats: {
          ...createInitialState().stats,
          ...(parsed.stats || {}),
        },
      };
    } catch (error) {
      console.error("讀取社群作戰台資料失敗：", error);
    }
  }

  function normalizeWeeklyState() {
    const currentWeekKey = getWeekKey();
    if (state.weekly.weekKey === currentWeekKey) return;

    const completedRuns = state.weekly.runs.filter((run) => run.actionAdvice && run.actionSearch && run.actionArticle).length;
    state.stats.streak = completedRuns >= WEEKLY_TARGET ? state.stats.streak + 1 : 0;
    state.weekly = {
      weekKey: currentWeekKey,
      bonusClaimed: false,
      runs: [createRun(1), createRun(2), createRun(3)],
    };
    saveState();
  }

  function setFeedback(message, mode = "") {
    const shell = document.getElementById("ops-feedback");
    if (!shell) return;
    shell.className = `ops-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function flashButton(button, text) {
    const original = button.textContent;
    button.textContent = text;
    window.setTimeout(() => {
      button.textContent = original;
    }, 1400);
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function buildSearchUrl(group, keyword) {
    return `https://www.facebook.com/groups/${encodeURIComponent(group.groupId)}/search/?q=${encodeURIComponent(keyword)}`;
  }

  function getCompletedRunCount() {
    return state.weekly.runs.filter((run) => run.actionAdvice && run.actionSearch && run.actionArticle).length;
  }

  function maybeClaimRunReward(run) {
    const isComplete = run.actionAdvice && run.actionSearch && run.actionArticle;
    if (!isComplete || run.rewardClaimed) return;
    run.rewardClaimed = true;
    run.completedAt = new Date().toISOString();
    state.stats.xp += RUN_XP;
    state.stats.lifetimeRuns += 1;

    const completedRuns = getCompletedRunCount();
    if (completedRuns >= WEEKLY_TARGET && !state.weekly.bonusClaimed) {
      state.weekly.bonusClaimed = true;
      state.stats.xp += WEEKLY_BONUS_XP;
      setFeedback("本週 3 次出擊已達標，已領取 +50 XP 週獎勵。", "is-success");
    }
  }

  function getLevel() {
    return Math.floor(state.stats.xp / 200) + 1;
  }

  function renderScoreboard() {
    const completedRuns = getCompletedRunCount();
    const remaining = Math.max(WEEKLY_TARGET - completedRuns, 0);
    document.getElementById("weekly-progress-count").textContent = `${completedRuns} / ${WEEKLY_TARGET}`;
    document.getElementById("weekly-progress-note").textContent =
      remaining === 0 ? "本週已達標，維持連勝節奏。" : `距離本週達標還差 ${remaining} 次出擊`;
    document.getElementById("level-value").textContent = `Lv.${getLevel()}`;
    document.getElementById("xp-value").textContent = `${state.stats.xp} XP`;
    document.getElementById("streak-value").textContent = String(state.stats.streak);
    document.getElementById("lifetime-runs-value").textContent = String(state.stats.lifetimeRuns);
    document.getElementById("log-count-value").textContent = String(state.logs.length);
  }

  function renderRuns() {
    const shell = document.getElementById("weekly-run-list");
    if (!shell) return;

    shell.innerHTML = state.weekly.runs
      .map((run, index) => {
        const isComplete = run.actionAdvice && run.actionSearch && run.actionArticle;
        return `
          <article class="run-card ${isComplete ? "is-complete" : ""}">
            <div class="run-card-header">
              <div>
                <span class="run-step">RUN ${index + 1}</span>
                <h3>${escapeHtml(run.title)}</h3>
              </div>
              <span class="run-state ${isComplete ? "is-complete" : "is-pending"}">${isComplete ? "已完成" : "進行中"}</span>
            </div>
            <div class="run-meta-grid">
              <label class="field">
                <span>主攻關鍵字</span>
                <select data-run-index="${index}" data-run-field="keyword">
                  <option value="南港" ${run.keyword === "南港" ? "selected" : ""}>南港</option>
                  <option value="汐止" ${run.keyword === "汐止" ? "selected" : ""}>汐止</option>
                </select>
              </label>
              <label class="field field-full">
                <span>這輪備註</span>
                <input data-run-index="${index}" data-run-field="notes" type="text" value="${escapeHtml(run.notes || "")}" placeholder="例如：今天主攻老屋翻新、壁癌、浴室漏水類問題" />
              </label>
            </div>
            <div class="run-checklist">
              <label><input type="checkbox" data-run-index="${index}" data-run-check="actionAdvice" ${run.actionAdvice ? "checked" : ""} /> 已給專業建議</label>
              <label><input type="checkbox" data-run-index="${index}" data-run-check="actionSearch" ${run.actionSearch ? "checked" : ""} /> 已用社團搜尋掃南港 / 汐止</label>
              <label><input type="checkbox" data-run-index="${index}" data-run-check="actionArticle" ${run.actionArticle ? "checked" : ""} /> 已附痛點文導流</label>
            </div>
            <div class="run-actions">
              <button type="button" class="btn btn-secondary" data-run-launch="${index}">開啟這輪搜尋包</button>
              <small>${run.completedAt ? `完成時間：${new Date(run.completedAt).toLocaleString("zh-TW")}` : "完成後會自動領取 100 XP"}</small>
            </div>
          </article>
        `;
      })
      .join("");
  }

  function renderGroups() {
    const shell = document.getElementById("group-launcher-grid");
    if (!shell) return;

    shell.innerHTML = state.groups
      .map((group, index) => `
        <article class="group-card">
          <label class="field">
            <span>社團名稱</span>
            <input data-group-index="${index}" data-group-field="alias" type="text" value="${escapeHtml(group.alias)}" />
          </label>
          <p class="group-note">${escapeHtml(group.note || "")}</p>
          <div class="group-actions">
            <a class="btn btn-secondary" href="${escapeHtml(group.url)}" target="_blank" rel="noreferrer">開啟社團</a>
            <a class="btn btn-secondary" href="${escapeHtml(buildSearchUrl(group, "南港"))}" target="_blank" rel="noreferrer">搜南港</a>
            <a class="btn btn-secondary" href="${escapeHtml(buildSearchUrl(group, "汐止"))}" target="_blank" rel="noreferrer">搜汐止</a>
          </div>
        </article>
      `)
      .join("");
  }

  function renderArticles() {
    const shell = document.getElementById("article-library");
    if (!shell) return;

    shell.innerHTML = state.articles
      .map((article, index) => `
        <article class="article-card ${article.status === "published" ? "is-published" : ""}">
          <div class="article-card-header">
            <div>
              <span class="article-state">${article.status === "published" ? "已完成" : "待產出"}</span>
              <h3>${escapeHtml(article.title)}</h3>
            </div>
            ${article.url ? `<a class="btn btn-secondary" href="${escapeHtml(article.url)}" target="_blank" rel="noreferrer">開啟連結</a>` : `<span class="article-missing-link">尚未補連結</span>`}
          </div>
          <p>${escapeHtml(article.summary || "")}</p>
          <div class="form-grid compact-grid">
            <label class="field">
              <span>標題</span>
              <input data-article-index="${index}" data-article-field="title" type="text" value="${escapeHtml(article.title)}" />
            </label>
            <label class="field">
              <span>狀態</span>
              <select data-article-index="${index}" data-article-field="status">
                <option value="published" ${article.status === "published" ? "selected" : ""}>已完成</option>
                <option value="draft" ${article.status === "draft" ? "selected" : ""}>待產出</option>
              </select>
            </label>
            <label class="field field-full">
              <span>文章連結</span>
              <input data-article-index="${index}" data-article-field="url" type="url" value="${escapeHtml(article.url || "")}" placeholder="例如：https://qingxidesign.tw/blog/..." />
            </label>
            <label class="field field-full">
              <span>摘要 / 用法</span>
              <input data-article-index="${index}" data-article-field="summary" type="text" value="${escapeHtml(article.summary || "")}" />
            </label>
          </div>
        </article>
      `)
      .join("");

    const logArticleSelect = document.getElementById("log-article");
    if (logArticleSelect) {
      logArticleSelect.innerHTML = state.articles
        .map((article) => `<option value="${escapeHtml(article.title)}">${escapeHtml(article.title)}</option>`)
        .join("");
    }
  }

  function renderBattleLog() {
    const shell = document.getElementById("battle-log-list");
    if (!shell) return;

    if (!state.logs.length) {
      shell.innerHTML = `<p class="empty-log">目前還沒有戰果紀錄。完成一次回覆後，就回來留一筆。</p>`;
      return;
    }

    shell.innerHTML = state.logs
      .slice()
      .reverse()
      .map((log) => `
        <article class="log-card">
          <div class="log-card-header">
            <strong>${escapeHtml(log.topic || "未命名主題")}</strong>
            <span>${escapeHtml(log.date || "")}｜${escapeHtml(log.groupAlias || "")}｜${escapeHtml(log.keyword || "")}</span>
          </div>
          <p>${escapeHtml(log.summary || "")}</p>
          <div class="log-tags">
            <span>${escapeHtml(log.articleTitle || "未附素材")}</span>
            ${log.url ? `<a href="${escapeHtml(log.url)}" target="_blank" rel="noreferrer">查看貼文</a>` : "<span>未附貼文網址</span>"}
          </div>
        </article>
      `)
      .join("");
  }

  function syncLogGroupOptions() {
    const select = document.getElementById("log-group");
    if (!select) return;
    const currentValue = select.value;
    select.innerHTML = state.groups
      .map((group) => `<option value="${escapeHtml(group.id)}">${escapeHtml(group.alias)}</option>`)
      .join("");
    if (currentValue) select.value = currentValue;
  }

  function rerender() {
    renderScoreboard();
    renderRuns();
    renderGroups();
    renderArticles();
    syncLogGroupOptions();
    renderBattleLog();
    saveState();
  }

  function openUrlPack(urls) {
    urls.forEach((url) => {
      window.open(url, "_blank", "noopener,noreferrer");
    });
  }

  document.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement || target instanceof HTMLSelectElement)) return;

    if (target.dataset.runCheck) {
      const index = Number(target.dataset.runIndex);
      const key = target.dataset.runCheck;
      const run = state.weekly.runs[index];
      if (!run || !key) return;
      run[key] = target.checked;
      maybeClaimRunReward(run);
      rerender();
      return;
    }

    if (target.dataset.runField) {
      const index = Number(target.dataset.runIndex);
      const key = target.dataset.runField;
      const run = state.weekly.runs[index];
      if (!run || !key) return;
      run[key] = target.value;
      rerender();
      return;
    }

    if (target.dataset.groupField) {
      const index = Number(target.dataset.groupIndex);
      const key = target.dataset.groupField;
      const group = state.groups[index];
      if (!group || !key) return;
      group[key] = target.value;
      rerender();
      return;
    }

    if (target.dataset.articleField) {
      const index = Number(target.dataset.articleIndex);
      const key = target.dataset.articleField;
      const article = state.articles[index];
      if (!article || !key) return;
      article[key] = target.value;
      rerender();
    }
  });

  document.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;

    if (target.dataset.runField) {
      const index = Number(target.dataset.runIndex);
      const key = target.dataset.runField;
      const run = state.weekly.runs[index];
      if (!run || !key) return;
      run[key] = target.value;
      saveState();
      return;
    }

    if (target.dataset.groupField) {
      const index = Number(target.dataset.groupIndex);
      const key = target.dataset.groupField;
      const group = state.groups[index];
      if (!group || !key) return;
      group[key] = target.value;
      saveState();
      return;
    }

    if (target.dataset.articleField) {
      const index = Number(target.dataset.articleIndex);
      const key = target.dataset.articleField;
      const article = state.articles[index];
      if (!article || !key) return;
      article[key] = target.value;
      saveState();
    }
  });

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const launchButton = target.closest("[data-run-launch]");
    if (launchButton instanceof HTMLButtonElement) {
      const index = Number(launchButton.dataset.runLaunch);
      const run = state.weekly.runs[index];
      if (!run) return;
      const urls = state.groups.map((group) => buildSearchUrl(group, run.keyword || "南港"));
      openUrlPack(urls);
      run.launchedAt = new Date().toISOString();
      run.actionSearch = true;
      rerender();
      flashButton(launchButton, "已開啟");
      setFeedback(`已開啟 ${run.keyword} 搜尋包，直接去挑最值得回的一題。`, "is-success");
      return;
    }

    if (target.id === "open-all-groups") {
      openUrlPack(state.groups.map((group) => group.url));
      setFeedback("已開啟 3 個社團首頁。", "is-success");
      flashButton(target, "已開啟");
      return;
    }

    if (target.id === "open-nangang-pack") {
      openUrlPack(state.groups.map((group) => buildSearchUrl(group, "南港")));
      setFeedback("已開啟南港搜尋包，先找最容易回的一題。", "is-success");
      flashButton(target, "已開啟");
      return;
    }

    if (target.id === "open-xizhi-pack") {
      openUrlPack(state.groups.map((group) => buildSearchUrl(group, "汐止")));
      setFeedback("已開啟汐止搜尋包，去挑最容易切進專業建議的貼文。", "is-success");
      flashButton(target, "已開啟");
      return;
    }

    if (target.id === "reset-social-ops") {
      state.weekly = {
        weekKey: getWeekKey(),
        bonusClaimed: false,
        runs: [createRun(1), createRun(2), createRun(3)],
      };
      rerender();
      setFeedback("本週任務已重設，XP 與戰果紀錄保留。", "is-warning");
    }
  });

  document.getElementById("battle-log-form")?.addEventListener("submit", (event) => {
    event.preventDefault();

    const groupSelect = document.getElementById("log-group");
    const keywordSelect = document.getElementById("log-keyword");
    const articleSelect = document.getElementById("log-article");
    const dateInput = document.getElementById("log-date");
    const topicInput = document.getElementById("log-topic");
    const summaryInput = document.getElementById("log-summary");
    const urlInput = document.getElementById("log-url");

    if (!(groupSelect instanceof HTMLSelectElement) || !(keywordSelect instanceof HTMLSelectElement) || !(articleSelect instanceof HTMLSelectElement) || !(dateInput instanceof HTMLInputElement) || !(topicInput instanceof HTMLInputElement) || !(summaryInput instanceof HTMLTextAreaElement) || !(urlInput instanceof HTMLInputElement)) {
      return;
    }

    const group = state.groups.find((item) => item.id === groupSelect.value);
    state.logs.push({
      id: `log-${Date.now()}`,
      date: dateInput.value || getCurrentDateString(),
      groupId: groupSelect.value,
      groupAlias: group?.alias || "",
      keyword: keywordSelect.value,
      articleTitle: articleSelect.value,
      topic: topicInput.value,
      summary: summaryInput.value,
      url: urlInput.value,
    });
    state.stats.xp += LOG_XP;
    rerender();

    dateInput.value = getCurrentDateString();
    topicInput.value = "";
    summaryInput.value = "";
    urlInput.value = "";
    setFeedback("已記錄本次出擊，+15 XP。", "is-success");
  });

  loadState();
  normalizeWeeklyState();
  rerender();
  const dateInput = document.getElementById("log-date");
  if (dateInput instanceof HTMLInputElement && !dateInput.value) {
    dateInput.value = getCurrentDateString();
  }
</script>

