  function setArticleAiFeedback(message, mode = "") {
    const shell = document.getElementById("article-ai-feedback");
    if (!shell) return;
    shell.className = `bookshelf-ai-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function spotlightActionButton(id) {
    const button = document.getElementById(id);
    if (!(button instanceof HTMLButtonElement)) return;
    button.classList.remove("is-guided");
    void button.offsetWidth;
    button.classList.add("is-guided");
    window.setTimeout(() => button.classList.remove("is-guided"), 2400);
  }

  function renderArticleProPrompt() {
    const shell = document.getElementById("article-pro-prompt-shell");
    const label = document.getElementById("article-pro-prompt-label");
    const note = document.getElementById("article-pro-prompt-note");
    const content = document.getElementById("article-pro-prompt-content");
    if (
      !(shell instanceof HTMLElement) ||
      !(label instanceof HTMLElement) ||
      !(note instanceof HTMLElement) ||
      !(content instanceof HTMLTextAreaElement)
    ) {
      return;
    }

    const hasPrompt = Boolean(articleProFinalizePrompt.trim());
    const hasAiResult = Boolean(articleAiResult.trim());
    shell.hidden = !hasPrompt;
    label.textContent = hasPrompt ? (hasAiResult ? "已備好" : "模板已備好") : "尚未備好";
    note.textContent = hasPrompt
      ? hasAiResult
        ? "下方是最近一次備好的版本；若你修改了問題內容，再按一次「複製 Pro 生文提示詞」就會自動更新，並繼續用於 Gemini 內建 Canvas 文件稿。"
        : "目前先備好的是模板版；若先完成 Flash 判題，再按一次複製會自動改成正式版本。"
      : "一鍵流程完成後，這裡會先備好可直接貼去 Gemini 高階模型、用來生成 Gemini 內建 Canvas 文件稿的正式生文提示詞，再嘗試自動複製。";
    content.value = articleProFinalizePrompt;
  }

  function revealArticleProPrompt() {
    const shell = document.getElementById("article-pro-prompt-shell");
    const details = document.getElementById("article-pro-prompt-details");
    if (shell instanceof HTMLElement) {
      shell.hidden = false;
    }
    if (details instanceof HTMLDetailsElement) {
      details.open = true;
    }
  }

  function prepareProFinalizePrompt(question = "") {
    const resolvedQuestion = question || articleSourceQuestion;
    let usedFallback = false;

    try {
      try {
        articleProFinalizePrompt = buildProFinalizePrompt(resolvedQuestion, articleAiResult);
      } catch (error) {
        console.error("完整 Pro 生文提示詞生成失敗，改用穩定版：", error);
        articleProFinalizePrompt = buildBasicProFinalizePrompt(resolvedQuestion, articleAiResult);
        usedFallback = true;
      }

      if (!articleProFinalizePrompt.trim()) {
        articleProFinalizePrompt = buildBasicProFinalizePrompt(resolvedQuestion, articleAiResult);
        usedFallback = true;
      }
    } catch (error) {
      console.error("穩定版 Pro 生文提示詞生成失敗，改用緊急保底版：", error);
      articleProFinalizePrompt = buildEmergencyProFinalizePrompt(resolvedQuestion, articleAiResult);
      usedFallback = true;
    }

    const saved = saveArticleProFinalizePrompt();
    renderArticleProPrompt();
    return {
      prompt: articleProFinalizePrompt,
      saved,
      hasAiResult: Boolean(articleAiResult.trim()),
      usedFallback,
    };
  }

  function getCopyFeedbackState(result, successMessage, manualMessage, failureMessage = "複製失敗，請直接手動複製。") {
    if (result === "clipboard") {
      return { message: successMessage, mode: "is-success" };
    }
    if (result === "manual") {
      return { message: manualMessage, mode: "is-warning" };
    }
    return { message: failureMessage, mode: "is-warning" };
  }

  function getArticleAiTimeoutMs(mode) {
    return mode === "metadata" ? ARTICLE_AI_METADATA_TIMEOUT_MS : ARTICLE_AI_TIMEOUT_MS;
  }

  function buildArticleAiTimeoutMessage(mode) {
    if (mode === "topic") {
      return "本題動態決題逾時，請再試一次。";
    }
    if (mode === "metadata") {
      return "主書系、章節與標題補齊逾時，已保留目前判題結果。";
    }
    return "Gemini Flash 回應逾時，請再試一次。";
  }

  function renderArticleAiResult() {
    const shell = document.getElementById("article-ai-result-shell");
    const label = document.getElementById("article-ai-result-label");
    const content = document.getElementById("article-ai-result-content");
    const decisionShell = document.getElementById("article-ai-decision");
    const decisionTitle = document.getElementById("article-ai-decision-title");
    const decisionAction = document.getElementById("article-ai-decision-action");
    const decisionSimilar = document.getElementById("article-ai-decision-similar");
    const decisionAngle = document.getElementById("article-ai-decision-angle");
    const topicNextAction = document.getElementById("article-topic-next-action");
    const topicSimilar = document.getElementById("article-topic-similar");
    const topicAngle = document.getElementById("article-topic-angle");
    if (
      !(shell instanceof HTMLDetailsElement) ||
      !(label instanceof HTMLElement) ||
      !(content instanceof HTMLElement) ||
      !(decisionShell instanceof HTMLElement) ||
      !(decisionTitle instanceof HTMLElement) ||
      !(decisionAction instanceof HTMLElement) ||
      !(decisionSimilar instanceof HTMLElement) ||
      !(decisionAngle instanceof HTMLElement)
    ) {
      return;
    }

    const hasResult = Boolean(articleAiResult.trim());
    const decision = getArticleAiDecision(articleAiResult);
    renderArticleConfirm(articleAiResult);
    renderArticleSocialReplies(articleAiResult);
    label.textContent = hasResult
      ? articleAiMode === "quick"
        ? "快速判題"
        : "Flash 長稿備援"
      : "尚未生成";
    decisionShell.hidden = !hasResult;
    decisionTitle.textContent = decision.title;
    decisionAction.textContent = decision.action;
    decisionSimilar.textContent = decision.similar;
    decisionAngle.textContent = decision.angle;
    if (topicNextAction instanceof HTMLElement) topicNextAction.textContent = decision.action;
    if (topicSimilar instanceof HTMLElement) topicSimilar.textContent = decision.similar;
    if (topicAngle instanceof HTMLElement) topicAngle.textContent = decision.angle;
    content.textContent = articleAiResult;
