  function renderPortals() {
    const facebookShell = document.getElementById("facebook-card-grid");
    const lineShell = document.getElementById("line-card-grid");
    const googleShell = document.getElementById("google-card-grid");
    if (!facebookShell || !lineShell || !googleShell) return;

    const facebookSources = sourceTemplate.filter((source) => source.platform === "Facebook");
    const lineSources = sourceTemplate.filter((source) => source.platform === "LINE");
    const googleSources = sourceTemplate.filter((source) => source.platform === "Google");

    facebookShell.innerHTML = renderPortalCards(facebookSources);
    lineShell.innerHTML = renderPortalCards(lineSources);
    googleShell.innerHTML = renderPortalCards(googleSources);
  }

  function formatCount(value) {
    const parsed = Number(value || 0);
    if (!Number.isFinite(parsed)) return "-";
    return parsed.toLocaleString("zh-TW");
  }

  function getArticleTitleFromPagePath(pagePath = "") {
    const slug = pagePath
      .replace(/^\/blog\//, "")
      .replace(/\/$/, "")
      .trim();
    if (!slug) return "未辨識文章";
    const matched = articleLibrary.find((post) => post.slug === slug);
    return matched?.title || slug;
  }

  function renderContentAnalytics() {
    const statusNode = document.getElementById("content-analytics-status");
    const updatedAtNode = document.getElementById("content-analytics-updated-at");
    const noteNode = document.getElementById("content-analytics-note");
    const topPostsNode = document.getElementById("content-analytics-top-posts");
    const blogViewsNode = document.getElementById("content-analytics-blog-views");
    const estimateGeneratedNode = document.getElementById("content-analytics-estimate-generated");
    const estimateCtaNode = document.getElementById("content-analytics-estimate-cta");
    const officialLineNode = document.getElementById("content-analytics-official-line");
    const requirementSuccessNode = document.getElementById("content-analytics-requirement-success");

    if (
      !statusNode ||
      !updatedAtNode ||
      !noteNode ||
      !topPostsNode ||
      !blogViewsNode ||
      !estimateGeneratedNode ||
      !estimateCtaNode ||
      !officialLineNode ||
      !requirementSuccessNode
    ) {
      return;
    }

    blogViewsNode.textContent = formatCount(contentAnalyticsState.metrics.blogViews);
    estimateGeneratedNode.textContent = formatCount(contentAnalyticsState.metrics.estimateGenerated);
    estimateCtaNode.textContent = formatCount(contentAnalyticsState.metrics.estimateCtaClick);
    officialLineNode.textContent = formatCount(contentAnalyticsState.metrics.officialLineClick);
    requirementSuccessNode.textContent = formatCount(contentAnalyticsState.metrics.requirementSuccess);

    if (contentAnalyticsState.status === "loading") {
      statusNode.textContent = "讀取中";
      updatedAtNode.textContent = "同步中";
      noteNode.textContent = "正在向 GA4 讀取近 7 天內容與轉換成效。";
      topPostsNode.innerHTML = "<li>正在讀取內容成效...</li>";
      return;
    }

    if (contentAnalyticsState.status === "setup_required") {
      statusNode.textContent = "待接 GA4";
      updatedAtNode.textContent = contentAnalyticsState.rangeLabel;
      noteNode.textContent = contentAnalyticsState.note || "設定好 GA4 報表權限後，這裡會自動顯示內容成效。";
      topPostsNode.innerHTML = "<li>目前尚未接通 GA4 Data API。</li>";
      return;
    }

    if (contentAnalyticsState.status === "error") {
      statusNode.textContent = "讀取失敗";
      updatedAtNode.textContent = contentAnalyticsState.rangeLabel;
      noteNode.textContent = contentAnalyticsState.note || "GA4 報表暫時讀取失敗，請稍後再試。";
      topPostsNode.innerHTML = "<li>目前無法取得熱門文章排行。</li>";
      return;
    }

    statusNode.textContent = contentAnalyticsState.configured ? "已同步" : "未設定";
    updatedAtNode.textContent = contentAnalyticsState.updatedAt
      ? `更新於 ${new Date(contentAnalyticsState.updatedAt).toLocaleString("zh-TW", {
          hour12: false,
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
        })}`
      : contentAnalyticsState.rangeLabel;
    const latestLineClickLabel = contentAnalyticsState.latestOfficialLineClickAt
      ? `最近一次官方 LINE 點擊：${new Date(contentAnalyticsState.latestOfficialLineClickAt).toLocaleString("zh-TW", {
          hour12: false,
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
        })}`
      : "最近 7 天尚未記錄到官方 LINE 點擊。";
    noteNode.textContent =
      contentAnalyticsState.note ||
      `${contentAnalyticsState.rangeLabel} 內，文章瀏覽、官網轉換與官方 LINE 點擊會集中顯示在這裡。${latestLineClickLabel}`;

    const topPosts = Array.isArray(contentAnalyticsState.topPosts)
      ? contentAnalyticsState.topPosts
      : [];
    topPostsNode.innerHTML = topPosts.length
      ? topPosts
          .map((post) => `
            <li>
              <span>${escapeHtml(getArticleTitleFromPagePath(post.pagePath))}</span>
              <strong>${formatCount(post.views)}</strong>
            </li>
          `)
          .join("")
      : "<li>近 7 天尚無文章瀏覽資料。</li>";
  }

  function renderVendorNotes() {
