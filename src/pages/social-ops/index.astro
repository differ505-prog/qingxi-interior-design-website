      "老屋翻新": ["老屋", "中古屋", "翻新", "翻修", "局部裝修"],
    };

    let bestCategory = "";
    let bestScore = 0;
    Object.entries(categoryKeywordsMap).forEach(([category, keywords]) => {
      const score = getInferenceKeywordScore(text, keywords);
      if (score > bestScore) {
        bestScore = score;
        bestCategory = category;
      }
    });

    if (bestScore > 0) return bestCategory;
    return directCategory || "";
  }

  function getInferenceKeywordScore(text, keywords) {
    return keywords.reduce((score, keyword) => score + (text.includes(keyword) ? 1 : 0), 0);
  }

