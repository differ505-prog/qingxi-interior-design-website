  document.getElementById("copy-article-prep-package")?.addEventListener("click", async () => {
    const result = await copyText(buildArticlePrepPackage(), "已複製完整生文前置包。");
    const feedback = getCopyFeedbackState(result, "已複製完整生文前置包。", "已開啟手動複製視窗，可直接複製完整生文前置包。");
    setFeedback(feedback.message, feedback.mode);
    setArticleAiFeedback(feedback.message, feedback.mode);
  });

  document.getElementById("copy-pro-finalize-prompt-inline")?.addEventListener("click", async () => {
    const sourceState = getSafeResolvedArticleSourcePackage();
    const successMessage = articleAiResult.trim()
      ? "已複製 Pro 生文提示詞。"
      : "已複製 Pro 生文提示詞模板，建議先生成 Flash 判題結果再使用。";
    const result = await copyProArticlePrompt(sourceState.packageText, successMessage, {
      manualFallbackMessage: "瀏覽器未完成自動複製，已開啟手動複製視窗。",
    });
    if (result.copyResult !== "clipboard") {
      revealArticleProPrompt();
    }
    const feedback = getCopyFeedbackState(
      result.copyResult,
      successMessage,
      result.hasAiResult
        ? "Pro 生文提示詞已備好，已開啟手動複製視窗。"
        : "Pro 生文提示詞模板已備好，已開啟手動複製視窗。",
      result.hasAiResult
        ? "Pro 生文提示詞已備好，但複製失敗，請直接手動複製下方內容。"
        : "Pro 生文提示詞模板已備好，但複製失敗，請直接手動複製下方內容。",
    );
    setArticleAiFeedback(feedback.message, feedback.mode);
  });

  document.getElementById("run-article-ai-quick")?.addEventListener("click", async () => {
    await runArticleAi("quick");
  });

  document.getElementById("run-article-ai-draft")?.addEventListener("click", async () => {
    await runArticleAi("full");
  });

  document.getElementById("copy-article-ai-result")?.addEventListener("click", async () => {
    if (!articleAiResult.trim()) {
      setArticleAiFeedback("目前沒有 AI 結果可複製。", "is-warning");
      return;
    }
    const result = await copyText(articleAiResult, "已複製 AI 結果。");
    const feedback = getCopyFeedbackState(result, "已複製 AI 結果。", "已開啟手動複製視窗，可直接複製 AI 結果。");
    setArticleAiFeedback(feedback.message, feedback.mode);
  });

  document.getElementById("copy-article-category")?.addEventListener("click", async () => {
    const data = getArticleConfirmData(articleAiResult);
    if (data.category === "尚未判定") {
      setArticleAiFeedback("請先生成 AI 結果。", "is-warning");
      return;
    }
    const result = await copyText(data.category, "已複製正式分類。");
    const feedback = getCopyFeedbackState(result, "已複製正式分類。", "已開啟手動複製視窗，可直接複製正式分類。");
    setArticleAiFeedback(feedback.message, feedback.mode);
  });

  document.getElementById("copy-article-confirm-payload")?.addEventListener("click", async () => {
    const data = getArticleConfirmData(articleAiResult);
    if (data.category === "尚未判定") {
      setArticleAiFeedback("請先生成 AI 結果。", "is-warning");
      return;
    }
    const result = await copyText(buildArticleConfirmPayload(data), "已複製分類落地資訊。");
    const feedback = getCopyFeedbackState(result, "已複製分類落地資訊。", "已開啟手動複製視窗，可直接複製分類落地資訊。");
    setArticleAiFeedback(feedback.message, feedback.mode);
  });

  document.getElementById("copy-social-reply-short")?.addEventListener("click", async () => {
    await copyArticleSocialReply("short", "已複製簡短版社團回覆。");
  });

  document.getElementById("copy-social-reply-pro")?.addEventListener("click", async () => {
    await copyArticleSocialReply("pro", "已複製專業版社團回覆。");
  });

  document.getElementById("copy-social-reply-lead")?.addEventListener("click", async () => {
    await copyArticleSocialReply("lead", "已複製導流版社團回覆。");
  });

  document.querySelectorAll("[data-canned-reply-copy-button]").forEach((button) => {
    button.addEventListener("click", async () => {
      if (!(button instanceof HTMLButtonElement)) return;
      const text = button.dataset.cannedReplyCopy || "";
      const label = button.dataset.cannedReplyLabel || "常見回覆";
      if (!text.trim()) {
        setArticleAiFeedback("目前沒有可複製的常見回覆。", "is-warning");
        return;
      }
      const result = await copyText(text, `已複製「${label}」常見回覆。`);
      const feedback = getCopyFeedbackState(
        result,
        `已複製「${label}」常見回覆。`,
        "已開啟手動複製視窗，可直接複製常見回覆。",
      );
      setArticleAiFeedback(feedback.message, feedback.mode);
    });
  });

  document.getElementById("clear-article-question")?.addEventListener("click", () => {
    articleSourceQuestion = "";
    localStorage.setItem(ARTICLE_SOURCE_QUESTION_KEY, "");
    clearArticleTopicDecision();
    clearArticleProFinalizePrompt();
    applyArticleSourceQuestionToField();
    renderArticleComposerPanel();
    setFeedback("已清空真實社團問題。", "is-warning");
  });

  document.getElementById("load-gemini-master")?.addEventListener("click", () => {
    loadGeminiMasterIntoEditor();
  });

  document.getElementById("import-gemini-share")?.addEventListener("click", async () => {
    await importGeminiShareFromUrl();
  });

  document.getElementById("run-gemini-backup")?.addEventListener("click", async () => {
    const currentDraft = readGeminiDraftFromFields();
    if (currentDraft?.sourceUrl && !currentDraft.content) {
      await importGeminiShareFromUrl({ sourceUrl: currentDraft.sourceUrl, silent: false });
    }
    const payload = buildGeminiBackupPayload();
    if (!payload) return;

    appendGeminiBackup(payload);
    setFeedback("已建立 Gemini 備份版本。", "is-success");
    setGeminiFeedback("已建立 Gemini 備份版本。", "is-success");
  });

  document.getElementById("copy-gemini-markdown")?.addEventListener("click", async () => {
    const payload = buildGeminiBackupPayload();
    if (!payload) return;
    await copyText(buildGeminiBackupMarkdown(payload), "已複製 Gemini Markdown 備份。");
    setGeminiFeedback("已複製 Gemini Markdown 備份。", "is-success");
  });

  document.getElementById("download-gemini-json")?.addEventListener("click", () => {
    const payload = buildGeminiBackupPayload();
    if (!payload) return;

    downloadTextFile(
      `qingxi-gemini-backup-${payload.savedAt.slice(0, 10)}.json`,
      JSON.stringify(
        {
          master: geminiCanvasMasterData,
          current: payload,
          history: geminiBackups,
        },
        null,
        2,
      ),
      "application/json;charset=utf-8",
    );
    setFeedback("已下載 Gemini JSON 備份。", "is-success");
    setGeminiFeedback("已下載 Gemini JSON 備份。", "is-success");
  });

  document.getElementById("gemini-backup-board")?.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const action = target.dataset.backupAction;
    const backupId = target.dataset.backupId;
    if (!action || !backupId) return;

    const backup = findGeminiBackupById(backupId);
    if (!backup) return;

    if (action === "restore") {
      geminiDraft = {
        title: backup.title,
        sourceUrl: backup.sourceUrl,
        content: backup.content,
      };
      localStorage.setItem(GEMINI_DRAFT_KEY, JSON.stringify(geminiDraft));
      applyGeminiDraftToFields();
      setFeedback("已載入指定備份版本。", "is-success");
      setGeminiFeedback("已載入指定備份版本。", "is-success");
      return;
    }

    if (action === "copy") {
      await copyText(buildGeminiBackupMarkdown(backup), "已複製該版本 Markdown。");
      setGeminiFeedback("已複製該版本 Markdown。", "is-success");
      return;
    }
  });

  document.getElementById("gemini-backup-board")?.addEventListener("input", (event) => {
    const target = event.target;
    if (
      target instanceof HTMLInputElement ||
      target instanceof HTMLTextAreaElement
    ) {
      persistGeminiDraftFromFields();
    }
  });

  document.getElementById("gemini-source-url")?.addEventListener("change", (event) => {
    if (!(event.target instanceof HTMLInputElement)) return;
    const nextUrl = event.target.value.trim();
    const previousUrl = geminiDraft?.sourceUrl?.trim() || "";
    const { content } = getGeminiFieldElements();
    const currentContent = content instanceof HTMLTextAreaElement ? content.value.trim() : "";
    const previousContent = geminiDraft?.content?.trim() || "";

    if (nextUrl && previousUrl && nextUrl !== previousUrl && currentContent && currentContent === previousContent) {
      resetGeminiDraftContentForNewSource();
      return;
    }

    persistGeminiDraftFromFields();
  });

  document.getElementById("refresh-content-analytics")?.addEventListener("click", () => {
    loadContentAnalytics();
  });

  document.getElementById("copy-vendor-intake-url")?.addEventListener("click", async () => {
    const shareUrlNode = document.getElementById("vendor-intake-share-url");
    const shareUrl = shareUrlNode instanceof HTMLInputElement ? shareUrlNode.value.trim() : buildVendorIntakeShareUrl();
    const result = await copyText(shareUrl, "已複製工班登錄網址。");
    const feedback = getCopyFeedbackState(
      result,
      "已複製工班登錄網址。",
      "已開啟手動複製視窗，可直接複製工班登錄網址。",
    );
    setVendorIntakeFeedback(feedback.message, feedback.mode);
  });

  document.getElementById("copy-vendor-intake-reply")?.addEventListener("click", async () => {
    const replyNode = document.getElementById("vendor-intake-canned-reply");
    const text = replyNode instanceof HTMLTextAreaElement ? replyNode.value.trim() : buildVendorIntakeCannedReply(buildVendorIntakeShareUrl());
    const result = await copyText(text, "已複製工班招募留言。");
    const feedback = getCopyFeedbackState(
      result,
      "已複製工班招募留言。",
      "已開啟手動複製視窗，可直接複製工班招募留言。",
    );
    setVendorIntakeFeedback(feedback.message, feedback.mode);
  });

  document.getElementById("vendor-intake-search")?.addEventListener("input", (event) => {
    if (!(event.target instanceof HTMLInputElement)) return;
    vendorIntakeSearch = event.target.value.trim();
    renderVendorIntakes();
  });

  document.getElementById("vendor-intake-trade-filter")?.addEventListener("change", (event) => {
    if (!(event.target instanceof HTMLSelectElement)) return;
    vendorIntakeTradeFilter = event.target.value || "";
    renderVendorIntakes();
  });

  document.getElementById("vendor-intake-status-filter")?.addEventListener("change", (event) => {
    if (!(event.target instanceof HTMLSelectElement)) return;
    vendorIntakeStatusFilter = event.target.value || "";
    renderVendorIntakes();
  });

  document.getElementById("vendor-intake-list")?.addEventListener("click", async (event) => {
    const target = event.target instanceof HTMLElement ? event.target.closest("[data-vendor-intake-save], [data-vendor-intake-promote]") : null;
    if (!(target instanceof HTMLButtonElement)) return;

    const itemId = target.dataset.vendorIntakeSave || target.dataset.vendorIntakePromote || "";
    const currentItem = (vendorIntakeState.items || []).find((entry) => entry.id === itemId);
    if (!itemId || !currentItem) return;

    const statusField = document.querySelector(`[data-vendor-intake-status="${itemId}"]`);
    const noteField = document.querySelector(`[data-vendor-intake-note="${itemId}"]`);
    const nextStatus = statusField instanceof HTMLSelectElement ? statusField.value.trim() : currentItem.status;
    const nextNote = noteField instanceof HTMLTextAreaElement ? noteField.value.trim() : currentItem.internalNote;

    target.disabled = true;
    try {
      if (target.dataset.vendorIntakePromote) {
        const notePayload = buildVendorNoteFromIntake({
          ...currentItem,
          status: nextStatus || currentItem.status,
          internalNote: nextNote,
        });
        await saveVendorNote(notePayload);
        await saveVendorIntake({
          ...currentItem,
          status: "promoted",
          internalNote: nextNote,
        });
        setVendorIntakeFeedback("已轉成優質廠商筆記，之後再按會更新同一筆筆記。", "is-success");
        setVendorNoteFeedback("已同步建立優質廠商筆記。", "is-success");
        return;
      }

      await saveVendorIntake({
        ...currentItem,
        status: nextStatus || "new",
        internalNote: nextNote,
      });
      setVendorIntakeFeedback("已更新這筆工班資料狀態。", "is-success");
    } catch (error) {
      console.error("更新工班登錄資料失敗：", error);
      setVendorIntakeFeedback(error instanceof Error ? error.message : "工班資料更新失敗，請稍後再試。", "is-warning");
    } finally {
      target.disabled = false;
    }
  });

  document.getElementById("vendor-note-search")?.addEventListener("input", (event) => {
    if (!(event.target instanceof HTMLInputElement)) return;
    vendorNoteSearch = event.target.value.trim();
    renderVendorNotes();
  });

  document.getElementById("vendor-note-sort")?.addEventListener("change", (event) => {
    if (!(event.target instanceof HTMLSelectElement)) return;
    vendorNoteSort = event.target.value || "default";
    renderVendorNotes();
  });

  document.getElementById("vendor-trade-filter")?.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target.closest("[data-vendor-trade-filter]") : null;
    if (!(target instanceof HTMLElement)) return;
    vendorNoteTradeFilter = target.dataset.vendorTradeFilter || "";
    renderVendorNotes();
  });

  document.getElementById("clear-vendor-note-form")?.addEventListener("click", () => {
    resetVendorNoteForm();
    setVendorNoteFeedback("已清空廠商筆記表單。", "is-warning");
  });

  document.getElementById("save-vendor-note")?.addEventListener("click", async () => {
    const formNote = readVendorNoteForm();
    if (!formNote.name || !formNote.trade) {
      setVendorNoteFeedback("至少請填廠商名稱與工種。", "is-warning");
      return;
    }

    const existingNote = (vendorNotesState.items || []).find((entry) => entry.id === formNote.id);
    const now = new Date().toISOString();
    const payload = {
      ...createVendorNoteTemplate(),
      ...existingNote,
      ...formNote,
      id: formNote.id || createVendorNoteId(),
      createdAt: existingNote?.createdAt || now,
      updatedAt: now,
      isPinned: Boolean(existingNote?.isPinned),
    };

    try {
      await saveVendorNote(payload);
      resetVendorNoteForm();
      setVendorNoteFeedback(existingNote ? "已更新共享廠商筆記。" : "已新增共享廠商筆記。", "is-success");
    } catch (error) {
      console.error("儲存共享廠商筆記失敗：", error);
      setVendorNoteFeedback(error instanceof Error ? error.message : "共享廠商筆記儲存失敗，請稍後再試。", "is-warning");
    }
  });

  document.getElementById("vendor-note-list")?.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const actionButton = target.closest("[data-vendor-action]");
    if (!(actionButton instanceof HTMLButtonElement)) return;

    const noteId = actionButton.dataset.vendorId;
    const action = actionButton.dataset.vendorAction;
    const currentNote = (vendorNotesState.items || []).find((entry) => entry.id === noteId);
    if (!noteId || !action || !currentNote) return;

    if (action === "edit") {
      applyVendorNoteToForm(currentNote);
      setVendorNoteFeedback("已載入這筆廠商筆記，可直接修改。", "is-success");
      return;
    }

    if (action === "pin") {
      try {
        await saveVendorNote({
          ...currentNote,
          isPinned: !currentNote.isPinned,
          updatedAt: new Date().toISOString(),
        });
        setVendorNoteFeedback(currentNote.isPinned ? "已取消優先標記。" : "已標記為優先合作名單。", "is-success");
      } catch (error) {
        console.error("更新廠商優先標記失敗：", error);
        setVendorNoteFeedback(error instanceof Error ? error.message : "更新優先標記失敗，請稍後再試。", "is-warning");
      }
      return;
    }

    if (action === "delete") {
      if (!window.confirm(`確定要刪除「${currentNote.name}」嗎？`)) return;
      try {
        await removeVendorNote(noteId);
        if (vendorNoteEditingId === noteId) {
          resetVendorNoteForm();
        }
        setVendorNoteFeedback("已刪除這筆共享廠商筆記。", "is-success");
      } catch (error) {
        console.error("刪除共享廠商筆記失敗：", error);
        setVendorNoteFeedback(error instanceof Error ? error.message : "刪除失敗，請稍後再試。", "is-warning");
      }
    }
  });

  document.getElementById("article-source-question")?.addEventListener("input", () => {
    const previousQuestion = articleSourceQuestion;
    const nextQuestion = persistArticleSourceQuestion();
    if (nextQuestion !== previousQuestion) {
      clearArticleTopicDecision();
      clearArticleProFinalizePrompt();
    }
    renderArticleComposerPanel();
  });

  document.getElementById("article-preset-title")?.addEventListener("input", () => {
    const previousTitle = articlePresetTitle;
    const nextTitle = persistArticlePresetTitle();
    if (nextTitle !== previousTitle) {
      clearArticleTopicDecision();
      clearArticleProFinalizePrompt();
    }
    renderArticleComposerPanel();
  });

  document.getElementById("publishing-asset-slot-target")?.addEventListener("change", () => {
    renderPublishingAssetSlots();
  });

  document.getElementById("publishing-asset-slot-input")?.addEventListener("change", (event) => {
    if (!(event.target instanceof HTMLInputElement)) return;
    attachAssetsToSelectedSlot(event.target.files);
    event.target.value = "";
  });

  document.getElementById("publishing-asset-dropzone")?.addEventListener("dragover", (event) => {
    event.preventDefault();
    const dropzone = event.currentTarget;
    if (dropzone instanceof HTMLElement) {
      dropzone.classList.add("is-dragover");
    }
  });

  document.getElementById("publishing-asset-dropzone")?.addEventListener("dragleave", (event) => {
    const dropzone = event.currentTarget;
    if (dropzone instanceof HTMLElement) {
      dropzone.classList.remove("is-dragover");
    }
  });

  document.getElementById("publishing-asset-dropzone")?.addEventListener("drop", (event) => {
    event.preventDefault();
    const dropzone = event.currentTarget;
    if (dropzone instanceof HTMLElement) {
      dropzone.classList.remove("is-dragover");
    }
    const files = event.dataTransfer?.files;
    attachAssetsToSelectedSlot(files);
  });

  document.getElementById("publishing-asset-slot-list")?.addEventListener("click", (event) => {
    const target = event.target instanceof HTMLElement ? event.target.closest("[data-asset-slot-key][data-asset-slot-index]") : null;
    if (!(target instanceof HTMLButtonElement)) return;
    removePublishingAssetSlotItem(target.dataset.assetSlotKey || "", Number(target.dataset.assetSlotIndex || "-1"));
  });

  document.getElementById("article-pro-prompt-content")?.addEventListener("focus", (event) => {
    if (event.target instanceof HTMLTextAreaElement) {
      event.target.select();
    }
  });

  loadArticleSourceQuestion();
  loadArticlePresetTitle();
  loadPublishingAssetSlotsState();
  loadArticleTopicDecision();
  loadArticleAiResult();
  loadArticleProFinalizePrompt();
  loadGeminiBackupState();
  loadPublishingChecklist();
  loadPublishingReviewFilter();
  loadPublishingTitlePoolReviewState();
  loadTopicMode();
  loadWorkspacePane();
  loadState();
  normalizeWeeklyState();
  normalizeDailyState();
  applyArticleSourceQuestionToField();
  applyArticlePresetTitleToField();
  renderArticleTopicDecision();
  renderArticleAiResult();
  renderArticleProPrompt();
  renderArticleComposerPanel();
  renderPublishingAssetSlots();
  renderCrossSeriesLock();
  applyGeminiDraftToFields();
  renderTopicModePanels();
  renderPublishingChecklist();
  refreshWorkspacePaneUi();
  handleWorkspacePaneSideEffects();
  // 监听「回看與成效」details 标签的展开事件
  const analyticsDetails = document.getElementById('content-analytics-details');
  if (analyticsDetails) {
    analyticsDetails.addEventListener('toggle', () => {
      if (analyticsDetails.open) {
        // 展开时重新渲染 UI
        renderContentAnalytics();
        // 如果还没有成功加载过，或者之前加载失败了，都重新尝试加载
        if (contentAnalyticsState.status === 'idle' || contentAnalyticsState.status === 'error' || contentAnalyticsState.status === 'loading') {
          loadContentAnalytics();
        }
      }
    });
  }

  rerender();
  try {
    hydrateVendorIntakeTools();
  } catch (error) {
    console.error("初始化工班登錄工具失敗：", error);
  }
  renderVendorIntakes();
  loadVendorIntakes();
  renderContentAnalytics();
  loadContentAnalytics();
  resetVendorNoteForm();
  loadVendorNotes();
</script>
