let blogPosts = staticBlogPosts.map(({ coverImage, ...post }) => post);
let blogSyncLabel = "目前先顯示已存在文章。";

try {
  if (import.meta.env.CONTENTFUL_SPACE_ID && import.meta.env.CONTENTFUL_ACCESS_TOKEN) {
    const client = contentful.createClient({
      space: import.meta.env.CONTENTFUL_SPACE_ID,
      accessToken: import.meta.env.CONTENTFUL_ACCESS_TOKEN,
      environment: "master",
    });

    const response = await client.getEntries({
      content_type: "blogPost",
      order: ["-fields.date"],
    });

    const syncedPosts = mapContentfulBlogPosts(response.items).map(
      ({ coverImage, ...post }) => post,
    );

    if (syncedPosts.length > 0) {
      blogPosts = mergeBlogPosts([
        ...staticBlogPosts.map(({ coverImage, ...post }) => post),
        ...syncedPosts,
      ]);
      blogSyncLabel = `已同步 ${blogPosts.length} 篇知識文章。`;
    } else {
      blogSyncLabel = "Contentful 目前無文章，先顯示已存在文章。";
    }
  } else {
    blogSyncLabel = "未連接 Contentful，先顯示已存在文章。";
  }
} catch (error) {
  console.error("讀取知識分享文章失敗：", error);
  blogSyncLabel = "同步失敗，先顯示已存在文章。";
}

function buildTopicModeRationale(modeValue: string, modeDashboard: any, modeRecommendation: any) {
  if (!modeDashboard?.focusTrack || !modeRecommendation) return "目前資料不足，先沿用既有排序。";

  if (modeValue === "publishing") {
    return `先補 ${modeRecommendation.chapter} > ${modeRecommendation.subchapter}，最快推進 ${modeDashboard.focusTrack.title} 出版進度。`;
  }

  if (modeValue === "balanced") {
    return `主線仍是 ${modeDashboard.focusTrack.title}，但這題也能順手補到 ${modeRecommendation.trackTitle}。`;
  }

  return modeRecommendation.sameSubchapterArticles.length
    ? `Flash 依既有文章換切角，但仍留在 ${modeRecommendation.trackTitle} 的書稿骨架內。`
    : `先用 Flash 找新切角，但不離開 ${modeRecommendation.trackTitle} 的固定骨架。`;
}

const publishingCoverage = getPublishingCoverageSummary(blogPosts, publishingFocusTrackTitle);
const topicModeMap = Object.fromEntries(
  publishingTopicModeOptions.map((modeOption) => {
    const publishingDashboard = getPublishingDashboard(blogPosts, publishingFocusTrackTitle, modeOption.value);
    const nextRecommendedTopic = getNextRecommendedTopic(blogPosts, publishingFocusTrackTitle, modeOption.value);
    const nextTopicCandidates = getNextRecommendedTopics(blogPosts, publishingFocusTrackTitle, modeOption.value, 6);
    const trackRecommendations = getTrackRecommendedTopics(blogPosts, publishingFocusTrackTitle, modeOption.value)
      .sort((left, right) => {
        if (!left || !right) return 0;
        const leftRank = publishingDashboard.rankedTracks.findIndex((track) => track.title === left.trackTitle);
        const rightRank = publishingDashboard.rankedTracks.findIndex((track) => track.title === right.trackTitle);
        return leftRank - rightRank;
      });
    return [
      modeOption.value,
      {
        ...modeOption,
        bookProposal: getPublicationBookProposal(publishingDashboard.focusTrack?.title || publishingFocusTrackTitle),
        publishingDashboard,
        nextRecommendedTopic,
        nextTopicCandidates,
        trackRecommendations,
        modeRationale: buildTopicModeRationale(modeOption.value, publishingDashboard, nextRecommendedTopic),
      },
    ];
  }),
);
const defaultTopicMode = publishingTopicModeOptions[0]?.value || "publishing";
const defaultModeOption = publishingTopicModeOptions.find((modeOption) => modeOption.value === defaultTopicMode) || publishingTopicModeOptions[0];
const defaultModeState = topicModeMap[defaultTopicMode];
const publishingDashboard = topicModeMap[defaultTopicMode].publishingDashboard;
const initialFocusTrack = defaultModeState?.publishingDashboard?.focusTrack || null;
const initialBookProposal = defaultModeState?.bookProposal || null;
const initialRecommendation = defaultModeState?.nextRecommendedTopic || null;
const initialRecommendationModeText = initialFocusTrack
  ? `${defaultModeState?.label || defaultTopicMode}｜${initialFocusTrack.title} 尚差 ${initialFocusTrack.remainingToBaseline} 篇`
  : "會跟內容書架同步";
const initialRankedCandidates = (() => {
  const focusTrackTitle = defaultModeState?.publishingDashboard?.focusTrack?.title;
  const allCandidates = Array.isArray(defaultModeState?.nextTopicCandidates) ? defaultModeState.nextTopicCandidates : [];
  const primaryRecommendation = defaultModeState?.nextRecommendedTopic || null;
  const filtered = focusTrackTitle
    ? allCandidates.filter((candidate) => candidate.trackTitle === focusTrackTitle)
    : allCandidates;
  const chapterFallbacks = (defaultModeState?.publishingDashboard?.focusTrack?.chapterGaps || [])
    .map((gap) => gap.recommendedTopic)
    .filter((candidate): candidate is NonNullable<typeof primaryRecommendation> => Boolean(candidate))
    .filter((candidate) => !focusTrackTitle || candidate.trackTitle === focusTrackTitle);
  const merged: NonNullable<typeof primaryRecommendation>[] = [];
  if (primaryRecommendation) {
    merged.push(primaryRecommendation);
  }
  [...filtered, ...chapterFallbacks].forEach((candidate) => {
    if (!merged.some((item) => item.primaryTitle === candidate.primaryTitle && item.subchapter === candidate.subchapter)) {
      merged.push(candidate);
    }
  });
  const chapterPriorityMap = {
    "現況判讀": 0,
    "預算拆解": 1,
    "基礎工程": 2,
    "空間重整": 3,
    "完工避雷": 4,
  };
  const explicitPriorityMap = {
    "現況判讀::翻新起手式": 0,
    "現況判讀::迷思破解": 1,
    "現況判讀::案例解析": 2,
    "現況判讀::專案節點": 3,
    "預算拆解::報價拆讀": 4,
    "預算拆解::追加風險": 5,
    "預算拆解::發包合約": 6,
  };
  const rankCandidate = (candidate: any, index: number) => {
    const riskRank = candidate?.collisionRisk === "low"
      ? 0
      : candidate?.collisionRisk === "medium"
        ? 1
        : 2;
    const explicitKey = `${candidate?.chapter || ""}::${candidate?.subchapter || ""}`;
    const explicitRank = Object.prototype.hasOwnProperty.call(explicitPriorityMap, explicitKey)
      ? explicitPriorityMap[explicitKey as keyof typeof explicitPriorityMap]
      : 50;
    const chapterRank = Object.prototype.hasOwnProperty.call(chapterPriorityMap, candidate?.chapter || "")
      ? chapterPriorityMap[candidate.chapter as keyof typeof chapterPriorityMap]
      : 9;
    const riskPenalty = candidate?.workflowAction === "Merge_and_Update" && explicitRank < 10 ? 0 : riskRank * 1000;
    return riskPenalty + explicitRank * 100 + chapterRank * 10 + index;
  };
  const safeCandidates = merged.filter((candidate) => (
    candidate?.collisionRisk !== "high" || candidate?.workflowAction === "Merge_and_Update"
  ));
  const candidatePool = safeCandidates.length ? safeCandidates : merged;
  return candidatePool
    .sort((left, right) => rankCandidate(left, merged.indexOf(left)) - rankCandidate(right, merged.indexOf(right)))
    .slice(0, 6);
})();
const initialForcedTopPriorityTitles = [
  "屋況初勘避雷：隱蔽風險排查與檢測要點",
  "全室預算拆解：報價單判讀與超支預防指南",
  "水電更新：老屋基礎工程的迴路重整與用電安全",
];
const initialMergeTask = initialRankedCandidates.find((candidate) => ["Merge_and_Update", "Merge_into_Asset"].includes(candidate?.workflowAction)) || null;
const initialMergeRule = initialMergeTask
  ? publicationMergeDirectives.find((rule) => rule.trackTitle === initialMergeTask.trackTitle && rule.chapterTitle === initialMergeTask.chapter) || null
  : null;
const initialTopPriorityRecommendations = (() => {
  const newPublishCandidates = initialRankedCandidates.filter((candidate) => candidate?.workflowAction === "New_Publish");
  const forced = initialForcedTopPriorityTitles
    .map((title) => newPublishCandidates.find((candidate) => (
      (candidate.primaryTitle || candidate.webTitle || candidate.bookTitle) === title
    )))
    .filter((candidate): candidate is NonNullable<typeof initialRecommendation> => Boolean(candidate));
  const seen = new Set(forced.map((candidate) => candidate.primaryTitle || candidate.webTitle || candidate.bookTitle));
  const remainder = newPublishCandidates.filter((candidate) => {
    const title = candidate.primaryTitle || candidate.webTitle || candidate.bookTitle;
    if (!title || seen.has(title)) return false;
    seen.add(title);
    return true;
  });
  return [...forced, ...remainder].slice(0, 3);
})();
const initialCrossTrackSyncNote = initialMergeTask
  ? initialMergeTask.workflowAction === "Merge_into_Asset"
