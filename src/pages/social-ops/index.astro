      `同子章既有文章：${recommendation.sameSubchapterArticles.join(" / ") || "目前沒有"}`,
      `同章既有文章：${recommendation.sameChapterArticles.join(" / ") || "目前沒有"}`,
      `同書系其他文章：${recommendation.sameTrackArticles.join(" / ") || "目前沒有"}`,
    ].join("\n");
  }

  function getCurrentTopicCandidates(mode = currentTopicMode) {
    const topCandidates = getTopPriorityRecommendations(mode, 3);
    const rawCandidates = getRankedTopicCandidates(mode, 8)
      .filter((candidate) => ["New_Publish", "Revise_Angle", "Merge_into_Asset"].includes(candidate?.workflowAction));
    const merged = [...topCandidates];
    rawCandidates.forEach((candidate) => {
      if (!merged.some((item) => item.primaryTitle === candidate.primaryTitle && item.subchapter === candidate.subchapter)) {
        merged.push(candidate);
      }
    });
    return merged;
  }

  function getTopicReviewCandidates(mode = currentTopicMode, limit = 10) {
    const ranked = getRankedTopicCandidates(mode, Math.max(limit, 8));
    const mergeCandidates = getMergeTaskRecommendations(mode, 4);
    const newCandidates = getTopPriorityRecommendations(mode, 6);
    const reviseCandidates = ranked.filter((candidate) => candidate?.workflowAction === "Revise_Angle").slice(0, 3);
    const merged = [];

    [...mergeCandidates, ...newCandidates, ...reviseCandidates, ...ranked].forEach((candidate) => {
      if (!candidate) return;
      if (!merged.some((item) => item.primaryTitle === candidate.primaryTitle && item.subchapter === candidate.subchapter)) {
        merged.push(candidate);
      }
    });

    return merged.slice(0, Math.max(1, limit)).map((candidate, index) => ({
      ...candidate,
      reviewIndex: index + 1,
    }));
  }

  function formatTopicReviewCandidateNotes(candidate, focusTrack) {
    const similarTitles = candidate?.similarArticles?.slice(0, 3).map((article) => `${article.title}（${article.score}）`).join(" / ") || "目前沒有明確相近舊文";
    const sameChapter = candidate?.sameChapterArticles?.join(" / ") || "目前沒有";
    const dependency = getDependencyLockMessage(candidate, focusTrack) || "目前無前置依賴阻斷";
    return [
      `規則層提名：${getWorkflowActionLabel(candidate?.workflowAction || "New_Publish")}`,
      `系統理由：${candidate?.reason || "尚未提供"}`,
      `規則初篩：${candidate?.collisionRisk || "unknown"}｜${candidate?.collisionReason || "尚未比對"}`,
      `相近舊文：${similarTitles}`,
      `同章既有文章：${sameChapter}`,
      `依賴鎖：${dependency}`,
    ].join("\n");
  }

  function buildTopicReviewCandidateText(mode = currentTopicMode) {
    const modeState = getCurrentTopicModeState(mode);
    const focusTrack = modeState?.publishingDashboard?.focusTrack;
    const candidates = getTopicReviewCandidates(mode, 10);
    return candidates
      .map((candidate) => [
        `候選 ${candidate.reviewIndex}`,
        `主書系：${candidate.trackTitle}`,
        `章節：${candidate.chapter}`,
        `子章節：${candidate.subchapter}`,
        `網站分類：${candidate.category}`,
        `統一標題：${getDisplayTitle(candidate)}`,
        `備選標題：${candidate.backupTitles?.slice(0, 2).join(" / ") || "無"}`,
        formatTopicReviewCandidateNotes(candidate, focusTrack),
      ].join("\n"))
      .join("\n\n");
  }

