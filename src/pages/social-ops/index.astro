          const subchapterRecommendation = gap.recommendedTopic?.subchapter === subchapter.title ? gap.recommendedTopic : null;
          const hasPendingRecommendation = Boolean(
            subchapterRecommendation?.primaryTitle && !isPublishedArticleTitle(subchapterRecommendation.primaryTitle),
          );
          const isDraft = Boolean(
            draftState &&
            draftState.track === focusTrack.title &&
            draftState.chapter === gap.chapter &&
            draftState.subchapter === subchapter.title
          );
          if (!publishingReviewShowUnpublishedOnly) return true;
          return !subchapter.coveredByArticle || hasPendingRecommendation || isDraft;
        });

        if (publishingReviewShowUnpublishedOnly && visibleSubchapters.length === 0) {
          return "";
        }

        const subchapterMarkup = visibleSubchapters.map((subchapter) => {
          const subchapterRecommendation = gap.recommendedTopic?.subchapter === subchapter.title ? gap.recommendedTopic : null;
          const titlePoolItem = (gap.titlePool || []).find((item) => item.subchapter === subchapter.title);
          const dependencyLockState = getDependencyLockState(focusTrack, gap.chapter, subchapter.title);
          const dependencyLocked = dependencyLockState.locked;
          const recommendationPublished = subchapterRecommendation
            ? isPublishedArticleTitle(subchapterRecommendation.primaryTitle)
            : false;
          const isPrimaryRecommendation = recommendation?.primaryTitle === subchapterRecommendation?.primaryTitle;
          const isDraft = Boolean(
            draftState &&
            draftState.track === focusTrack.title &&
            draftState.chapter === gap.chapter &&
            draftState.subchapter === subchapter.title
          );
          const subchapterStateClass = subchapter.coveredByArticle ? "is-covered" : isDraft ? "is-draft" : "is-pending";
          const recommendationMarkup = subchapterRecommendation && (!publishingReviewShowUnpublishedOnly || !recommendationPublished)
            ? `
              <div class="bookshelf-review-subchapter-article ${recommendationPublished ? "is-published" : ""} ${isPrimaryRecommendation ? "is-next" : ""}">
                <span>${isPrimaryRecommendation ? "主送審候選" : "本章送審候選"}</span>
                <strong>${escapeHtml(getDisplayTitle(subchapterRecommendation))}</strong>
                <small>${escapeHtml(subchapterRecommendation.category)}</small>
              </div>
            `
            : "";

          return `
            <li class="bookshelf-review-subchapter-item ${subchapterStateClass} ${isPrimaryRecommendation ? "is-next" : ""}">
              <div class="bookshelf-review-subchapter-head">
                <div class="bookshelf-review-subchapter-copy">
                  <span>${escapeHtml(titlePoolItem?.statusTag || "子章節")}</span>
                  <strong>${escapeHtml(subchapter.title)}</strong>
                </div>
                <em>${subchapter.coveredByMergeBacked ? "整併成立" : subchapter.coveredByArticle ? `已有 ${subchapter.articleCount} 篇` : isDraft ? "草稿中" : dependencyLocked ? "依賴鎖定" : "待補"}</em>
              </div>
              ${titlePoolItem?.assetSlotLabel ? `<small class="bookshelf-review-subchapter-asset">附錄掛載：${escapeHtml(titlePoolItem.assetSlotLabel)}</small>` : ""}
              ${dependencyLocked ? `<small class="bookshelf-dependency-lock" title="${escapeHtml(dependencyLockState.message)}" aria-label="${escapeHtml(dependencyLockState.message)}">&#128274; ${escapeHtml(dependencyLockState.message)}</small>` : ""}
              ${recommendationMarkup}
            </li>
          `;
        }).join("");

        const publishedPostsMarkup = publishedPosts.length && !publishingReviewShowUnpublishedOnly
          ? `
            <div class="bookshelf-review-published-block">
              <p class="bookshelf-review-block-title">本章已上線文章</p>
              <ul class="bookshelf-review-article-list">
                ${publishedPosts.map((post) => `
                  <li class="bookshelf-review-article-item is-published ${isMergeRequiredPublishedPost(post) ? "is-merge-needed" : ""}">
                    <div class="bookshelf-review-article-copy">
                      <span>${getPublishedStatusLabel(post)}</span>
                      <strong>${escapeHtml(getPublishedPostDisplayTitle(post))}</strong>
                      <small>${escapeHtml(post.siteCategory || post.category || "已發布文章")}</small>
                    </div>
                  </li>
                `).join("")}
              </ul>
            </div>
          `
          : "";

        return `
          <article class="bookshelf-review-chapter-card">
            <div class="bookshelf-review-chapter-head">
              <div>
                <span>章節 ${index + 1}</span>
                <strong>${escapeHtml(gap.chapter)}</strong>
              </div>
              <small>子章完成 ${gap.subchapters.filter((subchapter) => subchapter.coveredByArticle).length} / ${gap.subchapters.length}</small>
            </div>
            <p class="bookshelf-review-chapter-note">待補子章：${escapeHtml(gap.missingSubchapters.join(" / ") || "本章主幹已立住")}</p>
            ${mergeRule ? `<p class="bookshelf-review-chapter-merge">整併目標：${escapeHtml(mergeRule.targetTitle)}｜需整併：${escapeHtml(mergeRule.sourceTitles.join(" / "))}</p>` : ""}
            <ol class="bookshelf-review-subchapter-list">
              ${subchapterMarkup}
            </ol>
            ${publishedPostsMarkup}
          </article>
        `;
      })
      .filter(Boolean)
      .join("");

    plan.innerHTML = chapterCards || '<p class="bookshelf-confirm-note">目前沒有待補子章；可先切回顯示全部，檢查整體出版目錄。</p>';
    const totalPublishedCount = focusTrack.chapterGaps.reduce(
      (sum, gap) => sum + getPublishedPostsForChapter(focusTrack.title, gap.chapter).length,
      0,
    );
    const totalSubchapterCount = focusTrack.chapterGaps.reduce((sum, gap) => sum + gap.subchapters.length, 0);
    const uncoveredSubchapterCount = focusTrack.chapterGaps.reduce(
      (sum, gap) => sum + gap.subchapters.filter((subchapter) => !subchapter.coveredByArticle).length,
      0,
    );
    filterNote.textContent = publishingReviewShowUnpublishedOnly
      ? `目前只看未發佈：顯示 ${uncoveredSubchapterCount} 個待補子章，已隱藏 ${totalPublishedCount} 篇已上線文章。`
      : `目前顯示全部：共 ${totalSubchapterCount} 個子章、${totalPublishedCount} 篇已上線文章。`;

    promptContent.value = buildPublishingReviewPrompt(currentTopicMode);
    renderReviewNextTopicPanel(modeState);
    renderPublishingAssetSlots();
  }

  function getCurrentTopicModeState(mode = currentTopicMode) {
    return topicModeDataMap?.[mode] || topicModeDataMap?.[topicModeOptions?.[0]?.value] || null;
  }

  function loadTopicMode() {
    try {
      const savedMode = localStorage.getItem(TOPIC_MODE_KEY);
      if (savedMode && topicModeDataMap?.[savedMode]) {
        currentTopicMode = savedMode;
      }
    } catch (error) {
      console.error("讀取決題模式失敗：", error);
    }
  }

  function handlePublishingReviewFilterToggle() {
    publishingReviewShowUnpublishedOnly = !publishingReviewShowUnpublishedOnly;
    savePublishingReviewFilter();
    renderPublishingReviewBoard();
  }

  function saveTopicMode() {
    localStorage.setItem(TOPIC_MODE_KEY, currentTopicMode);
  }

  function renderTopicModePanels() {
    document.querySelectorAll("[data-topic-mode]").forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      const active = button.dataset.topicMode === currentTopicMode;
      button.classList.toggle("is-active", active);
      button.setAttribute("aria-pressed", active ? "true" : "false");
    });

    const panelRoot = document.querySelector("[data-topic-mode-root]");
    if (!(panelRoot instanceof HTMLElement)) return;

    const template = [...document.querySelectorAll("[data-topic-mode-template]")].find((node) => (
      node instanceof HTMLTemplateElement && node.dataset.topicModeTemplate === currentTopicMode
    ));

    if (!(template instanceof HTMLTemplateElement)) return;

    panelRoot.replaceChildren(template.content.cloneNode(true));
    renderPublishingReviewBoard();
  }

