      "智能家居": ["智能", "智慧", "自動化", "感應", "窗簾", "控制", "設備整合"],
      "格局動線": ["格局", "動線", "配置", "空間", "客廳", "餐廳", "臥室"],
      "水電照明": ["水電", "照明", "插座", "開關", "迴路", "燈光"],
