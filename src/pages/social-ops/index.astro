  function loadArticleSourceQuestion() {
    try {
      articleSourceQuestion = localStorage.getItem(ARTICLE_SOURCE_QUESTION_KEY) || "";
    } catch (error) {
      console.error("讀取社團問題草稿失敗：", error);
      articleSourceQuestion = "";
    }
  }

  function applyArticleSourceQuestionToField() {
    const field = document.getElementById("article-source-question");
    if (!(field instanceof HTMLTextAreaElement)) return;
    field.value = articleSourceQuestion;
  }

  function persistArticleSourceQuestion() {
    const field = document.getElementById("article-source-question");
    if (!(field instanceof HTMLTextAreaElement)) return "";
    articleSourceQuestion = field.value.trim();
    try {
      localStorage.setItem(ARTICLE_SOURCE_QUESTION_KEY, articleSourceQuestion);
    } catch (error) {
      console.error("儲存社團問題草稿失敗：", error);
    }
    return articleSourceQuestion;
  }

  function loadArticleTopicDecision() {
    try {
      const raw = localStorage.getItem(ARTICLE_TOPIC_DECISION_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      articleTopicDecision = parsed && typeof parsed === "object" ? parsed : null;
    } catch (error) {
      console.error("讀取本題動態決題失敗：", error);
      articleTopicDecision = null;
    }
  }

  function saveArticleTopicDecision() {
    try {
      localStorage.setItem(ARTICLE_TOPIC_DECISION_KEY, JSON.stringify(articleTopicDecision));
      return true;
    } catch (error) {
      console.error("儲存本題動態決題失敗：", error);
      return false;
    }
  }

  function clearArticleTopicDecision() {
    articleTopicDecision = null;
    try {
      localStorage.removeItem(ARTICLE_TOPIC_DECISION_KEY);
    } catch (error) {
      console.error("清除本題動態決題失敗：", error);
    }
    renderArticleTopicDecision();
  }

  function renderArticleTopicDecision() {
    const shell = document.getElementById("article-topic-shell");
    const label = document.getElementById("article-topic-label");
    const mode = document.getElementById("article-topic-mode");
    const category = document.getElementById("article-topic-category");
    const track = document.getElementById("article-topic-track");
    const chapter = document.getElementById("article-topic-chapter");
    const subchapter = document.getElementById("article-topic-subchapter");
    const title = document.getElementById("article-topic-title");
    const reason = document.getElementById("article-topic-reason");
    const nextAction = document.getElementById("article-topic-next-action");
    const similar = document.getElementById("article-topic-similar");
    const angle = document.getElementById("article-topic-angle");
    const note = document.getElementById("article-topic-note");
    if (
      !(shell instanceof HTMLElement) ||
      !(label instanceof HTMLElement) ||
      !(mode instanceof HTMLElement) ||
      !(category instanceof HTMLElement) ||
      !(track instanceof HTMLElement) ||
      !(chapter instanceof HTMLElement) ||
      !(subchapter instanceof HTMLElement) ||
      !(title instanceof HTMLElement) ||
      !(reason instanceof HTMLElement) ||
      !(nextAction instanceof HTMLElement) ||
      !(similar instanceof HTMLElement) ||
      !(angle instanceof HTMLElement) ||
      !(note instanceof HTMLElement)
    ) {
      return;
    }

    if (!articleTopicDecision) {
      shell.hidden = true;
      return;
    }

    const modeState = getCurrentTopicModeState(articleTopicDecision.mode);
    const candidateCount = getCurrentTopicCandidates(articleTopicDecision.mode).length;
    shell.hidden = false;
    label.textContent = articleTopicDecision.summary || "已完成本題動態決題";
    mode.textContent = articleTopicDecision.modeLabel || modeState?.label || articleTopicDecision.mode || "尚未決題";
    category.textContent = "尚未判定";
    track.textContent = articleTopicDecision.track || "尚未決題";
    chapter.textContent = articleTopicDecision.chapter || "尚未決題";
    subchapter.textContent = articleTopicDecision.subchapter || "尚未決題";
    title.textContent = articleTopicDecision.title || "尚未決題";
    reason.textContent = articleTopicDecision.reason || articleTopicDecision.questionLink || "已完成動態決題。";
    nextAction.textContent = "先完成 AI 判題與正式分類";
    similar.textContent = "尚未比對";
    angle.textContent = "先貼問題再判題";
    note.textContent =
      articleTopicDecision.bookLink ||
      `這一步會先依真實社團問題理解痛點，再從 ${candidateCount || "目前"} 個出版候選裡挑最適合落進書稿的題目。`;
  }

