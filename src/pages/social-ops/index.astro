    const question = persistArticleSourceQuestion();
    if (!question) {
      setFeedback("請先貼上真實社團問題。", "is-warning");
      setArticleAiFeedback("請先貼上真實社團問題。", "is-warning");
      return null;
    }

    try {
      const controller = new AbortController();
      const timeoutId = window.setTimeout(() => controller.abort(), getArticleAiTimeoutMs(mode));
      const response = await fetch("/api/social-ops/article-assist", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        signal: controller.signal,
        body: JSON.stringify({
          mode,
          prompt: buildArticlePrompt(question, mode, currentContent),
        }),
      });
      window.clearTimeout(timeoutId);

      const result = await response.json();
      if (!response.ok) {
        const errorMessage = result?.error === "GEMINI_API_KEY_MISSING"
          ? "尚未設定 GEMINI_API_KEY，先用手動提示詞模式。"
          : result?.error === "GEMINI_RATE_LIMITED"
            ? `Gemini Flash 目前達到額度上限${Number.isFinite(result?.retryAfterSeconds) ? `，約 ${result.retryAfterSeconds} 秒後再試。` : "，請稍後再試。"}`
            : "Gemini Flash 目前無法生成，請稍後再試。";
        setFeedback(errorMessage, "is-warning");
        setArticleAiFeedback(errorMessage, "is-warning");
        return null;
      }

      return typeof result?.content === "string" ? result.content : "";
    } catch (error) {
      if (error instanceof DOMException && error.name === "AbortError") {
