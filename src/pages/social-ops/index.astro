  function sortVendorNotes(notes = []) {
    const priceRank = {
      低: 1,
      中低: 2,
      中: 3,
      中高: 4,
      高: 5,
    };
    return [...notes].sort((left, right) => {
      const rightTime = new Date(right.updatedAt || right.createdAt || 0).getTime();
      const leftTime = new Date(left.updatedAt || left.createdAt || 0).getTime();
      const pinnedDelta = Number(Boolean(right.isPinned)) - Number(Boolean(left.isPinned));

      if (vendorNoteSort === "pinned") {
        if (pinnedDelta !== 0) return pinnedDelta;
        return rightTime - leftTime;
      }

      if (vendorNoteSort === "recent") {
        return rightTime - leftTime;
      }

      if (vendorNoteSort === "price-desc") {
        const priceDelta = (priceRank[right.priceLevel] || 0) - (priceRank[left.priceLevel] || 0);
        if (priceDelta !== 0) return priceDelta;
        if (pinnedDelta !== 0) return pinnedDelta;
        return rightTime - leftTime;
      }

      if (pinnedDelta !== 0) return pinnedDelta;
      return rightTime - leftTime;
    });
  }

  function getFilteredVendorNotes() {
    const query = vendorNoteSearch.trim().toLowerCase();
    const notes = sortVendorNotes(vendorNotesState.items || []).filter((note) =>
      !vendorNoteTradeFilter || (note.trade || "未分類") === vendorNoteTradeFilter,
    );
    if (!query) return notes;
    return notes.filter((note) =>
      [
        note.name,
        note.trade,
        note.priceLevel,
        note.craftLevel,
        note.location,
        note.impression,
        note.memo,
      ]
        .join("\n")
        .toLowerCase()
        .includes(query),
    );
  }

  function groupVendorNotesByTrade(notes = []) {
    const groups = new Map();
    notes.forEach((note) => {
      const trade = note.trade || "未分類";
      if (!groups.has(trade)) {
        groups.set(trade, []);
      }
      groups.get(trade).push(note);
    });

    const orderedTrades = [
      ...vendorTradeOptions.filter((trade) => groups.has(trade)),
      ...[...groups.keys()].filter((trade) => !vendorTradeOptions.includes(trade)),
    ];

    return orderedTrades.map((trade) => ({
      trade,
      items: groups.get(trade) || [],
    }));
  }

  function getVendorTradeFilterOptions() {
    const grouped = groupVendorNotesByTrade(sortVendorNotes(vendorNotesState.items || []));
    return [
      {
        value: "",
        label: "全部",
        count: vendorNotesState.items.length || 0,
      },
      ...grouped.map((group) => ({
        value: group.trade,
        label: group.trade,
        count: group.items.length,
      })),
    ];
  }

