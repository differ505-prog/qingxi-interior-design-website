    if (!(event.target instanceof HTMLSelectElement)) return;
    vendorNoteSort = event.target.value || "default";
    renderVendorNotes();
  });

  document.getElementById("vendor-trade-filter")?.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target.closest("[data-vendor-trade-filter]") : null;
    if (!(target instanceof HTMLElement)) return;
    vendorNoteTradeFilter = target.dataset.vendorTradeFilter || "";
    renderVendorNotes();
  });

  document.getElementById("clear-vendor-note-form")?.addEventListener("click", () => {
    resetVendorNoteForm();
    setVendorNoteFeedback("已清空廠商筆記表單。", "is-warning");
  });

  document.getElementById("save-vendor-note")?.addEventListener("click", async () => {
    const formNote = readVendorNoteForm();
    if (!formNote.name || !formNote.trade) {
      setVendorNoteFeedback("至少請填廠商名稱與工種。", "is-warning");
      return;
    }

    const existingNote = (vendorNotesState.items || []).find((entry) => entry.id === formNote.id);
    const now = new Date().toISOString();
    const payload = {
      ...createVendorNoteTemplate(),
      ...existingNote,
      ...formNote,
      id: formNote.id || createVendorNoteId(),
      createdAt: existingNote?.createdAt || now,
      updatedAt: now,
      isPinned: Boolean(existingNote?.isPinned),
    };

    try {
      await saveVendorNote(payload);
      resetVendorNoteForm();
      setVendorNoteFeedback(existingNote ? "已更新共享廠商筆記。" : "已新增共享廠商筆記。", "is-success");
    } catch (error) {
      console.error("儲存共享廠商筆記失敗：", error);
      setVendorNoteFeedback(error instanceof Error ? error.message : "共享廠商筆記儲存失敗，請稍後再試。", "is-warning");
    }
  });

  document.getElementById("vendor-note-list")?.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const actionButton = target.closest("[data-vendor-action]");
    if (!(actionButton instanceof HTMLButtonElement)) return;

    const noteId = actionButton.dataset.vendorId;
    const action = actionButton.dataset.vendorAction;
    const currentNote = (vendorNotesState.items || []).find((entry) => entry.id === noteId);
    if (!noteId || !action || !currentNote) return;

    if (action === "edit") {
      applyVendorNoteToForm(currentNote);
      setVendorNoteFeedback("已載入這筆廠商筆記，可直接修改。", "is-success");
      return;
    }

    if (action === "pin") {
      try {
        await saveVendorNote({
          ...currentNote,
          isPinned: !currentNote.isPinned,
          updatedAt: new Date().toISOString(),
        });
        setVendorNoteFeedback(currentNote.isPinned ? "已取消優先標記。" : "已標記為優先合作名單。", "is-success");
      } catch (error) {
        console.error("更新廠商優先標記失敗：", error);
        setVendorNoteFeedback(error instanceof Error ? error.message : "更新優先標記失敗，請稍後再試。", "is-warning");
      }
      return;
    }

    if (action === "delete") {
      if (!window.confirm(`確定要刪除「${currentNote.name}」嗎？`)) return;
      try {
        await removeVendorNote(noteId);
        if (vendorNoteEditingId === noteId) {
          resetVendorNoteForm();
        }
        setVendorNoteFeedback("已刪除這筆共享廠商筆記。", "is-success");
      } catch (error) {
        console.error("刪除共享廠商筆記失敗：", error);
        setVendorNoteFeedback(error instanceof Error ? error.message : "刪除失敗，請稍後再試。", "is-warning");
      }
    }
  });

  document.getElementById("article-source-question")?.addEventListener("input", () => {
    const previousQuestion = articleSourceQuestion;
    const nextQuestion = persistArticleSourceQuestion();
    if (nextQuestion !== previousQuestion) {
      clearArticleTopicDecision();
    }
  });

  document.getElementById("article-pro-prompt-content")?.addEventListener("focus", (event) => {
    if (event.target instanceof HTMLTextAreaElement) {
      event.target.select();
    }
  });

  loadArticleSourceQuestion();
  loadArticleTopicDecision();
  loadArticleAiResult();
  loadArticleProFinalizePrompt();
  loadGeminiBackupState();
  loadPublishingChecklist();
  loadTopicMode();
  loadState();
  normalizeWeeklyState();
  applyArticleSourceQuestionToField();
  renderArticleTopicDecision();
  renderArticleAiResult();
  renderArticleProPrompt();
  applyGeminiDraftToFields();
  renderTopicModePanels();
  renderPublishingChecklist();
  rerender();
  renderContentAnalytics();
  loadContentAnalytics();
  resetVendorNoteForm();
  loadVendorNotes();
</script>

