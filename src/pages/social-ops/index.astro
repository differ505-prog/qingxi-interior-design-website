      publishingChecklistOverrides[key] = target.checked;
      savePublishingChecklist();
      renderPublishingChecklist();
      return;
    }
    if (target.dataset.runLinkKey) {
      const index = Number(target.dataset.runIndex);
      const linkKey = target.dataset.runLinkKey;
      const run = state.weekly.runs[index];
      if (!run || !linkKey || !run.linkStash) return;
      run.linkStash[linkKey] = target.value.trim();
      rerender();
      return;
