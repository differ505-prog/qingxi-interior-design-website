---
import BaseLayout from "../../layouts/BaseLayout.astro";

const defaultGroups = [
  {
    id: "group-1654316948220005",
    alias: "主社團 01",
    groupId: "1654316948220005",
    url: "https://www.facebook.com/groups/1654316948220005/",
    note: "先掃在地修繕題。",
  },
  {
    id: "group-679286528824529",
    alias: "主社團 02",
    groupId: "679286528824529",
    url: "https://www.facebook.com/groups/679286528824529",
    note: "補第二輪搜尋。",
  },
  {
    id: "group-163175389244849",
    alias: "主社團 03",
    groupId: "163175389244849",
    url: "https://www.facebook.com/groups/163175389244849",
    note: "沒好題時補掃。",
  },
];

const defaultArticles = [
  {
    id: "soft-furnishing-sequence",
    title: "軟裝進場順序",
    status: "published",
    url: "",
    summary: "已可直接導流。",
  },
  {
    id: "next-pain-point",
    title: "下一篇痛點文",
    status: "draft",
    url: "",
    summary: "待補下一篇。",
  },
];

const defaultGroupsJson = JSON.stringify(defaultGroups);
const defaultArticlesJson = JSON.stringify(defaultArticles);
---

<BaseLayout
  title="社群作戰台 - 青曦空間設計"
  description="青曦內部使用的社群誘餌式回覆與知識導流作戰頁，採遊戲化任務面板設計。"
  noindex={true}
>
  <section class="social-ops-page">
    <div class="social-ops-shell">
      <header class="ops-hero">
        <div class="hero-copy">
          <p class="ops-eyebrow">SOCIAL OPS COMMAND</p>
          <h1>CEO 社群作戰台</h1>
          <p class="ops-description">
            每週開頁、選任務、做完劃掉。
          </p>
          <div class="hero-actions">
            <a href="#quest-board" class="btn btn-primary">開始本週任務</a>
            <a href="#portal-grid" class="btn btn-secondary">前往社團傳送門</a>
            <button type="button" id="reset-social-ops" class="btn btn-secondary btn-muted">重設本週任務</button>
          </div>
          <p id="ops-feedback" class="ops-feedback" aria-live="polite"></p>
        </div>

        <div class="hero-command-panel">
          <div class="command-badge">
            <span>當前職階</span>
            <strong id="rank-title">Apprentice Operator</strong>
            <small id="level-value">Lv.1</small>
          </div>
          <div class="command-metrics">
            <article class="metric-card metric-card-primary">
              <span>本週主線</span>
              <strong id="weekly-progress-count">0 / 3</strong>
              <small id="weekly-progress-note">還差 3 個任務</small>
              <div class="progress-track">
                <div id="weekly-progress-bar" class="progress-bar"></div>
              </div>
            </article>
            <article class="metric-card">
              <span>總 XP</span>
              <strong id="xp-value">0 XP</strong>
              <small>完成任務自動累積</small>
            </article>
            <article class="metric-card">
              <span>連勝週數</span>
              <strong id="streak-value">0</strong>
              <small>每週達標才延續</small>
            </article>
            <article class="metric-card">
              <span>累積通關</span>
              <strong id="lifetime-runs-value">0</strong>
              <small>已完成任務數</small>
            </article>
          </div>
        </div>
      </header>

      <div class="ops-grid">
        <div class="ops-main">
          <section id="quest-board" class="ops-panel quest-board">
            <div class="panel-heading">
              <div>
                <p class="panel-tag">WEEKLY QUESTS</p>
                <h2>本週主線任務</h2>
              </div>
              <p>找到題目、回覆、導流。</p>
            </div>
            <div id="quest-grid" class="quest-grid"></div>
          </section>

          <section id="portal-grid" class="ops-panel portal-board">
            <div class="panel-heading">
              <div>
                <p class="panel-tag">GROUP PORTALS</p>
                <h2>社團傳送門</h2>
              </div>
              <p>每個社團直接給你 3 個入口。</p>
            </div>
            <div id="portal-card-grid" class="portal-card-grid"></div>
          </section>
        </div>

        <aside class="ops-sidebar">
          <section class="ops-panel side-panel">
            <div class="panel-heading compact-heading">
              <div>
                <p class="panel-tag">PLAYBOOK</p>
                <h2>本局打法</h2>
              </div>
            </div>
            <ul class="command-list">
              <li>先找最好切入的一題。</li>
              <li>先解問題，再帶文章。</li>
              <li>做完直接打勾。</li>
            </ul>
          </section>

          <section class="ops-panel side-panel">
            <div class="panel-heading compact-heading">
              <div>
                <p class="panel-tag">ARSENAL</p>
                <h2>導流武器庫</h2>
              </div>
            </div>
            <div id="article-stack" class="article-stack"></div>
          </section>

          <section class="ops-panel side-panel">
            <div class="panel-heading compact-heading">
              <div>
                <p class="panel-tag">REWARDS</p>
                <h2>升級規則</h2>
              </div>
            </div>
            <ul class="command-list reward-list">
              <li>完成 1 個任務：+100 XP</li>
              <li>本週全清：+50 XP</li>
              <li>下週達標：連勝 +1</li>
            </ul>
          </section>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ defaultGroupsJson, defaultArticlesJson }}>
  const STORAGE_KEY = "qingxi-social-ops-v2";
  const WEEKLY_TARGET = 3;
  const RUN_XP = 100;
  const WEEKLY_BONUS_XP = 50;
  const groupTemplate = JSON.parse(defaultGroupsJson);
  const articleTemplate = JSON.parse(defaultArticlesJson);
  const rankTitles = [
    "Apprentice Operator",
    "Lead Hunter",
    "Signal Captain",
    "Market Commander",
    "Pipeline CEO",
    "Empire Architect",
  ];

  function getWeekKey(date = new Date()) {
    const target = new Date(date);
    const day = target.getDay() || 7;
    target.setHours(0, 0, 0, 0);
    target.setDate(target.getDate() + 4 - day);
    const yearStart = new Date(target.getFullYear(), 0, 1);
    const weekNo = Math.ceil((((target - yearStart) / 86400000) + 1) / 7);
    return `${target.getFullYear()}-W${String(weekNo).padStart(2, "0")}`;
  }

  function createRun(slot, keyword, title, guidance) {
    return {
      id: `run-${slot}`,
      slot,
      keyword,
      title,
      guidance,
      actionSearch: false,
      actionAdvice: false,
      actionArticle: false,
      rewardClaimed: false,
      completedAt: "",
    };
  }

  function createWeeklyRuns() {
    return [
      createRun(1, "南港", "Quest 01｜南港主線", "先解在地修繕問題，再附最貼近的痛點文。"),
      createRun(2, "汐止", "Quest 02｜汐止主線", "挑一題，快速完成。"),
      createRun(3, "自由掃場", "Quest 03｜自由補刀", "自由補一題。"),
    ];
  }

  function createInitialState() {
    return {
      weekly: {
        weekKey: getWeekKey(),
        bonusClaimed: false,
        runs: createWeeklyRuns(),
      },
      stats: {
        xp: 0,
        streak: 0,
        lifetimeRuns: 0,
      },
    };
  }

  let state = createInitialState();

  function saveState() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      state = {
        weekly: parsed.weekly || createInitialState().weekly,
        stats: {
          ...createInitialState().stats,
          ...(parsed.stats || {}),
        },
      };
    } catch (error) {
      console.error("讀取社群作戰台資料失敗：", error);
    }
  }

  function isRunComplete(run) {
    return run.actionSearch && run.actionAdvice && run.actionArticle;
  }

  function normalizeWeeklyState() {
    const currentWeekKey = getWeekKey();
    if (state.weekly.weekKey === currentWeekKey) return;

    const completedRuns = state.weekly.runs.filter(isRunComplete).length;
    state.stats.streak = completedRuns >= WEEKLY_TARGET ? state.stats.streak + 1 : 0;
    state.weekly = {
      weekKey: currentWeekKey,
      bonusClaimed: false,
      runs: createWeeklyRuns(),
    };
    saveState();
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function setFeedback(message, mode = "") {
    const shell = document.getElementById("ops-feedback");
    if (!shell) return;
    shell.className = `ops-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function buildSearchUrl(group, keyword) {
    return `https://www.facebook.com/groups/${encodeURIComponent(group.groupId)}/search/?q=${encodeURIComponent(keyword)}`;
  }

  function getRunPortals(run) {
    if (run.keyword === "南港" || run.keyword === "汐止") {
      return groupTemplate.map((group) => ({
        label: `${group.alias} ${run.keyword}`,
        url: buildSearchUrl(group, run.keyword),
      }));
    }

    return groupTemplate.map((group) => ({
      label: `${group.alias} 首頁`,
      url: group.url,
    }));
  }

  function getCompletedRunCount() {
    return state.weekly.runs.filter(isRunComplete).length;
  }

  function getLevel() {
    return Math.floor(state.stats.xp / 200) + 1;
  }

  function getRankTitle(level) {
    return rankTitles[Math.min(level - 1, rankTitles.length - 1)];
  }

  function maybeClaimRunReward(run) {
    if (!isRunComplete(run) || run.rewardClaimed) return;
    run.rewardClaimed = true;
    run.completedAt = new Date().toISOString();
    state.stats.xp += RUN_XP;
    state.stats.lifetimeRuns += 1;

    const completedRuns = getCompletedRunCount();
    if (completedRuns >= WEEKLY_TARGET && !state.weekly.bonusClaimed) {
      state.weekly.bonusClaimed = true;
      state.stats.xp += WEEKLY_BONUS_XP;
      setFeedback("本週三個任務已全清，已領取 +50 XP 額外獎勵。", "is-success");
    }
  }

  function renderHero() {
    const completedRuns = getCompletedRunCount();
    const remaining = Math.max(WEEKLY_TARGET - completedRuns, 0);
    const percent = Math.round((completedRuns / WEEKLY_TARGET) * 100);
    const level = getLevel();
    document.getElementById("weekly-progress-count").textContent = `${completedRuns} / ${WEEKLY_TARGET}`;
    document.getElementById("weekly-progress-note").textContent = remaining === 0
      ? "本週已清空。"
      : `還差 ${remaining} 個任務`;
    document.getElementById("weekly-progress-bar").style.width = `${percent}%`;
    document.getElementById("xp-value").textContent = `${state.stats.xp} XP`;
    document.getElementById("streak-value").textContent = String(state.stats.streak);
    document.getElementById("lifetime-runs-value").textContent = String(state.stats.lifetimeRuns);
    document.getElementById("level-value").textContent = `Lv.${level}`;
    document.getElementById("rank-title").textContent = getRankTitle(level);
  }

  function renderQuests() {
    const shell = document.getElementById("quest-grid");
    if (!shell) return;

    shell.innerHTML = state.weekly.runs
      .map((run, index) => {
        const complete = isRunComplete(run);
        const portals = getRunPortals(run)
          .map((portal) => `<a class="portal-chip" href="${escapeHtml(portal.url)}" target="_blank" rel="noreferrer">${escapeHtml(portal.label)}</a>`)
          .join("");

        return `
          <article class="quest-card ${complete ? "is-complete" : ""}">
            <div class="quest-topline">
              <span class="quest-slot">RUN ${run.slot}</span>
              <span class="quest-keyword">${escapeHtml(run.keyword)}</span>
            </div>
            <h3>${escapeHtml(run.title)}</h3>
            <p class="quest-guidance">${escapeHtml(run.guidance)}</p>
            <div class="quest-checklist">
              <label class="quest-check ${run.actionSearch ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionSearch" ${run.actionSearch ? "checked" : ""} />
                <span>已進場找題</span>
              </label>
              <label class="quest-check ${run.actionAdvice ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionAdvice" ${run.actionAdvice ? "checked" : ""} />
                <span>已給專業建議</span>
              </label>
              <label class="quest-check ${run.actionArticle ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionArticle" ${run.actionArticle ? "checked" : ""} />
                <span>已附痛點文導流</span>
              </label>
            </div>
            <div class="quest-portals">${portals}</div>
            <div class="quest-footer">
              <small>${complete ? `CLEAR：${new Date(run.completedAt).toLocaleString("zh-TW")}` : "清空三格 +100 XP"}</small>
              <strong>${complete ? "Quest Cleared" : "Quest Active"}</strong>
            </div>
          </article>
        `;
      })
      .join("");
  }

  function renderPortals() {
    const shell = document.getElementById("portal-card-grid");
    if (!shell) return;

    shell.innerHTML = groupTemplate
      .map((group) => `
        <article class="portal-card">
          <div class="portal-card-top">
            <span class="portal-card-label">${escapeHtml(group.alias)}</span>
            <h3>${escapeHtml(group.groupId)}</h3>
          </div>
          <p>${escapeHtml(group.note)}</p>
          <div class="portal-actions">
            <a class="portal-link primary-link" href="${escapeHtml(group.url)}" target="_blank" rel="noreferrer">社團首頁</a>
            <a class="portal-link" href="${escapeHtml(buildSearchUrl(group, "南港"))}" target="_blank" rel="noreferrer">搜南港</a>
            <a class="portal-link" href="${escapeHtml(buildSearchUrl(group, "汐止"))}" target="_blank" rel="noreferrer">搜汐止</a>
          </div>
        </article>
      `)
      .join("");
  }

  function renderArticles() {
    const shell = document.getElementById("article-stack");
    if (!shell) return;

    shell.innerHTML = articleTemplate
      .map((article) => `
        <article class="article-card ${article.status === "published" ? "is-published" : ""}">
          <div class="article-head">
            <span class="article-state">${article.status === "published" ? "READY" : "DRAFT"}</span>
            <h3>${escapeHtml(article.title)}</h3>
          </div>
          <p>${escapeHtml(article.summary)}</p>
          ${article.url ? `<a class="article-link" href="${escapeHtml(article.url)}" target="_blank" rel="noreferrer">開啟素材</a>` : `<span class="article-link is-muted">連結待補</span>`}
        </article>
      `)
      .join("");
  }

  function rerender() {
    renderHero();
    renderQuests();
    renderPortals();
    renderArticles();
    saveState();
  }

  document.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    if (!target.dataset.runCheck) return;

    const index = Number(target.dataset.runIndex);
    const key = target.dataset.runCheck;
    const run = state.weekly.runs[index];
    if (!run || !key) return;

    run[key] = target.checked;
    maybeClaimRunReward(run);
    rerender();
  });

  document.getElementById("reset-social-ops")?.addEventListener("click", () => {
    state.weekly = {
      weekKey: getWeekKey(),
      bonusClaimed: false,
      runs: createWeeklyRuns(),
    };
    rerender();
    setFeedback("本週任務已重設，XP 與連勝保留。", "is-warning");
  });

  loadState();
  normalizeWeeklyState();
  rerender();
</script>

<style>
  .social-ops-page {
    padding: 5rem 1.25rem 6rem;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.12), transparent 22%),
      radial-gradient(circle at right top, rgba(255, 255, 255, 0.08), transparent 26%),
      linear-gradient(180deg, #161616 0%, #1d1d1f 44%, #242426 100%);
    color: #f3f3f1;
  }

  .social-ops-shell {
    max-width: 1320px;
    margin: 0 auto;
    display: grid;
    gap: 1.5rem;
  }

  .ops-hero,
  .ops-panel {
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(180deg, rgba(41, 41, 43, 0.94), rgba(28, 28, 30, 0.94));
    box-shadow:
      0 26px 60px rgba(0, 0, 0, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(18px);
  }

  .ops-hero {
    padding: clamp(1.5rem, 3vw, 2.4rem);
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.9fr);
  }

  .ops-eyebrow,
  .panel-tag,
  .quest-slot,
  .portal-card-label,
  .article-state {
    margin: 0;
    letter-spacing: 0.18em;
    font-size: 0.74rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .hero-copy h1 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(2.3rem, 4vw, 3.8rem);
    line-height: 1.08;
    color: #fbfbfa;
  }

  .ops-description {
    margin: 1rem 0 0;
    max-width: 720px;
    color: rgba(244, 244, 242, 0.74);
    font-size: 1.02rem;
    line-height: 1.9;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.4rem;
  }

  .ops-feedback {
    min-height: 1.5rem;
    margin: 0.95rem 0 0;
    color: rgba(244, 244, 242, 0.72);
  }

  .ops-feedback.is-success {
    color: #e8e8e3;
  }

  .ops-feedback.is-warning {
    color: #d9d2c6;
  }

  .hero-command-panel,
  .command-metrics,
  .ops-grid,
  .ops-main,
  .ops-sidebar,
  .quest-grid,
  .portal-card-grid,
  .article-stack {
    display: grid;
    gap: 1rem;
  }

  .command-badge,
  .metric-card,
  .quest-card,
  .portal-card,
  .article-card {
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(58, 58, 61, 0.72), rgba(38, 38, 40, 0.76));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 10px 30px rgba(0, 0, 0, 0.12);
  }

  .command-badge {
    padding: 1.2rem 1.2rem 1rem;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.12), transparent 42%),
      linear-gradient(180deg, rgba(70, 70, 73, 0.96), rgba(40, 40, 42, 0.96));
  }

  .command-badge span,
  .metric-card span,
  .metric-card small,
  .quest-guidance,
  .quest-footer small,
  .portal-card p,
  .article-card p,
  .panel-heading p,
  .command-list li {
    color: rgba(243, 243, 241, 0.68);
  }

  .command-badge strong {
    display: block;
    margin-top: 0.45rem;
    font-size: 1.52rem;
    color: #fbfbfa;
  }

  .command-badge small {
    display: inline-flex;
    margin-top: 0.45rem;
    color: rgba(255, 255, 255, 0.72);
  }

  .command-metrics {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .metric-card {
    padding: 1rem 1.05rem;
  }

  .metric-card strong {
    display: block;
    margin-top: 0.32rem;
    font-size: 1.55rem;
    color: #fbfbfa;
  }

  .metric-card-primary {
    grid-column: 1 / -1;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.14), transparent 40%),
      linear-gradient(180deg, rgba(78, 78, 81, 0.98), rgba(42, 42, 44, 0.96));
  }

  .progress-track {
    margin-top: 0.85rem;
    height: 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.09);
    overflow: hidden;
  }

  .progress-bar {
    width: 0;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #f2f2ef, #b9b9b2);
    transition: width 0.35s ease;
  }

  .ops-grid {
    grid-template-columns: minmax(0, 1.56fr) minmax(320px, 0.74fr);
    align-items: start;
  }

  .ops-panel {
    padding: 1.35rem;
  }

  .panel-heading {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1.15rem;
  }

  .compact-heading {
    margin-bottom: 0.95rem;
  }

  .panel-heading h2 {
    margin: 0.2rem 0 0;
    font-family: "Noto Serif TC", serif;
    font-size: 1.55rem;
    color: #fbfbfa;
  }

  .panel-heading p {
    margin: 0;
    max-width: 360px;
    line-height: 1.8;
  }

  .quest-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .portal-card-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .quest-card,
  .portal-card,
  .article-card {
    padding: 1.15rem;
  }

  .quest-card {
    position: relative;
    overflow: hidden;
  }

  .quest-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.08), transparent 30%);
    pointer-events: none;
  }

  .quest-card.is-complete {
    border-color: rgba(255, 255, 255, 0.18);
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.08), transparent 34%),
      linear-gradient(180deg, rgba(74, 74, 76, 0.84), rgba(49, 49, 51, 0.92));
  }

  .quest-topline,
  .quest-portals,
  .portal-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .quest-topline {
    justify-content: space-between;
    align-items: center;
