    const text = `${titleText}\n${content}`.replace(/\s+/g, "");

    const categoryKeywordsMap = {
      "裝修預算": ["預算", "費用", "報價", "多少錢", "怎麼抓", "單價", "省錢"],
      "收納機能": ["收納", "櫃體", "儲物", "機能", "櫥櫃"],
