    gap: 1rem;
    align-items: start;
    margin-bottom: 0.95rem;
  }

  .panel-heading h2 {
    margin: 0.2rem 0 0;
    font-family: "Noto Sans TC", "PingFang TC", sans-serif;
    font-size: 1.28rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: #f5f3ef;
