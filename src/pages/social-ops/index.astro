            </div>
            <div class="gemini-history-actions">
              <button type="button" class="history-action-btn" data-backup-action="restore" data-backup-id="${escapeHtml(backup.id)}">${backup.isMaster ? "載入主檔" : "載入這版"}</button>
              <button type="button" class="history-action-btn" data-backup-action="copy" data-backup-id="${escapeHtml(backup.id)}">複製 Markdown</button>
            </div>
