<BaseLayout
  title="設計師工作面板 - 青曦空間設計"
  description="青曦內部使用的設計師工作面板，只留必要任務、進度與來源入口。"
  noindex={true}
>
  <link rel="stylesheet" href={socialOpsStylesheetHref} slot="head" />
  <section class="social-ops-page">
    <div class="social-ops-shell">
      <header class="ops-hero">
        <div class="hero-copy">
          <p class="ops-eyebrow">青曦內部面板</p>
          <h1>設計師工作面板</h1>
          <p class="ops-description">
            只留本週任務、生文主線與工種名錄。
          </p>
          <div class="hero-actions">
            <button type="button" class="btn btn-primary" data-open-workspace-pane="operations" data-workspace-scroll-target="quest-board">開始本週任務</button>
          </div>
          <p id="ops-feedback" class="ops-feedback" aria-live="polite"></p>
        </div>

        <div class="hero-command-panel">
          <div class="command-badge">
            <span>本週狀態</span>
            <strong id="rank-title">起稿中</strong>
            <small id="level-value">第 1 級</small>
          </div>
          <div class="command-metrics">
            <div class="command-metrics-main">
              <article class="metric-card metric-card-primary">
                <span>本週主線</span>
                <strong id="weekly-progress-count">0 / 3</strong>
                <small id="weekly-progress-note">還差 3 個任務</small>
                <div class="progress-track">
                  <div id="weekly-progress-bar" class="progress-bar"></div>
                </div>
              </article>
              <article class="metric-card metric-card-xp">
                <span>總進度</span>
                <strong id="xp-value">0 XP</strong>
                <small id="xp-progress-note">本級 0 / 200 XP</small>
                <div class="progress-track progress-track-xp">
                  <div id="xp-progress-bar" class="progress-bar progress-bar-xp"></div>
                </div>
              </article>
            </div>
            <details class="metric-fold metric-fold-secondary">
              <summary>
                <span>累積節奏</span>
                <small>看連勝與累積完成數</small>
              </summary>
              <div class="metric-fold-grid">
                <article class="metric-card">
                  <span>連續達標</span>
                  <strong id="streak-value">0</strong>
                </article>
                <article class="metric-card">
                  <span>完成累積</span>
                  <strong id="lifetime-runs-value">0</strong>
                </article>
              </div>
            </details>
          </div>
        </div>
      </header>

      <section class="ops-panel workspace-nav" id="workspace-tabs">
        <div class="workspace-nav-head">
          <div>
            <p class="panel-tag">工作台分區</p>
            <h2>按場景切換，不再全部堆在同一頁</h2>
          </div>
          <p>先用頁內分區整理動線，保留同一個工作台但降低視覺負擔。</p>
        </div>
        <div class="workspace-tab-list" role="tablist" aria-label="設計師工作台分區">
          <button type="button" class="workspace-tab is-active" data-workspace-tab="operations" aria-pressed="true">
            <strong>作戰台</strong>
            <small>每日任務、週任務、來源入口</small>
          </button>
          <button type="button" class="workspace-tab" data-workspace-tab="content" aria-pressed="false">
            <strong>內容台</strong>
            <small>判題、生文、書架、Gemini 備份</small>
          </button>
          <button type="button" class="workspace-tab" data-workspace-tab="knowledge" aria-pressed="false">
            <strong>知識庫</strong>
            <small>內部裝修知識、尺寸表、工班權責</small>
          </button>
          <button type="button" class="workspace-tab" data-workspace-tab="vendors" aria-pressed="false">
            <strong>工班台</strong>
            <small>工班登錄池與優質廠商筆記</small>
          </button>
          <button type="button" class="workspace-tab" data-workspace-tab="review" aria-pressed="false">
            <strong>回看</strong>
            <small>內容成效與低頻檢視資料</small>
          </button>
        </div>
      </section>

      <div class="ops-grid">
        <div class="ops-main">
          <div class="workspace-pane is-active" data-workspace-pane="operations">
            <div class="ops-task-layout">
              <div class="ops-task-main">
                <section id="daily-ops-board" class="ops-panel quest-board">
                  <div class="panel-heading">
                    <div>
                      <p class="panel-tag">日常任務</p>
                      <h2>主動獵殺</h2>
                      <p id="daily-panel-note" class="panel-inline-note">今日還差 3 個完成條件</p>
                    </div>
                  </div>
                  <div id="daily-quest-grid" class="quest-grid"></div>
                </section>

                <section id="quest-board" class="ops-panel quest-board">
                  <div class="panel-heading">
                    <div>
                      <p class="panel-tag">任務 6</p>
                      <h2>高意圖社群回覆與低成本分發</h2>
                      <p id="weekly-panel-note" class="panel-inline-note">本週還差 3 輪主任務</p>
                    </div>
                  </div>
                  <div id="quest-grid" class="quest-grid"></div>
                </section>
              </div>

              <aside class="ops-side ops-task-side">
                <section class="ops-panel bookshelf-canned-replies bookshelf-canned-replies-priority ops-canned-sidebar">
                  <div class="panel-heading panel-heading-compact">
                    <div>
                      <p class="panel-tag">快速工具</p>
                      <h2>常見罐頭回覆</h2>
                    </div>
                    <p>方便直接複製貼上回覆貼文</p>
                  </div>
                  <div class="bookshelf-reply-grid bookshelf-canned-grid">
                    {cannedReplies.map((reply) => (
                      <article class="bookshelf-reply-card bookshelf-canned-card bookshelf-canned-card-priority">
                        <span>{reply.category}</span>
                        <strong>{reply.promptTitle}</strong>
                        <em>{reply.promptHint}</em>
                        <p>{reply.message}</p>
                        <div class="bookshelf-actions bookshelf-canned-actions">
                          <button
                            type="button"
                            class="bookshelf-action bookshelp-action-primary"
                            data-canned-reply-copy-button
                            data-canned-reply-copy={reply.message}
                            data-canned-reply-label={reply.promptTitle}
                          >
                            複製這則
                          </button>
                        </div>
                      </article>
                    ))}
                  </div>
                </section>
              </aside>
            </div>

            <details id="portal-grid" class="ops-panel ops-fold portal-board">
              <summary class="ops-fold-summary">
                <div>
                  <p class="panel-tag">來源入口</p>
                  <h2>來源入口</h2>
                </div>
                <small>低頻時再展開</small>
              </summary>
              <div class="ops-fold-body">
                <div class="portal-section">
                  <div class="portal-section-heading">
                    <p>Facebook 社團</p>
                  </div>
                  <div id="facebook-card-grid" class="portal-card-grid"></div>
                </div>
