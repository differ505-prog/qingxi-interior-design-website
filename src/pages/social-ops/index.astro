  function renderArticleTopicDecision() {
    const shell = document.getElementById("article-topic-shell");
    const label = document.getElementById("article-topic-label");
    const mode = document.getElementById("article-topic-mode");
    const track = document.getElementById("article-topic-track");
    const chapter = document.getElementById("article-topic-chapter");
    const subchapter = document.getElementById("article-topic-subchapter");
    const title = document.getElementById("article-topic-title");
    const reason = document.getElementById("article-topic-reason");
    const note = document.getElementById("article-topic-note");
    if (
      !(shell instanceof HTMLElement) ||
      !(label instanceof HTMLElement) ||
      !(mode instanceof HTMLElement) ||
      !(track instanceof HTMLElement) ||
      !(chapter instanceof HTMLElement) ||
      !(subchapter instanceof HTMLElement) ||
      !(title instanceof HTMLElement) ||
      !(reason instanceof HTMLElement) ||
      !(note instanceof HTMLElement)
    ) {
      return;
    }

    if (!articleTopicDecision) {
      shell.hidden = true;
      return;
    }

    const modeState = getCurrentTopicModeState(articleTopicDecision.mode);
    const candidateCount = getCurrentTopicCandidates(articleTopicDecision.mode).length;
    shell.hidden = false;
    label.textContent = articleTopicDecision.summary || "已完成本題動態決題";
    mode.textContent = articleTopicDecision.modeLabel || modeState?.label || articleTopicDecision.mode || "尚未決題";
    track.textContent = articleTopicDecision.track || "尚未決題";
    chapter.textContent = articleTopicDecision.chapter || "尚未決題";
    subchapter.textContent = articleTopicDecision.subchapter || "尚未決題";
    title.textContent = articleTopicDecision.title || "尚未決題";
    reason.textContent = articleTopicDecision.reason || articleTopicDecision.questionLink || "已完成動態決題。";
    note.textContent =
      articleTopicDecision.bookLink ||
      `這一步會先依真實社團問題理解痛點，再從 ${candidateCount || "目前"} 個出版候選裡挑最適合落進書稿的題目。`;
  }

