    await copyText(buildArticleTitlesText(), "已複製文章標題清單。");
  });

  document.getElementById("copy-article-intake")?.addEventListener("click", async () => {
    await copyText(
      articleIntakeFields.map((field) => `${field}：`).join("\n"),
      "已複製文章入庫欄位。",
    );
  });

  document.getElementById("copy-article-prompt")?.addEventListener("click", async () => {
    const question = persistArticleSourceQuestion();
    const successMessage = question
      ? "已複製 Flash 長稿備援提示詞。"
      : "已複製 Flash 長稿備援提示詞模板。";
    await copyText(buildArticlePrompt(question, "full"), successMessage);
  });

  document.getElementById("run-article-ai-flow")?.addEventListener("click", async () => {
    await runArticleAiFlow();
  });

  document.getElementById("copy-pro-finalize-prompt")?.addEventListener("click", async () => {
    const question = persistArticleSourceQuestion();
    const successMessage = articleAiResult.trim()
      ? "已複製 Pro 生文提示詞。"
      : "已複製 Pro 生文提示詞模板，建議先生成 Flash 判題結果再使用。";
    await copyProArticlePrompt(question, successMessage);
  });

  document.getElementById("run-article-ai-quick")?.addEventListener("click", async () => {
    await runArticleAi("quick");
  });

  document.getElementById("run-article-ai-draft")?.addEventListener("click", async () => {
    await runArticleAi("full");
  });

  document.getElementById("copy-article-ai-result")?.addEventListener("click", async () => {
    if (!articleAiResult.trim()) {
      setArticleAiFeedback("目前沒有 AI 結果可複製。", "is-warning");
      return;
    }
    await copyText(articleAiResult, "已複製 AI 結果。");
    setArticleAiFeedback("已複製 AI 結果。", "is-success");
  });

  document.getElementById("copy-article-category")?.addEventListener("click", async () => {
    const data = getArticleConfirmData(articleAiResult);
    if (data.category === "尚未判定") {
      setArticleAiFeedback("請先生成 AI 結果。", "is-warning");
      return;
    }
    await copyText(data.category, "已複製正式分類。");
    setArticleAiFeedback("已複製正式分類。", "is-success");
  });

  document.getElementById("copy-article-confirm-payload")?.addEventListener("click", async () => {
    const data = getArticleConfirmData(articleAiResult);
    if (data.category === "尚未判定") {
      setArticleAiFeedback("請先生成 AI 結果。", "is-warning");
      return;
    }
    await copyText(buildArticleConfirmPayload(data), "已複製分類落地資訊。");
    setArticleAiFeedback("已複製分類落地資訊。", "is-success");
  });

  document.getElementById("copy-social-reply-short")?.addEventListener("click", async () => {
    await copyArticleSocialReply("short", "已複製簡短版社團回覆。");
  });

  document.getElementById("copy-social-reply-pro")?.addEventListener("click", async () => {
    await copyArticleSocialReply("pro", "已複製專業版社團回覆。");
  });

  document.getElementById("copy-social-reply-lead")?.addEventListener("click", async () => {
    await copyArticleSocialReply("lead", "已複製導流版社團回覆。");
  });

  document.getElementById("clear-article-question")?.addEventListener("click", () => {
    articleSourceQuestion = "";
    localStorage.setItem(ARTICLE_SOURCE_QUESTION_KEY, "");
    applyArticleSourceQuestionToField();
    setFeedback("已清空真實社團問題。", "is-warning");
  });

  document.getElementById("load-gemini-master")?.addEventListener("click", () => {
    loadGeminiMasterIntoEditor();
  });

  document.getElementById("run-gemini-backup")?.addEventListener("click", () => {
    const payload = buildGeminiBackupPayload();
    if (!payload) return;

    const result = upsertGeminiBackup(payload);
    const feedback = result.updated ? "已更新 Gemini 最新備份。" : "已建立 Gemini 備份版本。";
    setFeedback(feedback, "is-success");
    setGeminiFeedback(feedback, "is-success");
  });

  document.getElementById("copy-gemini-markdown")?.addEventListener("click", async () => {
    const payload = buildGeminiBackupPayload();
    if (!payload) return;
    await copyText(buildGeminiBackupMarkdown(payload), "已複製 Gemini Markdown 備份。");
    setGeminiFeedback("已複製 Gemini Markdown 備份。", "is-success");
  });

  document.getElementById("download-gemini-json")?.addEventListener("click", () => {
    const payload = buildGeminiBackupPayload();
    if (!payload) return;

    downloadTextFile(
      `qingxi-gemini-backup-${payload.savedAt.slice(0, 10)}.json`,
      JSON.stringify(
        {
          master: geminiCanvasMasterData,
          current: payload,
          history: geminiBackups,
        },
        null,
        2,
      ),
      "application/json;charset=utf-8",
    );
    setFeedback("已下載 Gemini JSON 備份。", "is-success");
    setGeminiFeedback("已下載 Gemini JSON 備份。", "is-success");
  });

  document.getElementById("gemini-backup-board")?.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const action = target.dataset.backupAction;
    const backupId = target.dataset.backupId;
    if (!action || !backupId) return;

    const backup = findGeminiBackupById(backupId);
    if (!backup) return;

    if (action === "restore") {
      geminiDraft = {
        title: backup.title,
        sourceUrl: backup.sourceUrl,
        content: backup.content,
      };
      localStorage.setItem(GEMINI_DRAFT_KEY, JSON.stringify(geminiDraft));
      applyGeminiDraftToFields();
      setFeedback("已載入指定備份版本。", "is-success");
      setGeminiFeedback("已載入指定備份版本。", "is-success");
      return;
    }

    if (action === "copy") {
      await copyText(buildGeminiBackupMarkdown(backup), "已複製該版本 Markdown。");
      setGeminiFeedback("已複製該版本 Markdown。", "is-success");
      return;
    }
  });

  document.getElementById("gemini-backup-board")?.addEventListener("input", (event) => {
    const target = event.target;
    if (
      target instanceof HTMLInputElement ||
      target instanceof HTMLTextAreaElement
    ) {
      persistGeminiDraftFromFields();
    }
  });

  document.getElementById("article-source-question")?.addEventListener("input", () => {
    persistArticleSourceQuestion();
  });

  loadArticleSourceQuestion();
  loadArticleAiResult();
  loadGeminiBackupState();
  loadState();
  normalizeWeeklyState();
  applyArticleSourceQuestionToField();
  renderArticleAiResult();
  applyGeminiDraftToFields();
  rerender();
</script>

