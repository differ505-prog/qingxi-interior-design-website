  function extractSectionText(content, sectionTitle) {
    const escapedTitle = sectionTitle.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    const pattern = new RegExp(`【${escapedTitle}】([\\s\\S]*?)(?=\\n\\s*\\d+\\.\\s*【|\\n\\s*【|$)`, "i");
    const match = content.match(pattern);
    return match?.[1]?.trim() || "";
  }

  function normalizeSectionLines(text) {
    return text
      .split("\n")
      .map((line) => line.replace(/^[-*\d.\s]+/, "").trim())
      .filter(Boolean);
  }

  function extractFieldValue(lines, keys) {
    const line = lines.find((entry) => keys.some((key) => entry.startsWith(`${key}：`) || entry.startsWith(`${key}:`)));
    if (!line) return "";
    return line.replace(/^[^：:]+[:：]\s*/, "").trim();
  }

  function escapeRegExp(text) {
    return text.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  }

  function extractFieldValueFromText(text, keys) {
    if (!text.trim()) return "";
    const keyPattern = keys.map((key) => escapeRegExp(key)).join("|");
    const match = text.match(new RegExp(`(?:^|\\n)\\s*(?:[-*]\\s*)?(?:${keyPattern})\\s*[:：]\\s*(.+)`, "i"));
    return match?.[1]?.trim() || "";
  }

  function findTrackFromText(text) {
    return bookshelfTracks.find((track) => text.includes(track.title))?.title || "";
  }

  function getTrackConfig(trackTitle) {
    return bookshelfTracks.find((track) => track.title === trackTitle) || null;
  }

  function getTrackChapters(trackTitle) {
    const track = getTrackConfig(trackTitle);
    if (!track?.chapters) return [];
    return track.chapters.split("/").map((chapter) => chapter.trim()).filter(Boolean);
  }

  function getTrackSubchapterMap(trackTitle, chapterTitle) {
    return bookshelfSubchapterPools?.[trackTitle]?.[chapterTitle] || {};
  }

  function getTrackSubchapters(trackTitle, chapterTitle) {
    return Object.keys(getTrackSubchapterMap(trackTitle, chapterTitle));
  }

