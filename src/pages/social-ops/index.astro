  function renderVendorNotes() {
    const countNode = document.getElementById("vendor-note-count");
    const summaryNode = document.getElementById("vendor-note-summary");
    const searchNode = document.getElementById("vendor-note-search");
    const sortNode = document.getElementById("vendor-note-sort");
    const filterNode = document.getElementById("vendor-trade-filter");
    const listNode = document.getElementById("vendor-note-list");
    if (
      !(countNode instanceof HTMLElement) ||
      !(summaryNode instanceof HTMLElement) ||
      !(searchNode instanceof HTMLInputElement) ||
      !(sortNode instanceof HTMLSelectElement) ||
      !(filterNode instanceof HTMLElement) ||
      !(listNode instanceof HTMLElement)
    ) {
      return;
    }

    if (searchNode.value !== vendorNoteSearch) {
      searchNode.value = vendorNoteSearch;
    }

    if (sortNode.value !== vendorNoteSort) {
      sortNode.value = vendorNoteSort;
    }

    const items = getFilteredVendorNotes();
    const filterOptions = getVendorTradeFilterOptions();
    countNode.textContent = String(vendorNotesState.items.length || 0);

