  function renderVendorIntakes() {
    const countNode = document.getElementById("vendor-intake-count");
    const statusNode = document.getElementById("vendor-intake-status");
    const summaryNode = document.getElementById("vendor-intake-summary");
    const metricsNode = document.getElementById("vendor-intake-metrics");
    const listNode = document.getElementById("vendor-intake-list");
    const tradeFilterNode = document.getElementById("vendor-intake-trade-filter");
    const statusFilterNode = document.getElementById("vendor-intake-status-filter");
    const searchNode = document.getElementById("vendor-intake-search");

    if (
      !(countNode instanceof HTMLElement) ||
      !(statusNode instanceof HTMLElement) ||
      !(summaryNode instanceof HTMLElement) ||
      !(metricsNode instanceof HTMLElement) ||
      !(listNode instanceof HTMLElement) ||
      !(tradeFilterNode instanceof HTMLSelectElement) ||
      !(statusFilterNode instanceof HTMLSelectElement) ||
      !(searchNode instanceof HTMLInputElement)
    ) {
      return;
    }

    const totalCount = vendorIntakeState.items.length || 0;
    countNode.textContent = String(totalCount);
    if (searchNode.value !== vendorIntakeSearch) {
      searchNode.value = vendorIntakeSearch;
    }

    const tradeOptions = getVendorIntakeTradeOptions();
    tradeFilterNode.innerHTML = tradeOptions
      .map((option) => `<option value="${escapeHtml(option.value)}">${escapeHtml(option.label)}</option>`)
      .join("");
    tradeFilterNode.value = vendorIntakeTradeFilter;

    statusFilterNode.innerHTML = [
      '<option value="">全部狀態</option>',
      ...vendorIntakeStatusOptions.map((option) => `<option value="${escapeHtml(option.value)}">${escapeHtml(option.label)}</option>`),
    ].join("");
    statusFilterNode.value = vendorIntakeStatusFilter;

    if (vendorIntakeState.status === "loading") {
      statusNode.textContent = "讀取中";
      summaryNode.textContent = "正在同步工班登錄資料";
      metricsNode.innerHTML = "";
      listNode.innerHTML = '<div class="vendor-note-empty">正在讀取工班登錄池...</div>';
      return;
    }

    if (vendorIntakeState.status === "setup_required") {
      statusNode.textContent = "待接共享儲存";
      summaryNode.textContent = "先接 Blob 才能跨裝置同步";
      metricsNode.innerHTML = "";
      listNode.innerHTML = `<div class="vendor-note-empty">${escapeHtml(vendorIntakeState.note || "尚未接通共享儲存。")}</div>`;
      return;
    }

    if (vendorIntakeState.status === "error") {
      statusNode.textContent = "讀取失敗";
      summaryNode.textContent = "稍後再重整一次";
      metricsNode.innerHTML = "";
      listNode.innerHTML = `<div class="vendor-note-empty">${escapeHtml(vendorIntakeState.note || "工班登錄池暫時讀取失敗。")}</div>`;
      return;
    }

    const filteredItems = getFilteredVendorIntakes();
    const metrics = vendorIntakeStatusOptions.map((option) => ({
      ...option,
      count: (vendorIntakeState.items || []).filter((item) => item.status === option.value).length,
    }));
    metricsNode.innerHTML = metrics
      .map((metric) => `
        <article class="bookshelf-track-card vendor-intake-metric-card">
          <div class="bookshelf-track-top"><p>${escapeHtml(metric.label)}</p></div>
          <strong>${escapeHtml(String(metric.count))}</strong>
          <small>${metric.value === "new" ? "最新待看名單" : "目前此狀態筆數"}</small>
        </article>
      `)
      .join("");

    statusNode.textContent = totalCount ? "已同步" : "尚無資料";
    summaryNode.textContent = vendorIntakeSearch
      ? `顯示 ${filteredItems.length} 筆符合搜尋的工班資料`
      : vendorIntakeTradeFilter || vendorIntakeStatusFilter
        ? `篩選後 ${filteredItems.length} 筆`
        : totalCount
          ? `最新 ${Math.min(filteredItems.length, 5)} 筆可直接優先看`
          : "尚未收到工班登錄資料";

    if (!filteredItems.length) {
      listNode.innerHTML = vendorIntakeSearch || vendorIntakeTradeFilter || vendorIntakeStatusFilter
        ? '<div class="vendor-note-empty">目前沒有符合條件的工班資料。</div>'
        : '<div class="vendor-note-empty">尚未收到工班登錄資料。</div>';
      return;
    }

    listNode.innerHTML = filteredItems
      .map((item) => {
        const attachmentHref = item.id ? `${VENDOR_INTAKE_FILE_URL}?id=${encodeURIComponent(item.id)}` : "";
        const promotedNoteId = getVendorIntakeNoteId(item.id);
        const hasPromotedNote = (vendorNotesState.items || []).some((entry) => entry.id === promotedNoteId);
        const sourceParts = [item.sourceLabel, item.utmSource, item.utmMedium].filter(Boolean);
        const metaItems = [
          item.serviceArea ? `<span>${escapeHtml(item.serviceArea)}</span>` : "",
          item.contactMethod && item.contactValue ? `<span>${escapeHtml(item.contactMethod)}：${escapeHtml(item.contactValue)}</span>` : "",
          item.invoiceStatus ? `<span>${escapeHtml(getVendorInvoiceLabel(item.invoiceStatus))}</span>` : "",
          item.acceptsContract ? `<span>${escapeHtml(getVendorContractLabel(item.acceptsContract))}</span>` : "",
          item.pricingMode ? `<span>${escapeHtml(getVendorPricingModeLabel(item.pricingMode))}</span>` : "",
          item.pricingDisclosure ? `<span>${escapeHtml(getVendorPricingDisclosureLabel(item.pricingDisclosure))}</span>` : "",
          item.createdAt ? `<span>提交 ${escapeHtml(formatVendorNoteTimestamp(item.createdAt))}</span>` : "",
        ].filter(Boolean).join("");

        return `
          <article class="vendor-note-card vendor-intake-card">
            <div class="vendor-note-card-head">
              <div class="vendor-note-card-main">
                <div class="vendor-note-badges">
                  <span class="vendor-note-badge">${escapeHtml(getVendorSourceTypeLabel(item.sourceType))}</span>
                  <span class="vendor-note-badge">${escapeHtml(item.trade || "未分類")}</span>
                  ${item.projectFocus ? `<span class="vendor-note-badge">${escapeHtml(item.projectFocus)}</span>` : ""}
                  ${item.craftApproach ? `<span class="vendor-note-badge">${escapeHtml(item.craftApproach)}</span>` : ""}
                  <span class="vendor-note-badge">${escapeHtml(getVendorIntakeStatusLabel(item.status))}</span>
                  ${hasPromotedNote ? '<span class="vendor-note-badge vendor-note-badge-star">已建優質筆記</span>' : ""}
                  ${item.attachmentKind ? `<span class="vendor-note-badge">${escapeHtml(item.attachmentKind)}</span>` : ""}
                </div>
                <strong>${escapeHtml(item.name || "未命名工班")}${item.teamName ? ` / ${escapeHtml(item.teamName)}` : ""}</strong>
                <p>${escapeHtml(item.note || "尚未補充說明，先看附件與聯絡方式。")}</p>
                <div class="vendor-note-meta">${metaItems || "<span>尚未補齊聯絡資訊</span>"}</div>
                ${sourceParts.length ? `<p class="vendor-intake-source">來源：${escapeHtml(sourceParts.join(" / "))}</p>` : ""}
              </div>
              <div class="vendor-note-card-actions">
                ${attachmentHref
                  ? `<a class="vendor-note-action-link" href="${escapeHtml(attachmentHref)}" target="_blank" rel="noreferrer">看附件${item.attachmentName ? ` (${escapeHtml(formatFileSize(item.attachmentSize)) || escapeHtml(item.attachmentName)})` : ""}</a>`
                  : '<span class="vendor-note-action-link is-disabled">無附件</span>'}
              </div>
            </div>
            <div class="vendor-intake-admin-grid">
              <label class="gemini-field">
                <span>合作狀態</span>
                <select data-vendor-intake-status="${escapeHtml(item.id)}">
                  ${vendorIntakeStatusOptions
                    .map((option) => `<option value="${escapeHtml(option.value)}" ${option.value === item.status ? "selected" : ""}>${escapeHtml(option.label)}</option>`)
                    .join("")}
                </select>
              </label>
              <label class="gemini-field gemini-field-full">
                <span>內部備註</span>
                <textarea data-vendor-intake-note="${escapeHtml(item.id)}" rows="3" placeholder="例如：報價帶合理、可先加 LINE、等下次案型再找">${escapeHtml(item.internalNote || "")}</textarea>
              </label>
            </div>
            <div class="vendor-note-card-actions">
              <button type="button" class="vendor-note-mini-btn" data-vendor-intake-save="${escapeHtml(item.id)}">儲存狀態</button>
              <button type="button" class="vendor-note-mini-btn" data-vendor-intake-promote="${escapeHtml(item.id)}">${hasPromotedNote ? "更新優質筆記" : "轉成優質筆記"}</button>
            </div>
          </article>
        `;
      })
      .join("");
  }

  function updateVendorIntakeState(result, fallbackItems = []) {
    vendorIntakeState = {
      status: typeof result?.status === "string" ? result.status : "error",
      configured: Boolean(result?.configured),
      items: Array.isArray(result?.items) ? result.items : fallbackItems,
      note: typeof result?.note === "string" ? result.note : "",
    };
  }

  async function loadVendorIntakes() {
    vendorIntakeState = {
      ...vendorIntakeState,
      status: "loading",
    };
    renderVendorIntakes();

    try {
      const response = await fetch(VENDOR_INTAKE_API_URL, {
        headers: {
          Accept: "application/json",
        },
      });
      const result = await response.json();
      updateVendorIntakeState(result, []);
    } catch (error) {
      console.error("讀取工班登錄池失敗：", error);
      vendorIntakeState = {
        ...vendorIntakeState,
        status: "error",
        configured: false,
        note: "工班登錄池暫時讀取失敗，請稍後再試。",
      };
    }

    renderVendorIntakes();
  }

  async function saveVendorIntake(item) {
    const response = await fetch(VENDOR_INTAKE_API_URL, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Accept: "application/json",
      },
      body: JSON.stringify({ item }),
    });
    const result = await response.json();
    updateVendorIntakeState(result, vendorIntakeState.items || []);
    renderVendorIntakes();
    if (!response.ok || result?.status !== "ok") {
      throw new Error(result?.note || `SAVE_VENDOR_INTAKE_FAILED:${response.status}`);
    }
  }

  function getWeekKey(date = new Date()) {
    const target = new Date(date);
    const day = target.getDay() || 7;
    target.setHours(0, 0, 0, 0);
    target.setDate(target.getDate() + 4 - day);
    const yearStart = new Date(target.getFullYear(), 0, 1);
    const weekNo = Math.ceil((((target - yearStart) / 86400000) + 1) / 7);
    return `${target.getFullYear()}-W${String(weekNo).padStart(2, "0")}`;
  }

  function getDayKey(date = new Date()) {
    const target = new Date(date);
    target.setHours(0, 0, 0, 0);
    return target.toISOString().split("T")[0];
  }

  function createDailyOps() {
    return {
      dayKey: getDayKey(),
      actionMorningPatrol: false,
      actionEveningPatrol: false,
      actionOutboundHunt: false,
      actionOutboundFallback: false,
      rewardClaimed: false,
      completedAt: "",
    };
  }

  function createRun(slot) {
    return {
      id: `run-${slot}`,
      slot,
      actionOutreach: false,
      actionOutreachFallback: false,
      actionImageGeneration: false,
      actionWebsite: false,
      actionGoogleBusiness: false,
      actionThreads: false,
      actionLocalCommunity: false,
      actionFacadeMaintenance: false,
      linkStash: {
        gemini: "",
        website: "",
        googleBusiness: "",
        threads: "",
        localCommunity: "",
        facadeMaintenance: "",
      },
      rewardClaimed: false,
      completedAt: "",
    };
  }

  function createWeeklyRuns() {
    return [
      createRun(1),
      createRun(2),
      createRun(3),
    ];
  }

  function createInitialState() {
    return {
      daily: createDailyOps(),
      weekly: {
        weekKey: getWeekKey(),
        bonusClaimed: false,
        runs: createWeeklyRuns(),
      },
      stats: {
        xp: 0,
        streak: 0,
        lifetimeRuns: 0,
      },
    };
  }

  function hydrateRunState(savedRun = {}, templateRun) {
    const migratedOutreach = savedRun?.actionOutreach !== undefined
      ? Boolean(savedRun?.actionOutreach)
      : Boolean(savedRun?.actionSearch) && Boolean(savedRun?.actionAdvice);
    const migratedImageGeneration = savedRun?.actionImageGeneration !== undefined
      ? Boolean(savedRun?.actionImageGeneration)
      : Boolean(savedRun?.actionImage) || Boolean(savedRun?.actionVisual) || Boolean(savedRun?.actionIllustration);
    const migratedWebsite = savedRun?.actionWebsite !== undefined
      ? Boolean(savedRun?.actionWebsite)
      : Boolean(savedRun?.actionArticle);
    const savedLinkStash = savedRun?.linkStash && typeof savedRun.linkStash === "object"
      ? savedRun.linkStash
      : {};
    return {
      ...templateRun,
      ...savedRun,
      actionOutreach: migratedOutreach,
      actionOutreachFallback: Boolean(savedRun?.actionOutreachFallback),
      actionImageGeneration: migratedImageGeneration,
      actionWebsite: migratedWebsite,
      actionGoogleBusiness: Boolean(savedRun?.actionGoogleBusiness),
      actionThreads: Boolean(savedRun?.actionThreads),
      actionLocalCommunity: savedRun?.actionLocalCommunity !== undefined
        ? Boolean(savedRun?.actionLocalCommunity)
        : Boolean(savedRun?.actionFacebook),
      actionFacadeMaintenance: savedRun?.actionFacadeMaintenance !== undefined
        ? Boolean(savedRun?.actionFacadeMaintenance)
        : Boolean(savedRun?.actionInstagram) || Boolean(savedRun?.actionXiaohongshu),
      linkStash: {
        ...templateRun.linkStash,
        gemini: typeof savedLinkStash?.gemini === "string" ? savedLinkStash.gemini : "",
        website: typeof savedLinkStash?.website === "string" ? savedLinkStash.website : "",
        googleBusiness: typeof savedLinkStash?.googleBusiness === "string" ? savedLinkStash.googleBusiness : "",
        threads: typeof savedLinkStash?.threads === "string" ? savedLinkStash.threads : "",
        localCommunity: typeof savedLinkStash?.localCommunity === "string"
          ? savedLinkStash.localCommunity
          : typeof savedLinkStash?.facebook === "string"
            ? savedLinkStash.facebook
            : "",
        facadeMaintenance: typeof savedLinkStash?.facadeMaintenance === "string"
          ? savedLinkStash.facadeMaintenance
          : typeof savedLinkStash?.instagram === "string" && savedLinkStash.instagram
            ? savedLinkStash.instagram
            : typeof savedLinkStash?.xiaohongshu === "string"
              ? savedLinkStash.xiaohongshu
              : "",
      },
    };
  }

  function syncRuns(savedRuns = []) {
    const templateRuns = createWeeklyRuns();
    return templateRuns.map((templateRun, index) => {
      const savedRun = savedRuns.find((run) => run?.id === templateRun.id) ?? savedRuns[index] ?? {};
      return hydrateRunState(savedRun, templateRun);
    });
  }

  function hydrateDailyState(savedDaily = {}, templateDaily = createDailyOps()) {
    return {
      ...templateDaily,
      ...savedDaily,
      dayKey: typeof savedDaily?.dayKey === "string" && savedDaily.dayKey ? savedDaily.dayKey : templateDaily.dayKey,
      actionMorningPatrol: Boolean(savedDaily?.actionMorningPatrol),
      actionEveningPatrol: Boolean(savedDaily?.actionEveningPatrol),
      actionOutboundHunt: Boolean(savedDaily?.actionOutboundHunt),
      actionOutboundFallback: Boolean(savedDaily?.actionOutboundFallback),
      rewardClaimed: Boolean(savedDaily?.rewardClaimed),
      completedAt: typeof savedDaily?.completedAt === "string" ? savedDaily.completedAt : "",
    };
  }

  let state = createInitialState();

  function saveState() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      const initialState = createInitialState();
      state = {
        daily: hydrateDailyState(parsed.daily, initialState.daily),
        weekly: {
          ...initialState.weekly,
          ...(parsed.weekly || {}),
          runs: syncRuns(parsed.weekly?.runs),
        },
        stats: {
          ...initialState.stats,
          ...(parsed.stats || {}),
        },
      };
    } catch (error) {
      console.error("讀取社群作戰台資料失敗：", error);
    }
  }

  function getWorkspaceTabs() {
    return Array.from(document.querySelectorAll("[data-workspace-tab]"));
  }

  function getWorkspacePanes() {
    return Array.from(document.querySelectorAll("[data-workspace-pane]"));
  }

  function isValidWorkspacePane(pane) {
    return ["operations", "content", "knowledge", "vendors", "review"].includes(pane);
  }

  function saveWorkspacePane() {
    localStorage.setItem(WORKSPACE_PANE_KEY, currentWorkspacePane);
  }

  function loadWorkspacePane() {
    const savedPane = localStorage.getItem(WORKSPACE_PANE_KEY);
    if (isValidWorkspacePane(savedPane)) {
      currentWorkspacePane = savedPane;
    }
  }

  function refreshWorkspacePaneUi() {
    getWorkspaceTabs().forEach((tab) => {
      const isActive = tab.dataset.workspaceTab === currentWorkspacePane;
      tab.classList.toggle("is-active", isActive);
      tab.setAttribute("aria-pressed", isActive ? "true" : "false");
    });

    getWorkspacePanes().forEach((pane) => {
      const isActive = pane.dataset.workspacePane === currentWorkspacePane;
      pane.classList.toggle("is-active", isActive);
      pane.hidden = !isActive;
    });
  }

  function handleWorkspacePaneSideEffects() {
    if (currentWorkspacePane !== "review") return;

    renderContentAnalytics();
    if (contentAnalyticsState.status === "idle" || contentAnalyticsState.status === "error") {
      loadContentAnalytics();
    }
  }

  function setWorkspacePane(nextPane, options = {}) {
    if (!isValidWorkspacePane(nextPane)) return;

    const { persist = true, scrollTarget = "" } = options;
    currentWorkspacePane = nextPane;
    refreshWorkspacePaneUi();
    handleWorkspacePaneSideEffects();

    if (persist) {
      saveWorkspacePane();
    }

    if (scrollTarget) {
      const target = document.getElementById(scrollTarget);
      target?.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  function isRunComplete(run) {
    return isRunOutreachSatisfied(run)
      && run.actionImageGeneration
      && run.actionWebsite
      && run.actionGoogleBusiness
      && isRunDistributionSatisfied(run);
  }

  function isDailyOpsComplete(daily = state.daily) {
    return daily.actionMorningPatrol
      && daily.actionEveningPatrol
      && isDailyHuntSatisfied(daily);
  }

  function isDailyHuntSatisfied(daily = state.daily) {
    return Boolean(daily.actionOutboundHunt || daily.actionOutboundFallback);
  }

  function isRunOutreachSatisfied(run) {
    return Boolean(run.actionOutreach || run.actionOutreachFallback);
  }

  function isRunDistributionSatisfied(run) {
    return Boolean(run.actionThreads || run.actionLocalCommunity);
  }

  function getDailyCompletedRequirementCount(daily = state.daily) {
    return [
      daily.actionMorningPatrol,
      daily.actionEveningPatrol,
      isDailyHuntSatisfied(daily),
    ].filter(Boolean).length;
  }

  function getChoiceState(isChecked, alternativeChecked) {
    if (isChecked) {
      return {
        className: "is-checked",
        badge: "已完成",
      };
    }

    if (alternativeChecked) {
      return {
        className: "is-satisfied",
        badge: "已滿足",
      };
    }

    return {
      className: "",
      badge: "",
    };
  }

  function renderChoiceStateBadge(choiceState) {
    if (!choiceState?.badge) return "";
    return `<em class="quest-check-state ${choiceState.className === "is-satisfied" ? "is-satisfied" : "is-complete"}">${choiceState.badge}</em>`;
  }

  function buildCarryoverWeeklyRuns(previousRuns = []) {
    const templateRuns = createWeeklyRuns();
    const unfinishedRuns = previousRuns.filter((run) => !isRunComplete(run));
    return templateRuns.map((templateRun, index) => {
      const carryoverRun = unfinishedRuns[index];
      if (!carryoverRun) return templateRun;
      const hydratedRun = hydrateRunState(carryoverRun, templateRun);
      return {
        ...hydratedRun,
        rewardClaimed: false,
        completedAt: "",
      };
    });
  }

  function normalizeWeeklyState() {
    const currentWeekKey = getWeekKey();
    if (state.weekly.weekKey === currentWeekKey) return;

    const completedRuns = state.weekly.runs.filter(isRunComplete).length;
    const carryoverCount = state.weekly.runs.filter((run) => !isRunComplete(run)).length;
    const previousStreak = state.stats.streak;
    const nextStreak = completedRuns >= WEEKLY_TARGET ? previousStreak + 1 : 0;
    state.stats.streak = nextStreak;
    if (nextStreak >= 2) {
      state.stats.xp += STREAK_BONUS_XP;
    }
    state.weekly = {
      weekKey: currentWeekKey,
      bonusClaimed: false,
      runs: buildCarryoverWeeklyRuns(state.weekly.runs),
    };
    saveState();
    setFeedback(
      nextStreak >= 2
        ? `已進入新的一週，連續達標 ${nextStreak} 週，額外 +${STREAK_BONUS_XP} XP。${carryoverCount > 0 ? `已保留 ${carryoverCount} 個未完成任務。` : "本週任務已刷新。"}`
        : carryoverCount > 0
          ? `已進入新的一週，已保留 ${carryoverCount} 個未完成任務，已完成項目已刷新。`
          : "已進入新的一週，本週任務已刷新。",
      nextStreak >= 2 ? "is-success" : carryoverCount > 0 ? "is-warning" : "is-success",
    );
  }

  function resetDailyOpsState(message = "今日主動獵殺任務已刷新。", mode = "is-warning") {
    state.daily = createDailyOps();
    rerender();
    setFeedback(message, mode);
  }

  function resetWeeklyOpsState(message = "已保留本週進度並解鎖下一輪主任務。", mode = "is-warning") {
    const lockedRunIndex = state.weekly.runs.findIndex((run) => isRunLockedUntilNextDay(run));
    if (lockedRunIndex === -1) {
      setFeedback(
        getCompletedRunCount() >= WEEKLY_TARGET
          ? "本週已經 3 / 3 全部完成，這顆按鈕不會重置既有進度。"
          : "目前本週任務已是可操作狀態，不需要另外刷新。",
        getCompletedRunCount() >= WEEKLY_TARGET ? "is-success" : "is-warning",
      );
      return;
    }

    state.weekly.runs[lockedRunIndex] = {
      ...state.weekly.runs[lockedRunIndex],
      completedAt: "",
    };
    rerender();
    setFeedback(message, mode);
  }

  function normalizeDailyState() {
    const currentDayKey = getDayKey();
    if (state.daily?.dayKey === currentDayKey) return;

    state.daily = createDailyOps();
    saveState();
    setFeedback("已進入新的一天，主動獵殺任務已刷新。", "is-success");
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function normalizeLinkValue(value = "") {
    const trimmed = String(value ?? "").trim();
    if (!trimmed) return "";
    if (/^https?:\/\//i.test(trimmed)) return trimmed;
    return `https://${trimmed.replace(/^\/+/, "")}`;
  }

  function setFeedback(message, mode = "") {
    const shell = document.getElementById("ops-feedback");
    if (!shell) return;
    shell.className = `ops-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function setGeminiFeedback(message, mode = "") {
    const shell = document.getElementById("gemini-feedback");
    if (!shell) return;
    shell.className = `gemini-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function getCompletedRunCount() {
    return state.weekly.runs.filter(isRunComplete).length;
  }

  function isRunLockedUntilNextDay(run, date = new Date()) {
    if (!isRunComplete(run) || !run?.completedAt) return false;
    const completedAt = new Date(run.completedAt);
    if (Number.isNaN(completedAt.getTime())) return false;
    return getDayKey(completedAt) === getDayKey(date);
  }

  function getActiveRunIndex() {
    const lockedRunIndex = state.weekly.runs.findIndex((run) => isRunLockedUntilNextDay(run));
    if (lockedRunIndex !== -1) return lockedRunIndex;
    const nextIndex = state.weekly.runs.findIndex((run) => !isRunComplete(run));
    return nextIndex === -1 ? Math.max(state.weekly.runs.length - 1, 0) : nextIndex;
  }

  function getLevel() {
    return Math.floor(state.stats.xp / 200) + 1;
  }

  function getCurrentLevelXp() {
    return state.stats.xp % 200;
  }

  function getNextLevelXpRequirement() {
    return 200;
  }

  function getRankTitle(level) {
    return rankTitles[Math.min(level - 1, rankTitles.length - 1)];
  }

  function maybeClaimRunReward(run) {
    if (!isRunComplete(run) || run.rewardClaimed) return;
    run.rewardClaimed = true;
    run.completedAt = new Date().toISOString();
    state.stats.xp += RUN_XP;
    state.stats.lifetimeRuns += 1;

    const completedRuns = getCompletedRunCount();
    if (completedRuns >= WEEKLY_TARGET && !state.weekly.bonusClaimed) {
      state.weekly.bonusClaimed = true;
      state.stats.xp += WEEKLY_BONUS_XP;
      setFeedback(`本輪週任務完成，+${RUN_XP} XP；本週三個任務已全清，額外 +${WEEKLY_BONUS_XP} XP。`, "is-success");
      return;
    }
    setFeedback(`本輪週任務完成，+${RUN_XP} XP。`, "is-success");
  }

  function maybeClaimDailyReward(daily = state.daily) {
    if (!isDailyOpsComplete(daily) || daily.rewardClaimed) return;
    daily.rewardClaimed = true;
    daily.completedAt = new Date().toISOString();
    state.stats.xp += DAILY_OPS_XP;
    setFeedback(`今日主動獵殺完成，+${DAILY_OPS_XP} XP。`, "is-success");
  }

  function renderHero() {
    const completedRuns = getCompletedRunCount();
    const remaining = Math.max(WEEKLY_TARGET - completedRuns, 0);
    const percent = Math.round((completedRuns / WEEKLY_TARGET) * 100);
    const level = getLevel();
    const currentLevelXp = getCurrentLevelXp();
    const nextLevelXpRequirement = getNextLevelXpRequirement();
    const xpPercent = Math.round((currentLevelXp / nextLevelXpRequirement) * 100);
    document.getElementById("weekly-progress-count").textContent = `${completedRuns} / ${WEEKLY_TARGET}`;
    document.getElementById("weekly-progress-note").textContent = remaining === 0
      ? "本週已清空，待下週刷新。"
      : `還差 ${remaining} 個任務`;
    document.getElementById("weekly-progress-bar").style.width = `${percent}%`;
    document.getElementById("xp-value").textContent = `${state.stats.xp} XP`;
    document.getElementById("xp-progress-note").textContent = `本級 ${currentLevelXp} / ${nextLevelXpRequirement} XP`;
    document.getElementById("xp-progress-bar").style.width = `${xpPercent}%`;
    document.getElementById("streak-value").textContent = `${state.stats.streak} 週`;
    document.getElementById("lifetime-runs-value").textContent = `${state.stats.lifetimeRuns} 次`;
    document.getElementById("level-value").textContent = `第 ${level} 級`;
    document.getElementById("rank-title").textContent = getRankTitle(level);
  }

  function renderQuests() {
    const shell = document.getElementById("quest-grid");
    if (!shell) return;

    const completedRuns = getCompletedRunCount();
    const weeklyRemaining = Math.max(WEEKLY_TARGET - completedRuns, 0);
    const weeklyPanelNote = document.getElementById("weekly-panel-note");
    if (weeklyPanelNote) {
      weeklyPanelNote.textContent = weeklyRemaining === 0
        ? "本週可完成項目已全數完成"
        : `本週還差 ${weeklyRemaining} 輪主任務`;
    }

    const activeRunIndex = getActiveRunIndex();
    const run = state.weekly.runs[activeRunIndex];
    if (!run) {
      shell.innerHTML = "";
      return;
    }

    const complete = isRunComplete(run);
    const actionOneComplete = isRunOutreachSatisfied(run);
    const actionTwoComplete = run.actionImageGeneration
      && run.actionWebsite
      && run.actionGoogleBusiness
      && isRunDistributionSatisfied(run);
    const outreachState = getChoiceState(run.actionOutreach, run.actionOutreachFallback);
    const outreachFallbackState = getChoiceState(run.actionOutreachFallback, run.actionOutreach);
    const threadsState = getChoiceState(run.actionThreads, run.actionLocalCommunity);
    const localCommunityState = getChoiceState(run.actionLocalCommunity, run.actionThreads);
    const completedSteps = [
      actionOneComplete,
      run.actionImageGeneration,
      run.actionWebsite,
      run.actionGoogleBusiness,
      isRunDistributionSatisfied(run),
      run.actionFacadeMaintenance,
    ].filter(Boolean).length;
    const progressLabel = `(${activeRunIndex + 1}/${WEEKLY_TARGET})`;
    const isLockedUntilNextDay = isRunLockedUntilNextDay(run);
    const progressState = completedRuns >= WEEKLY_TARGET
      ? "本週已清空"
      : isLockedUntilNextDay
        ? "今日已完成"
        : complete
          ? "本輪已完成"
        : completedSteps > 0
          ? "進行中"
          : "待開始";
    const actionOneNote = actionOneComplete
      ? "這組擇一條件已滿足，另一個選項不用再做。"
      : "這組任務請在「高意圖回覆」與「巡邏無合適發問」之間擇一完成。";
    const actionTwoNote = actionTwoComplete
      ? isLockedUntilNextDay
        ? "這一輪已完成，面板會保留到今天結束，隔天 00:00 後才切換到下一輪。"
