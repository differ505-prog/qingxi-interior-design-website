  function inferSubchapterFromTrack(trackTitle, chapterTitle, titleText = "", content = "") {
    const subchapterMap = getTrackSubchapterMap(trackTitle, chapterTitle);
    const subchapterEntries = Object.entries(subchapterMap);
    if (!subchapterEntries.length) return "";

    const text = `${titleText}\n${content}`.replace(/\s+/g, "");
    let bestSubchapter = "";
    let bestScore = 0;

    subchapterEntries.forEach(([subchapter, keywords]) => {
      const score = getInferenceKeywordScore(text, keywords);
      if (score > bestScore) {
        bestScore = score;
        bestSubchapter = subchapter;
      }
    });

    return bestSubchapter || subchapterEntries[0][0] || "";
  }

  function buildTitleKeywordSet(text) {
    return Array.from(new Set(
      text
        .split(/[\s,，。、「」\/()（）\-｜—:：]+/)
        .map((token) => token.trim())
        .filter((token) => token.length >= 2),
    ));
  }

  function inferSimilarArticleTitle(content, articleTitle = "") {
    const queryText = `${articleTitle}\n${content}`;
    const keywords = buildTitleKeywordSet(queryText);
    if (!keywords.length) return "";

    let bestTitle = "";
    let bestScore = 0;

    articleLibrary.forEach((post) => {
      const haystack = `${post.title}\n${formatArticleLibraryTaxonomy(post)}\n${formatArticleLibraryTags(post)}`.replace(/\s+/g, "");
      const score = keywords.reduce((sum, keyword) => sum + (haystack.includes(keyword) ? keyword.length : 0), 0);
      if (score > bestScore) {
        bestScore = score;
        bestTitle = post.title;
      }
    });

    return bestScore >= 4 ? bestTitle : "";
  }

  function findArticleByTitle(title = "") {
    const normalizedTitle = normalizeComparableText(title.replace(/[《》「」]/g, ""));
    if (!normalizedTitle || /暫未比對|請看下方 AI 原文|尚未判定/.test(title)) return null;

    return (
      articleLibrary.find((post) => normalizeComparableText(post.title) === normalizedTitle) ||
      articleLibrary.find((post) => normalizeComparableText(post.title).includes(normalizedTitle)) ||
      articleLibrary.find((post) => normalizedTitle.includes(normalizeComparableText(post.title))) ||
      null
    );
  }

  function inferSimilarArticle(content, articleTitle = "") {
    const queryText = `${articleTitle}\n${content}`;
    const keywords = buildTitleKeywordSet(queryText);
    if (!keywords.length) return null;

    let bestPost = null;
    let bestScore = 0;

    articleLibrary.forEach((post) => {
      const haystack = `${post.title}\n${formatArticleLibraryTaxonomy(post)}\n${formatArticleLibraryTags(post)}\n${post.summary || ""}`.replace(/\s+/g, "");
      const score = keywords.reduce((sum, keyword) => sum + (haystack.includes(keyword) ? keyword.length : 0), 0);
      if (score > bestScore) {
        bestScore = score;
        bestPost = post;
      }
    });

    return bestScore >= 4 ? bestPost : null;
  }

  function getBlogPostUrl(post) {
    if (!post?.slug) return BLOG_INDEX_URL;
    return `${SITE_ORIGIN}/blog/${post.slug}`;
  }

  async function getShortBlogUrl(url) {
    const normalizedUrl = String(url || "").trim();
    if (!normalizedUrl) return "";
    if (normalizedUrl.includes("/r/")) return normalizedUrl;
    if (socialReplyShortUrlCache.has(normalizedUrl)) {
      return socialReplyShortUrlCache.get(normalizedUrl);
    }

    try {
      const response = await fetch("/api/links/share", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ url: normalizedUrl }),
      });

      if (!response.ok) {
        throw new Error(`Short link request failed: ${response.status}`);
      }

      const result = await response.json();
      const resolvedUrl = typeof result?.url === "string" && result.url.trim() ? result.url.trim() : normalizedUrl;
      socialReplyShortUrlCache.set(normalizedUrl, resolvedUrl);
      return resolvedUrl;
    } catch (error) {
      console.error("建立社團導流短網址失敗：", error);
      socialReplyShortUrlCache.set(normalizedUrl, normalizedUrl);
      return normalizedUrl;
    }
  }

  function resolveSocialReplyTarget(content) {
    const decisionSimilar = summarizeDecisionSimilar(content);
    const articleTitle = parseArticleTitle(content);
    const matchedPost =
      findArticleByTitle(decisionSimilar) ||
      findArticleByTitle(articleTitle) ||
      inferSimilarArticle(content, articleTitle);

    if (matchedPost) {
      return {
        title: matchedPost.title,
        url: getBlogPostUrl(matchedPost),
      };
    }

    return {
      title: "知識分享",
      url: BLOG_INDEX_URL,
    };
  }

  function injectLeadReplyUrl(text, target) {
    const cleanText = String(text || "").trim();
    const fallbackSentence =
      target.title === "知識分享"
        ? `這類題目我有陸續整理，貼這篇給你參考：${target.url}`
        : `這題我之前有整理過，貼這篇給你參考：${target.url}`;

    if (!cleanText) return fallbackSentence;
    if (/https?:\/\//i.test(cleanText)) return cleanText;

    const replaced = cleanText.replace(/\[預留網址空間\]|\(預留網址空間\)|（預留網址空間）|預留網址空間/g, target.url);
    if (replaced !== cleanText) return replaced;

    if (/參考|看這篇|看這裡|看完整|完整分析/.test(cleanText)) {
      return `${cleanText} ${target.url}`.trim();
    }

    return `${cleanText}${/[。！？!?]$/.test(cleanText) ? "" : "。"}${fallbackSentence}`;
  }

  function softenSocialReplyTone(text, variant, target) {
    let value = String(text || "").trim();
    if (!value) return "";

    const replacementPairs = [
      [/完整分析/g, "幾個判斷重點"],
      [/歡迎參考/g, "貼給你參考"],
      [/有需要可以先看這裡/g, "貼這篇給你參考"],
      [/有需要可以先看這篇/g, "貼這篇給你參考"],
      [/官網知識分享/g, "網站裡"],
      [/我剛好整理過一篇/g, "我之前有整理過"],
      [/我剛好整理成一篇/g, "我之前有整理成"],
    ];
    replacementPairs.forEach(([pattern, replacement]) => {
      value = value.replace(pattern, replacement);
    });
    value = value.replace(/\s{2,}/g, " ").trim();

    if (variant === "lead" && !/https?:\/\//i.test(value)) {
      value = injectLeadReplyUrl(value, target);
    }
    return value;
  }

  function buildSocialReplySeed(content) {
    return `${articleSourceQuestion}\n${parseArticleTitle(content)}\n${content}`;
  }

  function inferSocialReplyCore(content) {
    const seed = buildSocialReplySeed(content);
    if (/預算|報價|費用|單價|抓多少/.test(seed)) {
      return {
