  function renderPortals() {
    const facebookShell = document.getElementById("facebook-card-grid");
    const lineShell = document.getElementById("line-card-grid");
    const googleShell = document.getElementById("google-card-grid");
    if (!facebookShell || !lineShell || !googleShell) return;

    const facebookSources = sourceTemplate.filter((source) => source.platform === "Facebook");
    const lineSources = sourceTemplate.filter((source) => source.platform === "LINE");
    const googleSources = sourceTemplate.filter((source) => source.platform === "Google");

    facebookShell.innerHTML = renderPortalCards(facebookSources);
    lineShell.innerHTML = renderPortalCards(lineSources);
    googleShell.innerHTML = renderPortalCards(googleSources);
  }

  function formatCount(value) {
    const parsed = Number(value || 0);
    if (!Number.isFinite(parsed)) return "-";
    return parsed.toLocaleString("zh-TW");
  }

  function getArticleTitleFromPagePath(pagePath = "") {
    const slug = pagePath
      .replace(/^\/blog\//, "")
      .replace(/\/$/, "")
      .trim();
    if (!slug) return "未辨識文章";
    const matched = articleLibrary.find((post) => post.slug === slug);
    return matched?.title || slug;
  }

  function getReadableLandingLabel(pagePath = "") {
    const normalizedPath = String(pagePath || "").split("?")[0].trim();
    if (!normalizedPath || normalizedPath === "(not set)") return "未提供落地頁";
    if (normalizedPath === "/") return "首頁";
    if (normalizedPath === "/tools") return "線上估價系統";
    if (normalizedPath === "/contact") return "免費格局健檢";
    if (normalizedPath === "/requirement-form") return "完整需求表";
    if (normalizedPath.startsWith("/blog/")) return getArticleTitleFromPagePath(normalizedPath);
    return normalizedPath;
  }

  function renderContentAnalytics() {
    const statusNode = document.getElementById("content-analytics-status");
    const updatedAtNode = document.getElementById("content-analytics-updated-at");
    const noteNode = document.getElementById("content-analytics-note");
    const topPostsNode = document.getElementById("content-analytics-top-posts");
    const topSourcesNode = document.getElementById("content-analytics-top-sources");
    const socialLandingsNode = document.getElementById("content-analytics-social-landings");
    const realtimeUsersNode = document.getElementById("content-analytics-realtime-users");
    const todaySessionsNode = document.getElementById("content-analytics-today-sessions");
    const totalSessionsNode = document.getElementById("content-analytics-total-sessions");
    const blogViewsNode = document.getElementById("content-analytics-blog-views");
    const socialSessionsNode = document.getElementById("content-analytics-social-sessions");
    const estimateGeneratedNode = document.getElementById("content-analytics-estimate-generated");
    const estimateCtaNode = document.getElementById("content-analytics-estimate-cta");
    const requirementSuccessNode = document.getElementById("content-analytics-requirement-success");

    // 即使找不到一些元素，也继续处理能找到的元素
    if (realtimeUsersNode) realtimeUsersNode.textContent = formatCount(contentAnalyticsState.metrics.realtimeActiveUsers);
    if (todaySessionsNode) todaySessionsNode.textContent = formatCount(contentAnalyticsState.metrics.todaySessions);
    if (totalSessionsNode) totalSessionsNode.textContent = formatCount(contentAnalyticsState.metrics.totalSessions);
    if (blogViewsNode) blogViewsNode.textContent = formatCount(contentAnalyticsState.metrics.blogViews);
    if (socialSessionsNode) socialSessionsNode.textContent = formatCount(contentAnalyticsState.metrics.socialSessions);
    if (estimateGeneratedNode) estimateGeneratedNode.textContent = formatCount(contentAnalyticsState.metrics.estimateGenerated);
    if (estimateCtaNode) estimateCtaNode.textContent = formatCount(contentAnalyticsState.metrics.estimateCtaClick);
    if (requirementSuccessNode) requirementSuccessNode.textContent = formatCount(contentAnalyticsState.metrics.requirementSuccess);

    if (contentAnalyticsState.status === "loading") {
      if (statusNode) statusNode.textContent = "讀取中";
      if (updatedAtNode) updatedAtNode.textContent = "同步中";
      if (noteNode) noteNode.textContent = "正在向 GA4 讀取即時活躍使用者、近 7 天內容、來源與轉換成效。";
      if (topPostsNode) topPostsNode.innerHTML = "<li>正在讀取內容成效...</li>";
      if (topSourcesNode) topSourcesNode.innerHTML = "<li>正在讀取來源資料...</li>";
      if (socialLandingsNode) socialLandingsNode.innerHTML = "<li>正在讀取社群落地頁...</li>";
      return;
    }

    if (contentAnalyticsState.status === "setup_required") {
      if (statusNode) statusNode.textContent = "待接 GA4";
      if (updatedAtNode) updatedAtNode.textContent = contentAnalyticsState.rangeLabel;
      if (noteNode) noteNode.textContent =
        contentAnalyticsState.note ||
        "設定好 GA4 權限後，這裡會自動顯示即時活躍使用者、內容、來源與落地頁成效。";
      if (topPostsNode) topPostsNode.innerHTML = "<li>目前尚未接通 GA4 Data API。</li>";
      if (topSourcesNode) topSourcesNode.innerHTML = "<li>接通後可直接看到來源 / 媒介排行。</li>";
      if (socialLandingsNode) socialLandingsNode.innerHTML = "<li>接通後可直接看到社群帶進站的頁面。</li>";
      return;
    }

    if (contentAnalyticsState.status === "error") {
      if (statusNode) statusNode.textContent = "讀取失敗";
      if (updatedAtNode) updatedAtNode.textContent = contentAnalyticsState.rangeLabel;
      if (noteNode) noteNode.textContent = contentAnalyticsState.note || "GA4 報表暫時讀取失敗，請稍後再試。";
      if (topPostsNode) topPostsNode.innerHTML = "<li>目前無法取得熱門文章排行。</li>";
      if (topSourcesNode) topSourcesNode.innerHTML = "<li>目前無法取得來源排行。</li>";
      if (socialLandingsNode) socialLandingsNode.innerHTML = "<li>目前無法取得社群落地頁排行。</li>";
      return;
    }

    if (statusNode) statusNode.textContent = contentAnalyticsState.configured ? "已同步" : "未設定";
    if (updatedAtNode) updatedAtNode.textContent = contentAnalyticsState.updatedAt
      ? `更新於 ${new Date(contentAnalyticsState.updatedAt).toLocaleString("zh-TW", {
          hour12: false,
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
        })}`
      : contentAnalyticsState.rangeLabel;
    if (noteNode) noteNode.textContent =
      contentAnalyticsState.note ||
      `即時活躍使用者顯示近 30 分鐘 active users；今日人次與總人次顯示整站 sessions；${contentAnalyticsState.rangeLabel} 內則集中回看內容、來源與官網轉換事件。`;

    const topPosts = Array.isArray(contentAnalyticsState.topPosts)
      ? contentAnalyticsState.topPosts
      : [];
    if (topPostsNode) topPostsNode.innerHTML = topPosts.length
      ? topPosts
          .map((post) => `
            <li>
              <span>${escapeHtml(getArticleTitleFromPagePath(post.pagePath))}</span>
              <strong>${formatCount(post.views)}</strong>
            </li>
          `)
          .join("")
      : "<li>近 7 天尚無文章瀏覽資料。</li>";

    const topSources = Array.isArray(contentAnalyticsState.topSources)
      ? contentAnalyticsState.topSources
      : [];
    if (topSourcesNode) topSourcesNode.innerHTML = topSources.length
      ? topSources
          .map((source) => `
            <li>
              <span>${escapeHtml(source.sourceMedium || "(direct) / (none)")}</span>
              <strong>${formatCount(source.sessions)}</strong>
            </li>
          `)
          .join("")
      : "<li>近 7 天尚無來源資料。</li>";

    const socialLandingPages = Array.isArray(contentAnalyticsState.socialLandingPages)
      ? contentAnalyticsState.socialLandingPages
      : [];
    if (socialLandingsNode) socialLandingsNode.innerHTML = socialLandingPages.length
      ? socialLandingPages
          .map((page) => `
            <li>
              <span>${escapeHtml(getReadableLandingLabel(page.pagePath))}</span>
              <strong>${formatCount(page.sessions)}</strong>
            </li>
          `)
          .join("")
      : "<li>近 7 天尚無社群導流資料。</li>";
  }

  function renderVendorNotes() {
    const countNode = document.getElementById("vendor-note-count");
    const summaryNode = document.getElementById("vendor-note-summary");
    const searchNode = document.getElementById("vendor-note-search");
    const sortNode = document.getElementById("vendor-note-sort");
    const filterNode = document.getElementById("vendor-trade-filter");
    const listNode = document.getElementById("vendor-note-list");
    if (
      !(countNode instanceof HTMLElement) ||
      !(summaryNode instanceof HTMLElement) ||
      !(searchNode instanceof HTMLInputElement) ||
      !(sortNode instanceof HTMLSelectElement) ||
      !(filterNode instanceof HTMLElement) ||
      !(listNode instanceof HTMLElement)
    ) {
      return;
    }

    if (searchNode.value !== vendorNoteSearch) {
      searchNode.value = vendorNoteSearch;
    }

    if (sortNode.value !== vendorNoteSort) {
      sortNode.value = vendorNoteSort;
    }

    const items = getFilteredVendorNotes();
    const filterOptions = getVendorTradeFilterOptions();
    countNode.textContent = String(vendorNotesState.items.length || 0);

    if (vendorNotesState.status === "loading") {
      summaryNode.textContent = "同步中";
      listNode.innerHTML = '<div class="vendor-note-empty">正在讀取共享筆記...</div>';
      return;
    }

    if (vendorNotesState.status === "setup_required") {
      summaryNode.textContent = "待接共享儲存";
      listNode.innerHTML = `<div class="vendor-note-empty">${escapeHtml(vendorNotesState.note || "尚未接通共享儲存。")}</div>`;
      return;
    }

    if (vendorNotesState.status === "error") {
      summaryNode.textContent = "讀取失敗";
      listNode.innerHTML = `<div class="vendor-note-empty">${escapeHtml(vendorNotesState.note || "共享筆記暫時讀取失敗。")}</div>`;
      return;
    }

    const groupedItems = groupVendorNotesByTrade(items);
    filterNode.innerHTML = filterOptions
      .map((option) => `
        <button
          type="button"
          class="vendor-trade-chip ${option.value === vendorNoteTradeFilter ? "is-active" : ""}"
          data-vendor-trade-filter="${escapeHtml(option.value)}"
        >
          <span>${escapeHtml(option.label)}</span>
          <small>${escapeHtml(String(option.count))}</small>
        </button>
      `)
      .join("");
    summaryNode.textContent = vendorNoteSearch
      ? `顯示 ${items.length} 筆，分成 ${groupedItems.length} 類`
      : vendorNoteTradeFilter
        ? `${vendorNoteTradeFilter} 共 ${items.length} 筆`
        : vendorNotesState.items.length
          ? `已按 ${groupedItems.length} 個工種整理`
        : "尚未建立筆記";

    if (!items.length) {
      listNode.innerHTML = vendorNoteSearch
        ? '<div class="vendor-note-empty">目前沒有符合搜尋的廠商筆記。</div>'
        : '<div class="vendor-note-empty">尚未建立優質廠商筆記。</div>';
      return;
    }

    listNode.innerHTML = groupedItems
      .map((group) => `
        <section class="vendor-trade-group">
          <div class="vendor-trade-group-head">
            <div class="vendor-trade-group-title">
              <strong>${escapeHtml(group.trade)}</strong>
              <span>${group.items.length} 筆</span>
            </div>
          </div>
          <div class="vendor-trade-group-list">
            ${group.items
              .map((note) => {
                const primaryUrl = normalizeLinkValue(note.primaryUrl);
                const secondaryUrl = normalizeLinkValue(note.secondaryUrl);
                const metaItems = [
                  note.location ? `<span>${escapeHtml(note.location)}</span>` : "",
                  note.updatedAt ? `<span>更新 ${escapeHtml(formatVendorNoteTimestamp(note.updatedAt))}</span>` : "",
                ].filter(Boolean).join("");

                return `
                  <article class="vendor-note-card ${note.isPinned ? "is-pinned" : ""}">
                    <div class="vendor-note-card-head">
                      <div class="vendor-note-card-main">
                        <div class="vendor-note-badges">
                          <span class="vendor-note-badge">${escapeHtml(getVendorSourceTypeLabel(note.sourceType))}</span>
                          ${note.priceLevel ? `<span class="vendor-note-badge">${escapeHtml(note.priceLevel)}價位</span>` : ""}
                          ${note.craftLevel ? `<span class="vendor-note-badge">${escapeHtml(note.craftLevel)}</span>` : ""}
                          ${note.isPinned ? '<span class="vendor-note-badge vendor-note-badge-star">優先</span>' : ""}
                        </div>
                        <strong>${escapeHtml(note.name || "未命名廠商")}</strong>
                        <p>${escapeHtml(note.impression || note.memo || "尚未補一句印象")}</p>
                        <div class="vendor-note-meta">${metaItems || "<span>尚未補地區或更新資訊</span>"}</div>
                      </div>
                      <div class="vendor-note-card-actions">
                        ${primaryUrl
                          ? `<a class="vendor-note-action-link" href="${escapeHtml(primaryUrl)}" target="_blank" rel="noreferrer">開啟</a>`
                          : '<span class="vendor-note-action-link is-disabled">無連結</span>'}
                        <button type="button" class="vendor-note-mini-btn" data-vendor-action="edit" data-vendor-id="${escapeHtml(note.id)}">編輯</button>
                        <button type="button" class="vendor-note-mini-btn" data-vendor-action="pin" data-vendor-id="${escapeHtml(note.id)}">${note.isPinned ? "取消優先" : "優先"}</button>
                        <button type="button" class="vendor-note-mini-btn vendor-note-mini-btn-danger" data-vendor-action="delete" data-vendor-id="${escapeHtml(note.id)}">刪除</button>
                      </div>
                    </div>
                    ${(secondaryUrl || note.memo)
                      ? `<div class="vendor-note-card-body">
                          ${note.memo ? `<p class="vendor-note-memo">${escapeHtml(note.memo)}</p>` : ""}
                          ${secondaryUrl ? `<a class="vendor-note-secondary-link" href="${escapeHtml(secondaryUrl)}" target="_blank" rel="noreferrer">補充連結</a>` : ""}
                        </div>`
                      : ""}
                  </article>
                `;
              })
              .join("")}
          </div>
        </section>
      `)
      .join("");
  }

  function updateVendorNotesState(result, fallbackItems = []) {
    vendorNotesState = {
      status: typeof result?.status === "string" ? result.status : "error",
      configured: Boolean(result?.configured),
      items: Array.isArray(result?.items) ? result.items : fallbackItems,
      note: typeof result?.note === "string" ? result.note : "",
    };
  }

  async function loadVendorNotes() {
    vendorNotesState = {
      ...vendorNotesState,
      status: "loading",
    };
    renderVendorNotes();

    try {
      const response = await fetch(VENDOR_NOTES_API_URL, {
        headers: {
          Accept: "application/json",
        },
      });
      const result = await response.json();
      updateVendorNotesState(result, []);
    } catch (error) {
      console.error("讀取共享廠商筆記失敗：", error);
      vendorNotesState = {
        ...vendorNotesState,
        status: "error",
        configured: false,
        note: "共享廠商筆記暫時讀取失敗，請稍後再試。",
      };
    }

    renderVendorNotes();
  }

  async function saveVendorNote(note) {
    const response = await fetch(VENDOR_NOTES_API_URL, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Accept: "application/json",
      },
      body: JSON.stringify({ note }),
    });
    const result = await response.json();
    updateVendorNotesState(result, vendorNotesState.items || []);
    renderVendorNotes();
    if (!response.ok || result?.status !== "ok") {
      throw new Error(result?.note || `SAVE_VENDOR_NOTE_FAILED:${response.status}`);
    }
  }

  async function removeVendorNote(noteId) {
    const response = await fetch(`${VENDOR_NOTES_API_URL}?id=${encodeURIComponent(noteId)}`, {
      method: "DELETE",
      headers: {
        Accept: "application/json",
      },
    });
    const result = await response.json();
    updateVendorNotesState(result, vendorNotesState.items || []);
    renderVendorNotes();
    if (!response.ok || result?.status !== "ok") {
      throw new Error(result?.note || `DELETE_VENDOR_NOTE_FAILED:${response.status}`);
    }
  }

