              </div>
              <div class="quest-check-row">
                <label class="quest-check ${daily.actionOutboundHunt ? "is-checked" : ""} ${!daily.actionOutboundHunt && daily.actionOutboundFallback ? "is-satisfied" : ""}">
                  <input type="checkbox" data-daily-check="actionOutboundHunt" ${daily.actionOutboundHunt ? "checked" : ""} />
                  <span class="quest-check-copy">
                    <span>已鎖定高意圖貼文並第一時間留下專業留言</span>
