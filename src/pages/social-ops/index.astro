  function splitTopicDecisionList(value = "") {
    return String(value)
      .split(/\s*(?:\/|／|、|；|;|\||\n)\s*/)
      .map((item) => item.replace(/^\d+[.)、]\s*/, "").trim())
      .filter((item) => item && item !== "無" && item !== "目前無" && item !== "無需跳過");
  }

  function extractPriorityTitles(section = "") {
    const lines = normalizeSectionLines(section);
    return lines
      .filter((line) => /第\s*\d+\s*優先/i.test(line))
      .map((line) => line.replace(/^第\s*\d+\s*優先[:：]\s*/i, "").trim())
      .filter(Boolean);
  }

  function parseArticleTopicDecision(content, mode = currentTopicMode, question = articleSourceQuestion) {
    const summary = extractSectionText(content, "決策摘要") || extractSectionText(content, "決題摘要");
    const mergeDecision = extractSectionText(content, "整併池判定");
    const sameMissionSection = extractSectionText(content, "同任務檢查");
    const prioritySection = extractSectionText(content, "剩餘優先文章");
    const picked = extractSectionText(content, "本輪採用題目") || extractSectionText(content, "採用候選");
    const decision = extractSectionText(content, "落位決策");
    const note = extractSectionText(content, "保留說明");
    const candidateIndex = Number.parseInt(extractFieldValueFromText(picked, ["候選編號"]), 10);
    const modeState = getCurrentTopicModeState(mode);
    const noteLines = normalizeSectionLines(note);
    const mergePool = splitTopicDecisionList(extractFieldValueFromText(mergeDecision, ["正式入池"]));
    const assetMergePool = splitTopicDecisionList(extractFieldValueFromText(mergeDecision, ["資產整併"]));
    const skippedTitles = splitTopicDecisionList(extractFieldValueFromText(mergeDecision, ["跳過優先序的文章"]));
    const deferredMergeTitles = splitTopicDecisionList(extractFieldValueFromText(mergeDecision, ["暫不入池"]));
    const remainingPriorityArticles = extractPriorityTitles(prioritySection);

    const parsed = {
      question,
      mode,
      modeLabel: extractFieldValueFromText(picked, ["決題模式"]) || modeState?.label || mode,
      finalAction: extractFieldValueFromText(picked, ["最終動作"]) || "New_Publish",
      candidateIndex: Number.isFinite(candidateIndex) ? candidateIndex : 0,
      summary: summary || "已完成本題動態決題。",
      mergePool,
      assetMergePool,
      skippedTitles,
      deferredMergeTitles,
      mergeReason: extractFieldValueFromText(mergeDecision, ["判定理由"]),
      topCandidateTitle: extractFieldValueFromText(sameMissionSection, ["Top 1 候選"]),
      sameMissionVerdict: extractFieldValueFromText(sameMissionSection, ["同任務判定"]),
      noMergeReason: extractFieldValueFromText(sameMissionSection, ["不進整併池理由"]),
      assetMergeTarget: extractFieldValueFromText(sameMissionSection, ["資產掛載建議"]),
      remainingPriorityArticles,
      track: extractFieldValueFromText(decision, ["主書系"]),
      chapter: extractFieldValueFromText(decision, ["章節"]),
      subchapter: extractFieldValueFromText(decision, ["子章節"]),
      title: extractFieldValueFromText(decision, ["建議標題"]),
      reason: extractFieldValueFromText(decision, ["決策理由"]),
      questionLink: extractFieldValueFromText(note, ["問題連結"]) || noteLines[0] || "",
      bookLink: extractFieldValueFromText(note, ["書稿連結"]) || noteLines[1] || "",
    };

    if (!parsed.track || !parsed.chapter || !parsed.subchapter || !parsed.title) {
      return null;
    }

    if (shouldEnforceOldHouseIsolation(mode)) {
      const conflictKeyword = hasCrossSeriesConflict(
        parsed.track,
        parsed.chapter,
        parsed.subchapter,
        parsed.title,
        parsed.reason,
        question,
      );
      if (conflictKeyword) {
        return getOldHouseFallbackTopicDecision(mode, question, conflictKeyword);
      }
    }

    return parsed;
  }

  function getPublishingChecklistEntryKey(trackTitle = "", chapterTitle = "", subchapterTitle = "") {
    return [trackTitle, chapterTitle, subchapterTitle].join("::");
  }

  function loadPublishingChecklist() {
    try {
      const raw = localStorage.getItem(PUBLISHING_CHECKLIST_KEY);
      publishingChecklistOverrides = raw ? JSON.parse(raw) : {};
    } catch (error) {
      console.error("讀取出版清單失敗：", error);
      publishingChecklistOverrides = {};
    }
  }

  function savePublishingChecklist() {
    localStorage.setItem(PUBLISHING_CHECKLIST_KEY, JSON.stringify(publishingChecklistOverrides));
  }

  function getPublishingChecklistChecked(trackTitle = "", chapterTitle = "", subchapterTitle = "", coveredByArticle = false) {
    const key = getPublishingChecklistEntryKey(trackTitle, chapterTitle, subchapterTitle);
    if (Object.prototype.hasOwnProperty.call(publishingChecklistOverrides, key)) {
      return Boolean(publishingChecklistOverrides[key]);
    }
    return coveredByArticle;
  }

  function renderPublishingChecklist() {
    document.querySelectorAll("[data-publishing-subchapter-item]").forEach((node) => {
      if (!(node instanceof HTMLElement)) return;
      const trackTitle = node.dataset.trackTitle || "";
      const chapterTitle = node.dataset.chapterTitle || "";
      const subchapterTitle = node.dataset.subchapterTitle || "";
      const coveredByArticle = node.dataset.coveredByArticle === "true";
      const checkbox = node.querySelector("[data-publishing-subchapter-checkbox]");
      const status = node.querySelector("[data-publishing-subchapter-status]");
      if (!(checkbox instanceof HTMLInputElement) || !(status instanceof HTMLElement)) return;

      const checked = getPublishingChecklistChecked(trackTitle, chapterTitle, subchapterTitle, coveredByArticle);
      checkbox.checked = checked;
      node.classList.toggle("is-checked", checked);
      node.classList.toggle("is-covered", coveredByArticle);
      node.classList.toggle("is-manual", checked && !coveredByArticle);
      node.classList.toggle("is-withheld", !checked && coveredByArticle);
      status.textContent = checked
        ? (coveredByArticle ? "已收書" : "人工納入")
        : (coveredByArticle ? "有文未收" : "待補");
    });

    document.querySelectorAll("[data-publishing-chapter-progress]").forEach((node) => {
      if (!(node instanceof HTMLElement)) return;
      const chapterTitle = node.dataset.publishingChapterProgress || "";
      const chapterCard = node.closest(".bookshelf-publishing-checklist-card");
      if (!(chapterCard instanceof HTMLElement)) return;
      const checkboxes = [...chapterCard.querySelectorAll("[data-publishing-subchapter-checkbox]")].filter(
        (input) => input instanceof HTMLInputElement,
      );
      const checkedCount = checkboxes.filter((input) => input.checked).length;
      node.textContent = `已勾 ${checkedCount} / ${checkboxes.length}`;
      if (chapterTitle) {
        chapterCard.classList.toggle("is-ready", checkedCount === checkboxes.length);
      }
    });
  }

  function normalizeComparableText(value = "") {
    return String(value).replace(/\s+/g, "").trim().toLowerCase();
  }

  function formatRelatedArticleList(entries = [], limit = 5) {
    if (!entries.length) return "（目前沒有明確可參考的既有文章）";
    return entries
      .slice(0, limit)
      .map((entry, index) => `${index + 1}. ${entry.title}｜${entry.chapter}${entry.subchapter ? ` > ${entry.subchapter}` : ""}｜${entry.category}`)
      .join("\n");
  }

  function buildProRelatedArticleContext(confirmData, aiDraftBlock = "") {
    const resolvedTrack = confirmData.track || findTrackFromText(aiDraftBlock) || "老屋翻新系";
    const resolvedChapter = confirmData.chapter || inferChapterFromTrack(resolvedTrack, confirmData.title, aiDraftBlock);
    const resolvedSubchapter = inferSubchapterFromTrack(resolvedTrack, resolvedChapter, confirmData.title, aiDraftBlock);
    const normalizedTitle = normalizeComparableText(confirmData.title);

    const sameTrackEntries = bookshelfEntries.filter((entry) =>
      entry.trackTitle === resolvedTrack &&
      (!normalizedTitle || normalizeComparableText(entry.title) !== normalizedTitle),
    );

    const sameChapterEntries = sameTrackEntries.filter((entry) => entry.chapter === resolvedChapter);
    const sameSubchapterEntries = sameChapterEntries.filter((entry) => entry.subchapter === resolvedSubchapter);
    const neighboringChapterEntries = sameTrackEntries.filter((entry) => entry.chapter !== resolvedChapter);

    return [
      "【同書系既有文章脈絡】",
      `主書系：${resolvedTrack || "尚未判定"}`,
      `章節定位：${resolvedChapter || "尚未判定"}`,
      `子章節定位：${resolvedSubchapter || "待 AI 補位"}`,
      `同書系既有文章數：${sameTrackEntries.length} 篇`,
      `同章既有文章數：${sameChapterEntries.length} 篇`,
      `同子章既有文章數：${sameSubchapterEntries.length} 篇`,
      "",
      "同子章既有文章：",
      formatRelatedArticleList(sameSubchapterEntries, 4),
      "",
      "同章既有文章：",
      formatRelatedArticleList(sameChapterEntries, 5),
      "",
      "同書系其他文章：",
      formatRelatedArticleList(neighboringChapterEntries, 6),
    ].join("\n");
  }

  function buildProGapContext(confirmData, aiDraftBlock = "") {
    const resolvedTrack = confirmData.track || findTrackFromText(aiDraftBlock) || "老屋翻新系";
    const resolvedChapter = confirmData.chapter || inferChapterFromTrack(resolvedTrack, confirmData.title, aiDraftBlock);
    const resolvedSubchapter = inferSubchapterFromTrack(resolvedTrack, resolvedChapter, confirmData.title, aiDraftBlock);
    const trackChapters = getTrackChapters(resolvedTrack);
    const sameTrackEntries = bookshelfEntries.filter((entry) => entry.trackTitle === resolvedTrack);
    const sameChapterEntries = sameTrackEntries.filter((entry) => entry.chapter === resolvedChapter);
    const sameSubchapterEntries = sameChapterEntries.filter((entry) => entry.subchapter === resolvedSubchapter);
    const missingChapters = trackChapters.filter((chapter) => !sameTrackEntries.some((entry) => entry.chapter === chapter));
    const chapterSubchapters = getTrackSubchapters(resolvedTrack, resolvedChapter);
    const missingSubchapters = chapterSubchapters.filter((subchapter) => !sameChapterEntries.some((entry) => entry.subchapter === subchapter));
    const chapterGapHint = sameChapterEntries.length === 0
      ? "這一章目前仍是空章，請優先寫成能直接立住章節的主文。"
      : sameChapterEntries.length === 1
        ? "這一章目前只有 1 篇，請優先補成更完整的章節骨架。"
        : "這一章已有基本內容，請優先補足不同情境、不同預算或不同決策切角。";
    const subchapterGapHint = sameSubchapterEntries.length === 0
      ? "這個子章節目前還沒有文章，請優先補成能站得住的第一篇。"
      : sameSubchapterEntries.length === 1
        ? "這個子章節目前只有 1 篇，可再補一篇互補角度。"
        : "這個子章節已有基本文章，可優先補不同情境或不同決策切角。";

    return [
      "【本章缺稿方向】",
      `主書系總篇數：${sameTrackEntries.length} 篇`,
      `本章現有篇數：${sameChapterEntries.length} 篇`,
      `子章節定位：${resolvedSubchapter || "待 AI 補位"}`,
      `本子章現有篇數：${sameSubchapterEntries.length} 篇`,
      `本章補位判斷：${chapterGapHint}`,
      `本子章補位判斷：${subchapterGapHint}`,
      `整本目前待補章：${missingChapters.slice(0, 3).join(" / ") || "主幹已具雛形"}`,
      `本章目前待補子章：${missingSubchapters.slice(0, 3).join(" / ") || "子章主幹已具雛形"}`,
      "寫作要求：請優先補強這一章目前最缺的判斷邏輯、情境分支、預算差異、施工順序或常見誤區，而不是重述已存在文章。",
    ].join("\n");
  }

