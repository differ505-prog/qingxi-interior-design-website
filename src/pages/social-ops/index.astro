  async function enrichArticleMetadataIfNeeded(content, sourceMode) {
    if (!needsArticleMetadataFallback(content)) {
      return content;
    }

    setArticleAiFeedback(
      "第 2 步進行中：正在補齊主書系、章節與標題...",
      "is-success",
    );

    const metadataContent = await requestArticleAi("metadata", content);
    if (!metadataContent) {
      setArticleAiFeedback(
        sourceMode === "full"
          ? "初稿已生成，但主書系、章節與標題補齊未完成，已保留目前結果。"
          : "判題已完成，但主書系、章節與標題補齊未完成，已保留目前結果。",
        "is-warning",
      );
      return content;
    }

    setArticleAiFeedback("主書系、章節與標題已補齊，正在整理結果...", "is-success");
    return mergeArticleAiContent(content, metadataContent);
  }

  async function runArticleAi(mode) {
    setArticleAiBusy(true);
    setArticleAiFeedback(mode === "quick" ? "Gemini Flash 判題中..." : "Gemini Flash 長稿備援生成中...");

    try {
      await ensureArticleTopicDecision(currentTopicMode);
      const content = await requestArticleAi(mode);
      if (!content) return false;
      articleAiResult = await enrichArticleMetadataIfNeeded(content, mode);
      articleAiMode = mode;
      clearArticleProFinalizePrompt();
      setArticleAiFeedback("結果整理完成，正在寫入工作台...", "is-success");
      const saved = saveArticleAiResult();
      renderArticleAiResult();
      const successMessage = mode === "quick" ? "已完成 AI 快速判題與社團回覆稿整理。" : "已完成 Flash 長稿備援生成。";
      const finalMessage = saved ? successMessage : `${successMessage} 但本機暫存寫入失敗。`;
      setFeedback(finalMessage, saved ? "is-success" : "is-warning");
      setArticleAiFeedback(finalMessage, saved ? "is-success" : "is-warning");
      return true;
    } catch (error) {
      console.error("Gemini Flash 結果整理失敗：", error);
      const errorMessage = mode === "quick"
        ? "判題已完成，但整理結果時發生問題，請重試一次。"
        : "長稿已生成，但整理結果時發生問題，請重試一次。";
      setFeedback(errorMessage, "is-warning");
      setArticleAiFeedback(errorMessage, "is-warning");
      return false;
    } finally {
      setArticleAiBusy(false);
    }
  }

  async function runArticleAiFlow() {
    setArticleAiBusy(true);
    setArticleAiFeedback("一鍵流程啟動中：先做本題動態決題，再判題並備好 Pro 生文提示詞...", "is-success");

    try {
      await ensureArticleTopicDecision(currentTopicMode);
      const quickContent = await requestArticleAi("quick");
      if (!quickContent) return;

      articleAiResult = await enrichArticleMetadataIfNeeded(quickContent, "quick");
      articleAiMode = "quick";
      clearArticleProFinalizePrompt();
      setArticleAiFeedback("結果整理完成，正在寫入工作台...", "is-success");
      const saved = saveArticleAiResult();
      renderArticleAiResult();

      const question = persistArticleSourceQuestion();
      setArticleAiFeedback("結果已整理，正在備好 Pro 生文提示詞...", "is-success");
      const promptState = prepareProFinalizePrompt(question);
      const storageOk = saved && promptState.saved;
      setArticleAiFeedback(
        promptState.usedFallback ? "Pro 生文提示詞已用穩定版備好，正在嘗試自動複製..." : "Pro 生文提示詞已備好，正在嘗試自動複製...",
        storageOk ? "is-success" : "is-warning",
      );
      const copyState = await copyText(promptState.prompt, "已完成判題並複製 Pro 生文提示詞。", {
        fallbackToPrompt: false,
      });
      if (copyState === "clipboard") {
        const finalMessage = promptState.usedFallback
          ? (storageOk ? "已完成判題並複製 Pro 生文提示詞（穩定版）。" : "已完成判題並複製 Pro 生文提示詞（穩定版），但本機暫存寫入失敗。")
          : saved
            ? (promptState.saved ? "已完成判題並複製 Pro 生文提示詞。" : "已完成判題並複製 Pro 生文提示詞，但 Pro 提示詞本機暫存寫入失敗。")
            : "已完成判題並複製 Pro 生文提示詞，但本機暫存寫入失敗。";
        setFeedback(finalMessage, storageOk ? "is-success" : "is-warning");
        setArticleAiFeedback(finalMessage, storageOk ? "is-success" : "is-warning");
      } else {
        revealArticleProPrompt();
        spotlightActionButton("copy-pro-finalize-prompt");
        spotlightActionButton("copy-pro-finalize-prompt-inline");
        const fallbackMessage = promptState.usedFallback
          ? (storageOk
            ? "已完成判題，並已改用穩定版 Pro 生文提示詞；瀏覽器未完成自動複製，可直接展開下方內容手動複製。"
            : "已完成判題，並已改用穩定版 Pro 生文提示詞；本機暫存或自動複製未完成，但頁面仍可直接展開下方內容手動複製。")
          : storageOk
            ? "已完成判題，Pro 生文提示詞也已備好，但瀏覽器未完成自動複製；可直接展開下方內容手動複製，或再按一次「複製 Pro 生文提示詞」。"
            : "已完成判題，Pro 生文提示詞也已備好，但本機暫存或自動複製未完成；目前頁面仍可直接展開下方內容手動複製。";
        setFeedback(fallbackMessage, "is-warning");
        setArticleAiFeedback(fallbackMessage, "is-warning");
      }
    } catch (error) {
      console.error("一鍵流程整理失敗：", error);
      if (articleProFinalizePrompt.trim()) {
        renderArticleProPrompt();
        revealArticleProPrompt();
        spotlightActionButton("copy-pro-finalize-prompt");
        spotlightActionButton("copy-pro-finalize-prompt-inline");
        setFeedback("判題已完成，Pro 生文提示詞也已備好，但後續流程中斷；可直接展開下方內容手動複製。", "is-warning");
        setArticleAiFeedback("判題已完成，Pro 生文提示詞也已備好，但後續流程中斷；可直接展開下方內容手動複製。", "is-warning");
        return;
      }
      setFeedback("判題已完成，但備好 Pro 生文提示詞時發生問題，請重試一次。", "is-warning");
      setArticleAiFeedback("判題已完成，但備好 Pro 生文提示詞時發生問題，請重試一次。", "is-warning");
    } finally {
      setArticleAiBusy(false);
    }
  }

  async function copyText(text, successMessage, options = {}) {
    const {
      fallbackToPrompt = true,
      manualFallbackMessage = "已開啟手動複製視窗。",
      failureMessage = "複製失敗，請再試一次。",
    } = options;

    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
        setFeedback(successMessage, "is-success");
        return "clipboard";
      }
    } catch (error) {
      console.error("自動複製失敗：", error);
    }

    if (fallbackToPrompt) {
      try {
        window.prompt("請手動複製以下內容", text);
        setFeedback(manualFallbackMessage, "is-warning");
        return "manual";
      } catch (error) {
        console.error("手動複製視窗開啟失敗：", error);
      }
    }

    if (failureMessage) {
      setFeedback(failureMessage, "is-warning");
    }
    return "failed";
  }

  function createGeminiDraftFromMaster() {
    return {
      title: geminiCanvasMasterData.title,
      sourceUrl: geminiCanvasMasterData.sourceUrl,
      content: geminiCanvasMasterData.content,
    };
  }

  function normalizeGeminiBackups(backups = []) {
    if (!Array.isArray(backups)) return [];

    return backups
      .filter(Boolean)
      .map((backup) => ({
        id: backup.id || `gemini-backup-${Date.now()}-${Math.random().toString(16).slice(2)}`,
        title: backup.title || geminiCanvasMasterData.title,
        sourceUrl: backup.sourceUrl || geminiCanvasMasterData.sourceUrl,
        content: backup.content || "",
        savedAt: backup.savedAt || new Date().toISOString(),
        isPinned: Boolean(backup.isPinned),
      }))
      .sort((a, b) => new Date(b.savedAt).getTime() - new Date(a.savedAt).getTime());
  }

  function trimGeminiBackups(backups = geminiBackups) {
    return normalizeGeminiBackups(backups).slice(0, GEMINI_RECENT_LIMIT);
  }

  function getGeminiFieldElements() {
    return {
      title: document.getElementById("gemini-title"),
      sourceUrl: document.getElementById("gemini-source-url"),
      content: document.getElementById("gemini-content"),
    };
  }

  function readGeminiDraftFromFields() {
    const { title, sourceUrl, content } = getGeminiFieldElements();
    if (!(title instanceof HTMLInputElement) || !(sourceUrl instanceof HTMLInputElement) || !(content instanceof HTMLTextAreaElement)) {
      return null;
    }

    return {
      title: title.value.trim() || geminiCanvasMasterData.title,
      sourceUrl: sourceUrl.value.trim() || geminiCanvasMasterData.sourceUrl,
      content: content.value.trim(),
    };
  }

  function applyGeminiDraftToFields() {
    const { title, sourceUrl, content } = getGeminiFieldElements();
    if (!(title instanceof HTMLInputElement) || !(sourceUrl instanceof HTMLInputElement) || !(content instanceof HTMLTextAreaElement)) {
      return;
    }

    title.value = geminiDraft?.title || "";
    sourceUrl.value = geminiDraft?.sourceUrl || "";
    content.value = geminiDraft?.content || "";
  }

  function persistGeminiDraftFromFields() {
    const nextDraft = readGeminiDraftFromFields();
    if (!nextDraft) return null;
    geminiDraft = nextDraft;
    localStorage.setItem(GEMINI_DRAFT_KEY, JSON.stringify(geminiDraft));
    return geminiDraft;
  }

  function resetGeminiDraftContentForNewSource() {
    const { content } = getGeminiFieldElements();
    if (!(content instanceof HTMLTextAreaElement)) return;
    content.value = "";
    persistGeminiDraftFromFields();
    setFeedback("已偵測到新的 Gemini 分享網址，先清空舊內容，請貼上新版本後再備份。", "is-warning");
    setGeminiFeedback("已換成新網址；請同步貼上新的 Gemini Canvas 內容後再備份。", "is-warning");
  }

  function applyImportedGeminiShare(payload) {
    const { title, sourceUrl, content } = getGeminiFieldElements();
    if (!(title instanceof HTMLInputElement) || !(sourceUrl instanceof HTMLInputElement) || !(content instanceof HTMLTextAreaElement)) {
      return false;
    }

    title.value = typeof payload?.title === "string" ? payload.title.trim() : "";
    sourceUrl.value = typeof payload?.sourceUrl === "string" ? payload.sourceUrl.trim() : "";
    content.value = typeof payload?.content === "string" ? payload.content.trim() : "";
    persistGeminiDraftFromFields();
    return true;
  }

  async function importGeminiShareFromUrl(options = {}) {
    const {
      silent = false,
      sourceUrl = "",
    } = options;
    const { sourceUrl: sourceUrlField } = getGeminiFieldElements();
    const rawUrl = sourceUrl || (sourceUrlField instanceof HTMLInputElement ? sourceUrlField.value.trim() : "");
    if (!rawUrl) {
      if (!silent) {
        setFeedback("請先貼上 Gemini 分享網址。", "is-warning");
        setGeminiFeedback("請先貼上 Gemini 分享網址。", "is-warning");
      }
      return null;
    }

    try {
      if (!silent) {
        setGeminiFeedback("正在從 Gemini 分享網址載入內容...", "is-success");
      }
      const response = await fetch("/api/social-ops/gemini-share", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ url: rawUrl }),
      });
      const result = await response.json();
      if (!response.ok) {
        const errorMessage = result?.error === "TARGET_NOT_ALLOWED"
          ? "目前只支援匯入 Gemini 分享網址。"
          : result?.error === "INVALID_URL"
            ? "請貼上有效的 Gemini 分享網址。"
            : result?.error === "EMPTY_CONTENT"
              ? "這個 Gemini 分享網址目前沒有可匯入的內容。"
              : "Gemini 分享內容暫時無法載入，請稍後再試。";
        if (!silent) {
          setFeedback(errorMessage, "is-warning");
          setGeminiFeedback(errorMessage, "is-warning");
        }
        return null;
      }

      const applied = applyImportedGeminiShare(result);
      if (!applied) return null;
      if (!silent) {
        setFeedback("已從 Gemini 分享網址載入最新內容。", "is-success");
        setGeminiFeedback("已從 Gemini 分享網址載入最新內容。", "is-success");
      }
      return result;
    } catch (error) {
      console.error("載入 Gemini 分享內容失敗：", error);
      if (!silent) {
        setFeedback("Gemini 分享內容載入失敗，請稍後再試。", "is-warning");
        setGeminiFeedback("Gemini 分享內容載入失敗，請稍後再試。", "is-warning");
      }
      return null;
    }
  }

  function loadGeminiBackupState() {
    try {
      const savedDraft = localStorage.getItem(GEMINI_DRAFT_KEY);
      geminiDraft = savedDraft ? JSON.parse(savedDraft) : createGeminiDraftFromMaster();
    } catch (error) {
      console.error("讀取 Gemini 草稿失敗：", error);
      geminiDraft = createGeminiDraftFromMaster();
    }

    try {
      const savedBackups = localStorage.getItem(GEMINI_BACKUPS_KEY);
      geminiBackups = trimGeminiBackups(savedBackups ? JSON.parse(savedBackups) : []);
    } catch (error) {
      console.error("讀取 Gemini 備份失敗：", error);
      geminiBackups = [];
    }
  }

  function saveGeminiBackups() {
    localStorage.setItem(GEMINI_BACKUPS_KEY, JSON.stringify(geminiBackups));
  }

  function formatTimestamp(value) {
    if (!value) return "未記錄";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;
    return new Intl.DateTimeFormat("zh-TW", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
    }).format(date);
  }

  function buildGeminiBackupMarkdown(payload) {
    return [
      `# ${payload.title || geminiCanvasMasterData.title}`,
      "",
      `- 備份時間：${formatTimestamp(payload.savedAt || new Date().toISOString())}`,
      `- 來源網址：${payload.sourceUrl || "未填寫"}`,
      "",
      "## 內容",
      "",
      payload.content || "",
      "",
    ].join("\n");
  }

  function downloadTextFile(fileName, text, mimeType = "text/plain;charset=utf-8") {
    const blob = new Blob([text], { type: mimeType });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = fileName;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  }

  function buildGeminiBackupPayload() {
    const draft = persistGeminiDraftFromFields();
    if (!draft?.content) {
      setFeedback("請先貼上 Gemini Canvas 內容，再建立備份。", "is-warning");
      setGeminiFeedback("請先貼上 Gemini Canvas 內容，再建立備份。", "is-warning");
      return null;
    }

    return {
      id: `gemini-backup-${Date.now()}-${Math.random().toString(16).slice(2, 8)}`,
      title: draft.title,
      sourceUrl: draft.sourceUrl,
      content: draft.content,
      savedAt: new Date().toISOString(),
    };
  }

  function getGeminiVersionEntries() {
    if (geminiBackups.length) return geminiBackups;

    return [{
      id: "gemini-master-version",
      title: geminiCanvasMasterData.title,
      sourceUrl: geminiCanvasMasterData.sourceUrl,
      content: geminiCanvasMasterData.content,
      savedAt: geminiCanvasMasterData.updatedAt,
      isMaster: true,
    }];
  }

  function findGeminiBackupById(backupId) {
    return getGeminiVersionEntries().find((backup) => backup.id === backupId) || null;
  }

  function renderGeminiHistory() {
    const historyShell = document.getElementById("gemini-history-list");
    const historyCount = document.getElementById("gemini-history-count");
    if (!historyShell || !historyCount) return;

    const versions = getGeminiVersionEntries();
    historyCount.textContent = `${versions.length} 版`;

    historyShell.innerHTML = versions
      .map((backup) => `
        <details class="gemini-version-item">
          <summary class="gemini-version-summary">
            <strong>${escapeHtml(formatTimestamp(backup.savedAt))}</strong>
          </summary>
          <div class="gemini-version-body">
            <div class="gemini-version-meta">
              <p>${escapeHtml(backup.title || "未命名備份")}</p>
              <small>${escapeHtml(backup.sourceUrl || "未填寫來源網址")}</small>
            </div>
            <div class="gemini-history-actions">
              <button type="button" class="history-action-btn" data-backup-action="restore" data-backup-id="${escapeHtml(backup.id)}">${backup.isMaster ? "載入主檔" : "載入這版"}</button>
              <button type="button" class="history-action-btn" data-backup-action="copy" data-backup-id="${escapeHtml(backup.id)}">複製 Markdown</button>
            </div>
            <pre class="gemini-preview-content">${escapeHtml(backup.content || "")}</pre>
          </div>
        </details>
      `)
      .join("");
  }

