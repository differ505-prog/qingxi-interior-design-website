  function prepareProFinalizePrompt(question = "") {
    const resolvedQuestion = question || articleSourceQuestion;
    let usedFallback = false;

    try {
      try {
        articleProFinalizePrompt = buildProFinalizePrompt(resolvedQuestion, articleAiResult);
      } catch (error) {
        console.error("完整 Pro 生文提示詞生成失敗，改用穩定版：", error);
        articleProFinalizePrompt = buildBasicProFinalizePrompt(resolvedQuestion, articleAiResult);
        usedFallback = true;
      }

      if (!articleProFinalizePrompt.trim()) {
        articleProFinalizePrompt = buildBasicProFinalizePrompt(resolvedQuestion, articleAiResult);
        usedFallback = true;
      }
    } catch (error) {
      console.error("穩定版 Pro 生文提示詞生成失敗，改用緊急保底版：", error);
      articleProFinalizePrompt = buildEmergencyProFinalizePrompt(resolvedQuestion, articleAiResult);
      usedFallback = true;
    }

    const saved = saveArticleProFinalizePrompt();
    renderArticleProPrompt();
    return {
      prompt: articleProFinalizePrompt,
      saved,
      hasAiResult: Boolean(articleAiResult.trim()),
      usedFallback,
    };
  }

  function getCopyFeedbackState(result, successMessage, manualMessage, failureMessage = "複製失敗，請直接手動複製。") {
    if (result === "clipboard") {
      return { message: successMessage, mode: "is-success" };
    }
    if (result === "manual") {
      return { message: manualMessage, mode: "is-warning" };
    }
    return { message: failureMessage, mode: "is-warning" };
  }

