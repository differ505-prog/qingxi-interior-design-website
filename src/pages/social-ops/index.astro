<script is:inline define:vars={{ defaultSourcesJson, blogPostsJson, bookshelfTracksJson, bookshelfSubchapterPoolsJson, geminiCanvasMasterJson, vendorTradeOptionsJson, topicModeOptionsJson, topicModeMapJson }}>
  const STORAGE_KEY = "qingxi-social-ops-v2";
  const ARTICLE_SOURCE_QUESTION_KEY = "qingxi-article-source-question-v1";
  const ARTICLE_TOPIC_DECISION_KEY = "qingxi-article-topic-decision-v1";
  const ARTICLE_AI_RESULT_KEY = "qingxi-article-ai-result-v1";
  const ARTICLE_PRO_FINALIZE_PROMPT_KEY = "qingxi-article-pro-finalize-prompt-v1";
  const GEMINI_DRAFT_KEY = "qingxi-gemini-canvas-draft-v1";
  const GEMINI_BACKUPS_KEY = "qingxi-gemini-canvas-backups-v1";
  const PUBLISHING_CHECKLIST_KEY = "qingxi-publishing-checklist-v1";
  const TOPIC_MODE_KEY = "qingxi-topic-mode-v1";
  const GEMINI_RECENT_LIMIT = 10;
  const WEEKLY_TARGET = 3;
  const RUN_XP = 100;
  const WEEKLY_BONUS_XP = 50;
  const SITE_ORIGIN = "https://qingxidesign.tw";
  const BLOG_INDEX_URL = `${SITE_ORIGIN}/blog`;
  const THREADS_PROFILE_URL = "https://www.threads.com/@qingxi.ds?hl=zh-tw";
  const INSTAGRAM_PROFILE_URL = "https://www.instagram.com/qingxi.ds/";
  const FACEBOOK_PAGE_URL = "https://www.facebook.com/profile.php?id=61562661642204";
  const ARTICLE_AI_TIMEOUT_MS = 45000;
  const ARTICLE_AI_METADATA_TIMEOUT_MS = 18000;
  const CONTENT_ANALYTICS_URL = "/api/social-ops/analytics";
  const VENDOR_NOTES_API_URL = "/api/social-ops/vendor-notes";
  const socialReplyShortUrlCache = new Map();
  const sourceTemplate = JSON.parse(defaultSourcesJson);
  const articleLibrary = JSON.parse(blogPostsJson);
  const bookshelfTracks = JSON.parse(bookshelfTracksJson);
  const bookshelfSubchapterPools = JSON.parse(bookshelfSubchapterPoolsJson);
  const geminiCanvasMasterData = JSON.parse(geminiCanvasMasterJson);
  const vendorTradeOptions = JSON.parse(vendorTradeOptionsJson);
  const topicModeOptions = JSON.parse(topicModeOptionsJson);
  const topicModeDataMap = topicModeMapJson ? JSON.parse(topicModeMapJson) : {};
  const articleIntakeFields = [
    "主書系",
    "章節定位",
    "網站分類",
    "搜尋主關鍵字",
    "相似舊文",
    "處理策略",
    "社團回覆角度",
    "導流目的",
    "下一篇延伸題目",
  ];
  const siteCategoryOptions = [
    "老屋翻新",
    "預售屋客變",
    "驗屋交屋",
    "格局動線",
    "水電照明",
    "裝修預算",
    "收納機能",
    "材質設備",
    "智能家居",
  ];
  const overlapRules = [
    {
      title: "同核心問題",
      detail: "若主判斷與既有文章相同，優先補強舊文，不重開新標題。",
    },
    {
      title: "同主題不同角度",
      detail: "若情境、預算、屋況或族群不同，可做同章延伸文，互相內鏈。",
    },
    {
      title: "可併成系列",
      detail: "若同一主書系下可串成前後篇，改做系列文，不做彼此搶重點的散文。",
    },
  ];
  const rankTitles = [
    "起稿中",
    "構圖中",
    "提案中",
    "執行中",
    "定稿中",
    "主理中",
  ];
  let articleSourceQuestion = "";
  let articleTopicDecision = null;
  let articleAiResult = "";
  let articleAiMode = "";
  let articleProFinalizePrompt = "";
  let geminiDraft = null;
  let geminiBackups = [];
  let publishingChecklistOverrides = {};
  let currentTopicMode = topicModeOptions?.[0]?.value || "publishing";
  let vendorNoteEditingId = "";
  let vendorNoteSearch = "";
  let vendorNoteTradeFilter = "";
  let vendorNoteSort = "default";
  let contentAnalyticsState = {
    status: "idle",
    configured: false,
    rangeLabel: "近 7 天",
    updatedAt: "",
    metrics: {
      blogViews: 0,
      estimateGenerated: 0,
      estimateCtaClick: 0,
      officialLineClick: 0,
      requirementSubmit: 0,
      requirementSuccess: 0,
    },
    latestOfficialLineClickAt: "",
    topPosts: [],
    note: "",
  };
  let vendorNotesState = {
    status: "idle",
    configured: false,
    items: [],
    note: "",
  };

  function createVendorNoteId() {
    return `vendor-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
  }

  function createVendorNoteTemplate() {
    return {
      id: "",
      name: "",
      trade: "",
      priceLevel: "",
      craftLevel: "",
      primaryUrl: "",
      secondaryUrl: "",
      location: "",
      impression: "",
      memo: "",
      isPinned: false,
      createdAt: "",
      updatedAt: "",
    };
  }

  function setVendorNoteFeedback(message, mode = "") {
    const shell = document.getElementById("vendor-note-feedback");
    if (!(shell instanceof HTMLElement)) return;
    shell.className = `vendor-note-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function getVendorNoteFormFields() {
    return {
      name: document.getElementById("vendor-note-name"),
      trade: document.getElementById("vendor-note-trade"),
      priceLevel: document.getElementById("vendor-note-price-level"),
      craftLevel: document.getElementById("vendor-note-craft-level"),
      primaryUrl: document.getElementById("vendor-note-primary-url"),
      secondaryUrl: document.getElementById("vendor-note-secondary-url"),
      location: document.getElementById("vendor-note-location"),
      impression: document.getElementById("vendor-note-impression"),
      memo: document.getElementById("vendor-note-memo"),
      extras: document.getElementById("vendor-note-extra-fields"),
      mode: document.getElementById("vendor-note-form-mode"),
      save: document.getElementById("save-vendor-note"),
    };
  }

  function readVendorNoteForm() {
    const fields = getVendorNoteFormFields();
    return {
      id: vendorNoteEditingId,
      name: fields.name instanceof HTMLInputElement ? fields.name.value.trim() : "",
      trade: fields.trade instanceof HTMLSelectElement ? fields.trade.value.trim() : "",
      priceLevel: fields.priceLevel instanceof HTMLSelectElement ? fields.priceLevel.value.trim() : "",
      craftLevel: fields.craftLevel instanceof HTMLSelectElement ? fields.craftLevel.value.trim() : "",
      primaryUrl: fields.primaryUrl instanceof HTMLInputElement ? normalizeLinkValue(fields.primaryUrl.value) : "",
      secondaryUrl: fields.secondaryUrl instanceof HTMLInputElement ? normalizeLinkValue(fields.secondaryUrl.value) : "",
      location: fields.location instanceof HTMLInputElement ? fields.location.value.trim() : "",
      impression: fields.impression instanceof HTMLInputElement ? fields.impression.value.trim() : "",
      memo: fields.memo instanceof HTMLTextAreaElement ? fields.memo.value.trim() : "",
    };
  }

  function applyVendorNoteToForm(note = createVendorNoteTemplate()) {
    const fields = getVendorNoteFormFields();
    vendorNoteEditingId = note.id || "";
    if (fields.name instanceof HTMLInputElement) fields.name.value = note.name || "";
    if (fields.trade instanceof HTMLSelectElement) fields.trade.value = note.trade || "";
    if (fields.priceLevel instanceof HTMLSelectElement) fields.priceLevel.value = note.priceLevel || "";
    if (fields.craftLevel instanceof HTMLSelectElement) fields.craftLevel.value = note.craftLevel || "";
    if (fields.primaryUrl instanceof HTMLInputElement) fields.primaryUrl.value = note.primaryUrl || "";
    if (fields.secondaryUrl instanceof HTMLInputElement) fields.secondaryUrl.value = note.secondaryUrl || "";
    if (fields.location instanceof HTMLInputElement) fields.location.value = note.location || "";
    if (fields.impression instanceof HTMLInputElement) fields.impression.value = note.impression || "";
    if (fields.memo instanceof HTMLTextAreaElement) fields.memo.value = note.memo || "";
    if (fields.extras instanceof HTMLDetailsElement) {
      fields.extras.open = Boolean(note.secondaryUrl || note.location || note.memo);
    }
    if (fields.mode instanceof HTMLElement) {
      fields.mode.textContent = vendorNoteEditingId ? "編輯模式" : "新增模式";
    }
    if (fields.save instanceof HTMLButtonElement) {
      fields.save.textContent = vendorNoteEditingId ? "更新筆記" : "儲存筆記";
    }
  }

  function resetVendorNoteForm() {
    applyVendorNoteToForm(createVendorNoteTemplate());
  }

  function sortVendorNotes(notes = []) {
    const priceRank = {
      低: 1,
      中低: 2,
      中: 3,
      中高: 4,
      高: 5,
    };
    return [...notes].sort((left, right) => {
      const rightTime = new Date(right.updatedAt || right.createdAt || 0).getTime();
      const leftTime = new Date(left.updatedAt || left.createdAt || 0).getTime();
      const pinnedDelta = Number(Boolean(right.isPinned)) - Number(Boolean(left.isPinned));

      if (vendorNoteSort === "pinned") {
        if (pinnedDelta !== 0) return pinnedDelta;
        return rightTime - leftTime;
      }

      if (vendorNoteSort === "recent") {
        return rightTime - leftTime;
      }

      if (vendorNoteSort === "price-desc") {
        const priceDelta = (priceRank[right.priceLevel] || 0) - (priceRank[left.priceLevel] || 0);
        if (priceDelta !== 0) return priceDelta;
        if (pinnedDelta !== 0) return pinnedDelta;
        return rightTime - leftTime;
      }

      if (pinnedDelta !== 0) return pinnedDelta;
      return rightTime - leftTime;
    });
  }

  function getFilteredVendorNotes() {
    const query = vendorNoteSearch.trim().toLowerCase();
    const notes = sortVendorNotes(vendorNotesState.items || []).filter((note) =>
      !vendorNoteTradeFilter || (note.trade || "未分類") === vendorNoteTradeFilter,
    );
    if (!query) return notes;
    return notes.filter((note) =>
      [
        note.name,
        note.trade,
        note.priceLevel,
        note.craftLevel,
        note.location,
        note.impression,
        note.memo,
      ]
        .join("\n")
        .toLowerCase()
        .includes(query),
    );
  }

  function groupVendorNotesByTrade(notes = []) {
    const groups = new Map();
    notes.forEach((note) => {
      const trade = note.trade || "未分類";
      if (!groups.has(trade)) {
        groups.set(trade, []);
      }
      groups.get(trade).push(note);
    });

    const orderedTrades = [
      ...vendorTradeOptions.filter((trade) => groups.has(trade)),
      ...[...groups.keys()].filter((trade) => !vendorTradeOptions.includes(trade)),
    ];

    return orderedTrades.map((trade) => ({
      trade,
      items: groups.get(trade) || [],
    }));
  }

  function getVendorTradeFilterOptions() {
    const grouped = groupVendorNotesByTrade(sortVendorNotes(vendorNotesState.items || []));
    return [
      {
        value: "",
        label: "全部",
        count: vendorNotesState.items.length || 0,
      },
      ...grouped.map((group) => ({
        value: group.trade,
        label: group.trade,
        count: group.items.length,
      })),
    ];
  }

  function formatVendorNoteTimestamp(value = "") {
    if (!value) return "";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "";
    return date.toLocaleDateString("zh-TW", {
      month: "2-digit",
      day: "2-digit",
    });
  }

  function getWeekKey(date = new Date()) {
    const target = new Date(date);
    const day = target.getDay() || 7;
    target.setHours(0, 0, 0, 0);
    target.setDate(target.getDate() + 4 - day);
    const yearStart = new Date(target.getFullYear(), 0, 1);
    const weekNo = Math.ceil((((target - yearStart) / 86400000) + 1) / 7);
    return `${target.getFullYear()}-W${String(weekNo).padStart(2, "0")}`;
  }

  function createRun(slot) {
    return {
      id: `run-${slot}`,
      slot,
      actionOutreach: false,
      actionImageGeneration: false,
      actionWebsite: false,
      actionThreads: false,
      actionInstagram: false,
      actionFacebook: false,
      actionXiaohongshu: false,
      linkStash: {
        gemini: "",
        website: "",
        threads: "",
        instagram: "",
        facebook: "",
        xiaohongshu: "",
      },
      rewardClaimed: false,
      completedAt: "",
    };
  }

  function createWeeklyRuns() {
    return [
      createRun(1),
      createRun(2),
      createRun(3),
    ];
  }

  function createInitialState() {
    return {
      weekly: {
        weekKey: getWeekKey(),
        bonusClaimed: false,
        runs: createWeeklyRuns(),
      },
      stats: {
        xp: 0,
        streak: 0,
        lifetimeRuns: 0,
      },
    };
  }

  function syncRuns(savedRuns = []) {
    const templateRuns = createWeeklyRuns();
    return templateRuns.map((templateRun, index) => {
      const savedRun = savedRuns.find((run) => run?.id === templateRun.id) ?? savedRuns[index] ?? {};
      const migratedOutreach = savedRun?.actionOutreach !== undefined
        ? Boolean(savedRun?.actionOutreach)
        : Boolean(savedRun?.actionSearch) && Boolean(savedRun?.actionAdvice);
      const migratedImageGeneration = savedRun?.actionImageGeneration !== undefined
        ? Boolean(savedRun?.actionImageGeneration)
        : Boolean(savedRun?.actionImage) || Boolean(savedRun?.actionVisual) || Boolean(savedRun?.actionIllustration);
      const migratedWebsite = savedRun?.actionWebsite !== undefined
        ? Boolean(savedRun?.actionWebsite)
        : Boolean(savedRun?.actionArticle);
      const savedLinkStash = savedRun?.linkStash && typeof savedRun.linkStash === "object"
        ? savedRun.linkStash
        : {};
      return {
        ...templateRun,
        ...savedRun,
        actionOutreach: migratedOutreach,
        actionImageGeneration: migratedImageGeneration,
        actionWebsite: migratedWebsite,
        actionThreads: Boolean(savedRun?.actionThreads),
        actionInstagram: Boolean(savedRun?.actionInstagram),
        actionFacebook: Boolean(savedRun?.actionFacebook),
        actionXiaohongshu: Boolean(savedRun?.actionXiaohongshu),
        linkStash: {
          ...templateRun.linkStash,
          gemini: typeof savedLinkStash?.gemini === "string" ? savedLinkStash.gemini : "",
          website: typeof savedLinkStash?.website === "string" ? savedLinkStash.website : "",
          threads: typeof savedLinkStash?.threads === "string" ? savedLinkStash.threads : "",
          instagram: typeof savedLinkStash?.instagram === "string" ? savedLinkStash.instagram : "",
          facebook: typeof savedLinkStash?.facebook === "string" ? savedLinkStash.facebook : "",
          xiaohongshu: typeof savedLinkStash?.xiaohongshu === "string" ? savedLinkStash.xiaohongshu : "",
        },
      };
    });
  }

  let state = createInitialState();

  function saveState() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      const initialState = createInitialState();
      state = {
        weekly: {
          ...initialState.weekly,
          ...(parsed.weekly || {}),
          runs: syncRuns(parsed.weekly?.runs),
        },
        stats: {
          ...initialState.stats,
          ...(parsed.stats || {}),
        },
      };
    } catch (error) {
      console.error("讀取社群作戰台資料失敗：", error);
    }
  }

  function isRunComplete(run) {
    return run.actionOutreach && run.actionImageGeneration && run.actionWebsite && run.actionThreads && run.actionInstagram && run.actionFacebook && run.actionXiaohongshu;
  }

  function normalizeWeeklyState() {
    const currentWeekKey = getWeekKey();
    if (state.weekly.weekKey === currentWeekKey) return;

    const completedRuns = state.weekly.runs.filter(isRunComplete).length;
    state.stats.streak = completedRuns >= WEEKLY_TARGET ? state.stats.streak + 1 : 0;
    state.weekly = {
      weekKey: currentWeekKey,
      bonusClaimed: false,
      runs: createWeeklyRuns(),
    };
    saveState();
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function normalizeLinkValue(value = "") {
    const trimmed = String(value ?? "").trim();
    if (!trimmed) return "";
    if (/^https?:\/\//i.test(trimmed)) return trimmed;
    return `https://${trimmed.replace(/^\/+/, "")}`;
  }

  function setFeedback(message, mode = "") {
    const shell = document.getElementById("ops-feedback");
    if (!shell) return;
    shell.className = `ops-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function setGeminiFeedback(message, mode = "") {
    const shell = document.getElementById("gemini-feedback");
    if (!shell) return;
    shell.className = `gemini-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function getCompletedRunCount() {
    return state.weekly.runs.filter(isRunComplete).length;
  }

  function getActiveRunIndex() {
    const nextIndex = state.weekly.runs.findIndex((run) => !isRunComplete(run));
    return nextIndex === -1 ? Math.max(state.weekly.runs.length - 1, 0) : nextIndex;
  }

  function getLevel() {
    return Math.floor(state.stats.xp / 200) + 1;
  }

  function getRankTitle(level) {
    return rankTitles[Math.min(level - 1, rankTitles.length - 1)];
  }

  function maybeClaimRunReward(run) {
    if (!isRunComplete(run) || run.rewardClaimed) return;
    run.rewardClaimed = true;
    run.completedAt = new Date().toISOString();
    state.stats.xp += RUN_XP;
    state.stats.lifetimeRuns += 1;

    const completedRuns = getCompletedRunCount();
    if (completedRuns >= WEEKLY_TARGET && !state.weekly.bonusClaimed) {
      state.weekly.bonusClaimed = true;
      state.stats.xp += WEEKLY_BONUS_XP;
      setFeedback("本週三個任務已全清，已領取 +50 XP 額外獎勵。", "is-success");
    }
  }

  function renderHero() {
    const completedRuns = getCompletedRunCount();
    const remaining = Math.max(WEEKLY_TARGET - completedRuns, 0);
    const percent = Math.round((completedRuns / WEEKLY_TARGET) * 100);
    const level = getLevel();
    document.getElementById("weekly-progress-count").textContent = `${completedRuns} / ${WEEKLY_TARGET}`;
    document.getElementById("weekly-progress-note").textContent = remaining === 0
      ? "本週已清空。"
      : `還差 ${remaining} 個任務`;
    document.getElementById("weekly-progress-bar").style.width = `${percent}%`;
    document.getElementById("xp-value").textContent = `${state.stats.xp} XP`;
    document.getElementById("streak-value").textContent = `${state.stats.streak} 週`;
    document.getElementById("lifetime-runs-value").textContent = `${state.stats.lifetimeRuns} 次`;
    document.getElementById("level-value").textContent = `第 ${level} 級`;
    document.getElementById("rank-title").textContent = getRankTitle(level);
  }

