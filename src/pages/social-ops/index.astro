  function summarizeDecisionTitle(content) {
    const decisionSection = extractSectionText(content, "判題結論");
    const singleLineDecision = normalizeDecisionLine(decisionSection);
    if (singleLineDecision) return singleLineDecision;
    const sourceText = content.split("\n").slice(0, 8).join("\n");
    const fallbackDecision = normalizeDecisionLine(sourceText);
    if (fallbackDecision) return fallbackDecision;
    return "請看 AI 原文";
  }

  function summarizeDecisionAction(title) {
    if (title === "優先補舊文") return "先補強既有文章，再用舊文連結回覆社團。";
    if (title === "先改寫舊文") return "先重整舊文標題與段落，再導回同一篇主文。";
    if (title === "可做同章延伸") return "保留舊文主幹，另外開一篇延伸角度並互相內鏈。";
    if (title === "值得另開新文") return "直接生成初稿，作為新主文收進對應書系。";
    return "先看下方 AI 原文，再決定是補舊文還是另開新文。";
  }

  function summarizeDecisionSimilar(content) {
    const duplicateSection = extractSectionText(content, "重複判斷");
    if (!duplicateSection) {
      return inferSimilarArticleTitle(content, parseArticleTitle(content)) || "暫未比對到明確舊文";
    }

    const lines = duplicateSection
      .split("\n")
      .map((line) => line.replace(/^[-*\d.\s]+/, "").trim())
      .filter(Boolean);

    const similarLine = lines.find((line) =>
      /最相似|相似舊文|既有文章|舊文/.test(line) &&
      !/開新文|補強舊文|改寫舊文|同章延伸|原因/.test(line),
    );

    if (similarLine) {
      return similarLine
        .replace(/^(最相似的?\s*1-3\s*篇既有文章標題|最相似文章|相似舊文|既有文章)[:：]?\s*/i, "")
        .slice(0, 42) || "請看下方 AI 原文";
    }

    const candidateLine = lines.find((line) => !/開新文|補強舊文|改寫舊文|同章延伸|原因/.test(line));
    if (candidateLine) return candidateLine.slice(0, 42);

    return inferSimilarArticleTitle(content, parseArticleTitle(content)) || "暫未比對到明確舊文";
  }

  function summarizeDecisionAngle(content) {
    const angleSection = extractSectionText(content, "社團回覆視角");
    if (angleSection) {
      return angleSection
        .split("\n")
        .map((line) => line.replace(/^[-*\d.\s]+/, "").trim())
        .filter(Boolean)[0]
        ?.slice(0, 42) || "先從對方最在意的痛點切入";
    }

    if (/預算/.test(content)) return "先從預算與取捨切入";
    if (/西曬|日照|溫度/.test(content)) return "先從舒適度與日照切入";
    if (/插座|開關|收納|不夠用/.test(content)) return "先從日後是否夠用切入";
    return "先從對方最在意的痛點切入";
  }

  async function copyArticleSocialReply(variant, successMessage) {
    let replies = getResolvedArticleSocialReplies(articleAiResult);

    if (variant === "lead") {
      const target = resolveSocialReplyTarget(articleAiResult);
      const shortUrl = await getShortBlogUrl(target.url);
      replies = getResolvedArticleSocialReplies(articleAiResult, {
        ...target,
        url: shortUrl || target.url,
      });
    }

    const text = replies[variant]?.trim();
    if (!text) {
      setArticleAiFeedback("目前沒有可複製的社團回覆稿。", "is-warning");
      return;
    }
    const result = await copyText(text, successMessage);
    const feedback = getCopyFeedbackState(
      result,
      successMessage,
      "已開啟手動複製視窗，可直接複製社團回覆稿。",
    );
    setArticleAiFeedback(feedback.message, feedback.mode);
  }

  function getArticleAiDecision(content) {
    if (!content.trim()) {
      return {
        title: "尚未判定",
        action: "先貼問題再判題",
        similar: "尚未比對",
        angle: "先貼問題再判題",
      };
    }

    const title = summarizeDecisionTitle(content);
    return {
      title,
      action: summarizeDecisionAction(title),
      similar: summarizeDecisionSimilar(content),
      angle: summarizeDecisionAngle(content),
    };
  }

  async function requestArticleTopicDecision(mode = currentTopicMode) {
    const sourceState = buildResolvedArticleSourcePackage();
    if (!sourceState.hasSeed) {
      setFeedback("請先在高頻區提供本輪預設題目，或貼上真實社團問題。", "is-warning");
      setArticleAiFeedback("請先在高頻區提供本輪預設題目，或貼上真實社團問題。", "is-warning");
      return null;
    }

    try {
      const controller = new AbortController();
      const timeoutId = window.setTimeout(() => controller.abort(), getArticleAiTimeoutMs("topic"));
      const response = await fetch("/api/social-ops/article-assist", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        signal: controller.signal,
        body: JSON.stringify({
          mode: "topic",
          prompt: buildArticleTopicPrompt(sourceState.packageText, mode),
        }),
      });
      window.clearTimeout(timeoutId);

      const result = await response.json();
      if (!response.ok) {
        const errorMessage = result?.error === "GEMINI_API_KEY_MISSING"
          ? "尚未設定 GEMINI_API_KEY，暫時無法做本題動態決題。"
          : result?.error === "GEMINI_RATE_LIMITED"
            ? `Gemini Pro 目前達到額度上限${Number.isFinite(result?.retryAfterSeconds) ? `，約 ${result.retryAfterSeconds} 秒後再試。` : "，請稍後再試。"}`
            : "Gemini Pro 目前無法完成本題動態決題，請稍後再試。";
        setFeedback(errorMessage, "is-warning");
        setArticleAiFeedback(errorMessage, "is-warning");
        return null;
      }

      return typeof result?.content === "string" ? result.content : "";
    } catch (error) {
      if (error instanceof DOMException && error.name === "AbortError") {
        const timeoutMessage = buildArticleAiTimeoutMessage("topic");
        setFeedback(timeoutMessage, "is-warning");
        setArticleAiFeedback(timeoutMessage, "is-warning");
        return null;
      }
      console.error("Gemini Pro 本題動態決題失敗：", error);
      setFeedback("Gemini Pro 連線失敗，暫時無法完成本題動態決題。", "is-warning");
      setArticleAiFeedback("Gemini Pro 連線失敗，暫時無法完成本題動態決題。", "is-warning");
      return null;
    }
  }

  async function ensureArticleTopicDecision(mode = currentTopicMode) {
    const sourceState = buildResolvedArticleSourcePackage();
    if (!sourceState.hasSeed) return null;

    if (articleTopicDecision?.question === sourceState.packageText && articleTopicDecision?.mode === mode) {
      renderArticleTopicDecision();
      return articleTopicDecision;
    }

    setArticleAiFeedback("第 1 步進行中：正在整理完整出版上下文並送交 Gemini Pro 做本題動態決題...", "is-success");
    const content = await requestArticleTopicDecision(mode);
    if (!content) return null;

    const parsed = parseArticleTopicDecision(content, mode, sourceState.packageText);
    if (!parsed) {
      setArticleAiFeedback("本題動態決題格式不完整，先改用固定骨架繼續。", "is-warning");
      return null;
    }

    articleTopicDecision = parsed;
    saveArticleTopicDecision();
    renderArticleTopicDecision();
    const topicDecisionFeedbackMode = parsed.invalid || isAssetMergeAction(parsed.finalAction) ? "is-warning" : "is-success";
    setArticleAiFeedback(
      parsed.invalid
        ? "偵測到跨書系污染，已自動回退到老屋主線的安全題目，正在接續整理 AI 結果..."
        : isAssetMergeAction(parsed.finalAction)
          ? getArticleTopicAssetMergeMessage(parsed)
          : "Gemini Pro 已完成整併池與採用題目判定，正在接續整理 AI 結果...",
      topicDecisionFeedbackMode,
    );
    return articleTopicDecision;
  }

