  function inferSubchapterFromTrack(trackTitle, chapterTitle, titleText = "", content = "") {
    const subchapterMap = getTrackSubchapterMap(trackTitle, chapterTitle);
    const subchapterEntries = Object.entries(subchapterMap);
    if (!subchapterEntries.length) return "";

    const text = `${titleText}\n${content}`.replace(/\s+/g, "");
    let bestSubchapter = "";
    let bestScore = 0;

    subchapterEntries.forEach(([subchapter, keywords]) => {
      const score = getInferenceKeywordScore(text, keywords);
      if (score > bestScore) {
        bestScore = score;
        bestSubchapter = subchapter;
      }
    });

    return bestSubchapter || subchapterEntries[0][0] || "";
