  function formatCount(value) {
    const parsed = Number(value || 0);
    if (!Number.isFinite(parsed)) return "-";
    return parsed.toLocaleString("zh-TW");
  }

  function formatDeltaPercent(value) {
    const parsed = Number(value || 0);
    if (!Number.isFinite(parsed)) return "0%";
    const rounded = Math.abs(parsed) >= 10 ? parsed.toFixed(1) : parsed.toFixed(1);
    return `${rounded}%`;
  }

  function getTrafficTrendSummary(trend) {
    const change = Number(trend?.change || 0);
    const percent = Number(trend?.changePercent || 0);
    if (change > 0) return `較前 7 天成長 ${formatDeltaPercent(percent)}`;
    if (change < 0) return `較前 7 天下降 ${formatDeltaPercent(Math.abs(percent))}`;
    return "與前 7 天持平";
  }

  function getTrafficTrendComment(trend) {
    const currentTotal = Number(trend?.currentTotal || 0);
    const previousTotal = Number(trend?.previousTotal || 0);
    const percent = Number(trend?.changePercent || 0);

    if (currentTotal <= 0 && previousTotal <= 0) {
      return "目前還沒有足夠流量資料，先持續累積內容與導流來源。";
    }

    if (percent >= 20) {
      return "這波流量有明顯升溫，代表近期內容或導流入口開始接住關注，可以持續追哪個來源正在放大。";
    }

    if (percent >= 5) {
      return "流量正在穩定往上，節奏是健康的，適合繼續延續最近有效的發文與導流做法。";
    }

    if (percent <= -20) {
      return "流量下滑幅度偏明顯，建議先回看來源是否掉量，或落地頁是否沒有接住進站意圖。";
    }

    if (percent <= -5) {
      return "流量有小幅回落，先檢查最近一週的發文節奏、連結入口與 CTA 是否變弱。";
    }

    return "整體流量仍在盤整區間，沒有明顯升降，現階段重點是持續觀察哪些題目最能穩定帶來進站。";
  }

  function buildTrafficTrendSvg(points = []) {
    if (!Array.isArray(points) || !points.length) {
      return '<div class="bookshelf-analytics-chart-empty">近 7 天尚無流量資料。</div>';
    }

    const width = 560;
    const height = 220;
    const paddingLeft = 18;
    const paddingRight = 18;
    const paddingTop = 18;
    const paddingBottom = 34;
    const values = points.map((point) => Number(point?.sessions || 0));
    const minValue = Math.min(...values);
    const maxValue = Math.max(...values);
    const valueSpan = Math.max(maxValue - minValue, 1);
    const yMin = Math.max(0, minValue - valueSpan * 0.2);
    const yMax = Math.max(maxValue, yMin + 1);
    const chartWidth = width - paddingLeft - paddingRight;
    const chartHeight = height - paddingTop - paddingBottom;
    const xStep = points.length > 1 ? chartWidth / (points.length - 1) : 0;
    const toX = (index) => paddingLeft + index * xStep;
    const toY = (value) => {
      const normalized = (Number(value || 0) - yMin) / (yMax - yMin || 1);
      return paddingTop + chartHeight - normalized * chartHeight;
    };

    const pointPairs = points.map((point, index) => [toX(index), toY(point.sessions)]);
    const polylinePoints = pointPairs.map(([x, y]) => `${x},${y}`).join(" ");
    const areaPath = [
      `M ${pointPairs[0][0]} ${height - paddingBottom}`,
      ...pointPairs.map(([x, y]) => `L ${x} ${y}`),
      `L ${pointPairs[pointPairs.length - 1][0]} ${height - paddingBottom}`,
      "Z",
    ].join(" ");
    const gridLevels = [0, 0.5, 1];
    const gridLines = gridLevels.map((level) => {
      const y = paddingTop + chartHeight * level;
      const value = Math.round(yMax - (yMax - yMin) * level);
      return `
        <g>
          <line x1="${paddingLeft}" y1="${y}" x2="${width - paddingRight}" y2="${y}" />
          <text x="${width - paddingRight}" y="${y - 6}">${formatCount(value)}</text>
        </g>
      `;
    }).join("");
    const pointDots = points.map((point, index) => `
      <g>
        <circle cx="${toX(index)}" cy="${toY(point.sessions)}" r="4" />
        <title>${point.label}：${formatCount(point.sessions)} sessions</title>
      </g>
    `).join("");
    const axisLabels = points.map((point, index) => `
      <text x="${toX(index)}" y="${height - 10}" text-anchor="middle">${point.label}</text>
    `).join("");

    return `
      <svg class="bookshelf-analytics-chart-svg" viewBox="0 0 ${width} ${height}" role="img" aria-label="近 7 天流量折線圖">
        <defs>
          <linearGradient id="analyticsTrendFill" x1="0" x2="0" y1="0" y2="1">
            <stop offset="0%" stop-color="rgba(231, 198, 126, 0.38)" />
            <stop offset="100%" stop-color="rgba(231, 198, 126, 0.04)" />
          </linearGradient>
        </defs>
        <g class="bookshelf-analytics-chart-grid">${gridLines}</g>
        <path class="bookshelf-analytics-chart-area" d="${areaPath}" />
        <polyline class="bookshelf-analytics-chart-line" points="${polylinePoints}" />
        <g class="bookshelf-analytics-chart-dots">${pointDots}</g>
        <g class="bookshelf-analytics-chart-axis">${axisLabels}</g>
      </svg>
    `;
  }

  function getArticleTitleFromPagePath(pagePath = "") {
    const slug = pagePath
      .replace(/^\/blog\//, "")
      .replace(/\/$/, "")
      .trim();
    if (!slug) return "未辨識文章";
    const matched = articleLibrary.find((post) => post.slug === slug);
    return matched?.title || slug;
  }

  function getReadableLandingLabel(pagePath = "") {
    const normalizedPath = String(pagePath || "").split("?")[0].trim();
    if (!normalizedPath || normalizedPath === "(not set)") return "未提供落地頁";
    if (normalizedPath === "/") return "首頁";
    if (normalizedPath === "/tools") return "線上估價系統";
    if (normalizedPath === "/contact") return "免費格局健檢";
    if (normalizedPath === "/requirement-form") return "完整需求表";
    if (normalizedPath.startsWith("/blog/")) return getArticleTitleFromPagePath(normalizedPath);
    return normalizedPath;
  }

  function getReadableSourceLabel(sourceMedium = "") {
    const rawValue = String(sourceMedium || "").trim();
    const normalized = rawValue.toLowerCase();

    if (normalized === "(not set)") {
      return "來源未標記";
    }

    if (normalized === "(data not available)") {
      return "來源資料暫時不足";
    }

    if (!normalized || normalized === "(direct) / (none)") {
      return "直接進站";
    }

    if (normalized.includes("ig_text_post_permalink_recent")) {
      return "Instagram 貼文導流（近期貼文）";
    }

    if (normalized.includes("ig_text_post_permalink")) {
      return "Instagram 貼文導流";
    }

    if (normalized.includes("instagram")) {
      return "Instagram 導流";
    }

    if (normalized.includes("threads")) {
      return "Threads 導流";
    }

    if (normalized.includes("facebook") || normalized.includes("m.facebook") || normalized.includes("l.facebook")) {
      return "Facebook 導流";
    }

    if (normalized.includes("line")) {
      return "LINE 導流";
    }

    if (normalized.includes("google") && normalized.includes("/ organic")) {
      return "Google 自然搜尋";
    }

    if (normalized.includes("google") && normalized.includes("/ cpc")) {
      return "Google 廣告";
    }

    if (normalized.includes("yahoo") && normalized.includes("/ organic")) {
      return "Yahoo 自然搜尋";
    }

    if (normalized.includes("bing") && normalized.includes("/ organic")) {
      return "Bing 自然搜尋";
    }

    if (normalized.includes("/ referral")) {
      const sourceName = rawValue.split("/")[0]?.trim() || "其他網站";
      return `${sourceName} 轉介`;
    }

    if (normalized.includes("/ organic")) {
      const sourceName = rawValue.split("/")[0]?.trim() || "搜尋引擎";
      return `${sourceName} 自然搜尋`;
    }

    if (normalized.includes("/ social")) {
      const sourceName = rawValue.split("/")[0]?.trim() || "社群";
      return `${sourceName} 社群導流`;
    }

    if (normalized.includes("/ cpc") || normalized.includes("/ paid")) {
      const sourceName = rawValue.split("/")[0]?.trim() || "廣告";
      return `${sourceName} 廣告流量`;
    }

    return rawValue;
  }

