      linear-gradient(180deg, rgba(70, 70, 72, 0.82), rgba(46, 46, 48, 0.92));
  }

  .quest-topline,
  .portal-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .quest-topline {
    justify-content: space-between;
    align-items: center;
  }

  .quest-keyword {
    display: inline-flex;
    padding: 0.3rem 0.62rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(236, 234, 227, 0.72);
    font-size: 0.79rem;
