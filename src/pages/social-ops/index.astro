                        </div>`
                      : ""}
                  </article>
                `;
              })
              .join("")}
          </div>
        </section>
      `)
      .join("");
  }

  function updateVendorNotesState(result, fallbackItems = []) {
    vendorNotesState = {
      status: typeof result?.status === "string" ? result.status : "error",
      configured: Boolean(result?.configured),
      items: Array.isArray(result?.items) ? result.items : fallbackItems,
      note: typeof result?.note === "string" ? result.note : "",
    };
  }

  async function loadVendorNotes() {
    vendorNotesState = {
      ...vendorNotesState,
      status: "loading",
    };
    renderVendorNotes();

    try {
      const response = await fetch(VENDOR_NOTES_API_URL, {
        headers: {
          Accept: "application/json",
        },
      });
      const result = await response.json();
      updateVendorNotesState(result, []);
    } catch (error) {
      console.error("讀取共享廠商筆記失敗：", error);
      vendorNotesState = {
        ...vendorNotesState,
        status: "error",
        configured: false,
        note: "共享廠商筆記暫時讀取失敗，請稍後再試。",
      };
    }

    renderVendorNotes();
  }

  async function saveVendorNote(note) {
    const response = await fetch(VENDOR_NOTES_API_URL, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Accept: "application/json",
      },
      body: JSON.stringify({ note }),
    });
    const result = await response.json();
    updateVendorNotesState(result, vendorNotesState.items || []);
    renderVendorNotes();
    if (!response.ok || result?.status !== "ok") {
      throw new Error(result?.note || `SAVE_VENDOR_NOTE_FAILED:${response.status}`);
    }
  }

  async function removeVendorNote(noteId) {
    const response = await fetch(`${VENDOR_NOTES_API_URL}?id=${encodeURIComponent(noteId)}`, {
      method: "DELETE",
      headers: {
        Accept: "application/json",
      },
    });
    const result = await response.json();
    updateVendorNotesState(result, vendorNotesState.items || []);
    renderVendorNotes();
    if (!response.ok || result?.status !== "ok") {
      throw new Error(result?.note || `DELETE_VENDOR_NOTE_FAILED:${response.status}`);
    }
  }

  async function loadContentAnalytics() {
    contentAnalyticsState = {
      ...contentAnalyticsState,
      status: "loading",
    };
    renderContentAnalytics();

    try {
      const response = await fetch(CONTENT_ANALYTICS_URL, {
        headers: {
          Accept: "application/json",
        },
      });
      const result = await response.json();

      contentAnalyticsState = {
        status: typeof result?.status === "string" ? result.status : "error",
        configured: Boolean(result?.configured),
        rangeLabel: typeof result?.rangeLabel === "string" ? result.rangeLabel : "近 7 天",
        updatedAt: typeof result?.updatedAt === "string" ? result.updatedAt : "",
        metrics: {
          realtimeActiveUsers: Number(result?.metrics?.realtimeActiveUsers || 0),
          todaySessions: Number(result?.metrics?.todaySessions || 0),
          totalSessions: Number(result?.metrics?.totalSessions || 0),
          blogViews: Number(result?.metrics?.blogViews || 0),
          socialSessions: Number(result?.metrics?.socialSessions || 0),
          estimateGenerated: Number(result?.metrics?.estimateGenerated || 0),
          estimateCtaClick: Number(result?.metrics?.estimateCtaClick || 0),
          requirementSubmit: Number(result?.metrics?.requirementSubmit || 0),
          requirementSuccess: Number(result?.metrics?.requirementSuccess || 0),
        },
        topPosts: Array.isArray(result?.topPosts) ? result.topPosts : [],
        topSources: Array.isArray(result?.topSources) ? result.topSources : [],
        socialLandingPages: Array.isArray(result?.socialLandingPages) ? result.socialLandingPages : [],
      trafficTrend: {
        points: Array.isArray(result?.trafficTrend?.points) ? result.trafficTrend.points : [],
        currentTotal: Number(result?.trafficTrend?.currentTotal || 0),
        previousTotal: Number(result?.trafficTrend?.previousTotal || 0),
        change: Number(result?.trafficTrend?.change || 0),
        changePercent: Number(result?.trafficTrend?.changePercent || 0),
      },
        note: typeof result?.note === "string" ? result.note : "",
      };
    } catch (error) {
      console.error("內容成效讀取失敗：", error);
      contentAnalyticsState = {
        ...contentAnalyticsState,
        status: "error",
        configured: false,
        note: "內容成效暫時讀取失敗，請稍後再試。",
      };
    }

    renderContentAnalytics();
  }

  function formatArticleLibraryTaxonomy(post) {
    const track = post?.track || "未分配主書系";
    const chapter = post?.chapter || "未分配章節";
    const siteCategory = post?.siteCategory || post?.category || "未分配網站分類";
    return `${track}｜${chapter}｜${siteCategory}`;
  }

  function formatArticleLibraryTags(post) {
    if (!Array.isArray(post?.tags)) return "";
    return post.tags.filter(Boolean).join(" ");
  }

  function buildArticleTitlesText() {
    return articleLibrary
      .map((post, index) => `${index + 1}. [${formatArticleLibraryTaxonomy(post)}] ${post.title}`)
      .join("\n");
  }

  function buildArticleCatalogText() {
    return articleLibrary
      .map((post, index) => `${index + 1}. [${formatArticleLibraryTaxonomy(post)}] ${post.title}｜${post.date}`)
      .join("\n");
  }

  function formatTrackStructureText() {
    return bookshelfTracks
      .map((track, index) => {
        const chapterText = getTrackChapters(track.title)
          .map((chapter) => {
            const subchapters = getTrackSubchapters(track.title, chapter);
            return subchapters.length
              ? `${chapter}（子章：${subchapters.join(" / ")}）`
              : chapter;
          })
          .join("；");

        return `${index + 1}. ${track.title}｜核心：${track.focus}｜章節：${chapterText}`;
      })
      .join("\n");
  }

