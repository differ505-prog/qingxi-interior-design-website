  document.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    if (target.hasAttribute("data-publishing-subchapter-checkbox")) {
      const trackTitle = target.dataset.trackTitle || "";
      const chapterTitle = target.dataset.chapterTitle || "";
      const subchapterTitle = target.dataset.subchapterTitle || "";
      const key = getPublishingChecklistEntryKey(trackTitle, chapterTitle, subchapterTitle);
      publishingChecklistOverrides[key] = target.checked;
      savePublishingChecklist();
      renderPublishingChecklist();
      return;
    }
    if (target.dataset.runLinkKey) {
      const index = Number(target.dataset.runIndex);
      const linkKey = target.dataset.runLinkKey;
      const run = state.weekly.runs[index];
      if (!run || !linkKey || !run.linkStash) return;
      run.linkStash[linkKey] = target.value.trim();
      rerender();
      return;
    }
    if (target.dataset.dailyCheck) {
      const key = target.dataset.dailyCheck;
      if (!state.daily || !key) return;

      if (key === "actionOutboundHunt" && target.checked) {
        state.daily.actionOutboundFallback = false;
      }
      if (key === "actionOutboundFallback" && target.checked) {
        state.daily.actionOutboundHunt = false;
      }

      state.daily[key] = target.checked;
      maybeClaimDailyReward(state.daily);
      rerender();
      return;
    }
    if (!target.dataset.runCheck) return;

    const index = Number(target.dataset.runIndex);
    const key = target.dataset.runCheck;
    const run = state.weekly.runs[index];
    if (!run || !key) return;

    if (key === "actionOutreach" && target.checked) {
      run.actionOutreachFallback = false;
    }
    if (key === "actionOutreachFallback" && target.checked) {
      run.actionOutreach = false;
    }
    if (key === "actionThreads" && target.checked) {
      run.actionLocalCommunity = false;
    }
    if (key === "actionLocalCommunity" && target.checked) {
      run.actionThreads = false;
    }

    run[key] = target.checked;
    maybeClaimRunReward(run);
    rerender();
  });

