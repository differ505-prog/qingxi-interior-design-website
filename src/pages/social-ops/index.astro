    background:
      radial-gradient(circle at top right, rgba(236, 234, 228, 0.07), transparent 40%),
      linear-gradient(180deg, rgba(70, 70, 68, 0.98), rgba(39, 39, 39, 0.96));
  }

  .progress-track {
    margin-top: 0.7rem;
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.09);
    overflow: hidden;
  }

  .progress-bar {
    width: 0;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #e9e6df, #a9a59b);
