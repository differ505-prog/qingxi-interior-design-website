                    <p>入庫欄位</p>
                    <span>{articleIntakeFields.length} 項</span>
                  </div>
                  <div class="bookshelf-intake-grid">
                    {articleIntakeFields.map((field, index) => (
                      <article class="bookshelf-intake-item">
                        <span>{String(index + 1).padStart(2, "0")}</span>
                        <p>{field}</p>
                      </article>
                    ))}
                  </div>
                </div>

                <div class="bookshelf-preview bookshelf-fold-body">
                  <div class="bookshelf-preview-head">
                    <p>去重規則</p>
                    <span>{overlapRules.length} 條</span>
                  </div>
                  <div class="bookshelf-rule-grid">
                    {overlapRules.map((rule) => (
                      <article class="bookshelf-rule-card">
                        <strong>{rule.title}</strong>
                        <p>{rule.detail}</p>
                      </article>
                    ))}
                  </div>
                </div>
              </div>
            </details>

            <details class="bookshelf-fold">
              <summary>
                <span>書架視圖</span>
                <small>{bookshelfEntries.length} 篇</small>
              </summary>
              <div class="bookshelf-preview bookshelf-fold-body">
                <div class="bookshelf-shelf-grid">
                  {bookshelfViewGroups.map((group) => (
                    <section class="bookshelf-shelf-card">
                      <div class="bookshelf-shelf-head">
                        <div>
                          <p>{group.title}</p>
                          <strong>{group.focus}</strong>
                        </div>
                        <span>{group.entries.length} 篇</span>
                      </div>
                      <small>{group.chapters}</small>
                      {group.entries.length > 0 ? (
                        <div class="bookshelf-shelf-entries">
                          {group.entries.map((entry) => (
                            <article class="bookshelf-entry">
                              <div class="bookshelf-entry-top">
                                <span>{entry.chapter}</span>
                                <p>{entry.strategy}</p>
                              </div>
                              <h3>{entry.title}</h3>
                              <div class="bookshelf-entry-stack">
                                <small>分類：{entry.category}</small>
                                <small>關鍵字：{entry.searchKeyword}</small>
                                <small>相似舊文：{entry.similarTitle}</small>
                              </div>
                              <div class="bookshelf-entry-meta">
                                <span>{entry.date}</span>
                                <a href={`/blog/${entry.slug}`} target="_blank" rel="noreferrer">查看文章</a>
                              </div>
                            </article>
                          ))}
                        </div>
                      ) : (
                        <div class="bookshelf-shelf-empty">待補主文</div>
                      )}
                    </section>
                  ))}
                </div>
              </div>
            </details>
          </section>

          <section id="gemini-backup-board" class="ops-panel gemini-board">
            <div class="panel-heading">
              <div>
                <p class="panel-tag">Gemini 備份艙</p>
                <h2>Gemini Canvas 備份</h2>
              </div>
              <p>只留日期版本，點開才展開。</p>
            </div>

            <div class="gemini-actions gemini-actions-primary">
              <button type="button" id="run-gemini-backup" class="bookshelf-action bookshelp-action-primary">立即備份</button>
            </div>

            <p id="gemini-feedback" class="gemini-feedback" aria-live="polite"></p>

            <details class="gemini-composer" id="gemini-composer">
              <summary>
                <span>進階設定</span>
                <small>需要改連結、內容或下載時再展開</small>
              </summary>
              <div class="gemini-editor-grid">
                <label class="gemini-field">
                  <span>分享網址</span>
                  <input id="gemini-source-url" type="url" placeholder="貼上 Gemini 分享網址" />
                </label>
                <label class="gemini-field">
                  <span>備份標題</span>
                  <input id="gemini-title" type="text" placeholder="這次備份名稱" />
                </label>
                <label class="gemini-field gemini-field-full">
                  <span>內容</span>
                  <textarea id="gemini-content" rows="16" placeholder="把 Gemini Canvas 內容整段貼進來"></textarea>
                </label>
              </div>
              <div class="gemini-composer-actions">
                <button type="button" id="load-gemini-master" class="bookshelf-action">載入主檔</button>
                <button type="button" id="copy-gemini-markdown" class="bookshelf-action">複製 Markdown</button>
                <button type="button" id="download-gemini-json" class="bookshelf-action">下載 JSON</button>
              </div>
            </details>

            <div class="gemini-history">
              <div class="bookshelf-preview-head">
                <p>版本列表</p>
                <span id="gemini-history-count">0 版</span>
              </div>
              <div id="gemini-history-list" class="gemini-version-list"></div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ defaultSourcesJson, blogPostsJson, geminiCanvasMasterJson }}>
  const STORAGE_KEY = "qingxi-social-ops-v2";
  const ARTICLE_SOURCE_QUESTION_KEY = "qingxi-article-source-question-v1";
  const ARTICLE_AI_RESULT_KEY = "qingxi-article-ai-result-v1";
  const GEMINI_DRAFT_KEY = "qingxi-gemini-canvas-draft-v1";
  const GEMINI_BACKUPS_KEY = "qingxi-gemini-canvas-backups-v1";
  const GEMINI_RECENT_LIMIT = 10;
  const WEEKLY_TARGET = 3;
  const RUN_XP = 100;
  const WEEKLY_BONUS_XP = 50;
  const sourceTemplate = JSON.parse(defaultSourcesJson);
  const articleLibrary = JSON.parse(blogPostsJson);
  const geminiCanvasMasterData = JSON.parse(geminiCanvasMasterJson);
  const bookshelfTracks = [
    {
      title: "老屋翻新系",
      focus: "老屋翻修、基礎工程、動線重整、收納與耐久配置",
      chapters: "現況判讀 / 基礎工程 / 空間重整 / 完工避雷",
    },
    {
      title: "預售屋客變系",
      focus: "客變、交屋前規劃、插座燈光、收納與機能預留",
      chapters: "客變判斷 / 配置預留 / 生活動線 / 交屋銜接",
    },
    {
      title: "驗屋交屋系",
      focus: "驗屋、點交、缺失判讀、交屋後先後順序與修正重點",
      chapters: "驗屋判讀 / 缺失排序 / 點交策略 / 交屋後進場",
    },
    {
      title: "格局動線系",
      focus: "小坪數規劃、收納、動線、尺度、空間效率與生活邏輯",
      chapters: "空間尺度 / 動線配置 / 收納系統 / 使用情境",
    },
    {
      title: "水電照明系",
      focus: "插座、開關、迴路、照明、窗簾、智能控制與設備整合",
      chapters: "插座開關 / 迴路安全 / 照明設計 / 智能整合",
    },
  ];
  const articleIntakeFields = [
    "主書系",
    "章節定位",
    "網站分類",
    "搜尋主關鍵字",
    "相似舊文",
    "處理策略",
    "社團回覆角度",
    "導流目的",
    "下一篇延伸題目",
  ];
  const overlapRules = [
    {
      title: "同核心問題",
      detail: "若主判斷與既有文章相同，優先補強舊文，不重開新標題。",
    },
    {
      title: "同主題不同角度",
      detail: "若情境、預算、屋況或族群不同，可做同章延伸文，互相內鏈。",
    },
    {
      title: "可併成系列",
      detail: "若同一主書系下可串成前後篇，改做系列文，不做彼此搶重點的散文。",
    },
  ];
  const rankTitles = [
    "起稿中",
    "構圖中",
    "提案中",
    "執行中",
    "定稿中",
    "主理中",
  ];
  let articleSourceQuestion = "";
  let articleAiResult = "";
  let articleAiMode = "";
  let geminiDraft = null;
  let geminiBackups = [];

  function getWeekKey(date = new Date()) {
    const target = new Date(date);
    const day = target.getDay() || 7;
    target.setHours(0, 0, 0, 0);
    target.setDate(target.getDate() + 4 - day);
    const yearStart = new Date(target.getFullYear(), 0, 1);
    const weekNo = Math.ceil((((target - yearStart) / 86400000) + 1) / 7);
    return `${target.getFullYear()}-W${String(weekNo).padStart(2, "0")}`;
  }

  function createRun(slot) {
    return {
      id: `run-${slot}`,
      slot,
      actionSearch: false,
      actionAdvice: false,
      actionArticle: false,
      rewardClaimed: false,
      completedAt: "",
    };
  }

  function createWeeklyRuns() {
    return [
      createRun(1),
      createRun(2),
      createRun(3),
    ];
  }

  function createInitialState() {
    return {
      weekly: {
        weekKey: getWeekKey(),
        bonusClaimed: false,
        runs: createWeeklyRuns(),
      },
      stats: {
        xp: 0,
        streak: 0,
        lifetimeRuns: 0,
      },
    };
  }

  function syncRuns(savedRuns = []) {
    const templateRuns = createWeeklyRuns();
    return templateRuns.map((templateRun, index) => {
      const savedRun = savedRuns.find((run) => run?.id === templateRun.id) ?? savedRuns[index] ?? {};
      return {
        ...templateRun,
        ...savedRun,
      };
    });
  }

  let state = createInitialState();

  function saveState() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      const initialState = createInitialState();
      state = {
        weekly: {
          ...initialState.weekly,
          ...(parsed.weekly || {}),
          runs: syncRuns(parsed.weekly?.runs),
        },
        stats: {
          ...initialState.stats,
          ...(parsed.stats || {}),
        },
      };
    } catch (error) {
      console.error("讀取社群作戰台資料失敗：", error);
    }
  }

  function isRunComplete(run) {
    return run.actionSearch && run.actionAdvice && run.actionArticle;
  }

  function normalizeWeeklyState() {
    const currentWeekKey = getWeekKey();
    if (state.weekly.weekKey === currentWeekKey) return;

    const completedRuns = state.weekly.runs.filter(isRunComplete).length;
    state.stats.streak = completedRuns >= WEEKLY_TARGET ? state.stats.streak + 1 : 0;
    state.weekly = {
      weekKey: currentWeekKey,
      bonusClaimed: false,
      runs: createWeeklyRuns(),
    };
    saveState();
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function setFeedback(message, mode = "") {
    const shell = document.getElementById("ops-feedback");
    if (!shell) return;
    shell.className = `ops-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function setGeminiFeedback(message, mode = "") {
    const shell = document.getElementById("gemini-feedback");
    if (!shell) return;
    shell.className = `gemini-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function getCompletedRunCount() {
    return state.weekly.runs.filter(isRunComplete).length;
  }

  function getLevel() {
    return Math.floor(state.stats.xp / 200) + 1;
  }

  function getRankTitle(level) {
    return rankTitles[Math.min(level - 1, rankTitles.length - 1)];
  }

  function maybeClaimRunReward(run) {
    if (!isRunComplete(run) || run.rewardClaimed) return;
    run.rewardClaimed = true;
    run.completedAt = new Date().toISOString();
    state.stats.xp += RUN_XP;
    state.stats.lifetimeRuns += 1;

    const completedRuns = getCompletedRunCount();
    if (completedRuns >= WEEKLY_TARGET && !state.weekly.bonusClaimed) {
      state.weekly.bonusClaimed = true;
      state.stats.xp += WEEKLY_BONUS_XP;
      setFeedback("本週三個任務已全清，已領取 +50 XP 額外獎勵。", "is-success");
    }
  }

  function renderHero() {
    const completedRuns = getCompletedRunCount();
    const remaining = Math.max(WEEKLY_TARGET - completedRuns, 0);
    const percent = Math.round((completedRuns / WEEKLY_TARGET) * 100);
    const level = getLevel();
    document.getElementById("weekly-progress-count").textContent = `${completedRuns} / ${WEEKLY_TARGET}`;
    document.getElementById("weekly-progress-note").textContent = remaining === 0
      ? "本週已清空。"
      : `還差 ${remaining} 個任務`;
    document.getElementById("weekly-progress-bar").style.width = `${percent}%`;
    document.getElementById("xp-value").textContent = `${state.stats.xp} XP`;
    document.getElementById("streak-value").textContent = `${state.stats.streak} 週`;
    document.getElementById("lifetime-runs-value").textContent = `${state.stats.lifetimeRuns} 次`;
    document.getElementById("level-value").textContent = `第 ${level} 級`;
    document.getElementById("rank-title").textContent = getRankTitle(level);
  }

  function renderQuests() {
    const shell = document.getElementById("quest-grid");
    if (!shell) return;

    shell.innerHTML = state.weekly.runs
      .map((run, index) => {
        const complete = isRunComplete(run);

        return `
          <article class="quest-card ${complete ? "is-complete" : ""}">
            <div class="quest-topline">
              <span class="quest-slot">問題 ${run.slot}</span>
              <span class="quest-keyword">任選題</span>
            </div>
            <div class="quest-checklist">
              <label class="quest-check ${run.actionSearch ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionSearch" ${run.actionSearch ? "checked" : ""} />
                <span>已進場找題</span>
              </label>
              <label class="quest-check ${run.actionAdvice ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionAdvice" ${run.actionAdvice ? "checked" : ""} />
                <span>已給專業建議</span>
              </label>
              <label class="quest-check ${run.actionArticle ? "is-checked" : ""}">
                <input type="checkbox" data-run-index="${index}" data-run-check="actionArticle" ${run.actionArticle ? "checked" : ""} />
                <span>已附痛點文導流</span>
              </label>
            </div>
          </article>
        `;
      })
      .join("");
  }

  function renderPortalCards(sources) {
    return sources
      .map((source) => `
        <article class="portal-card">
          <div class="portal-card-top">
            <strong>${escapeHtml(source.alias)}</strong>
          </div>
          <div class="portal-actions">
            ${source.url
              ? `<a class="portal-link primary-link" href="${escapeHtml(source.url)}" target="_blank" rel="noreferrer">開啟入口</a>`
              : `<span class="portal-link portal-link-muted">待補連結</span>`}
          </div>
        </article>
      `)
      .join("");
  }

  function renderPortals() {
    const facebookShell = document.getElementById("facebook-card-grid");
    const lineShell = document.getElementById("line-card-grid");
    const googleShell = document.getElementById("google-card-grid");
    if (!facebookShell || !lineShell || !googleShell) return;

    const facebookSources = sourceTemplate.filter((source) => source.platform === "Facebook");
    const lineSources = sourceTemplate.filter((source) => source.platform === "LINE");
    const googleSources = sourceTemplate.filter((source) => source.platform === "Google");

    facebookShell.innerHTML = renderPortalCards(facebookSources);
    lineShell.innerHTML = renderPortalCards(lineSources);
    googleShell.innerHTML = renderPortalCards(googleSources);
  }

  function buildArticleTitlesText() {
    return articleLibrary
      .map((post, index) => `${index + 1}. [${post.category}] ${post.title}`)
      .join("\n");
  }

  function buildArticleCatalogText() {
    return articleLibrary
      .map((post, index) => `${index + 1}. [${post.category}] ${post.title}｜${post.date}`)
      .join("\n");
  }

  function buildBookshelfLlmPrompt() {
    const categories = Array.from(new Set(articleLibrary.map((post) => post.category))).join("、");
    const tracksText = bookshelfTracks
      .map((track, index) => `${index + 1}. ${track.title}｜核心：${track.focus}｜章節：${track.chapters}`)
      .join("\n");

    return [
      "你是青曦空間設計的內容總編與出版策劃。",
      "以下是目前知識分享已存在的文章標題清單。請依照現有文章，幫我把內容整理成可持續完成與未來可出版的書系架構。",
      "優先沿用下列固定主書系，不要另外發散出太多新書名；除非真的必要，否則請把文章收斂進既有母架構。",
      "",
      "固定主書系：",
      tracksText,
      "",
      "工作目標：",
      "1. 把零散文章整理成一本一本可持續完成的書。",
      "2. 先用『主書系 -> 章節 -> 已有文章 -> 還缺文章』的方式規劃。",
      "3. 優先找出最適合先完成的第一本書。",
      "4. 每篇文章都要被分配到明確的主書系與章節，不要只做模糊分類。",
      "",
      "請直接輸出：",
      "A. 建議先主攻的 1 本主書系，以及原因",
      "B. 各主書系的定位與目標讀者",
      "C. 各主書系的章節架構",
      "D. 目前文章應歸到哪個主書系、哪一章",
      "E. 每個主書系還缺哪些關鍵文章",
      "F. 最優先下一篇該補哪 5 篇，並說明原因",
      "G. 哪些現有標題適合改名，讓未來更像書稿章名",
      "H. 請補一份『文章入庫規則』，格式固定為：主書系 / 章節定位 / 網站分類 / 搜尋主關鍵字 / 導流目的",
      "",
      `目前文章數：${articleLibrary.length}`,
      `目前分類：${categories || "未分類"}`,
      "",
      "現有文章清單：",
      buildArticleTitlesText(),
    ].join("\n");
  }

  function buildProFinalizePrompt(problemText = "", aiDraft = "") {
    const questionBlock = problemText.trim() || "（請在此貼上真實社團問題）";
    const aiDraftBlock = aiDraft.trim() || "（請先貼上 Gemini Flash 產出的 AI 結果）";
    const confirmData = getArticleConfirmData(aiDraftBlock);

    return [
      "你是青曦空間設計的內容總編與定稿編輯，現在要接手 Gemini Flash 的初稿，將其提升為可正式發布的高品質版本。",
      "品牌調性固定：高級、極簡、安定、耐看、不油、不賣弄，不要寫成內容農場或業配腔。",
      "",
      "你的任務不是重新亂寫一版，而是站在高階模型的角度，對既有初稿做：",
      "1. 結構校正",
      "2. 邏輯補強",
      "3. 文氣收斂",
      "4. SEO 與可讀性提升",
      "5. 檢查是否與既有文章過度重複",
      "",
      "【真實社團問題】",
      questionBlock,
      "",
      "【Gemini Flash 初稿 / 判題結果】",
      aiDraftBlock,
      "",
      "【目前工作台解析出的正式落地資訊】",
      `網站分類：${confirmData.category}`,
      `主書系：${confirmData.track}`,
      `章節定位：${confirmData.chapter}`,
      `文章標題：${confirmData.title}`,
      "",
      "請你輸出以下內容，並嚴格依照順序：",
      "",
      "A. 【定稿判斷】",
      "- 先判斷這篇內容是否已達可發佈水準。",
      "- 請只選一種：可直接發布 / 小修即可發布 / 仍需大修。",
      "- 用 2-4 句說明原因。",
      "",
      "B. 【重複風險覆核】",
      "- 判斷這篇文是否與既有舊文過於重複。",
      "- 若重複風險高，請明確指出應該保留哪個主軸、刪掉哪類重複段落。",
      "",
      "C. 【發布版標題】",
      "- 給出 1 個最推薦正式發布標題。",
      "- 再補 2 個備選標題。",
      "- 標題要兼顧品牌質感與 SEO，不要俗氣聳動。",
      "",
      "D. 【正式發布摘要】",
      "- 請輸出 120-160 字摘要，可直接作為知識分享摘要或 meta description 草稿。",
      "",
      "E. 【正式發布文章（Markdown）】",
      "- 請輸出一篇真正可發佈的完整版本。",
      "- 保留高資訊密度，但文氣要穩定、乾淨、有設計感。",
      "- 若某些段落屬於補舊文邏輯，請整理成可直接回填舊文的段落版本，不要無謂重複。",
      "- 絕對不要出現推銷腔、口號腔、空泛形容詞堆砌。",
      "",
      "F. 【最終發布欄位確認】",
      "- 請用固定格式輸出：網站分類 / 主書系 / 章節定位 / 文章標題 / 摘要 / 建議 slug",
      "- slug 請使用英文小寫加連字號。",
      "",
      "G. 【最後人工檢查清單】",
      "- 請列出 3-5 條發布前應人工確認的地方。",
      "- 例如：是否與既有文章重複、是否需要補真實案例、是否需要調整分類等。",
    ].join("\n");
  }

  function loadArticleSourceQuestion() {
    try {
      articleSourceQuestion = localStorage.getItem(ARTICLE_SOURCE_QUESTION_KEY) || "";
    } catch (error) {
      console.error("讀取社團問題草稿失敗：", error);
      articleSourceQuestion = "";
    }
  }

  function applyArticleSourceQuestionToField() {
    const field = document.getElementById("article-source-question");
    if (!(field instanceof HTMLTextAreaElement)) return;
    field.value = articleSourceQuestion;
  }

  function persistArticleSourceQuestion() {
    const field = document.getElementById("article-source-question");
    if (!(field instanceof HTMLTextAreaElement)) return "";
    articleSourceQuestion = field.value.trim();
    localStorage.setItem(ARTICLE_SOURCE_QUESTION_KEY, articleSourceQuestion);
    return articleSourceQuestion;
  }

  function loadArticleAiResult() {
    try {
      const raw = localStorage.getItem(ARTICLE_AI_RESULT_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      articleAiResult = typeof parsed?.content === "string" ? parsed.content : "";
      articleAiMode = typeof parsed?.mode === "string" ? parsed.mode : "";
    } catch (error) {
      console.error("讀取 AI 結果失敗：", error);
      articleAiResult = "";
      articleAiMode = "";
    }
  }

  function saveArticleAiResult() {
    localStorage.setItem(
      ARTICLE_AI_RESULT_KEY,
      JSON.stringify({
        content: articleAiResult,
        mode: articleAiMode,
      }),
    );
  }

  function setArticleAiFeedback(message, mode = "") {
    const shell = document.getElementById("article-ai-feedback");
    if (!shell) return;
    shell.className = `bookshelf-ai-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function renderArticleAiResult() {
    const shell = document.getElementById("article-ai-result-shell");
    const label = document.getElementById("article-ai-result-label");
    const content = document.getElementById("article-ai-result-content");
    const decisionShell = document.getElementById("article-ai-decision");
    const decisionTitle = document.getElementById("article-ai-decision-title");
    const decisionAction = document.getElementById("article-ai-decision-action");
    const decisionSimilar = document.getElementById("article-ai-decision-similar");
    const decisionAngle = document.getElementById("article-ai-decision-angle");
    const decisionTrack = document.getElementById("article-ai-decision-track");
    const decisionChapter = document.getElementById("article-ai-decision-chapter");
    const decisionArticleTitle = document.getElementById("article-ai-decision-article-title");
    if (
      !(shell instanceof HTMLDetailsElement) ||
      !(label instanceof HTMLElement) ||
      !(content instanceof HTMLElement) ||
      !(decisionShell instanceof HTMLElement) ||
      !(decisionTitle instanceof HTMLElement) ||
      !(decisionAction instanceof HTMLElement) ||
      !(decisionSimilar instanceof HTMLElement) ||
      !(decisionAngle instanceof HTMLElement) ||
      !(decisionTrack instanceof HTMLElement) ||
      !(decisionChapter instanceof HTMLElement) ||
      !(decisionArticleTitle instanceof HTMLElement)
    ) {
      return;
    }

    const hasResult = Boolean(articleAiResult.trim());
    const decision = getArticleAiDecision(articleAiResult);
    const confirmData = getArticleConfirmData(articleAiResult);
    renderArticleConfirm(articleAiResult);
    label.textContent = hasResult
      ? articleAiMode === "quick"
        ? "快速判題"
        : "完整初稿"
      : "尚未生成";
    decisionShell.hidden = !hasResult;
    decisionTitle.textContent = decision.title;
    decisionAction.textContent = decision.action;
    decisionSimilar.textContent = decision.similar;
    decisionAngle.textContent = decision.angle;
    decisionTrack.textContent = confirmData.track;
    decisionChapter.textContent = confirmData.chapter;
    decisionArticleTitle.textContent = confirmData.title;
    content.textContent = articleAiResult;
    shell.open = hasResult;
  }

  function setArticleAiBusy(isBusy) {
    ["run-article-ai-flow", "run-article-ai-quick", "run-article-ai-draft", "copy-pro-finalize-prompt", "copy-article-ai-result", "copy-article-category", "copy-article-confirm-payload"].forEach((id) => {
      const button = document.getElementById(id);
      if (button instanceof HTMLButtonElement) {
        button.disabled = isBusy;
      }
    });
  }

