import PublishingModePanel from "../../components/PublishingModePanel.astro";
import * as contentful from "contentful";
import {
  mapContentfulBlogPosts,
  mergeBlogPosts,
  staticBlogPosts,
} from "../../lib/blog-catalog";
import {
  bookshelfSubchapterPools,
  bookshelfTracks,
  getPublishingDashboard,
  getNextRecommendedTopic,
  getNextRecommendedTopics,
  getTrackRecommendedTopics,
  getPublishingCoverageSummary,
  publishingFocusTrackTitle,
  publishingTopicModeOptions,
} from "../../lib/content-taxonomy";
import { geminiCanvasMaster } from "../../lib/gemini-canvas-master";

const defaultSources = [
  {
    id: "group-1654316948220005",
    alias: "汐止集團｜汐止人交流｜大小事",
    platform: "Facebook",
    url: "https://www.facebook.com/groups/1654316948220005/",
  },
  {
    id: "group-679286528824529",
    alias: "內湖 & 松山 & 南港 & 汐止 集團",
    platform: "Facebook",
    url: "https://www.facebook.com/groups/679286528824529",
  },
  {
    id: "group-163175389244849",
    alias: "汐止 南港 台北 新北 租屋 買賣網",
    platform: "Facebook",
    url: "https://www.facebook.com/groups/163175389244849",
  },
  {
    id: "line-community-1",
    alias: "南港人內湖人店家房市大小事",
    platform: "LINE",
    url: "https://line.me/ti/g2/PqRgmGp0TD6NdO_mU2Cp5NZEUCjU6UeE1hrrXw?utm_source=invitation&utm_medium=link_copy&utm_campaign=default",
  },
  {
    id: "line-community-2",
    alias: "南港內湖生活圈討論群",
    platform: "LINE",
    url: "https://line.me/ti/g2/hc7WHOLh4D5ZKYgSiA7cW1klztRTtza3CMK4PA?utm_source=invitation&utm_medium=link_copy&utm_campaign=default",
  },
  {
    id: "google-business",
    alias: "Google 商家編輯",
    platform: "Google",
    url: "https://www.google.com/search?q=%E9%9D%92%E6%9B%A6%E7%A9%BA%E9%96%93%E8%A8%AD%E8%A8%88&stick=H4sIAAAAAAAA_wE8AMP_CAYiIzB4Y2Y1NzIzYWQyN2I2OGVmOjB4MzMzYmU1YWI0ZDAxYjBiogUS6Z2S5pum56m66ZaT6Kit6KiI6b38AjwAAAA&hl=zh-TW&mat=CZzruPD9kuTbElcBa0lj_0QRxYoywBlV9k9DYHoy-VFRkTjl1IkHR0qufOOE0MNc1wkNSVfDEkXxAJyYs12m8HUMY9ODzhD28iMbxLDtTMqjl02vI5c77ni0KGBTZjiz2vc&authuser=9",
  },
];

const vendorTradeOptions = [
  "木作",
  "系統櫃",
  "泥作",
  "水電",
  "油漆",
  "燈光",
  "窗簾",
  "地板",
  "鐵件",
  "玻璃",
  "軟裝",
  "清潔",
  "其他",
];

const vendorPriceLevelOptions = [
  "低",
  "中低",
  "中",
  "中高",
  "高",
];

const vendorCraftLevelOptions = [
  "粗工",
  "標準",
  "細緻",
  "很細",
];

let blogPosts = staticBlogPosts.map(({ coverImage, ...post }) => post);
let blogSyncLabel = "目前先顯示已存在文章。";

try {
  if (import.meta.env.CONTENTFUL_SPACE_ID && import.meta.env.CONTENTFUL_ACCESS_TOKEN) {
    const client = contentful.createClient({
      space: import.meta.env.CONTENTFUL_SPACE_ID,
      accessToken: import.meta.env.CONTENTFUL_ACCESS_TOKEN,
      environment: "master",
    });

    const response = await client.getEntries({
      content_type: "blogPost",
      order: ["-fields.date"],
    });

    const syncedPosts = mapContentfulBlogPosts(response.items).map(
      ({ coverImage, ...post }) => post,
    );

    if (syncedPosts.length > 0) {
      blogPosts = mergeBlogPosts([
        ...staticBlogPosts.map(({ coverImage, ...post }) => post),
        ...syncedPosts,
      ]);
      blogSyncLabel = `已同步 ${blogPosts.length} 篇知識文章。`;
    } else {
      blogSyncLabel = "Contentful 目前無文章，先顯示已存在文章。";
    }
  } else {
    blogSyncLabel = "未連接 Contentful，先顯示已存在文章。";
  }
} catch (error) {
  console.error("讀取知識分享文章失敗：", error);
  blogSyncLabel = "同步失敗，先顯示已存在文章。";
}

function buildTopicModeRationale(modeValue: string, modeDashboard: any, modeRecommendation: any) {
  if (!modeDashboard?.focusTrack || !modeRecommendation) return "目前資料不足，先沿用既有排序。";

  if (modeValue === "publishing") {
    return `先補 ${modeRecommendation.chapter} > ${modeRecommendation.subchapter}，最快推進 ${modeDashboard.focusTrack.title} 出版進度。`;
  }

  if (modeValue === "balanced") {
    return `主線仍是 ${modeDashboard.focusTrack.title}，但這題也能順手補到 ${modeRecommendation.trackTitle}。`;
  }

  return modeRecommendation.sameSubchapterArticles.length
    ? `Flash 依既有文章換切角，但仍留在 ${modeRecommendation.trackTitle} 的書稿骨架內。`
    : `先用 Flash 找新切角，但不離開 ${modeRecommendation.trackTitle} 的固定骨架。`;
}

const publishingCoverage = getPublishingCoverageSummary(blogPosts, publishingFocusTrackTitle);
const topicModeMap = Object.fromEntries(
  publishingTopicModeOptions.map((modeOption) => {
    const publishingDashboard = getPublishingDashboard(blogPosts, publishingFocusTrackTitle, modeOption.value);
    const nextRecommendedTopic = getNextRecommendedTopic(blogPosts, publishingFocusTrackTitle, modeOption.value);
    const nextTopicCandidates = getNextRecommendedTopics(blogPosts, publishingFocusTrackTitle, modeOption.value, 6);
    const trackRecommendations = getTrackRecommendedTopics(blogPosts, publishingFocusTrackTitle, modeOption.value)
      .sort((left, right) => {
        const leftRank = publishingDashboard.rankedTracks.findIndex((track) => track.title === left.trackTitle);
        const rightRank = publishingDashboard.rankedTracks.findIndex((track) => track.title === right.trackTitle);
        return leftRank - rightRank;
      });
    return [
      modeOption.value,
      {
        ...modeOption,
        publishingDashboard,
        nextRecommendedTopic,
        nextTopicCandidates,
        trackRecommendations,
        modeRationale: buildTopicModeRationale(modeOption.value, publishingDashboard, nextRecommendedTopic),
      },
    ];
  }),
);
const defaultTopicMode = publishingTopicModeOptions[0]?.value || "publishing";
const defaultModeOption = publishingTopicModeOptions.find((modeOption) => modeOption.value === defaultTopicMode) || publishingTopicModeOptions[0];
const defaultModeState = topicModeMap[defaultTopicMode];
const publishingDashboard = topicModeMap[defaultTopicMode].publishingDashboard;

const defaultSourcesJson = JSON.stringify(defaultSources);
const blogPostsJson = JSON.stringify(blogPosts);
const bookshelfTracksJson = JSON.stringify(bookshelfTracks);
const bookshelfSubchapterPoolsJson = JSON.stringify(bookshelfSubchapterPools);
const geminiCanvasMasterJson = JSON.stringify(geminiCanvasMaster);
const vendorTradeOptionsJson = JSON.stringify(vendorTradeOptions);
const topicModeOptionsJson = JSON.stringify(publishingTopicModeOptions);
const topicModeMapJson = JSON.stringify(topicModeMap);
---

