  function hydrateVendorIntakeTools() {
    const shareUrlNode = document.getElementById("vendor-intake-share-url");
    const replyNode = document.getElementById("vendor-intake-canned-reply");
    const openNode = document.getElementById("open-vendor-intake-page");
    const shareUrl = buildVendorIntakeShareUrl();
    const cannedReply = buildVendorIntakeCannedReply(shareUrl);

    if (shareUrlNode instanceof HTMLInputElement) {
      shareUrlNode.value = shareUrl;
    }
    if (replyNode instanceof HTMLTextAreaElement) {
      replyNode.value = cannedReply;
    }
