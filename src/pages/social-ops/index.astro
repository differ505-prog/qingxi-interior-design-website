      };
    }
    if (/格局|動線|客廳|餐廳|臥室|空間/.test(seed)) {
      return {
        short: "這種通常要先把動線跟尺寸抓清楚，不然做完才發現不好用。",
        pro: "這類問題通常不是單看平面或風格，還要一起看家具尺寸、收納位置跟實際使用習慣，不然很容易做完又想改。",
