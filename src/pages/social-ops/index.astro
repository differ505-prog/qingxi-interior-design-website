  document.getElementById("run-article-ai-flow-highfreq")?.addEventListener("click", async () => {
    await runArticleAiFlow();
  });

  document.getElementById("copy-article-context-summary")?.addEventListener("click", async () => {
    const result = await copyText(buildArticleContextSummary(), "已複製情境摘要。");
    const feedback = getCopyFeedbackState(result, "已複製情境摘要。", "已開啟手動複製視窗，可直接複製情境摘要。");
    setFeedback(feedback.message, feedback.mode);
    setArticleAiFeedback(feedback.message, feedback.mode);
