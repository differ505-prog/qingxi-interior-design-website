let blogPosts = staticBlogPosts.map(({ coverImage, ...post }) => post);
let blogSyncLabel = "目前先顯示已存在文章。";

try {
  if (import.meta.env.CONTENTFUL_SPACE_ID && import.meta.env.CONTENTFUL_ACCESS_TOKEN) {
    const client = contentful.createClient({
      space: import.meta.env.CONTENTFUL_SPACE_ID,
      accessToken: import.meta.env.CONTENTFUL_ACCESS_TOKEN,
      environment: "master",
    });

    const response = await client.getEntries({
      content_type: "blogPost",
      order: ["-fields.date"],
    });

    const syncedPosts = mapContentfulBlogPosts(response.items).map(
      ({ coverImage, ...post }) => post,
    );

    if (syncedPosts.length > 0) {
      blogPosts = mergeBlogPosts([
        ...staticBlogPosts.map(({ coverImage, ...post }) => post),
        ...syncedPosts,
      ]);
      blogSyncLabel = `已同步 ${blogPosts.length} 篇知識文章。`;
    } else {
      blogSyncLabel = "Contentful 目前無文章，先顯示已存在文章。";
    }
  } else {
    blogSyncLabel = "未連接 Contentful，先顯示已存在文章。";
  }
} catch (error) {
  console.error("讀取知識分享文章失敗：", error);
  blogSyncLabel = "同步失敗，先顯示已存在文章。";
}

function buildTopicModeRationale(modeValue: string, modeDashboard: any, modeRecommendation: any) {
  if (!modeDashboard?.focusTrack || !modeRecommendation) return "目前資料不足，先沿用既有排序。";

  if (modeValue === "publishing") {
    return `先補 ${modeRecommendation.chapter} > ${modeRecommendation.subchapter}，最快推進 ${modeDashboard.focusTrack.title} 出版進度。`;
  }

  if (modeValue === "balanced") {
    return `主線仍是 ${modeDashboard.focusTrack.title}，但這題也能順手補到 ${modeRecommendation.trackTitle}。`;
  }

  return modeRecommendation.sameSubchapterArticles.length
    ? `Flash 依既有文章換切角，但仍留在 ${modeRecommendation.trackTitle} 的書稿骨架內。`
    : `先用 Flash 找新切角，但不離開 ${modeRecommendation.trackTitle} 的固定骨架。`;
}

const publishingCoverage = getPublishingCoverageSummary(blogPosts, publishingFocusTrackTitle);
const topicModeMap = Object.fromEntries(
  publishingTopicModeOptions.map((modeOption) => {
    const publishingDashboard = getPublishingDashboard(blogPosts, publishingFocusTrackTitle, modeOption.value);
    const nextRecommendedTopic = getNextRecommendedTopic(blogPosts, publishingFocusTrackTitle, modeOption.value);
    const nextTopicCandidates = getNextRecommendedTopics(blogPosts, publishingFocusTrackTitle, modeOption.value, 6);
    const trackRecommendations = getTrackRecommendedTopics(blogPosts, publishingFocusTrackTitle, modeOption.value)
      .sort((left, right) => {
        const leftRank = publishingDashboard.rankedTracks.findIndex((track) => track.title === left.trackTitle);
        const rightRank = publishingDashboard.rankedTracks.findIndex((track) => track.title === right.trackTitle);
        return leftRank - rightRank;
      });
    return [
      modeOption.value,
      {
        ...modeOption,
        publishingDashboard,
        nextRecommendedTopic,
        nextTopicCandidates,
        trackRecommendations,
        modeRationale: buildTopicModeRationale(modeOption.value, publishingDashboard, nextRecommendedTopic),
      },
    ];
  }),
);
const defaultTopicMode = publishingTopicModeOptions[0]?.value || "publishing";
