                        <div class="vendor-note-meta">${metaItems || "<span>尚未補地區或更新資訊</span>"}</div>
                      </div>
                      <div class="vendor-note-card-actions">
                        ${primaryUrl
                          ? `<a class="vendor-note-action-link" href="${escapeHtml(primaryUrl)}" target="_blank" rel="noreferrer">開啟</a>`
