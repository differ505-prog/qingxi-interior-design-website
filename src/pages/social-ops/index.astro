  function loadPublishingAssetSlotsState() {
    try {
      const raw = localStorage.getItem(PUBLISHING_ASSET_SLOTS_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      publishingAssetSlotsState = parsed && typeof parsed === "object" ? parsed : {};
    } catch (error) {
      console.error("讀取資產掛載槽失敗：", error);
      publishingAssetSlotsState = {};
    }
  }

  function savePublishingAssetSlotsState() {
    try {
      localStorage.setItem(PUBLISHING_ASSET_SLOTS_KEY, JSON.stringify(publishingAssetSlotsState));
    } catch (error) {
      console.error("儲存資產掛載槽失敗：", error);
    }
  }

  function getPublishingAssetSlotItems() {
    const focusTrack = getCurrentTopicModeState(currentTopicMode)?.publishingDashboard?.focusTrack;
    const titlePool = Array.isArray(focusTrack?.titlePool)
      ? focusTrack.titlePool
      : focusTrack?.chapterGaps?.flatMap((gap) => gap.titlePool || []) || [];
    return titlePool.filter((item) => item.assetSlotLabel || item.nodeKind === "form" || item.nodeKind === "project");
  }

  function getPublishingAssetSlotKey(item) {
    return [item.trackTitle || "", item.chapter || "", item.subchapter || "", item.primaryTitle || ""].join("::");
  }

  function applyArticleSourceQuestionToField() {
    const field = document.getElementById("article-source-question");
    if (!(field instanceof HTMLTextAreaElement)) return;
    field.value = articleSourceQuestion;
  }

  function getRecommendedArticleSeed() {
    const modeState = getCurrentTopicModeState(currentTopicMode);
    const recommendation = getPrimaryReviewRecommendation(currentTopicMode);
    const focusTrack = modeState?.publishingDashboard?.focusTrack;
    return {
      recommendation,
      focusTrack,
      bookProposal: getBookProposal(currentTopicMode),
    };
  }

  function getResolvedArticlePresetTitle() {
    const field = document.getElementById("article-preset-title");
    const rawValue = field instanceof HTMLInputElement ? field.value.trim() : articlePresetTitle.trim();
    if (rawValue) return rawValue;
    if (articleTopicDecision?.title) return articleTopicDecision.title;
    return getDisplayTitle(getRecommendedArticleSeed().recommendation);
  }

  function applyArticlePresetTitleToField() {
    const field = document.getElementById("article-preset-title");
    if (!(field instanceof HTMLInputElement)) return;
    field.value = articlePresetTitle || "";
    field.placeholder = getResolvedArticlePresetTitle() || "例如：屋況盤點與範圍界定總表";
  }

  function persistArticleSourceQuestion() {
    const field = document.getElementById("article-source-question");
    if (!(field instanceof HTMLTextAreaElement)) return "";
    articleSourceQuestion = field.value.trim();
    try {
      localStorage.setItem(ARTICLE_SOURCE_QUESTION_KEY, articleSourceQuestion);
    } catch (error) {
      console.error("儲存社團問題草稿失敗：", error);
    }
    return articleSourceQuestion;
  }

  function persistArticlePresetTitle() {
    const field = document.getElementById("article-preset-title");
    if (!(field instanceof HTMLInputElement)) return articlePresetTitle;
    articlePresetTitle = field.value.trim();
    try {
      localStorage.setItem(ARTICLE_PRESET_TITLE_KEY, articlePresetTitle);
    } catch (error) {
      console.error("儲存本輪預設題目失敗：", error);
    }
    return articlePresetTitle;
  }

  function renderPublishingAssetSlots() {
    const target = document.getElementById("publishing-asset-slot-target");
    const list = document.getElementById("publishing-asset-slot-list");
    const note = document.getElementById("publishing-asset-slot-note");
    if (!(target instanceof HTMLSelectElement) || !(list instanceof HTMLElement) || !(note instanceof HTMLElement)) {
      return;
    }
    const assetSlots = getPublishingAssetSlotItems();
    const currentValue = target.value;
    target.innerHTML = assetSlots.length
      ? assetSlots.map((item) => {
        const key = getPublishingAssetSlotKey(item);
        return `<option value="${escapeHtml(key)}">${escapeHtml(getPublicationChapterLabel(item.chapter))} / ${escapeHtml(item.assetSlotLabel || item.primaryTitle)}</option>`;
      }).join("")
      : '<option value="">目前尚無可掛載的附錄節點</option>';
    if (assetSlots.some((item) => getPublishingAssetSlotKey(item) === currentValue)) {
      target.value = currentValue;
    }
    const activeKey = target.value;
    const totalAssets = Object.values(publishingAssetSlotsState).reduce(
      (sum, items) => sum + (Array.isArray(items) ? items.length : 0),
      0,
    );
    list.innerHTML = assetSlots.length
      ? assetSlots.map((item) => {
        const key = getPublishingAssetSlotKey(item);
        const assets = Array.isArray(publishingAssetSlotsState[key]) ? publishingAssetSlotsState[key] : [];
        const latestAssetUpdate = assets[assets.length - 1]?.updatedAt || "";
        return `
          <article class="bookshelf-asset-slot-card ${key === activeKey ? "is-active" : ""}">
            <div class="bookshelf-asset-slot-head">
              <span>${escapeHtml(item.statusTag || "附錄節點")}</span>
              <strong>${escapeHtml(item.assetSlotLabel || item.primaryTitle)}</strong>
              <em>${assets.length} 份資產</em>
            </div>
            <small>${escapeHtml(item.chapter)} / ${escapeHtml(item.subchapter)}</small>
            ${latestAssetUpdate ? `<p class="bookshelf-confirm-note">最後更新：${escapeHtml(latestAssetUpdate)}｜若 Google Sheets / PDF 已更新，請同步檢查文章是否需要改版。</p>` : ""}
            ${assets.length ? `
              <ul class="bookshelf-asset-slot-assets">
                ${assets.map((asset, index) => `
                  <li>
                    <div>
                      <strong>${escapeHtml(asset.name || "未命名資產")}</strong>
                      <small>${escapeHtml(asset.type || "未知類型")}｜${escapeHtml(asset.updatedAt || "剛剛掛載")}</small>
                    </div>
                    <button type="button" class="bookshelf-review-mini-btn" data-asset-slot-key="${escapeHtml(key)}" data-asset-slot-index="${index}">移除</button>
                  </li>
                `).join("")}
              </ul>
            ` : '<p class="bookshelf-confirm-note">尚未掛載資產，可拖入 Spreadsheet、PDF，或後續串接互動工具下載點。</p>'}
          </article>
        `;
      }).join("")
      : '<p class="bookshelf-confirm-note">目前尚無可掛載的附錄節點。</p>';
    note.textContent = totalAssets
      ? `目前已掛載 ${totalAssets} 份資產；若試算表或 PDF 更新，工作台會提示你回頭檢查文章是否同步改版。`
      : "目前尚未掛載附錄資產；可先把表單、規格表、Excel 或 PDF 掛進對應節點。";
  }

  function attachAssetsToSelectedSlot(fileList) {
    const target = document.getElementById("publishing-asset-slot-target");
    if (!(target instanceof HTMLSelectElement) || !target.value) return;
    const files = Array.from(fileList || []).filter(Boolean);
    if (!files.length) return;
    const existing = Array.isArray(publishingAssetSlotsState[target.value]) ? publishingAssetSlotsState[target.value] : [];
    const nextItems = files.map((file) => ({
      name: file.name || "未命名檔案",
      type: file.type || "application/octet-stream",
      size: file.size || 0,
      updatedAt: new Date().toLocaleString("zh-TW"),
    }));
    publishingAssetSlotsState[target.value] = [...existing, ...nextItems];
    savePublishingAssetSlotsState();
    renderPublishingAssetSlots();
  }

  function removePublishingAssetSlotItem(slotKey, index) {
    if (!slotKey || typeof index !== "number") return;
    const currentItems = Array.isArray(publishingAssetSlotsState[slotKey]) ? publishingAssetSlotsState[slotKey] : [];
    publishingAssetSlotsState[slotKey] = currentItems.filter((_, itemIndex) => itemIndex !== index);
    if (!publishingAssetSlotsState[slotKey].length) {
      delete publishingAssetSlotsState[slotKey];
    }
    savePublishingAssetSlotsState();
    renderPublishingAssetSlots();
  }

