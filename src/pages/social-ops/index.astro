  function loadArticleSourceQuestion() {
    try {
      articleSourceQuestion = localStorage.getItem(ARTICLE_SOURCE_QUESTION_KEY) || "";
    } catch (error) {
      console.error("讀取社團問題草稿失敗：", error);
      articleSourceQuestion = "";
    }
  }

  function applyArticleSourceQuestionToField() {
    const field = document.getElementById("article-source-question");
    if (!(field instanceof HTMLTextAreaElement)) return;
    field.value = articleSourceQuestion;
  }

  function persistArticleSourceQuestion() {
    const field = document.getElementById("article-source-question");
    if (!(field instanceof HTMLTextAreaElement)) return "";
    articleSourceQuestion = field.value.trim();
    localStorage.setItem(ARTICLE_SOURCE_QUESTION_KEY, articleSourceQuestion);
    return articleSourceQuestion;
  }

  function loadArticleAiResult() {
    try {
      const raw = localStorage.getItem(ARTICLE_AI_RESULT_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      articleAiResult = typeof parsed?.content === "string" ? parsed.content : "";
      articleAiMode = typeof parsed?.mode === "string" ? parsed.mode : "";
    } catch (error) {
      console.error("讀取 AI 結果失敗：", error);
      articleAiResult = "";
      articleAiMode = "";
    }
  }

  function saveArticleAiResult() {
    localStorage.setItem(
      ARTICLE_AI_RESULT_KEY,
      JSON.stringify({
        content: articleAiResult,
        mode: articleAiMode,
      }),
    );
  }

  function setArticleAiFeedback(message, mode = "") {
    const shell = document.getElementById("article-ai-feedback");
    if (!shell) return;
    shell.className = `bookshelf-ai-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function renderArticleAiResult() {
    const shell = document.getElementById("article-ai-result-shell");
    const label = document.getElementById("article-ai-result-label");
    const content = document.getElementById("article-ai-result-content");
    const decisionShell = document.getElementById("article-ai-decision");
    const decisionTitle = document.getElementById("article-ai-decision-title");
    const decisionAction = document.getElementById("article-ai-decision-action");
    const decisionSimilar = document.getElementById("article-ai-decision-similar");
    const decisionAngle = document.getElementById("article-ai-decision-angle");
    const decisionTrack = document.getElementById("article-ai-decision-track");
    const decisionChapter = document.getElementById("article-ai-decision-chapter");
    const decisionArticleTitle = document.getElementById("article-ai-decision-article-title");
    if (
      !(shell instanceof HTMLDetailsElement) ||
      !(label instanceof HTMLElement) ||
      !(content instanceof HTMLElement) ||
      !(decisionShell instanceof HTMLElement) ||
      !(decisionTitle instanceof HTMLElement) ||
      !(decisionAction instanceof HTMLElement) ||
      !(decisionSimilar instanceof HTMLElement) ||
      !(decisionAngle instanceof HTMLElement) ||
      !(decisionTrack instanceof HTMLElement) ||
      !(decisionChapter instanceof HTMLElement) ||
      !(decisionArticleTitle instanceof HTMLElement)
    ) {
      return;
    }

    const hasResult = Boolean(articleAiResult.trim());
    const decision = getArticleAiDecision(articleAiResult);
    const confirmData = getArticleConfirmData(articleAiResult);
    renderArticleConfirm(articleAiResult);
    renderArticleSocialReplies(articleAiResult);
    label.textContent = hasResult
      ? articleAiMode === "quick"
        ? "快速判題"
        : "Flash 長稿備援"
      : "尚未生成";
    decisionShell.hidden = !hasResult;
    decisionTitle.textContent = decision.title;
    decisionAction.textContent = decision.action;
    decisionSimilar.textContent = decision.similar;
    decisionAngle.textContent = decision.angle;
    decisionTrack.textContent = confirmData.track;
    decisionChapter.textContent = confirmData.chapter;
    decisionArticleTitle.textContent = confirmData.title;
    content.textContent = articleAiResult;
    shell.open = hasResult;
  }

  function setArticleAiBusy(isBusy) {
