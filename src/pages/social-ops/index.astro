  .command-badge {
    padding: 1rem 1rem 0.92rem;
    background:
      radial-gradient(circle at top left, rgba(244, 242, 236, 0.06), transparent 42%),
      linear-gradient(180deg, rgba(63, 63, 62, 0.96), rgba(34, 34, 34, 0.96));
  }

