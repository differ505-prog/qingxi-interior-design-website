    return itemId ? `${SITE_ORIGIN}${VENDOR_INTAKE_FILE_URL}?id=${encodeURIComponent(itemId)}` : "";
  }

  function buildVendorIntakePromotedImpression(item = {}) {
    const emphasis = [item.projectFocus, item.craftApproach].filter(Boolean).join(" / ");
    if (emphasis) return emphasis;
    if (item.trade) return `${item.trade} 可先列入待評估合作名單`;
    return "可先列入待評估合作名單";
  }

  function buildVendorIntakePromotedMemo(item = {}) {
    const lines = [];
    if (item.note) lines.push(`工班自填說明：${item.note}`);
    if (item.internalNote) lines.push(`內部備註：${item.internalNote}`);
    const summaryParts = [
      item.projectFocus ? `擅長案型：${item.projectFocus}` : "",
      item.craftApproach ? `工法細緻度：${item.craftApproach}` : "",
      item.pricingMode ? `報價方式：${getVendorPricingModeLabel(item.pricingMode)}` : "",
      item.pricingDisclosure ? `資料提供：${getVendorPricingDisclosureLabel(item.pricingDisclosure)}` : "",
      item.acceptsContract ? `簽約：${getVendorContractLabel(item.acceptsContract)}` : "",
      item.invoiceStatus ? `發票：${getVendorInvoiceLabel(item.invoiceStatus)}` : "",
    ].filter(Boolean);
    if (summaryParts.length) lines.push(summaryParts.join("｜"));
    return lines.join("\n");
  }

  function buildVendorNoteFromIntake(item = {}) {
    const noteId = getVendorIntakeNoteId(item.id);
    const existingNote = (vendorNotesState.items || []).find((entry) => entry.id === noteId);
    const now = new Date().toISOString();
    return {
      ...createVendorNoteTemplate(),
      ...existingNote,
      id: noteId || createVendorNoteId(),
      name: item.teamName ? `${item.name || "未命名工班"} / ${item.teamName}` : (item.name || "未命名工班"),
      trade: item.trade || existingNote?.trade || "",
      priceLevel: existingNote?.priceLevel || mapPricingDisclosureToPriceLevel(item.pricingDisclosure),
      craftLevel: existingNote?.craftLevel || mapCraftApproachToCraftLevel(item.craftApproach),
      primaryUrl: buildVendorIntakeAttachmentUrl(item.id),
      secondaryUrl: existingNote?.secondaryUrl || "",
      location: item.serviceArea || existingNote?.location || "",
      impression: existingNote?.impression || buildVendorIntakePromotedImpression(item),
      memo: buildVendorIntakePromotedMemo(item),
      sourceType: "vendor_submitted",
      isPinned: Boolean(existingNote?.isPinned),
      createdAt: existingNote?.createdAt || now,
      updatedAt: now,
    };
  }

  function setVendorNoteFeedback(message, mode = "") {
    const shell = document.getElementById("vendor-note-feedback");
    if (!(shell instanceof HTMLElement)) return;
    shell.className = `vendor-note-feedback ${mode}`.trim();
    shell.textContent = message;
