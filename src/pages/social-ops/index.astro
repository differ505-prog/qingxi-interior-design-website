      "2. 先用『主書系 -> 章節 -> 子章節 -> 已有文章 -> 還缺文章』的方式規劃。",
      "3. 優先找出最適合先完成的第一本書。",
      "4. 每篇文章都要被分配到明確的主書系、章節與子章節，不要只做模糊分類。",
      "",
      "請直接輸出：",
      "A. 建議先主攻的 1 本主書系，以及原因",
      "B. 各主書系的定位與目標讀者",
      "C. 各主書系的章節與子章節架構",
      "D. 目前文章應歸到哪個主書系、哪一章、哪個子章節",
      "E. 每個主書系還缺哪些關鍵文章與子章節補位",
      "F. 最優先下一篇該補哪 5 篇，並說明原因",
      "G. 哪些現有標題適合改名，讓未來更像書稿章名",
      "H. 請補一份『文章入庫規則』，格式固定為：主書系 / 章節定位 / 網站分類 / 搜尋主關鍵字 / 導流目的",
      "",
      `目前文章數：${articleLibrary.length}`,
      `目前網站分類：${categories || "未分類"}`,
      "",
      "現有文章清單：",
      buildArticleTitlesText(),
    ].join("\n");
  }

  function normalizeTitleForCompare(value = "") {
    return value.replace(/\s+/g, "").trim().toLowerCase();
  }

  function isPublishedArticleTitle(title = "") {
    const normalizedTitle = normalizeTitleForCompare(title);
    if (!normalizedTitle) return false;
    return articleLibrary.some((post) => normalizeTitleForCompare(post.title) === normalizedTitle);
  }

  function getPublishedPostsForChapter(trackTitle = "", chapterTitle = "") {
    return articleLibrary.filter((post) => post.track === trackTitle && post.chapter === chapterTitle);
  }

  function getPublishedPostSubchapter(post) {
    return inferSubchapterFromTrack(
      post.track || "",
      post.chapter || "",
      post.title || "",
      post.summary || "",
      Array.isArray(post.tags) ? post.tags.join(" ") : "",
    );
  }

  function getPublishedPostBookTitle(post) {
    return post.title || buildBookTopicTitle(post.track || "", post.chapter || "", getPublishedPostSubchapter(post));
  }

  function getPublicationMergeRule(trackTitle = "", chapterTitle = "") {
    return publicationMergeRules.find((rule) => (
      rule.trackTitle === trackTitle && rule.chapterTitle === chapterTitle
    )) || null;
  }

  function isMergeRequiredPublishedPost(post) {
    const mergeRule = getPublicationMergeRule(post.track || "", post.chapter || "");
    return Boolean(mergeRule?.sourceTitles?.includes(post.title));
  }

  function buildChapterProgressMarkup(focusTrack) {
    if (!focusTrack?.chapterGaps?.length) return "";
    const titlePoolItems = Array.isArray(focusTrack.titlePool)
      ? focusTrack.titlePool
      : focusTrack.chapterGaps.flatMap((gap) => gap.titlePool || []);
    const dimensionDefinitions = [
      {
        key: "theory",
        label: "觀念",
        helper: "核心原理與起手判讀",
        matcher: (item) => item.nodeKind === "core",
      },
      {
        key: "toolForm",
        label: "表單",
        helper: "清單、總表與工具資產",
        matcher: (item) => item.nodeKind === "form",
      },
      {
        key: "process",
        label: "硬知識",
        helper: "工序、發包、介面與合約",
        matcher: (item) => item.nodeKind === "project" || /工序|流程|發包|合約|介面|點交/.test(`${item.chapter} ${item.subchapter} ${item.primaryTitle}`),
      },
      {
        key: "case",
        label: "案例",
        helper: "案例拆解與 QA 補位",
        matcher: (item) => ["case", "qa"].includes(item.nodeKind),
      },
    ];
    const buildDimensionMetrics = (items = []) => dimensionDefinitions.map((definition) => ({
      ...definition,
      completed: items.filter((item) => definition.matcher(item) && item.status === "published").length,
      total: items.filter((item) => definition.matcher(item)).length,
    }));
    const chapterProgressMetrics = focusTrack.chapterGaps.map((gap) => {
      const total = gap.subchapters.length || 1;
      const completed = gap.subchapters.filter((subchapter) => subchapter.coveredByArticle).length;
      const rate = Math.round((completed / total) * 100);
      return { chapter: gap.chapter, completed, total, rate };
    });
    const contiguousTimelineCovered = chapterProgressMetrics.reduce((count, item, index) => {
      if (count !== index) return count;
      return item.rate >= publicationChronologyMinCompletionRate ? count + 1 : count;
    }, 0);
    const timelineRate = chapterProgressMetrics.length
      ? Math.round((contiguousTimelineCovered / chapterProgressMetrics.length) * 100)
      : 0;
    const wordWeightMap = {
      core: 3200,
      case: 2400,
      qa: 1800,
      form: 900,
      project: 2200,
    };
    const dimensionMetrics = buildDimensionMetrics(titlePoolItems);
    const minimumReadyCount = focusTrack.chapterGaps.filter((gap) => {
      const chapterMetrics = buildDimensionMetrics(gap.titlePool || []);
      return chapterMetrics
        .filter((item) => ["theory", "toolForm", "process"].includes(item.key))
        .every((item) => item.total > 0 && item.completed > 0);
    }).length;
    const minimumReadyRate = focusTrack.chapterGaps.length
      ? Math.round((minimumReadyCount / focusTrack.chapterGaps.length) * 100)
      : 0;
    const estimatedTotalWords = titlePoolItems.reduce(
      (sum, item) => sum + (wordWeightMap[item.nodeKind] || 1600),
      0,
    );
    const estimatedCompletedWords = titlePoolItems.reduce(
      (sum, item) => sum + (item.status === "published" ? (wordWeightMap[item.nodeKind] || 1600) : 0),
      0,
    );
    const dimensionMarkup = dimensionMetrics.map((item) => {
      const total = item.total || 1;
      const rate = Math.round((item.completed / total) * 100);
      return `
        <article class="bookshelf-review-progress-card bookshelf-review-progress-card-dimension ${rate === 100 ? "is-complete" : rate === 0 ? "is-empty" : ""}">
          <div class="bookshelf-review-progress-head">
            <span>${escapeHtml(item.label)}</span>
            <strong>${item.completed} / ${item.total}</strong>
            <em>${rate}%</em>
          </div>
          <div class="bookshelf-review-progress-bar">
            <i style="width: ${Math.max(rate, item.completed > 0 ? 12 : 0)}%"></i>
          </div>
          <small>${escapeHtml(item.helper)}</small>
        </article>
      `;
    }).join("");
    const summaryMarkup = `
      <article class="bookshelf-review-progress-card bookshelf-review-progress-card-dimension ${timelineRate === 100 ? "is-complete" : timelineRate === 0 ? "is-empty" : ""}">
        <div class="bookshelf-review-progress-head">
          <span>時間軸覆蓋率</span>
          <strong>${contiguousTimelineCovered} / ${chapterProgressMetrics.length}</strong>
          <em>${timelineRate}%</em>
        </div>
        <div class="bookshelf-review-progress-bar">
          <i style="width: ${Math.max(timelineRate, contiguousTimelineCovered > 0 ? 12 : 0)}%"></i>
        </div>
        <small>以前段章節是否至少達 ${publicationChronologyMinCompletionRate}% 為基準，避免後段工程排程早於前置決策。</small>
      </article>
      <article class="bookshelf-review-progress-card bookshelf-review-progress-card-dimension ${minimumReadyRate === 100 ? "is-complete" : minimumReadyRate === 0 ? "is-empty" : ""}">
        <div class="bookshelf-review-progress-head">
          <span>最小出版體積</span>
          <strong>${minimumReadyCount} / ${focusTrack.chapterGaps.length}</strong>
          <em>${minimumReadyRate}%</em>
        </div>
        <div class="bookshelf-review-progress-bar">
          <i style="width: ${Math.max(minimumReadyRate, minimumReadyCount > 0 ? 12 : 0)}%"></i>
        </div>
        <small>每章至少要有觀念、表單、硬知識三種核心節點，才算達到可出版的最小骨架。</small>
      </article>
      <article class="bookshelf-review-progress-card bookshelf-review-progress-card-dimension ${estimatedCompletedWords >= estimatedTotalWords && estimatedTotalWords > 0 ? "is-complete" : ""}">
        <div class="bookshelf-review-progress-head">
          <span>預估書籍字數</span>
          <strong>${Math.round(estimatedCompletedWords / 1000)}k / ${Math.round(estimatedTotalWords / 1000)}k</strong>
          <em>${estimatedTotalWords ? Math.round((estimatedCompletedWords / estimatedTotalWords) * 100) : 0}%</em>
        </div>
        <div class="bookshelf-review-progress-bar">
          <i style="width: ${estimatedTotalWords ? Math.max(Math.round((estimatedCompletedWords / estimatedTotalWords) * 100), estimatedCompletedWords > 0 ? 12 : 0) : 0}%"></i>
        </div>
        <small>依節點類型估算全書體量，不只看文章篇數。</small>
      </article>
    `;
    const chapterMarkup = focusTrack.chapterGaps.map((gap, index) => {
      const completed = gap.subchapters.filter((subchapter) => subchapter.coveredByArticle).length;
      const total = gap.subchapters.length || 1;
      const rate = Math.round((completed / total) * 100);
      const chapterDimensions = buildDimensionMetrics(gap.titlePool || []);
      const minimumReady = chapterDimensions
        .filter((item) => ["theory", "toolForm", "process"].includes(item.key))
        .every((item) => item.total > 0 && item.completed > 0);
      const chapterMeters = chapterDimensions.map((item) => {
        const totalCount = item.total || 1;
        const itemRate = Math.round((item.completed / totalCount) * 100);
        return `
          <li class="bookshelf-review-progress-meter ${itemRate === 100 ? "is-complete" : itemRate === 0 ? "is-empty" : ""}">
            <div class="bookshelf-review-progress-meter-head">
              <span>${escapeHtml(item.label)}</span>
              <em>${item.completed} / ${item.total}</em>
            </div>
            <div class="bookshelf-review-progress-bar">
              <i style="width: ${Math.max(itemRate, item.completed > 0 ? 12 : 0)}%"></i>
            </div>
          </li>
        `;
      }).join("");
      return `
        <article class="bookshelf-review-progress-card ${rate === 100 ? "is-complete" : rate === 0 ? "is-empty" : ""} ${minimumReady ? "is-minimum-ready" : ""}">
          <div class="bookshelf-review-progress-head">
            <span>第 ${index + 1} 章</span>
            <strong>${escapeHtml(gap.chapter)}</strong>
            <em>${rate}%</em>
          </div>
          <div class="bookshelf-review-progress-bar">
            <i style="width: ${Math.max(rate, completed > 0 ? 12 : 0)}%"></i>
          </div>
          <small>${completed} / ${total} 子章已到位｜${minimumReady ? "最小出版體積已成形" : "仍缺觀念／表單／硬知識核心節點"}</small>
          <ul class="bookshelf-review-progress-meter-list">
            ${chapterMeters}
          </ul>
        </article>
      `;
    }).join("");
    return `
      <div class="bookshelf-review-progress-dimensions">
        ${summaryMarkup}
        ${dimensionMarkup}
      </div>
      <div class="bookshelf-review-progress-chapters">
        ${chapterMarkup}
      </div>
    `;
  }

  function getTitlePoolStatusLabel(status = "pending", statusTag = "") {
    if (statusTag) return statusTag;
    if (status === "merge_needed") return "需整併";
    if (status === "published") return "已上線";
    if (status === "draft") return "草稿中";
    return "待補";
  }

  function getTitlePoolConfidenceLabel(confidence = "medium") {
    if (confidence === "high") return "高信心";
    if (confidence === "low") return "低信心";
    return "中信心";
  }

  function getWorkflowActionLabel(action = "") {
    if (action === "Published_Reference") return "已上線參考";
    if (action === "Merge_and_Update") return "整併升級";
    if (action === "Merge_into_Asset") return "整併為資產";
    if (action === "Revise_Angle") return "改切角";
    if (action === "New_Publish") return "新發佈";
    return "待判定";
  }

  function getRecommendationBadgeLabel(item) {
    if (!item?.isRecommended) return "";
    if (item.workflowAction === "Published_Reference") return "";
    if (item.workflowAction === "New_Publish") return "最推薦";
    if (item.workflowAction === "Revise_Angle") return "優先覆核";
    if (item.workflowAction === "Merge_into_Asset") return "優先審資產";
    if (item.workflowAction === "Merge_and_Update") return "優先整併";
    return "優先處理";
  }

  function getChapterCandidateLead(recommendation) {
    if (!recommendation) return "本章候選";
    if (recommendation.workflowAction === "Published_Reference") return "本章已上線參考";
    if (recommendation.workflowAction === "New_Publish") return "本章純新候選";
    if (recommendation.workflowAction === "Revise_Angle") return "本章待覆核候選";
    if (recommendation.workflowAction === "Merge_into_Asset") return "本章資產候選";
    if (recommendation.workflowAction === "Merge_and_Update") return "本章修復候選";
    return "本章候選";
  }

  function getPublishingReviewCandidateDisplayTitle(recommendation) {
    return recommendation ? getDisplayTitle(recommendation) : "待 Gemini Pro 由候補素材池裁定";
  }

  function getTitlePoolReviewKey(item) {
    return [
      item.trackTitle || "",
      item.chapter || "",
      item.subchapter || "",
      item.primaryTitle || "",
    ].join("::");
  }

  function getManualReviewLabel(status = "") {
    if (status === "approved") return "已核准";
    if (status === "revise") return "待修改";
    if (status === "snoozed") return "暫緩";
    if (status === "rejected") return "已淘汰";
    return "未覆核";
  }

  function getManualReviewOptions() {
    return [
      { value: "approved", label: "已核准" },
      { value: "revise", label: "待修改" },
      { value: "snoozed", label: "暫緩" },
      { value: "rejected", label: "已淘汰" },
    ];
  }

  function getManualReviewStatus(item) {
    return publishingTitlePoolReviewState[getTitlePoolReviewKey(item)] || "";
  }

  function savePublishingTitlePoolReviewState() {
    localStorage.setItem(PUBLISHING_TITLE_POOL_REVIEW_KEY, JSON.stringify(publishingTitlePoolReviewState));
  }

  function loadPublishingTitlePoolReviewState() {
    try {
      const raw = localStorage.getItem(PUBLISHING_TITLE_POOL_REVIEW_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      publishingTitlePoolReviewState = parsed && typeof parsed === "object" ? parsed : {};
    } catch (error) {
      console.error("讀取標題池人工覆核狀態失敗：", error);
      publishingTitlePoolReviewState = {};
    }
  }

  function updatePublishingTitlePoolReviewState(itemKey, status) {
    if (!itemKey) return;
    if (!status) {
      delete publishingTitlePoolReviewState[itemKey];
    } else {
      publishingTitlePoolReviewState[itemKey] = status;
    }
    savePublishingTitlePoolReviewState();
    renderPublishingReviewBoard();
  }

  function getRankedTopicCandidates(mode = currentTopicMode, limit = 6) {
    const modeState = getCurrentTopicModeState(mode);
    const focusTrack = modeState?.publishingDashboard?.focusTrack;
    const focusTrackTitle = modeState?.publishingDashboard?.focusTrack?.title;
    const allCandidates = Array.isArray(modeState?.nextTopicCandidates) ? modeState.nextTopicCandidates : [];
    const primaryRecommendation = modeState?.nextRecommendedTopic || null;
    const filtered = focusTrackTitle
      ? allCandidates.filter((candidate) => candidate.trackTitle === focusTrackTitle)
      : allCandidates;
    const chapterFallbacks = (modeState?.publishingDashboard?.focusTrack?.chapterGaps || [])
      .map((gap) => gap.recommendedTopic)
      .filter(Boolean)
      .filter((candidate) => !focusTrackTitle || candidate.trackTitle === focusTrackTitle);
    const merged = [];
    if (primaryRecommendation) {
      merged.push(primaryRecommendation);
    }
    [...filtered, ...chapterFallbacks].forEach((candidate) => {
      if (!candidate) return;
      if (!merged.some((item) => item.primaryTitle === candidate.primaryTitle && item.subchapter === candidate.subchapter)) {
        merged.push(candidate);
      }
    });
    const chapterPriorityMap = {
      "現況判讀": 0,
      "預算拆解": 1,
      "基礎工程": 2,
      "空間重整": 3,
      "完工避雷": 4,
    };
    const explicitPriorityMap = {
      "現況判讀::翻新起手式": 0,
      "現況判讀::實戰表單": 1,
      "現況判讀::專案節點": 2,
      "現況判讀::案例解析": 3,
      "現況判讀::迷思破解": 4,
      "預算拆解::發包合約": 5,
      "預算拆解::報價拆讀": 6,
    };
    const rankCandidate = (candidate, index) => {
      const riskRank = candidate?.collisionRisk === "low"
        ? 0
        : candidate?.collisionRisk === "medium"
          ? 1
          : 2;
      const explicitKey = `${candidate?.chapter || ""}::${candidate?.subchapter || ""}`;
      const explicitRank = Object.prototype.hasOwnProperty.call(explicitPriorityMap, explicitKey)
        ? explicitPriorityMap[explicitKey]
        : 50;
      const chapterRank = Object.prototype.hasOwnProperty.call(chapterPriorityMap, candidate?.chapter || "")
        ? chapterPriorityMap[candidate.chapter]
        : 9;
      const semanticScore = getCandidateIntentScore(candidate, articleSourceQuestion);
      const mergeIntentOverride = articleSourceQuestion.trim() && candidate?.workflowAction === "Merge_and_Update" && semanticScore >= 0.5
        ? -5000 - Math.round(semanticScore * 100)
        : 0;
      const dependencyPenalty = getDependencyLockState(focusTrack, candidate?.chapter, candidate?.subchapter).locked ? 40 : 0;
      const riskPenalty = candidate?.workflowAction === "Merge_and_Update" && explicitRank < 10 ? 0 : riskRank * 1000;
      return mergeIntentOverride + riskPenalty + dependencyPenalty + explicitRank * 100 + chapterRank * 10 + index;
    };
    const safeCandidates = merged.filter((candidate) => (
      candidate?.collisionRisk !== "high" || candidate?.workflowAction === "Merge_and_Update"
    ));
    const candidatePool = safeCandidates.length ? safeCandidates : merged;
    return candidatePool
      .sort((left, right) => rankCandidate(left, merged.indexOf(left)) - rankCandidate(right, merged.indexOf(right)))
      .slice(0, Math.max(1, limit));
  }

  function getMergeTaskRecommendations(mode = currentTopicMode, limit = 3) {
    return getRankedTopicCandidates(mode, 8)
      .filter((candidate) => ["Merge_and_Update", "Merge_into_Asset"].includes(candidate?.workflowAction))
      .slice(0, Math.max(1, limit));
  }

  function sortTopPriorityCandidates(candidates = [], limit = 3) {
    const forced = forcedTopPriorityTitles
      .map((title) => candidates.find((candidate) => getDisplayTitle(candidate) === title))
      .filter(Boolean);
    const seen = new Set(forced.map((candidate) => getDisplayTitle(candidate)));
    const remainder = candidates.filter((candidate) => {
      const title = getDisplayTitle(candidate);
      if (seen.has(title)) return false;
      seen.add(title);
      return true;
    });
    return [...forced, ...remainder].slice(0, Math.max(1, limit));
  }

  function getDirectTopPriorityRecommendations(mode = currentTopicMode, limit = 3) {
    const candidates = getRankedTopicCandidates(mode, 20)
      .filter((candidate) => candidate?.workflowAction === "New_Publish");
    return sortTopPriorityCandidates(candidates, limit);
  }

  function getTopPriorityRecommendationResolution(mode = currentTopicMode, limit = 3) {
    const safeLimit = Math.max(1, limit);
    const directCandidates = getDirectTopPriorityRecommendations(mode, safeLimit);
    if (directCandidates.length >= safeLimit) {
      return {
        candidates: directCandidates,
        directCandidates,
        fallbackCandidates: [],
        autoReplenished: false,
        partiallyAutoReplenished: false,
      };
    }

    const seen = new Set(directCandidates.map((candidate) => getDisplayTitle(candidate)));
    const fallbackCandidates = getPureNewPublishFallbackCandidates(mode, safeLimit * 2)
      .filter((candidate) => {
        const title = getDisplayTitle(candidate);
        if (seen.has(title)) return false;
        seen.add(title);
        return true;
      });
    const mergedCandidates = sortTopPriorityCandidates([...directCandidates, ...fallbackCandidates], safeLimit);
    return {
      candidates: mergedCandidates,
      directCandidates,
      fallbackCandidates,
      autoReplenished: directCandidates.length === 0 && mergedCandidates.length > 0,
      partiallyAutoReplenished: directCandidates.length > 0 && mergedCandidates.length > directCandidates.length,
    };
  }

  function getTopPriorityRecommendations(mode = currentTopicMode, limit = 3) {
    return getTopPriorityRecommendationResolution(mode, limit).candidates;
  }

  function getPrimaryMergeTaskRecommendation(mode = currentTopicMode) {
    return getMergeTaskRecommendations(mode, 1)[0] || null;
  }

  function getMergeTaskNote(recommendation) {
    if (!recommendation) {
      return "整併任務會先顯示需合併的既有文章，避免把舊文改寫誤當成新的獨立題目。";
    }
    if (recommendation.workflowAction === "Merge_into_Asset") {
      return recommendation.similarArticles?.length
        ? `先掛回主文資產槽：${recommendation.similarArticles.slice(0, 2).map((article) => article.title).join(" / ")}`
        : "這題屬操作型資產，請直接掛回既有主文，不另開新文章。";
    }
    const mergeRule = getPublicationMergeRule(recommendation.trackTitle, recommendation.chapter);
    if (mergeRule?.sourceTitles?.length) {
      return `先整併舊文：${mergeRule.sourceTitles.join(" / ")}`;
    }
    const similarTitles = recommendation.similarArticles?.slice(0, 2).map((article) => article.title).join(" / ");
    return similarTitles
      ? `先檢查並整併相近舊文：${similarTitles}`
      : "此題與既有文章核心解法靠近，建議先出整併升級稿，不要直接另開新文。";
  }

  function getCrossTrackSyncMessage(mode = currentTopicMode) {
    const mergeTask = getPrimaryMergeTaskRecommendation(mode);
    if (!mergeTask) return "";
    return mergeTask.workflowAction === "Merge_into_Asset"
      ? "注意：本題主要解法已分配至 [Merge_into_Asset] 軌道處理。操作型資產需掛回主文，純新文章軌道不得再把它列入 Top 3。"
      : "注意：本題主要解法已分配至 [Merge_and_Update] 軌道處理。舊文修復軌道與純新文章軌道可並行，當前新文章順位不應被整併任務佔位。";
  }

  function getPublicationBaselinePlan(mode = currentTopicMode, articleLimit = 3) {
    const modeState = getCurrentTopicModeState(mode);
    const focusTrack = modeState?.publishingDashboard?.focusTrack;
    if (!focusTrack) return null;
    const chapterBreakdown = [...focusTrack.chapterGaps]
      .map((gap) => ({
        chapter: gap.chapter,
        missingCount: gap.remainingToBaseline,
        publishedCount: gap.articleCount,
        completionRate: gap.subchapters.length
          ? Math.round((gap.subchapters.filter((subchapter) => subchapter.coveredByArticle).length / gap.subchapters.length) * 100)
          : 0,
      }))
      .sort((left, right) => {
        if (right.missingCount !== left.missingCount) return right.missingCount - left.missingCount;
        if (left.publishedCount !== right.publishedCount) return left.publishedCount - right.publishedCount;
        return left.chapter.localeCompare(right.chapter, "zh-Hant");
      });
    const weakestChapter = chapterBreakdown[0] || null;
    const topPriorityResolution = getTopPriorityRecommendationResolution(mode, articleLimit);
    const topRecommendations = topPriorityResolution.candidates;
    const recoverableCount = Math.min(articleLimit, focusTrack.remainingToBaseline);
    const projectedCoverage = focusTrack.totalSubchapters
      ? Math.round(((focusTrack.completedSubchapters + recoverableCount) / focusTrack.totalSubchapters) * 100)
      : focusTrack.coverageRate;
    return {
      remainingToBaseline: focusTrack.remainingToBaseline,
      weakestChapter,
      topRecommendations,
      projectedCoverage,
      chapterBreakdown,
      fastTrackLabel: topRecommendations.length
        ? topRecommendations.map((item) => getDisplayTitle(item)).join(" / ")
        : "目前 Top 3 為空，請改讀純新文章空窗候補素材池。",
      autoReplenished: topPriorityResolution.autoReplenished,
      partiallyAutoReplenished: topPriorityResolution.partiallyAutoReplenished,
    };
  }

  function buildPublicationBaselinePlanText(mode = currentTopicMode, articleLimit = 3) {
    const plan = getPublicationBaselinePlan(mode, articleLimit);
    if (!plan) return "目前尚無可用的純新文章推進路徑。";
    const lines = [
      "【出版基線達標路徑】",
      "以下路徑僅統計純新文章軌道，不混入 Merge_and_Update 或 Merge_into_Asset。",
      "以下為理想推估，不代表目前已存在 3 篇可立即發布的純新文章。",
      `距離出版基線：還差 ${plan.remainingToBaseline} 篇`,
      `目前最短板章節：${plan.weakestChapter?.chapter || "尚未判定"}｜缺口 ${plan.weakestChapter?.missingCount ?? 0} 篇｜完成度 ${plan.weakestChapter?.completionRate ?? 0}%`,
      `純新文章軌道最快推進路徑：${plan.autoReplenished ? `系統已自動由候補素材池試排：${plan.fastTrackLabel}` : plan.partiallyAutoReplenished ? `系統已補齊候補素材：${plan.fastTrackLabel}` : plan.fastTrackLabel}`,
      `若後續補足 3 篇合格的純新文章：主書完成度可由現況推進至 ${plan.projectedCoverage}%`,
      "章節缺口排序：",
      ...plan.chapterBreakdown.map((item, index) => `${index + 1}. ${item.chapter}｜缺口 ${item.missingCount} 篇｜完成度 ${item.completionRate}%`),
    ];
    return lines.join("\n");
  }

  function buildPublicationBaselinePlanMarkup(mode = currentTopicMode, articleLimit = 3) {
    const plan = getPublicationBaselinePlan(mode, articleLimit);
    if (!plan) {
      return '<p class="bookshelf-confirm-note">目前尚無可用的純新文章推進路徑。</p>';
    }
    const recommendationList = plan.topRecommendations.length
      ? plan.topRecommendations.map((item, index) => `
        <li>
          <strong>Top ${index + 1}</strong>
          <span>${escapeHtml(getDisplayTitle(item))}</span>
        </li>
      `).join("")
      : `<li><span>${escapeHtml(getPureNewPublishEmptyStateGuidance(mode))}</span></li>`;
    return `
      <div class="bookshelf-review-baseline-summary">
        <article class="bookshelf-review-baseline-card">
          <span>距離出版基線</span>
          <strong>還差 ${plan.remainingToBaseline} 篇</strong>
          <small>主書完成度補齊前，仍有結構性缺口待填。</small>
        </article>
        <article class="bookshelf-review-baseline-card is-alert">
          <span>目前最短板章節</span>
          <strong>${escapeHtml(plan.weakestChapter?.chapter || "尚未判定")}</strong>
          <small>缺口 ${plan.weakestChapter?.missingCount ?? 0} 篇｜完成度 ${plan.weakestChapter?.completionRate ?? 0}%</small>
        </article>
        <article class="bookshelf-review-baseline-card">
          <span>補足 3 篇合格新文章後預估</span>
          <strong>${plan.projectedCoverage}%</strong>
          <small>此為理想推估，不代表目前已存在 3 篇可立即發布的純新文章。</small>
        </article>
      </div>
      <div class="bookshelf-review-baseline-route">
        <article class="bookshelf-review-baseline-route-card">
          <span>純新文章推進路徑</span>
          <ul>${recommendationList}</ul>
        </article>
        <article class="bookshelf-review-baseline-route-card">
          <span>章節缺口排序</span>
          <ol>
            ${plan.chapterBreakdown.map((item) => `
              <li>
                <strong>${escapeHtml(item.chapter)}</strong>
                <small>缺口 ${item.missingCount} 篇｜完成度 ${item.completionRate}%</small>
              </li>
            `).join("")}
          </ol>
        </article>
      </div>
    `;
  }

  function buildTopPriorityText(mode = currentTopicMode, limit = 3) {
    const resolution = getTopPriorityRecommendationResolution(mode, limit);
    const candidates = resolution.candidates;
    if (!candidates.length) {
      return [
        "目前純新文章軌道 Top 3 為空。",
        "這不代表系統沒有可用素材；請改看下方『純新文章空窗候補素材池』，並依章節缺口與時間軸重建本輪純新文章排序。",
      ].join("\n");
    }
    return [
      resolution.autoReplenished
        ? "【純新文章軌道 Top 3｜系統已自動由候補素材池試排】"
        : resolution.partiallyAutoReplenished
          ? "【純新文章軌道 Top 3｜系統已自動補齊候補素材】"
          : "【純新文章軌道 Top 3】",
      resolution.autoReplenished || resolution.partiallyAutoReplenished
        ? "以下題目已先排除 Merge_and_Update 與 Merge_into_Asset；當正式 New_Publish 不足時，系統會自動從候補素材池遞補並試排，再交由高階 LLM 最終裁定是否保留、改題或重排。"
        : "以下 3 題已先排除 Merge_and_Update 與 Merge_into_Asset；若高階 LLM 判定其中任一題仍應整併或資產化，必須先移出新文章軌道再重排。",
      ...candidates.map((candidate, index) => (
        `${index + 1}. ${getDisplayTitle(candidate)}｜${getPublicationChapterLabel(candidate.chapter)} / ${candidate.subchapter}｜${getPublishingReviewCandidateReason(candidate)}`
      )),
    ].join("\n");
  }

  function buildTopPriorityMarkup(mode = currentTopicMode, limit = 3) {
    const resolution = getTopPriorityRecommendationResolution(mode, limit);
    const candidates = resolution.candidates;
    const focusTrack = getCurrentTopicModeState(mode)?.publishingDashboard?.focusTrack;
    if (!candidates.length) {
      const fallbackCandidates = getPureNewPublishFallbackCandidates(mode, limit);
      const fallbackMarkup = fallbackCandidates.length
        ? fallbackCandidates.map((candidate, index) => `
          <article class="bookshelf-review-empty-card">
            <div class="bookshelf-review-empty-head">
              <span>${index === 0 ? "同章補充（建議）" : "下一章主幹"}</span>
              <em>${escapeHtml(getPublicationChapterLabel(candidate.chapter))} / ${escapeHtml(candidate.subchapter)}</em>
            </div>
            <strong>${escapeHtml(getDisplayTitle(candidate))}</strong>
            <p>${escapeHtml(getPublishingReviewCandidateReason(candidate))}</p>
            <button
              type="button"
              class="bookshelf-action"
              data-apply-replenish-title="${escapeHtml(getDisplayTitle(candidate))}"
            >一鍵置入本輪題目</button>
          </article>
        `).join("")
        : `<article class="bookshelf-review-empty-card">
          <div class="bookshelf-review-empty-head">
            <span>待 Gemini Pro 遞補</span>
            <em>規則層不預設答案</em>
          </div>
          <strong>目前沒有可直接自動置入的純新文章候選</strong>
          <p>系統已保留章節缺口與時間軸上下文，避免把應整併或應資產化的題目誤塞回 New_Publish。</p>
        </article>`;
      return `
        <section class="bookshelf-review-empty-state">
          <p class="bookshelf-confirm-note">${escapeHtml(getPureNewPublishEmptyStateGuidance(mode))}</p>
          <div class="bookshelf-review-empty-grid">${fallbackMarkup}</div>
        </section>
      `;
    }
    return candidates.map((candidate, index) => `
      <article class="bookshelf-review-top3-card ${index === 0 ? "is-primary" : ""}">
        <div class="bookshelf-review-top3-head">
          <span>${resolution.autoReplenished || (resolution.partiallyAutoReplenished && index >= resolution.directCandidates.length) ? `Auto Top ${index + 1}` : `Top ${index + 1}`}</span>
          <em>${escapeHtml(getPublicationChapterLabel(candidate.chapter))} / ${escapeHtml(candidate.subchapter)}</em>
        </div>
        <strong>${escapeHtml(getDisplayTitle(candidate))}</strong>
        <div class="bookshelf-review-top3-meta">
          <span class="bookshelf-review-semantic-badge is-${getSemanticMatchBadgeData(candidate).state}">${escapeHtml(getSemanticMatchBadgeData(candidate).label)}</span>
          ${(() => {
            const lockState = getDependencyLockState(focusTrack, candidate.chapter, candidate.subchapter);
            return lockState.locked
              ? `<span class="bookshelf-dependency-lock" title="${escapeHtml(lockState.message)}" aria-label="${escapeHtml(lockState.message)}">&#128274; ${escapeHtml(lockState.shortLabel || "依賴鎖定")}</span>`
              : "";
          })()}
        </div>
        <p>${escapeHtml(getPublishingReviewCandidateReason(candidate))}</p>
      </article>
    `).join("");
  }

  function getPublishingReviewCandidateReason(candidate) {
    if (!candidate) return "規則層暫無候選理由。";
    const trackTitle = candidate.track || getCurrentTopicModeState(currentTopicMode)?.publishingDashboard?.focusTrack?.title || "";
    const hasMergeBackedTheory = hasMergeBackedTheoryCoverage(trackTitle, candidate.chapter);
    const similarTitles = candidate.similarArticles?.slice(0, 2).map((article) => `${article.title}（${article.score}）`).join(" / ");
    const isAssetLike = /表單|清單|檢核|確認表|試算表|交接表|追蹤表/.test(candidate.subchapter || "") || /表單|清單|檢核|確認表|試算表|交接表|追蹤表/.test(getDisplayTitle(candidate));

    if (hasMergeBackedTheory && isAssetLike) {
      return `規則層暫列為補位工具候選；但本章已有已上線舊文可支撐整併主幹，請優先檢查是否應移出新文章池，或改判為 Merge_into_Asset／待覆核資產化${similarTitles ? `｜相近舊文：${similarTitles}` : ""}。`;
    }
    if (hasMergeBackedTheory) {
      return `規則層暫列為同章補位候選；但本章理論主幹可由已上線舊文整併成立，請以整併後狀態重排，不可沿用「空章／先立主幹」敘述${similarTitles ? `｜相近舊文：${similarTitles}` : ""}。`;
    }
      return `規則層暫列候選，仍需高階 LLM 覆核是否應保留在新文章池，或改寫為其他出版動作${similarTitles ? `｜相近舊文：${similarTitles}` : ""}。`;
  }

  function getBookProposal(mode = currentTopicMode) {
    return getCurrentTopicModeState(mode)?.bookProposal || null;
  }

  function hasCrossSeriesConflict(...values) {
    const text = values.join(" ").replace(/\s+/g, "");
    return crossSeriesForbiddenKeywords.find((keyword) => text.includes(keyword)) || "";
  }

  function shouldEnforceOldHouseIsolation(mode = currentTopicMode) {
    const proposal = getBookProposal(mode);
    const focusTrackTitle = getCurrentTopicModeState(mode)?.publishingDashboard?.focusTrack?.title || "";
    return (proposal?.bookTitle || "").includes("老屋") || focusTrackTitle === publishingFocusTrackTitle;
  }

  function getOldHouseFallbackConfirmData() {
    return {
      category: "老屋翻新",
      track: publishingFocusTrackTitle,
      chapter: "現況判讀",
      title: "屋況盤點與範圍界定總表",
    };
  }

  function getOldHouseFallbackTopicDecision(mode = currentTopicMode, question = articleSourceQuestion, conflictKeyword = "") {
    const modeState = getCurrentTopicModeState(mode);
    return {
      question,
      mode,
      modeLabel: modeState?.label || mode,
      candidateIndex: 0,
      summary: conflictKeyword
        ? `偵測到互斥詞彙「${conflictKeyword}」，已回退到老屋主線的安全題目。`
        : "已回退到老屋主線的安全題目。",
      track: publishingFocusTrackTitle,
      chapter: "現況判讀",
      subchapter: "翻新起手式",
      title: "屋況盤點與範圍界定總表",
      reason: "老屋主書模式下偵測到預售屋／客變污染，系統已強制回退到老屋主線最前段的起手式整併題目。",
      questionLink: "",
      bookLink: "",
      invalid: true,
      conflictKeyword,
    };
  }

  function getFocusTrackChapterCoverageRate(focusTrack, chapterTitle = "") {
    const gap = focusTrack?.chapterGaps?.find((item) => item.chapter === chapterTitle);
    if (!gap?.subchapters?.length) return 0;
    return Math.round((gap.subchapters.filter((subchapter) => subchapter.coveredByArticle).length / gap.subchapters.length) * 100);
  }

  function hasMergeBackedTheoryCoverage(trackTitle = "", chapterTitle = "") {
    const mergeRule = getPublicationMergeRule(trackTitle, chapterTitle);
    if (!mergeRule?.sourceTitles?.length) return false;
    return articleLibrary.some((post) => (
      post.track === trackTitle &&
      post.chapter === chapterTitle &&
      mergeRule.sourceTitles.includes(post.title)
    ));
  }

  function getChronologyWarningMessage(recommendation, focusTrack) {
    if (!recommendation || !focusTrack) return "";
    const chapterIndex = publicationChapterOrder.indexOf(recommendation.chapter);
    if (chapterIndex < 1) return "";
    const blockingChapter = publicationChapterOrder.find((chapterTitle, index) => (
      index < chapterIndex && getFocusTrackChapterCoverageRate(focusTrack, chapterTitle) < publicationChronologyMinCompletionRate
    ));
    if (!blockingChapter) return "";
    return `前置工程章節尚未穩固，禁止跳躍發布｜${blockingChapter} 目前有效完成度仍低於 ${publicationChronologyMinCompletionRate}%，暫時不可先排 ${recommendation.chapter}；請先補前段章節，或在高階 LLM 覆核報告明寫特例理由。`;
  }

  function getRecommendationBlockerMessage(recommendation) {
    if (!recommendation || recommendation.collisionRisk !== "high") return "";
    const similarTitles = recommendation.similarArticles?.slice(0, 2).map((article) => `${article.title}（${article.score}）`).join(" / ");
    return `送審提醒：規則層初篩認為此題與 ${similarTitles || "相近舊文"} 靠近；請交由高階 LLM 裁定是否改走「Merge_and_Update」、「更改切角」或保留「New_Publish」。`;
  }

  function getSemanticMatchBadgeData(recommendation, question = articleSourceQuestion) {
    if (!recommendation) {
      return {
        score: 0,
        state: "neutral",
        label: "意圖待比對",
        note: "尚未選定候選，暫時無法比對語意匹配度。",
      };
    }
    if (!question.trim()) {
      return {
        score: 0,
        state: "neutral",
        label: "意圖待比對",
        note: "尚未貼入本輪原始問題，因此暫不顯示匹配分數。",
      };
    }
    const score = Math.round(getCandidateIntentScore(recommendation, question) * 100);
    const state = score >= 80 ? "high" : score >= 60 ? "medium" : "low";
    const note = state === "high"
      ? "本輪原始問題與這個候選高度貼合，可直接作為送審主軸。"
      : state === "medium"
        ? "語意仍在合理範圍，但建議再檢查是否有更切題的整併候選。"
        : "本輪原始問題與候選距離偏大，建議優先重檢排序或改回更切題的整併題。";
    return {
      score,
      state,
      label: `意圖匹配 ${score}%`,
      note,
    };
  }

  function getDependencyLockState(focusTrack, chapterTitle = "", subchapterTitle = "") {
    if (!focusTrack?.chapterGaps?.length) {
      return { locked: false, message: "", shortLabel: "" };
    }
    const chapterGap = focusTrack.chapterGaps.find((gap) => gap.chapter === chapterTitle);
    const titlePoolItem = chapterGap?.titlePool?.find((item) => item.subchapter === subchapterTitle) || null;
    if (!titlePoolItem) {
      return { locked: false, message: "", shortLabel: "" };
    }
    if (titlePoolItem.nodeKind === "form") {
      const hasTheoryReady = Boolean(
        chapterGap?.titlePool?.some((item) => item.nodeKind === "core" && ["published", "merge_needed"].includes(item.status))
      );
      const hasMergeBackedTheory = hasMergeBackedTheoryCoverage(focusTrack.title, chapterTitle);
      return (hasTheoryReady || hasMergeBackedTheory)
        ? { locked: false, message: "", shortLabel: "" }
        : { locked: true, message: "需先完成前置觀念文章：翻新起手式", shortLabel: "前置觀念未完成" };
    }
    if (titlePoolItem.nodeKind === "project") {
      const formItem = chapterGap?.titlePool?.find((item) => item.nodeKind === "form");
      const formReady = Boolean(formItem?.status === "published");
      return formReady
        ? { locked: false, message: "", shortLabel: "" }
        : { locked: true, message: `必須先發布前置表單：${formItem?.primaryTitle || "初勘健檢：老屋第一輪現場檢查清單"}`, shortLabel: "前置表單未發布" };
    }
    if (titlePoolItem.nodeKind === "case") {
      const processItem = chapterGap?.titlePool?.find((item) => item.nodeKind === "project");
      const processReady = Boolean(processItem?.status === "published");
      return processReady
        ? { locked: false, message: "", shortLabel: "" }
        : { locked: true, message: `必須先完成前置專案節點：${processItem?.primaryTitle || "專案節點：初勘至開工的決策沙盤推演"}`, shortLabel: "前置專案未完成" };
    }
    return { locked: false, message: "", shortLabel: "" };
  }

  function isDependencyLocked(focusTrack, chapterTitle = "", subchapterTitle = "") {
    return getDependencyLockState(focusTrack, chapterTitle, subchapterTitle).locked;
  }

  function getDependencyLockMessage(recommendation, focusTrack) {
    if (!recommendation || !focusTrack) return "";
    return getDependencyLockState(focusTrack, recommendation.chapter, recommendation.subchapter).message;
  }

  function getPrimaryReviewRecommendation(mode = currentTopicMode) {
    const focusTrack = getCurrentTopicModeState(mode)?.publishingDashboard?.focusTrack;
    const topCandidates = getTopPriorityRecommendations(mode, 3);
    return topCandidates.find((candidate) => !isDependencyLocked(focusTrack, candidate.chapter, candidate.subchapter)) || topCandidates[0] || null;
  }

  function isAssetLikeReviewCandidate(candidate) {
    if (!candidate) return false;
    const probeText = `${candidate.subchapter || ""} ${getDisplayTitle(candidate)}`;
    return /表單|清單|檢核|確認表|試算表|Checklist|Check-list|交接表|追蹤表|配件清單/.test(probeText);
  }

  function getPureNewPublishFallbackCandidates(mode = currentTopicMode, limit = 3) {
    const modeState = getCurrentTopicModeState(mode);
    const focusTrack = modeState?.publishingDashboard?.focusTrack;
    if (!focusTrack) return [];

    const mergeTask = getPrimaryMergeTaskRecommendation(mode);
    const mergeChapter = mergeTask?.chapter || publicationChapterOrder[0] || "";
    const mergeChapterIndex = publicationChapterOrder.indexOf(mergeChapter);
    const ranked = getRankedTopicCandidates(mode, 12)
      .filter((candidate) => ["New_Publish", "Revise_Angle"].includes(candidate?.workflowAction))
      .filter((candidate) => !isAssetLikeReviewCandidate(candidate))
      .filter((candidate) => !isDependencyLocked(focusTrack, candidate.chapter, candidate.subchapter));

    const scored = ranked.map((candidate) => {
      const chapterIndex = publicationChapterOrder.indexOf(candidate.chapter);
      const chapterGap = focusTrack.chapterGaps.find((gap) => gap.chapter === candidate.chapter);
      const titlePoolItem = chapterGap?.titlePool?.find((item) => item.subchapter === candidate.subchapter) || null;
      const nodeKind = titlePoolItem?.nodeKind || "core";
      const sameChapterSupplement = candidate.chapter === mergeChapter && ["案例解析", "專案節點", "迷思破解"].includes(candidate.subchapter);
      const nextChapterTheory = chapterIndex === mergeChapterIndex + 1 && !["實戰表單", "案例解析", "迷思破解", "專案節點"].includes(candidate.subchapter);
      const pendingCoreChapters = publicationChapterOrder.filter((chapterTitle) => {
        const chapterTitlePool = focusTrack.chapterGaps.find((gap) => gap.chapter === chapterTitle)?.titlePool || [];
        return chapterTitlePool.some((item) => (
          item.nodeKind === "core" &&
          !["published", "merge_needed"].includes(item.status) &&
          item.workflowAction !== "Merge_into_Asset"
        ));
      });
      const pendingCoreChapterRank = pendingCoreChapters.indexOf(candidate.chapter);
      const coreCatchupBoost = nodeKind === "core" && pendingCoreChapterRank >= 0
        ? Math.max(0, 260 - pendingCoreChapterRank * 90)
        : 0;
      const foundationCatchupBoost = candidate.chapter === "基礎工程" && nodeKind === "core" ? 110 : 0;
      const laterSpacePenalty = candidate.chapter === "空間重整" && nodeKind === "core" && pendingCoreChapters.includes("基礎工程")
        ? 120
        : 0;
      const fallbackScore =
        (sameChapterSupplement ? 300 : 0) +
        (nextChapterTheory ? 220 : 0) +
        coreCatchupBoost +
        foundationCatchupBoost -
        laterSpacePenalty +
        (candidate.workflowAction === "New_Publish" ? 120 : 0) +
        Math.max(0, 100 - chapterIndex * 10);
      return { candidate, fallbackScore };
    });

    return scored
      .sort((left, right) => right.fallbackScore - left.fallbackScore)
      .slice(0, Math.max(1, limit))
      .map((item) => item.candidate);
  }

  function buildPureNewPublishFallbackText(mode = currentTopicMode, limit = 3) {
    const candidates = getPureNewPublishFallbackCandidates(mode, limit);
    if (!candidates.length) return "【純新文章空窗候補素材池】\n目前尚無可用的候補素材，請交由高階 LLM 直接從章節缺口與時間軸重新判題。";
    return [
      "【純新文章空窗候補素材池】",
      "以下僅為規則層整理給 Gemini Pro 的遞補素材池，不是正式 New_Publish 排序；最終是否遞補、遞補哪一題，必須由 Gemini Pro 裁定。",
      ...candidates.map((candidate, index) => `${index + 1}. ${getDisplayTitle(candidate)}｜${getPublicationChapterLabel(candidate.chapter)} / ${candidate.subchapter}｜${getPublishingReviewCandidateReason(candidate)}`),
    ].join("\n");
  }

  function getPureNewPublishEmptyStateGuidance(mode = currentTopicMode) {
    const focusTrack = getCurrentTopicModeState(mode)?.publishingDashboard?.focusTrack;
    if (!focusTrack?.title) {
      return "目前純新文章池為空；系統只整理候補素材池，請交由 Gemini Pro 決定是否補同章案例／專案節點，或直接推進下一章主幹理論。";
    }
    const fallbackCandidates = getPureNewPublishFallbackCandidates(mode, 2);
    if (fallbackCandidates.length) {
      return `目前純新文章池為空；系統已整理候補素材池，請交由 Gemini Pro 從「${getDisplayTitle(fallbackCandidates[0])}」${fallbackCandidates[1] ? ` / 「${getDisplayTitle(fallbackCandidates[1])}」` : ""} 等候補題中裁定正式遞補順位。`;
    }
    return "目前純新文章池為空；系統僅提供章節缺口與時間軸上下文，請交由 Gemini Pro 直接判定下一個純新文章遞補題。";
  }

  function getExpectedCandidate(mode = currentTopicMode) {
    const modeState = getCurrentTopicModeState(mode);
    if (articleTopicDecision?.title && articleTopicDecision?.track && articleTopicDecision?.chapter) {
      return {
        trackTitle: articleTopicDecision.track,
        chapter: articleTopicDecision.chapter,
        subchapter: articleTopicDecision.subchapter,
        category: modeState?.nextRecommendedTopic?.category || "老屋翻新",
        primaryTitle: articleTopicDecision.title,
        reason: articleTopicDecision.reason || articleTopicDecision.summary || "",
      };
    }
    return getPrimaryReviewRecommendation(mode);
  }

  function getRawArticleConfirmData(content) {
    if (!content.trim()) {
      return {
        category: "尚未判定",
        track: "尚未判定",
        chapter: "尚未判定",
        title: "尚未判定",
        invalid: false,
        conflictKeyword: "",
      };
    }

    const intake = parseArticleIntakeCard(content);
    return sanitizeArticleConfirmData({
      ...intake,
      title: parseArticleTitle(content),
    }, content);
  }

  function getCandidateIntentScore(candidate, question = articleSourceQuestion) {
    if (!candidate || !question.trim()) return 1;
    const inferredTrack = findTrackFromText(question) || candidate.trackTitle || publishingFocusTrackTitle;
    const inferredChapter = inferChapterFromTrack(inferredTrack, question, question);
    const inferredSubchapter = inferSubchapterFromTrack(inferredTrack, inferredChapter, question, question);
    const candidateTerms = buildTitleKeywordSet([
      getDisplayTitle(candidate),
      candidate.chapter || "",
      candidate.subchapter || "",
      candidate.reason || "",
    ].join("\n"));
    const questionTerms = buildTitleKeywordSet(question);
    const sharedTerms = questionTerms.filter((term) => candidateTerms.includes(term));
    let score = 0;
    if (candidate.trackTitle === inferredTrack) score += 0.2;
    if (candidate.chapter === inferredChapter) score += 0.25;
    if (candidate.subchapter === inferredSubchapter) score += 0.25;
    if (questionTerms.length) {
      score += Math.min(0.3, sharedTerms.length / Math.max(1, Math.min(questionTerms.length, candidateTerms.length || 1)));
    }
    return Math.max(0, Math.min(1, Number(score.toFixed(2))));
  }

  function getLandingConsistencyScore(confirmData, candidate) {
    if (!candidate || !confirmData || confirmData.title === "尚未判定") return 1;
    const expectedTitle = normalizeComparableText(getDisplayTitle(candidate));
    const landingTitle = normalizeComparableText(confirmData.title);
    const inferredSubchapter = inferSubchapterFromTrack(
      confirmData.track || candidate.trackTitle || publishingFocusTrackTitle,
      confirmData.chapter || candidate.chapter || "",
      confirmData.title || "",
      confirmData.title || "",
    );
    let score = 0;
    if (expectedTitle && landingTitle && expectedTitle === landingTitle) score += 0.7;
    if (confirmData.track === candidate.trackTitle) score += 0.1;
    if (confirmData.chapter === candidate.chapter) score += 0.1;
    if (inferredSubchapter === candidate.subchapter) score += 0.1;
    if (/系統櫃配件清單|規格確認表/.test(confirmData.title) && candidate.subchapter !== "實戰表單") {
      score = Math.min(score, 0.2);
    }
    return Math.max(0, Math.min(1, Number(score.toFixed(2))));
  }

  function getTopicStateSyncState(content = articleAiResult, mode = currentTopicMode) {
    const expectedCandidate = getExpectedCandidate(mode);
    const rawConfirmData = getRawArticleConfirmData(content);
    if (!expectedCandidate) {
      return {
        fatal: false,
        intentScore: 1,
        landingScore: 1,
        expectedCandidate: null,
        confirmData: rawConfirmData,
        message: "",
      };
    }
    const intentScore = getCandidateIntentScore(expectedCandidate, articleSourceQuestion);
    const landingScore = getLandingConsistencyScore(rawConfirmData, expectedCandidate);
    const hasStaleLanding = /系統櫃配件清單|規格確認表/.test(rawConfirmData.title || "") && expectedCandidate.subchapter !== "實戰表單";
    const fatal = hasStaleLanding || intentScore < 0.6 || landingScore < 0.6;
    const confirmData = fatal
      ? {
          category: expectedCandidate.category || "老屋翻新",
          track: expectedCandidate.trackTitle || publishingFocusTrackTitle,
          chapter: expectedCandidate.chapter || "現況判讀",
          title: getDisplayTitle(expectedCandidate),
          invalid: false,
          conflictKeyword: "",
        }
      : rawConfirmData;
    const message = hasStaleLanding
      ? "偵測到舊的落地資訊仍停在「系統櫃配件清單」，已自動清空並校準回本輪送審候選。"
      : intentScore < 0.6
        ? `原始問題與本輪候選的語意關聯僅 ${Math.round(intentScore * 100)}%，低於 60%，已判定為 Fatal Error 並回退到同步狀態。`
        : landingScore < 0.6
          ? `正式落地資訊與本輪候選的同步分數僅 ${Math.round(landingScore * 100)}%，已判定為 Fatal Error 並改用候選資料覆寫顯示。`
          : "本輪送審候選、原始問題與正式落地資訊已同步。";
    return {
      fatal,
      intentScore,
      landingScore,
      expectedCandidate,
      confirmData,
      message,
    };
  }

  function getStateSyncWarningMessage(content = articleAiResult, mode = currentTopicMode) {
    const syncState = getTopicStateSyncState(content, mode);
    return syncState.fatal ? syncState.message : "";
  }

  function sanitizeArticleConfirmData(data, sourceText = "", mode = currentTopicMode) {
    const safeData = {
      category: data?.category || "尚未判定",
      track: data?.track || "尚未判定",
      chapter: data?.chapter || "尚未判定",
      title: data?.title || "尚未判定",
    };
    if (!shouldEnforceOldHouseIsolation(mode)) {
      return {
        ...safeData,
        invalid: false,
        conflictKeyword: "",
      };
    }
    const conflictKeyword = hasCrossSeriesConflict(
      safeData.category,
      safeData.track,
      safeData.chapter,
      safeData.title,
      sourceText,
    );
    if (!conflictKeyword) {
      return {
        ...safeData,
        invalid: false,
        conflictKeyword: "",
      };
    }
    return {
      ...getOldHouseFallbackConfirmData(),
      invalid: true,
      conflictKeyword,
    };
  }

  function getPublishedStatusLabel(post) {
    return isMergeRequiredPublishedPost(post) ? "官網已上線｜已整併下架轉向" : "官網已上線";
  }

  function buildPublishingTitlePoolText(mode = currentTopicMode) {
    const modeState = getCurrentTopicModeState(mode);
    const focusTrack = modeState?.publishingDashboard?.focusTrack;
    if (!focusTrack?.chapterGaps?.length) return "目前尚無可用的未來出版標題池。";
    const bookProposal = getBookProposal(mode);

    const lines = [
      `正式書名：${bookProposal?.bookTitle || focusTrack.title}`,
      `副標定位：${bookProposal?.subtitle || "尚未定義"}`,
      `一句話定位：${bookProposal?.positioning || "尚未定義"}`,
      `主攻書系：${focusTrack.title}`,
      `主書完成度：${focusTrack.coverageRate}%`,
      "【完整未來出版標題池】",
    ];

    focusTrack.chapterGaps.forEach((gap, index) => {
      lines.push("", `${index + 1}. ${getPublicationChapterLabel(gap.chapter)}`);
      gap.titlePool.forEach((item) => {
        const manualReview = getManualReviewStatus(item);
        const badgeLabel = getRecommendationBadgeLabel(item);
        lines.push(
          `- 子章節：${item.subchapter}`,
          `  主標題：${item.primaryTitle}`,
          `  備選標題：${item.backupTitles.join(" / ") || "無"}`,
          `  狀態：${getTitlePoolStatusLabel(item.status, item.statusTag)}｜${getTitlePoolConfidenceLabel(item.confidence)}${badgeLabel ? `｜${badgeLabel}` : ""}`,
          `  工作流：${item.workflowAction}｜${getWorkflowActionLabel(item.workflowAction)}`,
          `  資產預判：${item.workflowAction === "Merge_into_Asset" ? "Asset Ready（資產掛載預備）" : "一般節點"}`,
          `  人工覆核：${getManualReviewLabel(manualReview)}`,
          `${item.assetSlotLabel ? `  資產掛載：${item.assetSlotLabel}` : "  資產掛載：無"}`,
          `  備註：${item.note}`,
        );
      });
    });

    return lines.join("\n");
  }

  function buildPublishingTitlePoolMarkup(focusTrack) {
    if (!focusTrack?.chapterGaps?.length) {
      return '<p class="bookshelf-confirm-note">目前尚無可用的未來出版標題池。</p>';
    }

    return focusTrack.chapterGaps.map((gap, index) => `
      <article class="bookshelf-review-title-pool-chapter">
        <div class="bookshelf-review-title-pool-head">
          <span>第 ${index + 1} 章</span>
          <strong>${escapeHtml(getPublicationChapterLabel(gap.chapter))}</strong>
          <small>${gap.titlePool.length} 個子章標題</small>
        </div>
        <ul class="bookshelf-review-title-pool-items">
          ${gap.titlePool.map((item) => `
            <li class="bookshelf-review-title-pool-item is-${item.status} is-review-${getManualReviewStatus(item) || "none"} ${item.isRecommended ? "is-recommended" : ""} ${item.workflowAction === "Merge_into_Asset" ? "is-asset-ready" : ""}">
              <div class="bookshelf-review-title-pool-copy">
                <div class="bookshelf-review-title-pool-meta">
                  <span>${escapeHtml(item.subchapter)}</span>
                  <em>${escapeHtml(getTitlePoolStatusLabel(item.status, item.statusTag))}｜${escapeHtml(getTitlePoolConfidenceLabel(item.confidence))}${getRecommendationBadgeLabel(item) ? `｜${escapeHtml(getRecommendationBadgeLabel(item))}` : ""}｜${escapeHtml(getWorkflowActionLabel(item.workflowAction))}</em>
                </div>
                <strong>${escapeHtml(item.primaryTitle)}</strong>
                <small>${escapeHtml(item.note)}</small>
                ${item.workflowAction === "Merge_into_Asset" ? '<p><span class="bookshelf-asset-ready-badge">Asset Ready｜資產掛載預備</span></p>' : ""}
                ${item.backupTitles?.length ? `<p>備選：${escapeHtml(item.backupTitles.join(" / "))}</p>` : ""}
                ${item.assetSlotLabel ? `<p>掛載槽：${escapeHtml(item.assetSlotLabel)}</p>` : ""}
                <div class="bookshelf-review-title-pool-review">
                  <span>人工覆核：${escapeHtml(getManualReviewLabel(getManualReviewStatus(item)))}</span>
                  <div class="bookshelf-review-title-pool-review-actions">
                    ${getManualReviewOptions().map((option) => `
                      <button
                        type="button"
                        class="bookshelf-review-mini-btn ${getManualReviewStatus(item) === option.value ? "is-active" : ""}"
                        data-title-pool-review-key="${escapeHtml(getTitlePoolReviewKey(item))}"
                        data-title-pool-review-status="${escapeHtml(option.value)}"
                      >${escapeHtml(option.label)}</button>
                    `).join("")}
                    <button
                      type="button"
                      class="bookshelf-review-mini-btn ${!getManualReviewStatus(item) ? "is-active" : ""}"
                      data-title-pool-review-key="${escapeHtml(getTitlePoolReviewKey(item))}"
                      data-title-pool-review-status=""
                    >清除</button>
                  </div>
                </div>
              </div>
            </li>
          `).join("")}
        </ul>
      </article>
    `).join("");
  }

  function getDisplayTitle(recommendation) {
    if (!recommendation) return "尚未產生";
    return recommendation.primaryTitle || recommendation.webTitle || recommendation.bookTitle || "尚未產生";
  }

  function getPublicationChapterLabel(chapterTitle = "") {
    return publicationChapterDisplayTitles?.[chapterTitle] || chapterTitle;
  }

  function getPublishedPostDisplayTitle(post) {
    return post.title || getPublishedPostBookTitle(post);
  }

  function getTitleViewLabel() {
    return "統一標題";
  }

  function getCurrentDraftState() {
    const confirmData = getArticleConfirmData(articleAiResult);
    if (confirmData.title !== "尚未判定" && !isPublishedArticleTitle(confirmData.title)) {
      return {
        track: confirmData.track,
        chapter: confirmData.chapter,
        subchapter: inferSubchapterFromTrack(confirmData.track || "", confirmData.chapter || "", confirmData.title || "", articleAiResult || ""),
        title: confirmData.title,
      };
    }

    if (articleTopicDecision?.title && !isPublishedArticleTitle(articleTopicDecision.title)) {
      return {
        track: articleTopicDecision.track,
        chapter: articleTopicDecision.chapter,
        subchapter: articleTopicDecision.subchapter,
        title: articleTopicDecision.title,
      };
    }

    return null;
  }

  function renderSimilarArticleList(container, recommendation) {
    if (!(container instanceof HTMLElement)) return;
    if (!recommendation?.similarArticles?.length) {
      container.innerHTML = "<li>目前尚無需送審比對的規則初篩相近題</li>";
      return;
    }

    container.innerHTML = recommendation.similarArticles.map((article) => `
      <li class="${recommendation.collisionRisk === "low" ? "" : "is-alert"}">
        <strong>${escapeHtml(article.title)}</strong>
        <small>${escapeHtml(article.chapter)} / ${escapeHtml(article.subchapter)}｜規則分數 ${article.score}${article.reason ? `｜${escapeHtml(article.reason)}` : ""}</small>
      </li>
    `).join("");
  }

  function renderSimilarityDiffAnalysis(container, recommendation) {
    if (!(container instanceof HTMLElement)) return;
    if (!recommendation?.similarArticles?.length) {
      container.innerHTML = "<p>目前未發現需要展開送審的規則初篩相近題。</p>";
      return;
    }
    container.innerHTML = recommendation.similarArticles.map((article, index) => `
      <article class="bookshelf-review-diff-card ${recommendation.collisionRisk === "low" ? "" : "is-alert"}">
        <strong>規則初篩相近題 ${index + 1}｜${escapeHtml(article.title)}</strong>
        <p>章節定位：${escapeHtml(article.chapter)} / ${escapeHtml(article.subchapter)}</p>
        <p>規則分數：${article.score}</p>
        <p>初篩理由：${escapeHtml(article.reason || "系統依章節、子章與核心詞彙重疊進行初篩。")}</p>
        <p>覆核提醒：這不是最終撞題判決，請交由高階 LLM 或人工覆核確認是否真的重疊。</p>
      </article>
    `).join("");
  }

  function applyRiskBadge(element, risk = "low", fallbackText = "規則初篩低相近") {
    if (!(element instanceof HTMLElement)) return;
    element.classList.remove("is-low", "is-medium", "is-high");
    element.classList.add(`is-${risk}`);
    element.textContent = risk === "high" ? "規則初篩高相近" : risk === "medium" ? "規則初篩中相近" : fallbackText;
  }

  function revealPublishingReviewPrompt() {
    const textarea = document.getElementById("publishing-review-prompt-content");
    if (!(textarea instanceof HTMLTextAreaElement)) return;
    const details = textarea.closest("details");
    if (details instanceof HTMLDetailsElement) {
      details.open = true;
    }
    textarea.focus();
    textarea.select();
  }

  function togglePublishingDiffPanel() {
    const panel = document.getElementById("publishing-review-diff-panel");
    if (!(panel instanceof HTMLDetailsElement)) return;
    panel.open = !panel.open;
    if (panel.open) {
      panel.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }
  }

  function buildPublishingReviewOutline(mode = currentTopicMode) {
    const modeState = getCurrentTopicModeState(mode);
    const focusTrack = modeState?.publishingDashboard?.focusTrack;
    const recommendation = getPrimaryReviewRecommendation(mode);
    const topCandidates = getTopPriorityRecommendations(mode, 3);
    const bookProposal = getBookProposal(mode);
    if (!focusTrack) return "目前尚無可用的出版補位清單。";

    const lines = [
      `決題模式：${modeState?.label || mode}`,
      `正式書名：${bookProposal?.bookTitle || focusTrack.title}`,
      `副標定位：${bookProposal?.subtitle || "尚未定義"}`,
      `一句話定位：${bookProposal?.positioning || "尚未定義"}`,
      `主攻書系：${focusTrack.title}`,
      `主書完成度：${focusTrack.coverageRate}%`,
      `距離出版基線：還差 ${focusTrack.remainingToBaseline} 篇`,
      `本輪送審候選：${getPublishingReviewCandidateDisplayTitle(recommendation)}`,
    ];

    if (recommendation) {
      lines.push(
        `送審候選定位：${recommendation.chapter} / ${recommendation.subchapter} / ${recommendation.category}`,
        `送審候選原因：${getPublishingReviewCandidateReason(recommendation)}`,
        `規則層初篩：${recommendation.collisionRisk}｜${recommendation.collisionReason}`,
      );
      if (recommendation.similarArticles?.length) {
        lines.push(`規則初篩相近題：${recommendation.similarArticles.map((article) => `${article.title}（${article.score}）`).join(" / ")}`);
      }
    }

    lines.push("", buildPublicationBaselinePlanText(mode));
    lines.push("", buildTopPriorityText(mode));
    if (!topCandidates.length) {
      lines.push("", buildPureNewPublishFallbackText(mode));
    }
    lines.push("", "【目前出版清單】");

    focusTrack.chapterGaps.forEach((gap, index) => {
      const publishedPosts = getPublishedPostsForChapter(focusTrack.title, gap.chapter);
      const mergeRule = getPublicationMergeRule(focusTrack.title, gap.chapter);
      lines.push(
        `${index + 1}. ${gap.chapter}｜已上線 ${publishedPosts.length} 篇｜待補 ${gap.remainingToBaseline} 篇`,
      );
      if (mergeRule) {
        lines.push(
          `- 整併目標：${mergeRule.targetTitle}`,
          `- 需整併舊文：${mergeRule.sourceTitles.join(" / ")}`,
        );
      }
      if (gap.recommendedTopic?.primaryTitle) {
        lines.push(
          `- ${getChapterCandidateLead(gap.recommendedTopic)}：${getDisplayTitle(gap.recommendedTopic)}｜子章節：${gap.recommendedTopic.subchapter}｜工作流：${gap.recommendedTopic.workflowAction}`,
        );
      }
      if (publishedPosts.length) {
        lines.push(`- 官網已上線：${publishedPosts.map((post) => `[${isMergeRequiredPublishedPost(post) ? "已整併下架轉向" : "已上線"}] ${getPublishedPostDisplayTitle(post)}`).join(" / ")}`);
      } else {
        lines.push("- 官網已上線：目前無");
      }
      lines.push(`- 待補子章：${gap.missingSubchapters.join(" / ") || "本章主幹已立住"}`);
    });

    lines.push("", buildPublishingTitlePoolText(mode));

    if (articleTopicDecision) {
      lines.push(
        "",
        "【本輪動態決題】",
        `本輪建議標題：${articleTopicDecision.title || "尚未決題"}`,
        `本輪主書系：${articleTopicDecision.track || "尚未決題"}`,
        `本輪章節：${articleTopicDecision.chapter || "尚未決題"}`,
        `本輪子章節：${articleTopicDecision.subchapter || "尚未決題"}`,
        `本輪決題理由：${articleTopicDecision.reason || articleTopicDecision.summary || "尚未提供"}`,
      );
    }

    return lines.join("\n");
  }

