  function renderArticleTopicDecision() {
    const shell = document.getElementById("article-topic-shell");
    const label = document.getElementById("article-topic-label");
    const mode = document.getElementById("article-topic-mode");
    const track = document.getElementById("article-topic-track");
    const chapter = document.getElementById("article-topic-chapter");
    const subchapter = document.getElementById("article-topic-subchapter");
    const title = document.getElementById("article-topic-title");
    const reason = document.getElementById("article-topic-reason");
    const note = document.getElementById("article-topic-note");
    if (
      !(shell instanceof HTMLElement) ||
      !(label instanceof HTMLElement) ||
      !(mode instanceof HTMLElement) ||
      !(track instanceof HTMLElement) ||
      !(chapter instanceof HTMLElement) ||
      !(subchapter instanceof HTMLElement) ||
      !(title instanceof HTMLElement) ||
      !(reason instanceof HTMLElement) ||
      !(note instanceof HTMLElement)
    ) {
      return;
    }

    if (!articleTopicDecision) {
      shell.hidden = true;
      renderPublishingReviewBoard();
      return;
    }

    const modeState = getCurrentTopicModeState(articleTopicDecision.mode);
    const candidateCount = getTopicReviewCandidates(articleTopicDecision.mode, 10).length;
    const mergePoolText = articleTopicDecision.mergePool?.length
      ? `Gemini Pro 已正式納入整併池：${articleTopicDecision.mergePool.join(" / ")}`
      : "";
    const assetMergeText = articleTopicDecision.assetMergePool?.length
      ? `Gemini Pro 已判定資產整併：${articleTopicDecision.assetMergePool.join(" / ")}`
      : "";
    const noMergeReasonText = articleTopicDecision.noMergeReason
      ? `Top 1 不進整併池理由：${articleTopicDecision.noMergeReason}`
      : "";
    const remainingPriorityText = articleTopicDecision.remainingPriorityArticles?.length
      ? `扣掉整併題後，剩餘優先文章為：${articleTopicDecision.remainingPriorityArticles.slice(0, 3).join(" / ")}`
      : "";
    shell.hidden = false;
    label.textContent = articleTopicDecision.summary || "已完成本題動態決題";
    mode.textContent = articleTopicDecision.modeLabel || modeState?.label || articleTopicDecision.mode || "尚未決題";
    track.textContent = articleTopicDecision.track || "尚未決題";
    chapter.textContent = articleTopicDecision.chapter || "尚未決題";
    subchapter.textContent = articleTopicDecision.subchapter || "尚未決題";
    title.textContent = articleTopicDecision.title || "尚未決題";
    reason.textContent = articleTopicDecision.reason || articleTopicDecision.questionLink || "已完成動態決題。";
    note.textContent =
      [
        articleTopicDecision.bookLink || "",
        articleTopicDecision.mergeReason || "",
        mergePoolText,
        assetMergeText,
        noMergeReasonText,
        remainingPriorityText,
        articleTopicDecision.assetMergeTarget ? `資產掛載建議：${articleTopicDecision.assetMergeTarget}` : "",
      ].filter(Boolean).join("｜") ||
      `這一步會先整理書名、章節、既有文章與私訊情境，再交由 Gemini Pro 從 ${candidateCount || "目前"} 個送審候選中決定整併池與本輪採用題目。`;
    renderPublishingReviewBoard();
  }

  function isAssetMergeAction(action = "") {
    return action === "Merge_into_Asset";
  }

  function getArticleTopicAssetMergeMessage(decision = articleTopicDecision) {
    if (!decision || !isAssetMergeAction(decision.finalAction)) return "";
    const title = decision.title || decision.topCandidateTitle || "本題";
    const target = decision.assetMergeTarget ? `建議掛載：${decision.assetMergeTarget}` : "請改回既有文章或資產槽處理，不另開新文。";
    return `Gemini Pro 判定「${title}」應整併為既有文章資產。${target}`;
  }

  function handleArticleTopicAssetMergeStop(decision = articleTopicDecision) {
    const message = getArticleTopicAssetMergeMessage(decision);
    if (!message) return false;
    clearArticleAiResultState();
    clearArticleProFinalizePrompt();
    setFeedback(message, "is-warning");
    setArticleAiFeedback(message, "is-warning");
    return true;
  }

  function loadArticleAiResult() {
    try {
      const raw = localStorage.getItem(ARTICLE_AI_RESULT_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      articleAiResult = typeof parsed?.content === "string" ? parsed.content : "";
      articleAiMode = typeof parsed?.mode === "string" ? parsed.mode : "";
    } catch (error) {
      console.error("讀取 AI 結果失敗：", error);
      articleAiResult = "";
      articleAiMode = "";
    }
  }

  function saveArticleAiResult() {
    try {
      localStorage.setItem(
        ARTICLE_AI_RESULT_KEY,
        JSON.stringify({
          content: articleAiResult,
          mode: articleAiMode,
        }),
      );
      return true;
    } catch (error) {
      console.error("儲存 AI 結果失敗：", error);
      return false;
    }
  }

  function clearArticleAiResultState() {
    articleAiResult = "";
    articleAiMode = "";
    try {
      localStorage.removeItem(ARTICLE_AI_RESULT_KEY);
    } catch (error) {
      console.error("清除 AI 結果失敗：", error);
    }
    renderArticleAiResult();
  }

  function loadArticleProFinalizePrompt() {
    try {
      articleProFinalizePrompt = localStorage.getItem(ARTICLE_PRO_FINALIZE_PROMPT_KEY) || "";
    } catch (error) {
      console.error("讀取 Pro 生文提示詞失敗：", error);
      articleProFinalizePrompt = "";
    }
  }

  function saveArticleProFinalizePrompt() {
    try {
      localStorage.setItem(ARTICLE_PRO_FINALIZE_PROMPT_KEY, articleProFinalizePrompt);
      return true;
    } catch (error) {
      console.error("儲存 Pro 生文提示詞失敗：", error);
      return false;
    }
  }

  function clearArticleProFinalizePrompt() {
    articleProFinalizePrompt = "";
    try {
      localStorage.removeItem(ARTICLE_PRO_FINALIZE_PROMPT_KEY);
    } catch (error) {
      console.error("清除 Pro 生文提示詞失敗：", error);
    }
    renderArticleProPrompt();
  }

  function setArticleAiFeedback(message, mode = "") {
    ["article-ai-feedback", "article-composer-feedback"].forEach((id) => {
      const shell = document.getElementById(id);
      if (!(shell instanceof HTMLElement)) return;
      shell.className = `bookshelf-ai-feedback ${mode}`.trim();
      shell.textContent = message;
    });
  }

  function setPublishingReviewFeedback(message, mode = "") {
    const shell = document.getElementById("publishing-review-feedback");
    if (!(shell instanceof HTMLElement)) return;
    shell.className = `bookshelf-ai-feedback ${mode}`.trim();
    shell.textContent = message;
  }

  function spotlightActionButton(id) {
    const button = document.getElementById(id);
    if (!(button instanceof HTMLButtonElement)) return;
    button.classList.remove("is-guided");
    void button.offsetWidth;
    button.classList.add("is-guided");
    window.setTimeout(() => button.classList.remove("is-guided"), 2400);
  }

  function renderArticleProPrompt() {
    const shell = document.getElementById("article-pro-prompt-shell");
    const label = document.getElementById("article-pro-prompt-label");
    const note = document.getElementById("article-pro-prompt-note");
    const content = document.getElementById("article-pro-prompt-content");
    if (
      !(shell instanceof HTMLElement) ||
      !(label instanceof HTMLElement) ||
      !(note instanceof HTMLElement) ||
      !(content instanceof HTMLTextAreaElement)
    ) {
      return;
    }

    const hasPrompt = Boolean(articleProFinalizePrompt.trim());
    const hasAiResult = Boolean(articleAiResult.trim());
    shell.hidden = !hasPrompt;
    label.textContent = hasPrompt ? (hasAiResult ? "已備好" : "模板已備好") : "尚未備好";
    note.textContent = hasPrompt
      ? hasAiResult
        ? "下方是最近一次備好的版本；若你修改了問題內容，再按一次「複製 Pro 生文提示詞」就會自動更新，並繼續用於 Gemini 內建 Canvas 文件稿。"
        : "目前先備好的是模板版；若先完成 Flash 判題，再按一次複製會自動改成正式版本。"
      : "一鍵流程完成後，這裡會先備好可直接貼去 Gemini 高階模型、用來生成 Gemini 內建 Canvas 文件稿的正式生文提示詞，再嘗試自動複製。";
    content.value = articleProFinalizePrompt;
  }

  function revealArticleProPrompt() {
    const shell = document.getElementById("article-pro-prompt-shell");
    const details = document.getElementById("article-pro-prompt-details");
    if (shell instanceof HTMLElement) {
      shell.hidden = false;
    }
    if (details instanceof HTMLDetailsElement) {
      details.open = true;
    }
  }

  function prepareProFinalizePrompt(question = "") {
    const resolvedQuestion = question || getSafeResolvedArticleSourcePackage().packageText;
    let usedFallback = false;

    try {
      articleProFinalizePrompt = buildProFinalizePrompt(resolvedQuestion, articleAiResult);
      if (!articleProFinalizePrompt.trim()) {
        throw new Error("完整版 Pro 提示詞為空字串");
      }
    } catch (fullError) {
      console.error("完整 Pro 生文提示詞生成失敗，改用穩定版：", fullError);
      usedFallback = true;
      try {
        articleProFinalizePrompt = buildBasicProFinalizePrompt(resolvedQuestion, articleAiResult);
        if (!articleProFinalizePrompt.trim()) {
          throw new Error("穩定版 Pro 提示詞為空字串");
        }
      } catch (basicError) {
        console.error("穩定版 Pro 生文提示詞生成失敗，改用緊急保底版：", basicError);
        try {
          articleProFinalizePrompt = buildEmergencyProFinalizePrompt(resolvedQuestion, articleAiResult);
          if (!articleProFinalizePrompt.trim()) {
            throw new Error("緊急版 Pro 提示詞為空字串");
          }
        } catch (emergencyError) {
          console.error("緊急版 Pro 生文提示詞生成失敗，改用最小保底版：", emergencyError);
          articleProFinalizePrompt = buildMinimalProFinalizePrompt(resolvedQuestion, articleAiResult);
        }
      }
    }

    if (!articleProFinalizePrompt.trim()) {
      console.error("所有 Pro 生文提示詞版本皆為空，改用最小保底版。");
      articleProFinalizePrompt = buildMinimalProFinalizePrompt(resolvedQuestion, articleAiResult);
      usedFallback = true;
    }

    const saved = saveArticleProFinalizePrompt();
    renderArticleProPrompt();
    return {
      prompt: articleProFinalizePrompt,
      saved,
      hasAiResult: Boolean(articleAiResult.trim()),
      usedFallback,
    };
  }

  function getCopyFeedbackState(result, successMessage, manualMessage, failureMessage = "複製失敗，請直接手動複製。") {
    if (result === "clipboard") {
      return { message: successMessage, mode: "is-success" };
    }
    if (result === "manual") {
      return { message: manualMessage, mode: "is-warning" };
    }
    return { message: failureMessage, mode: "is-warning" };
  }

  function getArticleAiTimeoutMs(mode) {
    if (mode === "topic") return ARTICLE_TOPIC_TIMEOUT_MS;
    return mode === "metadata" ? ARTICLE_AI_METADATA_TIMEOUT_MS : ARTICLE_AI_TIMEOUT_MS;
  }

  function buildArticleAiTimeoutMessage(mode) {
    if (mode === "topic") {
      return "Gemini Pro 本題動態決題逾時，請再試一次。";
    }
    if (mode === "metadata") {
      return "主書系、章節與標題補齊逾時，已保留目前判題結果。";
    }
    return "Gemini Flash 回應逾時，請再試一次。";
  }

  function renderArticleAiResult() {
    const shell = document.getElementById("article-ai-result-shell");
    const label = document.getElementById("article-ai-result-label");
    const content = document.getElementById("article-ai-result-content");
    const decisionShell = document.getElementById("article-ai-decision");
    const decisionTitle = document.getElementById("article-ai-decision-title");
    const decisionAction = document.getElementById("article-ai-decision-action");
    const decisionSimilar = document.getElementById("article-ai-decision-similar");
    const decisionAngle = document.getElementById("article-ai-decision-angle");
    const decisionTrack = document.getElementById("article-ai-decision-track");
    const decisionChapter = document.getElementById("article-ai-decision-chapter");
    const decisionArticleTitle = document.getElementById("article-ai-decision-article-title");
    if (
      !(shell instanceof HTMLDetailsElement) ||
      !(label instanceof HTMLElement) ||
      !(content instanceof HTMLElement) ||
      !(decisionShell instanceof HTMLElement) ||
      !(decisionTitle instanceof HTMLElement) ||
      !(decisionAction instanceof HTMLElement) ||
      !(decisionSimilar instanceof HTMLElement) ||
      !(decisionAngle instanceof HTMLElement) ||
      !(decisionTrack instanceof HTMLElement) ||
      !(decisionChapter instanceof HTMLElement) ||
      !(decisionArticleTitle instanceof HTMLElement)
    ) {
      return;
    }

    const hasResult = Boolean(articleAiResult.trim());
    const decision = getArticleAiDecision(articleAiResult);
    const confirmData = getArticleConfirmData(articleAiResult);
    label.textContent = hasResult
      ? articleAiMode === "quick"
        ? "快速判題"
        : "Flash 長稿備援"
      : "尚未生成";
    decisionShell.hidden = !hasResult;
    decisionTitle.textContent = decision.title;
    decisionAction.textContent = decision.action;
    decisionSimilar.textContent = decision.similar;
    decisionAngle.textContent = decision.angle;
    decisionTrack.textContent = confirmData.track;
    decisionChapter.textContent = confirmData.chapter;
    decisionArticleTitle.textContent = confirmData.title;
    content.textContent = articleAiResult;
    shell.open = hasResult;
    try {
      renderArticleConfirm(articleAiResult);
    } catch (error) {
      console.error("渲染文章確認卡失敗：", error);
    }
    try {
      renderArticleSocialReplies(articleAiResult);
    } catch (error) {
      console.error("渲染社群回覆卡失敗：", error);
    }
    try {
      renderPublishingReviewBoard();
    } catch (error) {
      console.error("渲染出版覆核看板失敗：", error);
    }
    try {
      renderArticleComposerPanel();
    } catch (error) {
      console.error("渲染生文前置包區塊失敗：", error);
    }
  }

  function setArticleAiBusy(isBusy) {
    ["run-article-ai-flow-highfreq", "run-article-ai-quick", "run-article-ai-draft", "copy-article-ai-result", "copy-article-category", "copy-article-confirm-payload", "copy-social-reply-short", "copy-social-reply-pro", "copy-social-reply-lead", "copy-publishing-review-prompt", "copy-publishing-review-outline", "copy-article-context-summary", "copy-article-prep-package"].forEach((id) => {
      const button = document.getElementById(id);
      if (button instanceof HTMLButtonElement) {
        button.disabled = isBusy;
      }
    });
    document.querySelectorAll("[data-canned-reply-copy-button]").forEach((button) => {
      if (button instanceof HTMLButtonElement) {
        button.disabled = isBusy;
      }
    });
    if (!isBusy) {
      renderCrossSeriesLock();
    }
  }

  function buildArticleTopicDecisionContext(decision = articleTopicDecision) {
    if (!decision) return "（尚未產生本題動態決題，請先依本輪前置包與固定骨架保守判斷。）";
    return [
      `決題模式：${decision.modeLabel || decision.mode || currentTopicMode}`,
      `最終動作：${decision.finalAction || "New_Publish"}`,
      `主書系：${decision.track}`,
      `章節：${decision.chapter}`,
      `子章節：${decision.subchapter}`,
      `建議標題：${decision.title}`,
      `正式入池：${decision.mergePool?.join(" / ") || "目前無"}`,
      `資產整併：${decision.assetMergePool?.join(" / ") || "目前無"}`,
      `跳過優先序的文章：${decision.skippedTitles?.join(" / ") || "目前無"}`,
      `Top 1 候選：${decision.topCandidateTitle || "尚未標註"}`,
      `同任務判定：${decision.sameMissionVerdict || "尚未標註"}`,
      `不進整併池理由：${decision.noMergeReason || "尚未提供"}`,
      `資產掛載建議：${decision.assetMergeTarget || "尚未提供"}`,
      `剩餘優先文章：${decision.remainingPriorityArticles?.join(" / ") || "目前無"}`,
      `決題理由：${decision.reason || decision.summary || "已先完成動態決題。"}`,
      `問題連結：${decision.questionLink || "請沿用本輪前置包的核心痛點"}`,
      `書稿連結：${decision.bookLink || "請維持在這個書稿骨架內落位"}`,
    ].join("\n");
  }

  function buildChapterMissionText(chapter = "", subchapter = "") {
    if (chapter === "現況判讀") return `先立住「${subchapter || "前期判讀"}」這個主幹，讓讀者知道翻新前應先看什麼、先判斷什麼。`;
    if (chapter === "預算拆解") return `補強「${subchapter || "預算拆解"}」的決策框架，避免讀者只看到零散預算資訊。`;
    if (chapter === "基礎工程") return `把「${subchapter || "基礎工程"}」寫成能支撐後續施工排序與避雷的基礎主幹。`;
    if (chapter === "空間重整") return `把「${subchapter || "空間重整"}」整理成可直接對應生活動線與配置取捨的實用框架。`;
    if (chapter === "完工避雷") return `讓「${subchapter || "完工避雷"}」成為讀者在驗收、保固與爭議預防上的收尾工具文。`;
    return `請把這篇寫成能補齊「${chapter || "本章"} / ${subchapter || "本子章"}」缺口的主幹文。`;
  }

  function buildArticleContextSummary() {
    const { recommendation, focusTrack, bookProposal } = getRecommendedArticleSeed();
    const title = getResolvedArticlePresetTitle() || "尚未設定";
    const track = articleTopicDecision?.track || recommendation?.trackTitle || focusTrack?.title || "尚未判定";
    const chapter = articleTopicDecision?.chapter || recommendation?.chapter || "尚未判定";
    const subchapter = articleTopicDecision?.subchapter || recommendation?.subchapter || "尚未判定";
    const similarArticles = recommendation?.similarArticles?.slice(0, 2) || [];
    const sourceQuestion = articleSourceQuestion.trim();
    return [
      `目標書名：${bookProposal?.bookTitle || track}`,
      `本輪預設題目：${title}`,
      `出版落位：${track} / ${chapter} / ${subchapter}`,
      `文章任務：${buildChapterMissionText(chapter, subchapter)}`,
      `推薦理由：${articleTopicDecision?.reason || recommendation?.reason || "目前先沿用系統推薦落位與出版缺口判斷。"}`,
      `規則層初篩：${recommendation?.collisionRisk ? `${recommendation.collisionRisk}｜${recommendation.collisionReason}` : "尚未比對"}`,
      `規則初篩相近題：${similarArticles.length ? similarArticles.map((item) => `${item.title}（${item.score}）`).join(" / ") : "目前尚無需送審比對的規則初篩相近題"}`,
      `真實社團問題：${sourceQuestion || "目前尚未貼入；請先用出版落位與預設題目起稿，高階 LLM 可視需要改題。"}`,
    ].join("\n");
  }

  function buildArticlePrepPackage() {
    const sourceQuestion = articleSourceQuestion.trim();
    const presetTitle = getResolvedArticlePresetTitle();
    const topicDecisionBlock = buildArticleTopicDecisionContext();
    return [
      "【本輪預設題目】",
      presetTitle || "尚未設定",
      "",
      "【題目使用原則】",
      "這是目前最推薦的起稿題目，高階 LLM 可沿用、微調或改題，但需維持在同一本主書骨架內並交代理由。",
      "",
      "【情境摘要】",
      buildArticleContextSummary(),
      "",
      "【本題動態決題】",
      topicDecisionBlock,
      "",
      "【真實社團問題】",
      sourceQuestion || "目前尚未貼入真實社團問題。",
    ].join("\n");
  }

  function buildResolvedArticleSourcePackage() {
    const sourceQuestion = persistArticleSourceQuestion();
    const presetTitle = persistArticlePresetTitle();
    const packageText = buildArticlePrepPackage();
    return {
      sourceQuestion,
      presetTitle,
      packageText,
      hasSeed: Boolean(sourceQuestion || presetTitle || articleTopicDecision?.title || getRecommendedArticleSeed().recommendation?.primaryTitle),
    };
  }

  function buildFallbackArticleSourcePackage() {
    const sourceQuestion = articleSourceQuestion.trim();
    const presetTitle = articlePresetTitle.trim() || articleTopicDecision?.title || "尚未設定";
    const lines = [
      "【本輪預設題目】",
      presetTitle || "尚未設定",
      "",
      "【真實社團問題】",
      sourceQuestion || "目前尚未貼入真實社團問題。",
    ];
    if (articleTopicDecision?.title) {
      lines.push(
        "",
        "【本題動態決題】",
        `建議標題：${articleTopicDecision.title}`,
        `主書系：${articleTopicDecision.track || "尚未判定"}`,
        `章節：${articleTopicDecision.chapter || "尚未判定"}`,
        `子章節：${articleTopicDecision.subchapter || "尚未判定"}`,
      );
    }
    return {
      sourceQuestion,
      presetTitle,
      packageText: lines.join("\n"),
      hasSeed: Boolean(sourceQuestion || presetTitle),
      usedFallback: true,
    };
  }

  function getSafeResolvedArticleSourcePackage() {
    try {
      return {
        ...buildResolvedArticleSourcePackage(),
        usedFallback: false,
      };
    } catch (error) {
      console.error("整理生文前置包失敗，改用最小可用版本：", error);
      return buildFallbackArticleSourcePackage();
    }
  }

  function renderArticleComposerPanel() {
    const summaryField = document.getElementById("article-context-summary");
    const prepField = document.getElementById("article-prep-package");
    const note = document.getElementById("article-prep-note");
    if (!(summaryField instanceof HTMLTextAreaElement) || !(prepField instanceof HTMLTextAreaElement) || !(note instanceof HTMLElement)) {
      return;
    }
    summaryField.value = buildArticleContextSummary();
    prepField.value = buildArticlePrepPackage();
    note.textContent = articleSourceQuestion.trim()
      ? "目前前置包已包含真實社團問題；高階 LLM 可沿用、微調或改題。"
      : "目前未貼入真實社團問題，前置包會先用出版落位與情境摘要補足起稿資訊。";
    applyArticlePresetTitleToField();
    renderPublishingAssetSlots();
    renderCrossSeriesLock();
  }

  function buildArticlePrompt(problemText = "", mode = "full", currentContent = "") {
    const questionBlock = problemText.trim() || "（請在此貼上本輪生文前置包）";
    const isShortQuestion = questionBlock.length <= 90;
    const currentContentBlock = currentContent.trim() || "（目前尚無 AI 初判內容）";
    const topicDecisionBlock = buildArticleTopicDecisionContext();
    const tracksText = formatTrackStructureText();
    const intakeFieldText = articleIntakeFields.join(" / ");
    const siteCategoryText = siteCategoryOptions.join(" / ");
    const overlapRuleText = overlapRules
      .map((rule, index) => `${index + 1}. ${rule.title}：${rule.detail}`)
      .join("\n");
    const modeInstruction = mode === "quick"
      ? [
          "本次模式：快速判題。",
          "請先完成『判題結論』、『文章標題』、『章節名稱』、『文章入庫卡』，再往下輸出其他段落。",
          "不要輸出任何前言或收到指示的回應，第一行必須直接從「0. 【判題結論】」開始。",
          "若已有明確舊文可補，官網文章只需給精簡段落架構，不必完整展開。",
          "Copilot 生圖提示詞仍要照樣輸出，方便先備圖。",
        ].join("\n")
      : [
          "本次模式：完整初稿。",
          "請先完成『判題結論』、『文章標題』、『章節名稱』、『文章入庫卡』，再繼續輸出重複判斷、社團回覆、官網文章初稿與 Copilot 生圖提示詞。",
          "不要輸出任何前言或收到指示的回應，第一行必須直接從「0. 【判題結論】」開始。",
        ].join("\n");
    const contextInstruction = isShortQuestion
      ? [
          "注意：這次原始問題偏短，資訊不足。",
          "請先主動補出最合理的情境假設，再往後做判題與文章生成。",
          "補全方向請優先涵蓋：屋況、空間位置、使用者情境、常見預算顧慮、施工或材料限制。",
          "補全時要保持保守，不要亂編過度具體的數字或地址；請用『可能是 / 多半是 / 若以一般住宅情境推估』這種寫法。",
          "若牽涉預算、費用、單價或報價，只能用保守區間與條件差異來寫，不可寫成像正式報價單或固定承諾價。",
        ].join("\n")
      : [
          "若原始問題已帶有足夠情境，就沿用原始問題，不必額外補太多假設。",
          "若牽涉預算、費用、單價或報價，請優先寫成保守區間、條件差異與常見變動因子，不要寫成固定價格承諾。",
        ].join("\n");
