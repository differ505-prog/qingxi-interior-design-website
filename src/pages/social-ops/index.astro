  function renderCrossSeriesLock(content = articleAiResult) {
    const shell = document.getElementById("article-cross-series-lock");
    const note = document.getElementById("article-cross-series-lock-note");
    const currentBookTitle = getBookProposal(currentTopicMode)?.bookTitle || "";
    const confirmData = getArticleConfirmData(content);
    const hasResolvedConfirm = Boolean(
      confirmData.title &&
      confirmData.title !== "尚未判定" &&
      confirmData.track &&
      confirmData.track !== "尚未判定",
    );
    const conflictKeyword = currentBookTitle.includes("老屋") && hasResolvedConfirm
      ? hasCrossSeriesConflict(
        confirmData.title,
        confirmData.category,
        confirmData.track,
        articleTopicDecision?.title || "",
        articleTopicDecision?.track || "",
      )
      : "";
    const isLocked = Boolean(conflictKeyword);
    if (shell instanceof HTMLElement) {
      shell.hidden = !isLocked;
    }
    if (note instanceof HTMLElement && isLocked) {
      note.textContent = `偵測到互斥詞彙「${conflictKeyword}」，目前主書為老屋翻新主線，請退回改題或清理標籤後再確認。`;
    }
    return isLocked;
  }

  function renderArticleSyncGuard(content = articleAiResult) {
    const shell = document.getElementById("article-sync-guard");
    const title = document.getElementById("article-sync-guard-title");
    const note = document.getElementById("article-sync-guard-note");
    const modeState = getCurrentTopicModeState(currentTopicMode);
    const focusTrack = modeState?.publishingDashboard?.focusTrack;
    const syncState = getTopicStateSyncState(content, currentTopicMode);
    const chronologyMessage = getChronologyWarningMessage(syncState.expectedCandidate, focusTrack);
    const dependencyMessage = getDependencyLockMessage(syncState.expectedCandidate, focusTrack);
    const isLocked = Boolean(chronologyMessage || dependencyMessage || syncState.fatal);
    if (shell instanceof HTMLElement) {
      shell.hidden = !content.trim();
      shell.classList.toggle("is-alert", isLocked);
    }
    if (title instanceof HTMLElement) {
      title.textContent = chronologyMessage
        ? "前置工程章節尚未穩固，禁止跳躍發布"
        : dependencyMessage
          ? "章節內依賴順序未滿足，已鎖定確認動作"
        : syncState.fatal
          ? "候選、問題與落地資訊不同步，已鎖定確認動作"
          : "本輪送審候選與落地資訊已同步";
    }
    if (note instanceof HTMLElement) {
      note.textContent = chronologyMessage || dependencyMessage || syncState.message;
    }
    return isLocked;
  }

  function renderArticleConfirm(content) {
    const shell = document.getElementById("article-category-confirm");
    const category = document.getElementById("article-confirm-category");
    const track = document.getElementById("article-confirm-track");
    const chapter = document.getElementById("article-confirm-chapter");
    const title = document.getElementById("article-confirm-title");
    const confirmButton = document.getElementById("copy-article-confirm-payload");
    const categoryButton = document.getElementById("copy-article-category");
    if (
      !(shell instanceof HTMLElement) ||
      !(category instanceof HTMLElement) ||
      !(track instanceof HTMLElement) ||
      !(chapter instanceof HTMLElement) ||
      !(title instanceof HTMLElement)
    ) {
      return;
    }

    const hasResult = Boolean(content.trim());
    const data = getArticleConfirmData(content);
    shell.hidden = !hasResult;
    category.textContent = data.category;
