                  {bookshelfOutlineGroups.map((group) => (
                    <details class="bookshelf-outline-card">
                      <summary class="bookshelf-outline-summary">
                        <div class="bookshelf-outline-head">
                          <div>
                            <p>{group.title}</p>
                            <strong>{group.filledChapters} / {group.chapters.length} 章已成形</strong>
