  function buildTitleKeywordSet(text) {
    return Array.from(new Set(
      text
        .split(/[\s,，。、「」\/()（）\-｜—:：]+/)
        .map((token) => token.trim())
        .filter((token) => token.length >= 2),
    ));
  }

  function inferSimilarArticleTitle(content, articleTitle = "") {
    const queryText = `${articleTitle}\n${content}`;
    const keywords = buildTitleKeywordSet(queryText);
    if (!keywords.length) return "";

    let bestTitle = "";
    let bestScore = 0;

    articleLibrary.forEach((post) => {
      const haystack = `${post.title}\n${post.category}`.replace(/\s+/g, "");
      const score = keywords.reduce((sum, keyword) => sum + (haystack.includes(keyword) ? keyword.length : 0), 0);
      if (score > bestScore) {
        bestScore = score;
        bestTitle = post.title;
      }
    });

    return bestScore >= 4 ? bestTitle : "";
  }

  function findArticleByTitle(title = "") {
    const normalizedTitle = normalizeComparableText(title.replace(/[《》「」]/g, ""));
    if (!normalizedTitle || /暫未比對|請看下方 AI 原文|尚未判定/.test(title)) return null;

    return (
      articleLibrary.find((post) => normalizeComparableText(post.title) === normalizedTitle) ||
      articleLibrary.find((post) => normalizeComparableText(post.title).includes(normalizedTitle)) ||
      articleLibrary.find((post) => normalizedTitle.includes(normalizeComparableText(post.title))) ||
      null
    );
  }

  function inferSimilarArticle(content, articleTitle = "") {
    const queryText = `${articleTitle}\n${content}`;
    const keywords = buildTitleKeywordSet(queryText);
    if (!keywords.length) return null;

    let bestPost = null;
    let bestScore = 0;

    articleLibrary.forEach((post) => {
      const haystack = `${post.title}\n${post.category}\n${post.summary || ""}`.replace(/\s+/g, "");
      const score = keywords.reduce((sum, keyword) => sum + (haystack.includes(keyword) ? keyword.length : 0), 0);
      if (score > bestScore) {
        bestScore = score;
        bestPost = post;
      }
    });

    return bestScore >= 4 ? bestPost : null;
  }

  function getBlogPostUrl(post) {
    if (!post?.slug) return BLOG_INDEX_URL;
    return `${SITE_ORIGIN}/blog/${post.slug}`;
  }

  function resolveSocialReplyTarget(content) {
    const decisionSimilar = summarizeDecisionSimilar(content);
    const articleTitle = parseArticleTitle(content);
    const matchedPost =
      findArticleByTitle(decisionSimilar) ||
      findArticleByTitle(articleTitle) ||
      inferSimilarArticle(content, articleTitle);

    if (matchedPost) {
      return {
        title: matchedPost.title,
        url: getBlogPostUrl(matchedPost),
      };
    }

    return {
      title: "知識分享",
      url: BLOG_INDEX_URL,
    };
  }

  function injectLeadReplyUrl(text, target) {
    const cleanText = String(text || "").trim();
    const fallbackSentence =
      target.title === "知識分享"
        ? `這題細節比較多，我有持續整理在官網知識分享，有需要可以先看這裡：${target.url}`
        : `這題細節比較多，我剛好整理過一篇更完整的分析，有需要可以先看這篇：${target.url}`;

    if (!cleanText) return fallbackSentence;
    if (/https?:\/\//i.test(cleanText)) return cleanText;

    const replaced = cleanText.replace(/\[預留網址空間\]|\(預留網址空間\)|（預留網址空間）|預留網址空間/g, target.url);
    if (replaced !== cleanText) return replaced;

    if (/參考|看這篇|看這裡|看完整|完整分析/.test(cleanText)) {
      return `${cleanText} ${target.url}`.trim();
    }

    return `${cleanText}${/[。！？!?]$/.test(cleanText) ? "" : "。"}${fallbackSentence}`;
  }

  function extractSectionByTitles(content, titles) {
    for (const title of titles) {
      const section = extractSectionText(content, title);
      if (section) return section;
    }
    return "";
  }

  function parseSingleLineSection(content, titles, keys = []) {
    const section = extractSectionByTitles(content, titles);
    const lines = normalizeSectionLines(section);
    if (!lines.length) return "";
    return (
      (keys.length ? extractFieldValue(lines, keys) || extractFieldValueFromText(section, keys) : "") ||
      lines[0] ||
      ""
    );
  }

  function normalizeDecisionLine(value) {
    const line = value.split("\n")[0]?.trim() || "";
    if (/優先補舊文|補強舊文/.test(line)) return "優先補舊文";
    if (/改寫舊文|先改寫舊文/.test(line)) return "先改寫舊文";
    if (/同章延伸|可做同章延伸/.test(line)) return "可做同章延伸";
    if (/開新文|值得另開新文/.test(line)) return "值得另開新文";
    return "";
  }

  function parseArticleIntakeCard(content) {
    const section = extractSectionText(content, "文章入庫卡");
    const lines = normalizeSectionLines(section);
    const track = extractFieldValue(lines, ["主書系"]) || extractFieldValueFromText(content, ["主書系"]) || findTrackFromText(section) || findTrackFromText(content);
    const categoryValue = extractFieldValue(lines, ["網站分類", "分類"]) || extractFieldValueFromText(content, ["網站分類", "分類"]);
    const category = normalizeSiteCategory(categoryValue);
    const explicitChapter = extractFieldValue(lines, ["章節定位"]) || parseSingleLineSection(content, ["章節名稱"], ["章節名稱", "章節定位", "章名"]) || extractFieldValueFromText(content, ["章節定位", "章節名稱", "章名"]);
    const inferredChapter = track ? inferChapterFromTrack(track, parseArticleTitle(content), content) : "";
    const inferredCategory = inferSiteCategory(track, parseArticleTitle(content), content);
    return {
      category: category || inferredCategory || "尚未判定",
      track: track || "尚未判定",
      chapter: explicitChapter || inferredChapter || "尚未判定",
    };
  }

  function parseArticleTitle(content) {
    const section = extractSectionByTitles(content, ["文章標題", "書籍章節級別的文章標題"]);
    const lines = normalizeSectionLines(section);
    return (
      extractFieldValue(lines, ["標題", "文章標題"]) ||
      extractFieldValueFromText(section, ["標題", "文章標題"]) ||
      extractFieldValueFromText(content, ["文章標題"]) ||
      lines.find((line) => !/建議分類|分類/.test(line)) ||
      "尚未判定"
    );
  }

  function parseArticleSocialReplies(content) {
    const section = extractSectionByTitles(content, ["社團回覆稿", "社團回覆誘餌（約 50-80 字）", "社團回覆誘餌"]);
    const lines = normalizeSectionLines(section);
    const short = extractFieldValue(lines, ["簡短版"]) || extractFieldValueFromText(section, ["簡短版"]);
    const pro = extractFieldValue(lines, ["專業版"]) || extractFieldValueFromText(section, ["專業版"]);
    const lead = extractFieldValue(lines, ["導流版"]) || extractFieldValueFromText(section, ["導流版"]);
    const fallback = lines.join(" ").trim();

    if (short || pro || lead) {
      return {
        short: short || pro || lead || "",
        pro: pro || short || lead || "",
        lead: lead || pro || short || "",
      };
    }

    return {
      short: fallback,
      pro: fallback,
      lead: fallback,
    };
  }

  function getResolvedArticleSocialReplies(content) {
    const replies = parseArticleSocialReplies(content);
    const target = resolveSocialReplyTarget(content);
    return {
      ...replies,
      lead: injectLeadReplyUrl(replies.lead, target),
    };
  }

  function getArticleConfirmData(content) {
    if (!content.trim()) {
      return {
        category: "尚未判定",
        track: "尚未判定",
        chapter: "尚未判定",
        title: "尚未判定",
      };
    }

    const intake = parseArticleIntakeCard(content);
    return {
      ...intake,
      title: parseArticleTitle(content),
    };
  }

  function needsArticleMetadataFallback(content) {
    if (!content.trim()) return false;
    const confirmData = getArticleConfirmData(content);
    return (
      summarizeDecisionTitle(content) === "請看 AI 原文" ||
      confirmData.track === "尚未判定" ||
      confirmData.chapter === "尚未判定" ||
      confirmData.title === "尚未判定"
    );
  }

  function buildArticleSectionBlock(order, title, body) {
    if (!body.trim()) return "";
    return `${order}. 【${title}】\n${body.trim()}`;
  }

  function mergeArticleAiContent(baseContent, metadataContent) {
    const base = baseContent.trim();
    const metadata = metadataContent.trim();
    if (!base) return metadata;
    if (!metadata) return base;

    const blocks = [base];
    const baseConfirm = getArticleConfirmData(base);
    const baseDecisionTitle = summarizeDecisionTitle(base);
    const metadataDecision = extractSectionText(metadata, "判題結論");
    const metadataTitle = extractSectionByTitles(metadata, ["文章標題", "書籍章節級別的文章標題"]);
    const metadataChapter = extractSectionText(metadata, "章節名稱");
    const metadataIntake = extractSectionText(metadata, "文章入庫卡");

    if (baseDecisionTitle === "請看 AI 原文" && metadataDecision) {
      blocks.push(buildArticleSectionBlock(0, "判題結論", metadataDecision));
    }
    if (baseConfirm.title === "尚未判定" && metadataTitle) {
      blocks.push(buildArticleSectionBlock(1, "文章標題", metadataTitle));
    }
    if (baseConfirm.chapter === "尚未判定" && metadataChapter) {
      blocks.push(buildArticleSectionBlock(2, "章節名稱", metadataChapter));
    }
    if (
      (baseConfirm.track === "尚未判定" || baseConfirm.chapter === "尚未判定" || baseConfirm.category === "尚未判定") &&
      metadataIntake
    ) {
      blocks.push(buildArticleSectionBlock(3, "文章入庫卡", metadataIntake));
    }

    return blocks.filter(Boolean).join("\n\n");
  }

  function buildArticleConfirmPayload(data) {
    return [
      `網站分類：${data.category}`,
      `主書系：${data.track}`,
      `章節定位：${data.chapter}`,
      `文章標題：${data.title}`,
    ].join("\n");
  }

  function renderArticleConfirm(content) {
    const shell = document.getElementById("article-category-confirm");
    const category = document.getElementById("article-confirm-category");
    const track = document.getElementById("article-confirm-track");
    const chapter = document.getElementById("article-confirm-chapter");
    const title = document.getElementById("article-confirm-title");
    if (
      !(shell instanceof HTMLElement) ||
      !(category instanceof HTMLElement) ||
      !(track instanceof HTMLElement) ||
      !(chapter instanceof HTMLElement) ||
      !(title instanceof HTMLElement)
    ) {
      return;
    }

    const hasResult = Boolean(content.trim());
    const data = getArticleConfirmData(content);
    shell.hidden = !hasResult;
    category.textContent = data.category;
    track.textContent = data.track;
    chapter.textContent = data.chapter;
    title.textContent = data.title;
  }

  function renderArticleSocialReplies(content) {
    const shell = document.getElementById("article-social-replies");
    const short = document.getElementById("article-social-reply-short");
    const pro = document.getElementById("article-social-reply-pro");
    const lead = document.getElementById("article-social-reply-lead");
    if (
      !(shell instanceof HTMLElement) ||
      !(short instanceof HTMLElement) ||
      !(pro instanceof HTMLElement) ||
      !(lead instanceof HTMLElement)
    ) {
      return;
    }

    const hasResult = Boolean(content.trim());
    const replies = getResolvedArticleSocialReplies(content);
    const hasReplies = Boolean(replies.short || replies.pro || replies.lead);
    shell.hidden = !(hasResult && hasReplies);
    short.textContent = replies.short || "尚未生成";
    pro.textContent = replies.pro || "尚未生成";
    lead.textContent = replies.lead || "尚未生成";
  }

  function summarizeDecisionTitle(content) {
    const decisionSection = extractSectionText(content, "判題結論");
    const singleLineDecision = normalizeDecisionLine(decisionSection);
    if (singleLineDecision) return singleLineDecision;
    const sourceText = content.split("\n").slice(0, 8).join("\n");
    const fallbackDecision = normalizeDecisionLine(sourceText);
    if (fallbackDecision) return fallbackDecision;
    return "請看 AI 原文";
  }

  function summarizeDecisionAction(title) {
    if (title === "優先補舊文") return "先補強既有文章，再用舊文連結回覆社團。";
    if (title === "先改寫舊文") return "先重整舊文標題與段落，再導回同一篇主文。";
    if (title === "可做同章延伸") return "保留舊文主幹，另外開一篇延伸角度並互相內鏈。";
    if (title === "值得另開新文") return "直接生成初稿，作為新主文收進對應書系。";
    return "先看下方 AI 原文，再決定是補舊文還是另開新文。";
  }

  function summarizeDecisionSimilar(content) {
    const duplicateSection = extractSectionText(content, "重複判斷");
    if (!duplicateSection) {
      return inferSimilarArticleTitle(content, parseArticleTitle(content)) || "暫未比對到明確舊文";
    }

    const lines = duplicateSection
      .split("\n")
      .map((line) => line.replace(/^[-*\d.\s]+/, "").trim())
      .filter(Boolean);

    const similarLine = lines.find((line) =>
      /最相似|相似舊文|既有文章|舊文/.test(line) &&
      !/開新文|補強舊文|改寫舊文|同章延伸|原因/.test(line),
    );

    if (similarLine) {
      return similarLine
        .replace(/^(最相似的?\s*1-3\s*篇既有文章標題|最相似文章|相似舊文|既有文章)[:：]?\s*/i, "")
        .slice(0, 42) || "請看下方 AI 原文";
    }

    const candidateLine = lines.find((line) => !/開新文|補強舊文|改寫舊文|同章延伸|原因/.test(line));
    if (candidateLine) return candidateLine.slice(0, 42);

    return inferSimilarArticleTitle(content, parseArticleTitle(content)) || "暫未比對到明確舊文";
  }

  function summarizeDecisionAngle(content) {
    const angleSection = extractSectionText(content, "社團回覆視角");
    if (angleSection) {
      return angleSection
        .split("\n")
        .map((line) => line.replace(/^[-*\d.\s]+/, "").trim())
        .filter(Boolean)[0]
        ?.slice(0, 42) || "先從對方最在意的痛點切入";
    }

    if (/預算/.test(content)) return "先從預算與取捨切入";
    if (/西曬|日照|溫度/.test(content)) return "先從舒適度與日照切入";
    if (/插座|開關|收納|不夠用/.test(content)) return "先從日後是否夠用切入";
    return "先從對方最在意的痛點切入";
  }

  async function copyArticleSocialReply(variant, successMessage) {
    const replies = getResolvedArticleSocialReplies(articleAiResult);
    const text = replies[variant]?.trim();
    if (!text) {
      setArticleAiFeedback("目前沒有可複製的社團回覆稿。", "is-warning");
      return;
    }
    await copyText(text, successMessage);
    setArticleAiFeedback(successMessage, "is-success");
  }

  function getArticleAiDecision(content) {
    if (!content.trim()) {
      return {
        title: "尚未判定",
        action: "先貼問題再判題",
        similar: "尚未比對",
        angle: "先貼問題再判題",
      };
    }

    const title = summarizeDecisionTitle(content);
    return {
      title,
      action: summarizeDecisionAction(title),
      similar: summarizeDecisionSimilar(content),
      angle: summarizeDecisionAngle(content),
    };
  }

  async function requestArticleAi(mode, currentContent = "") {
    const question = persistArticleSourceQuestion();
    if (!question) {
      setFeedback("請先貼上真實社團問題。", "is-warning");
      setArticleAiFeedback("請先貼上真實社團問題。", "is-warning");
      return null;
    }

    try {
      const response = await fetch("/api/social-ops/article-assist", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          mode,
          prompt: buildArticlePrompt(question, mode, currentContent),
        }),
      });

      const result = await response.json();
      if (!response.ok) {
        const errorMessage = result?.error === "GEMINI_API_KEY_MISSING"
          ? "尚未設定 GEMINI_API_KEY，先用手動提示詞模式。"
          : "Gemini Flash 目前無法生成，請稍後再試。";
        setFeedback(errorMessage, "is-warning");
        setArticleAiFeedback(errorMessage, "is-warning");
        return null;
      }

      return typeof result?.content === "string" ? result.content : "";
    } catch (error) {
      console.error("Gemini Flash 生成失敗：", error);
      setFeedback("Gemini Flash 連線失敗，請稍後再試。", "is-warning");
      setArticleAiFeedback("Gemini Flash 連線失敗，請稍後再試。", "is-warning");
      return null;
    }
  }

  async function copyProArticlePrompt(question, successMessage, warningMessage) {
    const prompt = buildProFinalizePrompt(question, articleAiResult);
    await copyText(prompt, successMessage);
    setArticleAiFeedback(successMessage, articleAiResult.trim() ? "is-success" : "is-warning");
    if (!articleAiResult.trim() && warningMessage) {
      setFeedback(warningMessage, "is-warning");
    }
  }

  async function enrichArticleMetadataIfNeeded(content, sourceMode) {
    if (!needsArticleMetadataFallback(content)) {
      return content;
    }

    setArticleAiFeedback(
      sourceMode === "full"
        ? "初稿已生成，正在自動補齊主書系、章節與標題..."
        : "判題已完成，正在自動補齊主書系、章節與標題...",
      "is-success",
    );

    const metadataContent = await requestArticleAi("metadata", content);
    if (!metadataContent) {
      return content;
    }

    return mergeArticleAiContent(content, metadataContent);
  }

  async function runArticleAi(mode) {
    setArticleAiBusy(true);
    setArticleAiFeedback(mode === "quick" ? "Gemini Flash 判題中..." : "Gemini Flash 長稿備援生成中...");

    try {
      const content = await requestArticleAi(mode);
      if (!content) return false;
      articleAiResult = await enrichArticleMetadataIfNeeded(content, mode);
      articleAiMode = mode;
      saveArticleAiResult();
      renderArticleAiResult();
      const successMessage = mode === "quick" ? "已完成 AI 快速判題與社團回覆稿整理。" : "已完成 Flash 長稿備援生成。";
      setFeedback(successMessage, "is-success");
      setArticleAiFeedback(successMessage, "is-success");
      return true;
    } finally {
      setArticleAiBusy(false);
    }
  }

  async function runArticleAiFlow() {
    setArticleAiBusy(true);
    setArticleAiFeedback("一鍵流程啟動中：先判題，再備好 Pro 生文提示詞...", "is-success");

    try {
      const quickContent = await requestArticleAi("quick");
      if (!quickContent) return;

      articleAiResult = await enrichArticleMetadataIfNeeded(quickContent, "quick");
      articleAiMode = "quick";
      saveArticleAiResult();
      renderArticleAiResult();

      const question = persistArticleSourceQuestion();
      await copyProArticlePrompt(question, "已完成判題並複製 Pro 生文提示詞。");
      setArticleAiFeedback("已完成判題並複製 Pro 生文提示詞。", "is-success");
    } finally {
      setArticleAiBusy(false);
    }
  }

  async function copyText(text, successMessage) {
    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
      } else {
        window.prompt("請手動複製以下內容", text);
      }
      setFeedback(successMessage, "is-success");
    } catch (error) {
      console.error("複製失敗：", error);
      setFeedback("複製失敗，請再試一次。", "is-warning");
    }
  }

  function createGeminiDraftFromMaster() {
    return {
      title: geminiCanvasMasterData.title,
      sourceUrl: geminiCanvasMasterData.sourceUrl,
      content: geminiCanvasMasterData.content,
    };
  }

  function normalizeGeminiBackups(backups = []) {
    if (!Array.isArray(backups)) return [];

    return backups
      .filter(Boolean)
      .map((backup) => ({
        id: backup.id || `gemini-backup-${Date.now()}-${Math.random().toString(16).slice(2)}`,
        title: backup.title || geminiCanvasMasterData.title,
        sourceUrl: backup.sourceUrl || geminiCanvasMasterData.sourceUrl,
        content: backup.content || "",
        savedAt: backup.savedAt || new Date().toISOString(),
        isPinned: Boolean(backup.isPinned),
      }))
      .sort((a, b) => new Date(b.savedAt).getTime() - new Date(a.savedAt).getTime());
  }

  function trimGeminiBackups(backups = geminiBackups) {
    return normalizeGeminiBackups(backups).slice(0, GEMINI_RECENT_LIMIT);
  }

  function getGeminiFieldElements() {
    return {
      title: document.getElementById("gemini-title"),
      sourceUrl: document.getElementById("gemini-source-url"),
      content: document.getElementById("gemini-content"),
    };
  }

  function applyGeminiDraftToFields() {
    const { title, sourceUrl, content } = getGeminiFieldElements();
    if (!(title instanceof HTMLInputElement) || !(sourceUrl instanceof HTMLInputElement) || !(content instanceof HTMLTextAreaElement)) {
      return;
    }

    title.value = geminiDraft?.title || "";
    sourceUrl.value = geminiDraft?.sourceUrl || "";
    content.value = geminiDraft?.content || "";
  }

  function persistGeminiDraftFromFields() {
    const { title, sourceUrl, content } = getGeminiFieldElements();
    if (!(title instanceof HTMLInputElement) || !(sourceUrl instanceof HTMLInputElement) || !(content instanceof HTMLTextAreaElement)) {
      return null;
    }

    geminiDraft = {
      title: title.value.trim() || geminiCanvasMasterData.title,
      sourceUrl: sourceUrl.value.trim() || geminiCanvasMasterData.sourceUrl,
      content: content.value.trim(),
    };
    localStorage.setItem(GEMINI_DRAFT_KEY, JSON.stringify(geminiDraft));
    return geminiDraft;
  }

  function loadGeminiBackupState() {
    try {
      const savedDraft = localStorage.getItem(GEMINI_DRAFT_KEY);
      geminiDraft = savedDraft ? JSON.parse(savedDraft) : createGeminiDraftFromMaster();
    } catch (error) {
      console.error("讀取 Gemini 草稿失敗：", error);
      geminiDraft = createGeminiDraftFromMaster();
    }

    try {
      const savedBackups = localStorage.getItem(GEMINI_BACKUPS_KEY);
      geminiBackups = trimGeminiBackups(savedBackups ? JSON.parse(savedBackups) : []);
    } catch (error) {
      console.error("讀取 Gemini 備份失敗：", error);
      geminiBackups = [];
    }
  }

  function saveGeminiBackups() {
    localStorage.setItem(GEMINI_BACKUPS_KEY, JSON.stringify(geminiBackups));
  }

  function formatTimestamp(value) {
    if (!value) return "未記錄";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;
    return new Intl.DateTimeFormat("zh-TW", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
    }).format(date);
  }

  function buildGeminiBackupMarkdown(payload) {
    return [
      `# ${payload.title || geminiCanvasMasterData.title}`,
      "",
      `- 備份時間：${formatTimestamp(payload.savedAt || new Date().toISOString())}`,
      `- 來源網址：${payload.sourceUrl || "未填寫"}`,
      "",
      "## 內容",
      "",
      payload.content || "",
      "",
    ].join("\n");
  }

  function downloadTextFile(fileName, text, mimeType = "text/plain;charset=utf-8") {
    const blob = new Blob([text], { type: mimeType });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = fileName;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  }

  function buildGeminiBackupPayload() {
    const draft = persistGeminiDraftFromFields();
    if (!draft?.content) {
      setFeedback("請先貼上 Gemini Canvas 內容，再建立備份。", "is-warning");
      setGeminiFeedback("請先貼上 Gemini Canvas 內容，再建立備份。", "is-warning");
      return null;
    }

    return {
      id: `gemini-backup-${Date.now()}`,
      title: draft.title,
      sourceUrl: draft.sourceUrl,
      content: draft.content,
      savedAt: new Date().toISOString(),
    };
  }

  function getGeminiVersionEntries() {
    if (geminiBackups.length) return geminiBackups;

    return [{
      id: "gemini-master-version",
      title: geminiCanvasMasterData.title,
      sourceUrl: geminiCanvasMasterData.sourceUrl,
      content: geminiCanvasMasterData.content,
      savedAt: geminiCanvasMasterData.updatedAt,
      isMaster: true,
    }];
  }

  function findGeminiBackupById(backupId) {
    return getGeminiVersionEntries().find((backup) => backup.id === backupId) || null;
  }

  function renderGeminiHistory() {
    const historyShell = document.getElementById("gemini-history-list");
    const historyCount = document.getElementById("gemini-history-count");
    if (!historyShell || !historyCount) return;

    const versions = getGeminiVersionEntries();
    historyCount.textContent = `${versions.length} 版`;

    historyShell.innerHTML = versions
      .map((backup) => `
        <details class="gemini-version-item">
          <summary class="gemini-version-summary">
            <strong>${escapeHtml(formatTimestamp(backup.savedAt))}</strong>
          </summary>
          <div class="gemini-version-body">
            <div class="gemini-version-meta">
              <p>${escapeHtml(backup.title || "未命名備份")}</p>
              <small>${escapeHtml(backup.sourceUrl || "未填寫來源網址")}</small>
            </div>
            <div class="gemini-history-actions">
              <button type="button" class="history-action-btn" data-backup-action="restore" data-backup-id="${escapeHtml(backup.id)}">${backup.isMaster ? "載入主檔" : "載入這版"}</button>
              <button type="button" class="history-action-btn" data-backup-action="copy" data-backup-id="${escapeHtml(backup.id)}">複製 Markdown</button>
            </div>
            <pre class="gemini-preview-content">${escapeHtml(backup.content || "")}</pre>
          </div>
        </details>
      `)
      .join("");
  }

  function loadGeminiMasterIntoEditor() {
    geminiDraft = createGeminiDraftFromMaster();
    localStorage.setItem(GEMINI_DRAFT_KEY, JSON.stringify(geminiDraft));
    applyGeminiDraftToFields();
    setFeedback("已載入目前主檔。", "is-success");
    setGeminiFeedback("已載入目前主檔。", "is-success");
  }

  function upsertGeminiBackup(payload) {
    const existing = geminiBackups.find((backup) => backup.content === payload.content);
    const nextPayload = existing
      ? {
          ...existing,
          title: payload.title,
          sourceUrl: payload.sourceUrl,
          content: payload.content,
          savedAt: payload.savedAt,
        }
      : payload;

    geminiBackups = trimGeminiBackups([
      nextPayload,
      ...geminiBackups.filter((backup) => backup.id !== existing?.id),
    ]);
    saveGeminiBackups();
    renderGeminiHistory();
    return { payload: nextPayload, updated: Boolean(existing) };
  }

  function rerender() {
    renderHero();
    renderQuests();
    renderPortals();
    renderGeminiHistory();
    saveState();
  }

  document.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    if (!target.dataset.runCheck) return;

    const index = Number(target.dataset.runIndex);
    const key = target.dataset.runCheck;
    const run = state.weekly.runs[index];
    if (!run || !key) return;

    run[key] = target.checked;
    maybeClaimRunReward(run);
    rerender();
  });

  document.getElementById("reset-social-ops")?.addEventListener("click", () => {
    state.weekly = {
      weekKey: getWeekKey(),
      bonusClaimed: false,
      runs: createWeeklyRuns(),
    };
    rerender();
    setFeedback("本週任務已重設，XP 與連勝保留。", "is-warning");
  });

