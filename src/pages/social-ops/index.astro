  function getVendorIntakeNoteId(itemId = "") {
    return itemId ? `vendor-intake-${itemId}` : "";
  }

  function mapPricingDisclosureToPriceLevel(value = "") {
    if (value === "direct") return "中";
    if (value === "sanitized") return "中";
    if (value === "later") return "中低";
    return "";
  }

  function mapCraftApproachToCraftLevel(value = "") {
    if (value === "偏效率施工") return "粗工";
    if (value === "標準住宅施工") return "標準";
    if (value === "偏細緻收邊") return "細緻";
    if (value === "依案型調整") return "細緻";
    return "";
  }

