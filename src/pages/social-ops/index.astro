const fallbackBlogPosts = [
  {
    title: "畫出家的神經系統——全屋開關與插座的最適定位",
    slug: "whole-house-switch-socket-positioning",
    date: "2025-11-12",
    summary: "整理全屋開關與插座定位原則，從生活動線、家具尺寸到常見錯誤，幫助裝修前先把隱蔽工程規劃清楚。",
    category: "水電篇",
  },
];

const bookshelfTracks = [
  {
    title: "老屋翻新系",
    focus: "老屋翻修、基礎工程、動線重整、收納與耐久配置",
    chapters: "現況判讀 / 基礎工程 / 空間重整 / 完工避雷",
  },
  {
    title: "預售屋客變系",
    focus: "客變、交屋前規劃、插座燈光、收納與機能預留",
    chapters: "客變判斷 / 配置預留 / 生活動線 / 交屋銜接",
  },
  {
    title: "驗屋交屋系",
    focus: "驗屋、點交、缺失判讀、交屋後先後順序與修正重點",
    chapters: "驗屋判讀 / 缺失排序 / 點交策略 / 交屋後進場",
  },
  {
    title: "格局動線系",
    focus: "小坪數規劃、收納、動線、尺度、空間效率與生活邏輯",
    chapters: "空間尺度 / 動線配置 / 收納系統 / 使用情境",
  },
  {
    title: "水電照明系",
    focus: "插座、開關、迴路、照明、窗簾、智能控制與設備整合",
    chapters: "插座開關 / 迴路安全 / 照明設計 / 智能整合",
  },
];

const articleIntakeFields = [
  "主書系",
  "章節定位",
  "網站分類",
  "搜尋主關鍵字",
  "相似舊文",
  "處理策略",
  "社團回覆角度",
  "導流目的",
  "下一篇延伸題目",
];

const overlapRules = [
  {
    title: "同核心問題",
    detail: "若主判斷與既有文章相同，優先補強舊文，不重開新標題。",
  },
  {
    title: "同主題不同角度",
    detail: "若情境、預算、屋況或族群不同，可做同章延伸文，互相內鏈。",
  },
  {
    title: "可併成系列",
    detail: "若同一主書系下可串成前後篇，改做系列文，不做彼此搶重點的散文。",
  },
];

const workflowGuideSteps = [
  {
    title: "先貼問題",
    detail: "把社團原始發問貼進工作台，保留真實語境。",
  },
  {
    title: "先判題",
    detail: "先用 AI 快速判題，決定開新文、補舊文或同章延伸。",
  },
  {
    title: "再出稿",
    detail: "值得寫的題目先交給 Gemini Flash 生成初稿，不把時間浪費在低價值重複文。",
  },
  {
    title: "再定稿",
    detail: "把 Flash 結果交給 Gemini Pro 這類高階模型潤稿、覆核與拉高完成度。",
  },
  {
    title: "最後入庫",
    detail: "確認主書系、章節、正式分類與發布草稿，讓每篇文章都能集結成書。",
  },
];

let blogPosts = [...fallbackBlogPosts];
let blogSyncLabel = "目前先顯示已存在文章。";

try {
  if (import.meta.env.CONTENTFUL_SPACE_ID && import.meta.env.CONTENTFUL_ACCESS_TOKEN) {
    const client = contentful.createClient({
      space: import.meta.env.CONTENTFUL_SPACE_ID,
      accessToken: import.meta.env.CONTENTFUL_ACCESS_TOKEN,
      environment: "master",
    });

    const response = await client.getEntries({
      content_type: "blogPost",
      order: ["-fields.date"],
    });

    const syncedPosts = response.items.map((item: any) => ({
      title: item.fields.title,
      slug: item.fields.slug,
      date: new Date(item.fields.date).toISOString().split("T")[0],
      summary: item.fields.summary,
      category: item.fields.category,
    }));

    if (syncedPosts.length > 0) {
      const postMap = new Map(
        [...fallbackBlogPosts, ...syncedPosts].map((post) => [post.slug, post]),
      );
      blogPosts = Array.from(postMap.values()).sort((a, b) => b.date.localeCompare(a.date));
      blogSyncLabel = `已同步 ${syncedPosts.length} 篇知識文章。`;
    } else {
      blogSyncLabel = "Contentful 目前無文章，先顯示已存在文章。";
    }
  } else {
    blogSyncLabel = "未連接 Contentful，先顯示已存在文章。";
  }
} catch (error) {
  console.error("讀取知識分享文章失敗：", error);
  blogSyncLabel = "同步失敗，先顯示已存在文章。";
}

function inferBookshelfTrack(post: { title: string; category: string }) {
  const haystack = `${post.title} ${post.category}`.toLowerCase();

  if (/驗屋|交屋|點交|缺失/.test(haystack)) return "驗屋交屋系";
  if (/客變|預售屋/.test(haystack)) return "預售屋客變系";
  if (/格局|動線|收納|小坪數|空間/.test(haystack)) return "格局動線系";
  if (/水電|插座|開關|照明|燈光|迴路|智能|窗簾/.test(haystack)) return "水電照明系";
  return "老屋翻新系";
}

function inferBookshelfChapter(trackTitle: string, post: { title: string; category: string }) {
  const haystack = `${post.title} ${post.category}`.toLowerCase();

  if (trackTitle === "驗屋交屋系") {
    if (/缺失|裂縫|漏水/.test(haystack)) return "缺失排序";
    if (/點交|交屋/.test(haystack)) return "點交策略";
    return "驗屋判讀";
  }

  if (trackTitle === "預售屋客變系") {
    if (/插座|開關|照明|燈光/.test(haystack)) return "配置預留";
    if (/動線|收納|格局/.test(haystack)) return "生活動線";
    return "客變判斷";
  }

  if (trackTitle === "格局動線系") {
    if (/收納/.test(haystack)) return "收納系統";
    if (/動線|走道/.test(haystack)) return "動線配置";
    return "空間尺度";
  }

  if (trackTitle === "水電照明系") {
    if (/插座|開關/.test(haystack)) return "插座開關";
    if (/迴路|安全/.test(haystack)) return "迴路安全";
    if (/智能|窗簾/.test(haystack)) return "智能整合";
    return "照明設計";
  }

  if (/拆除|泥作|防水|基礎/.test(haystack)) return "基礎工程";
  if (/格局|收納|動線/.test(haystack)) return "空間重整";
  return "現況判讀";
}

function inferSearchKeyword(post: { title: string; category: string }) {
  const haystack = `${post.title} ${post.category}`.toLowerCase();

  if (/驗屋|交屋|點交/.test(haystack)) return "驗屋交屋";
  if (/客變|預售屋/.test(haystack)) return "預售屋客變";
  if (/收納|小坪數|格局|動線/.test(haystack)) return "格局動線規劃";
  if (/插座|開關|水電|照明|燈光/.test(haystack)) return "水電照明規劃";
  return "老屋翻新";
}

const bookshelfEntries = blogPosts.map((post, index) => {
  const trackTitle = inferBookshelfTrack(post);
  const chapter = inferBookshelfChapter(trackTitle, post);
  const searchKeyword = inferSearchKeyword(post);
  return {
    ...post,
    index,
    trackTitle,
    chapter,
    searchKeyword,
  };
}).map((entry, _, entries) => {
  const similarEntry = entries.find((candidate) =>
    candidate.slug !== entry.slug &&
    candidate.trackTitle === entry.trackTitle &&
    (candidate.chapter === entry.chapter || candidate.category === entry.category),
  );

  const strategy = similarEntry
    ? similarEntry.chapter === entry.chapter
      ? "同章延伸"
      : "補強舊文"
    : "開新文";

  return {
    ...entry,
    similarTitle: similarEntry?.title || "無明確重複",
    strategy,
  };
});

const bookshelfViewGroups = bookshelfTracks.map((track) => ({
  ...track,
  entries: bookshelfEntries.filter((entry) => entry.trackTitle === track.title),
}));

const defaultSourcesJson = JSON.stringify(defaultSources);
const blogPostsJson = JSON.stringify(blogPosts);
const blogCategoryCount = new Set(blogPosts.map((post) => post.category)).size;
const geminiCanvasMasterJson = JSON.stringify(geminiCanvasMaster);
