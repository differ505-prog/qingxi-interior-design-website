</style>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', function() {
    const requirementForm = document.getElementById('requirement-form');
    const estimatorBrief = document.getElementById('estimator-brief');
    const estimatorSummaryInput = document.getElementById('estimator-summary');
    const estimatorTotalRangeInput = document.getElementById('estimator-total-range-input');
    const estimatorPerPingRangeInput = document.getElementById('estimator-per-ping-range-input');
    const estimatorProjectTypeInput = document.getElementById('estimator-project-type-input');
    const estimatorQualityLevelInput = document.getElementById('estimator-quality-level-input');
    const estimatorHouseConditionInput = document.getElementById('estimator-house-condition-input');
    const estimatorSelectedItemsInput = document.getElementById('estimator-selected-items-input');
    const estimatorTotalRange = document.getElementById('estimator-total-range');
    const estimatorPerPing = document.getElementById('estimator-per-ping');
    const estimatorProjectMeta = document.getElementById('estimator-project-meta');
    const estimatorSelectedItems = document.getElementById('estimator-selected-items');
    const utmSourceInput = document.getElementById('utm-source-input');
    const utmMediumInput = document.getElementById('utm-medium-input');
    const utmCampaignInput = document.getElementById('utm-campaign-input');
    const utmTermInput = document.getElementById('utm-term-input');
    const utmContentInput = document.getElementById('utm-content-input');
    const landingPageInput = document.getElementById('landing-page-input');
    const pageReferrerInput = document.getElementById('page-referrer-input');
    const requirementPrefillStorageKey = 'requirementFormPrefill';

    function fillAttributionFields() {
      const searchParams = new URLSearchParams(window.location.search);

      if (utmSourceInput) utmSourceInput.value = searchParams.get('utm_source') || '';
      if (utmMediumInput) utmMediumInput.value = searchParams.get('utm_medium') || '';
      if (utmCampaignInput) utmCampaignInput.value = searchParams.get('utm_campaign') || '';
      if (utmTermInput) utmTermInput.value = searchParams.get('utm_term') || '';
      if (utmContentInput) utmContentInput.value = searchParams.get('utm_content') || '';
      if (landingPageInput) landingPageInput.value = window.location.href;
      if (pageReferrerInput) pageReferrerInput.value = document.referrer || '';
    }

    function restoreEstimatorSnapshot() {
      try {
        const snapshotRaw = window.sessionStorage.getItem('renovationEstimateSnapshot');
        if (!snapshotRaw) return;

        const snapshot = JSON.parse(snapshotRaw);
        const selectedItemsText = Array.isArray(snapshot.selectedItems) && snapshot.selectedItems.length
          ? snapshot.selectedItems.join('、')
          : '尚未勾選工項';
        const projectMetaText = [
          snapshot.projectTypeLabel,
          snapshot.qualityLevelLabel,
          snapshot.houseConditionLabel,
        ]
          .filter(Boolean)
          .join(' / ');
        const summaryText = [
          `預估總價：${snapshot.totalRange || '--'}`,
          `每坪抓法：${snapshot.perPingRange || '--'}`,
          `專案條件：${projectMetaText || '--'}`,
          `裝修工項：${selectedItemsText}`,
        ].join(' ｜ ');

        if (estimatorBrief) estimatorBrief.style.display = 'block';
        if (estimatorTotalRange) estimatorTotalRange.textContent = snapshot.totalRange || '--';
        if (estimatorPerPing) estimatorPerPing.textContent = snapshot.perPingRange || '--';
        if (estimatorProjectMeta) estimatorProjectMeta.textContent = projectMetaText || '--';
        if (estimatorSelectedItems) estimatorSelectedItems.textContent = selectedItemsText;

        if (estimatorSummaryInput) estimatorSummaryInput.value = summaryText;
        if (estimatorTotalRangeInput) estimatorTotalRangeInput.value = snapshot.totalRange || '';
        if (estimatorPerPingRangeInput) estimatorPerPingRangeInput.value = snapshot.perPingRange || '';
        if (estimatorProjectTypeInput) estimatorProjectTypeInput.value = snapshot.projectTypeLabel || '';
        if (estimatorQualityLevelInput) estimatorQualityLevelInput.value = snapshot.qualityLevelLabel || '';
        if (estimatorHouseConditionInput) estimatorHouseConditionInput.value = snapshot.houseConditionLabel || '';
        if (estimatorSelectedItemsInput) estimatorSelectedItemsInput.value = selectedItemsText;
      } catch (error) {
        console.warn('Unable to restore estimator snapshot.', error);
      }
    }

    restoreEstimatorSnapshot();
    fillAttributionFields();

    function detectContactMethodType(value) {
      if (!value) return '';

      const trimmedValue = value.trim();
      const digitsOnly = trimmedValue.replace(/\D/g, '');

      if (/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(trimmedValue)) return 'email';
      if (digitsOnly.length >= 6) return 'phone';
      return 'line';
    }

    function hydrateQuickConsultationPrefill() {
      try {
        const prefillRaw = window.sessionStorage.getItem(requirementPrefillStorageKey);
        if (!prefillRaw) return;

        const prefill = JSON.parse(prefillRaw);
        const nameInput = document.getElementById('name');
        const phoneInput = document.getElementById('phone');
        const lineIdInput = document.getElementById('line-id');
        const emailInput = document.getElementById('email');
        const contactPreferenceInput = document.getElementById('contact-preference');
        const otherNotesBasicInput = document.getElementById('other-notes-basic');

        if (nameInput && !nameInput.value && prefill.name) {
          nameInput.value = prefill.name;
        }

        if (otherNotesBasicInput && !otherNotesBasicInput.value && prefill.consultationFocus) {
          otherNotesBasicInput.value = prefill.consultationFocus;
        }

        if (prefill.contactMethod) {
          const contactType = detectContactMethodType(prefill.contactMethod);

          if (contactType === 'email' && emailInput && !emailInput.value) {
            emailInput.value = prefill.contactMethod;
          } else if (contactType === 'phone' && phoneInput && !phoneInput.value) {
            phoneInput.value = prefill.contactMethod;
          } else if (lineIdInput && !lineIdInput.value) {
            lineIdInput.value = prefill.contactMethod;
          }

          if (contactPreferenceInput && !contactPreferenceInput.value) {
            contactPreferenceInput.value = contactType || '';
          }
        }
      } catch (error) {
        console.warn('Unable to hydrate quick consultation prefill.', error);
      }
    }

    hydrateQuickConsultationPrefill();

    function hasPrimaryContact() {
      const phoneInput = document.getElementById('phone');
      const lineIdInput = document.getElementById('line-id');
      const emailInput = document.getElementById('email');

      return Boolean(
        phoneInput?.value?.trim() ||
        lineIdInput?.value?.trim() ||
        emailInput?.value?.trim()
      );
    }

    function validatePrimaryContact(event) {
      if (hasPrimaryContact()) return true;

      event.preventDefault();
      window.alert('請至少留下電話、Line ID、Email 其中一種聯絡方式，青曦才能與你接續討論。');
      document.getElementById('phone')?.focus();
      return false;
    }

    if (requirementForm?.dataset.formEnabled !== 'true') {
      requirementForm?.addEventListener('submit', function(event) {
        if (!validatePrimaryContact(event)) return;
        event.preventDefault();
        window.alert('表單收件尚未完成設定，請透過官方 LINE 聯絡青曦');
      });
    } else {
      requirementForm?.addEventListener('submit', function(event) {
        if (!validatePrimaryContact(event)) return;
        window.trackLeadEvent?.('requirement_form_submit', {
          form_name: 'design_requirement_form',
          has_estimator_summary: estimatorBrief?.style.display === 'block',
        });
      });
    }

    requestAnimationFrame(() => {
      initFormAnimations();
    });

    function initFormAnimations() {
      // 滾動動畫 - 使用 Intersection Observer
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver(function(entries) {
        entries.forEach((entry, index) => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              entry.target.classList.add('animate-in');
            }, index * 100);
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      // 觀察所有表單區塊
      const formSections = document.querySelectorAll('.form-section');
      formSections.forEach(section => {
        observer.observe(section);
      });

      // 初始動畫 - 第一個區塊立即顯示
      if (formSections.length > 0) {
        setTimeout(() => {
          formSections[0].classList.add('animate-in');
        }, 200);
      }
    }
    // 預售屋相關欄位
    const presaleYes = document.getElementById('presale-yes');
    const presaleNo = document.getElementById('presale-no');
    const presaleDetails = document.getElementById('presale-details');

    function togglePresaleDetails() {
      if (presaleYes.checked) {
        presaleDetails.style.display = 'block';
      } else {
        presaleDetails.style.display = 'none';
      }
    }

    presaleYes?.addEventListener('change', togglePresaleDetails);
    presaleNo?.addEventListener('change', togglePresaleDetails);

    // 智慧家庭需求相關欄位
    const smartHomeYes = document.getElementById('smart-home-yes');
    const smartHomeMaybe = document.getElementById('smart-home-maybe');
    const smartHomeNo = document.getElementById('smart-home-no');
    const smartHomeDetails = document.getElementById('smart-home-details');

    function toggleSmartHomeDetails() {
      if (smartHomeYes?.checked || smartHomeMaybe?.checked) {
        smartHomeDetails.style.display = 'block';
      } else {
        smartHomeDetails.style.display = 'none';
      }
    }

    smartHomeYes?.addEventListener('change', toggleSmartHomeDetails);
    smartHomeMaybe?.addEventListener('change', toggleSmartHomeDetails);
    smartHomeNo?.addEventListener('change', toggleSmartHomeDetails);

    const existingSmartDevicesYes = document.getElementById('existing-smart-devices-yes');
    const existingSmartDevicesNo = document.getElementById('existing-smart-devices-no');
    const existingSmartDevicesInput = document.getElementById('existing-smart-devices-input');

    function toggleExistingSmartDevicesInput() {
      if (existingSmartDevicesYes?.checked) {
        existingSmartDevicesInput.style.display = 'block';
      } else {
        existingSmartDevicesInput.style.display = 'none';
      }
    }

    existingSmartDevicesYes?.addEventListener('change', toggleExistingSmartDevicesInput);
    existingSmartDevicesNo?.addEventListener('change', toggleExistingSmartDevicesInput);

    // 家庭組成其他選項
    const householdStructureOtherCheck = document.getElementById('household-structure-other-check');
    const householdStructureOtherInput = document.getElementById('household-structure-other-input');

    householdStructureOtherCheck?.addEventListener('change', function() {
      if (this.checked) {
        householdStructureOtherInput.style.display = 'block';
      } else {
        householdStructureOtherInput.style.display = 'none';
      }
    });

    // 寵物資訊
    const petDetails = document.getElementById('pet-details');
    const petPlansCurrent = document.getElementById('pet-plans-current');
    const petPlansPlanned = document.getElementById('pet-plans-planned');
    const petPlansNone = document.getElementById('pet-plans-none');
    const petTypeOtherCheck = document.getElementById('pet-type-other-check');
    const petTypeOtherInput = document.getElementById('pet-type-other-input');

    function togglePetDetails() {
      if (petPlansCurrent?.checked || petPlansPlanned?.checked) {
        petDetails.style.display = 'block';
      } else {
        petDetails.style.display = 'none';
      }
    }

    petPlansCurrent?.addEventListener('change', togglePetDetails);
    petPlansPlanned?.addEventListener('change', togglePetDetails);
    petPlansNone?.addEventListener('change', togglePetDetails);

    petTypeOtherCheck?.addEventListener('change', function() {
      if (this.checked) {
        petTypeOtherInput.style.display = 'block';
      } else {
        petTypeOtherInput.style.display = 'none';
      }
    });

    togglePetDetails();

    // 假日其他選項
    const holidaysOtherCheck = document.getElementById('holidays-other-check');
    const holidaysOtherInput = document.getElementById('holidays-other-input');
    
    holidaysOtherCheck?.addEventListener('change', function() {
      if (this.checked) {
        holidaysOtherInput.style.display = 'block';
      } else {
        holidaysOtherInput.style.display = 'none';
      }
    });

    // 來源其他選項
    const sourceOtherCheck = document.getElementById('source-other-check');
    const sourceOtherInput = document.getElementById('source-other-input');
    
    sourceOtherCheck?.addEventListener('change', function() {
      if (this.checked) {
        sourceOtherInput.style.display = 'block';
      } else {
        sourceOtherInput.style.display = 'none';
      }
    });

    // 預算其他選項
    const budgetSelect = document.getElementById('budget');
    const budgetOtherInput = document.getElementById('budget-other-input');
    
    budgetSelect?.addEventListener('change', function() {
      if (this.value === 'other') {
        budgetOtherInput.style.display = 'block';
      } else {
        budgetOtherInput.style.display = 'none';
      }
    });

    // 最高預算其他選項
    const maxBudgetSelect = document.getElementById('max-budget');
    const maxBudgetOtherInput = document.getElementById('max-budget-other-input');
    
    maxBudgetSelect?.addEventListener('change', function() {
      if (this.value === 'other') {
        maxBudgetOtherInput.style.display = 'block';
      } else {
        maxBudgetOtherInput.style.display = 'none';
      }
    });

    // 廚房裝修備註
    const kitchenNotesRadio = document.getElementById('kitchen-notes-radio');
    const kitchenNotesInput = document.getElementById('kitchen-notes-input');
    
    document.querySelectorAll('input[name="kitchen-renovation"]').forEach(radio => {
      radio.addEventListener('change', function() {
        if (this.value === 'notes') {
          kitchenNotesInput.style.display = 'block';
        } else {
          kitchenNotesInput.style.display = 'none';
        }
      });
    });

    // 衛浴裝修備註
    const bathroomNotesRadio = document.getElementById('bathroom-notes-radio');
    const bathroomNotesInput = document.getElementById('bathroom-notes-input');
    
    document.querySelectorAll('input[name="bathroom-renovation"]').forEach(radio => {
      radio.addEventListener('change', function() {
        if (this.value === 'notes') {
          bathroomNotesInput.style.display = 'block';
        } else {
          bathroomNotesInput.style.display = 'none';
        }
      });
    });

    // CAD 檔案備註
    const cadNotesRadio = document.getElementById('cad-notes-radio');
    const cadNotesInput = document.getElementById('cad-notes-input');
    
    document.querySelectorAll('input[name="cad-file"]').forEach(radio => {
      radio.addEventListener('change', function() {
        if (this.value === 'notes') {
          cadNotesInput.style.display = 'block';
        } else {
          cadNotesInput.style.display = 'none';
        }
      });
    });

    // 空間詳細需求
    const spaceCheckboxes = document.querySelectorAll('.space-checkbox');
    const spaceDetailsContainer = document.getElementById('space-details-container');
    const spaceQuantityContainer = document.getElementById('space-quantity-container');

    const spaceDetails = {
      'living-room': {
        title: '客廳',
        options: [
          { label: '造型電視牆', value: 'tv-wall' },
          { label: '收納櫃', value: 'storage-cabinet' },
          { label: '展示櫃', value: 'display-cabinet' },
          { label: 'L型沙發', value: 'l-sofa' },
          { label: '一字型沙發', value: 'straight-sofa' },
          { label: '其他', value: 'other' }
        ]
      },
      'dining-room': {
        title: '餐廳',
        options: [
          { label: '電器櫃', value: 'appliance-cabinet' },
          { label: '餐櫃', value: 'dining-cabinet' },
          { label: '中島', value: 'island' },
          { label: '餐桌', value: 'dining-table', hasInput: true, inputLabel: '人餐桌' },
          { label: '一字型沙發', value: 'straight-sofa' },
          { label: '其他', value: 'other' }
        ]
      },
      'bathroom': {
        title: '浴廁',
        quantityField: {
          label: '這次預計處理幾間浴廁？',
          hint: '如果有主衛、客衛或客用洗手間，先抓總數即可。'
        },
