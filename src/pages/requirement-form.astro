---
import BaseLayout from '../layouts/BaseLayout.astro';

const requirementFormId =
  import.meta.env.PUBLIC_FORMSPREE_REQUIREMENT_FORM_ID?.trim() || '';
const requirementFormAction = requirementFormId ? '/api/forms/requirement' : '';
const requirementFormEnabled = Boolean(requirementFormAction);
const siteOrigin = (Astro.site || new URL('https://qingxidesign.tw')).toString();
const requirementFormSuccessURL = new URL('/consultation-thank-you', siteOrigin).toString();
const submitError = Astro.url.searchParams.get('submit_error') === '1';
---

<BaseLayout
  title="設計需求表 - 青曦空間設計"
  description="先留下聯絡方式、屋況、預算與時程，讓青曦先判斷這次裝修方向；其餘細節可後補。"
  ogImage="/images/portfolio/xizhi-1.jpg"
>
  <section class="form-page-hero">
    <div class="form-hero-shell">
      <div class="hero-copy">
        <p class="hero-eyebrow">DESIGN BRIEF</p>
        <h1>先把需求講清楚。</h1>
        <p class="hero-description">
          留下聯絡方式、屋況、預算與時程，青曦就能接手判斷。
        </p>
        <div class="hero-highlights">
          <span>核心資訊優先</span>
          <span>細節可後補</span>
        </div>
      </div>

      <aside class="hero-panel">
        <p class="panel-label">BEFORE YOU START</p>
        <ul>
          <li>剛完成快速諮詢可直接續填</li>
          <li>先準備地區、坪數與交屋時間</li>
          <li>送出後青曦會依聯絡方式回覆</li>
        </ul>
        <div class="panel-credential">
          <p class="panel-credential-label">PROFESSIONAL CREDENTIAL</p>
          <p class="panel-credential-title">室內裝修工程管理乙級證照</p>
          <p class="panel-credential-meta">技術士證編號：126-0024871</p>
        </div>
      </aside>
    </div>
  </section>

  <!-- 表單容器 -->
  <div class="form-container" id="form-container">
    <div class="form-wrapper">
      <div class="form-header">
        <p class="form-eyebrow">CONSULTATION FORM</p>
        <h1>設計需求表</h1>
        <p class="form-subtitle">先填核心欄位。</p>
        <div class="form-assurance">
          <p class="form-assurance-title">先把關鍵交給青曦</p>
          <p class="form-assurance-description">
            其餘細節可後補。
          </p>
        </div>

        <div class="form-steps-overview">
          <div class="form-steps-heading">
            <p class="form-steps-label">FILLING STEPS</p>
            <h2>填寫只需 4 步</h2>
          </div>
          <div class="form-steps-grid">
            <div class="form-step-card">
              <div class="form-step-index">01</div>
              <div>
                <h3>快速聯絡資訊</h3>
                <p>留下姓名、電話或 LINE</p>
              </div>
            </div>
            <div class="form-step-card">
              <div class="form-step-index">02</div>
              <div>
                <h3>案件基本條件</h3>
                <p>地址、坪數、預算與時程</p>
              </div>
            </div>
            <div class="form-step-card">
              <div class="form-step-index">03</div>
              <div>
                <h3>空間與方向</h3>
                <p>需求配置與生活重點</p>
              </div>
            </div>
            <div class="form-step-card">
              <div class="form-step-index">04</div>
              <div>
                <h3>智慧家庭（選填）</h3>
                <p>若有興趣可以先告訴我們</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Progress Bar -->
        <div class="progress-container">
          <div class="progress-bar">
            <div class="progress-fill" id="progress-fill"></div>
          </div>
          <div class="progress-text">
            <span>快速送出完成度：</span>
            <span id="progress-percentage">0%</span>
          </div>
        </div>
      </div>

      {
        submitError && (
          <div class="form-status-notice" role="alert">
            <p>表單送出時沒有成功轉交，請稍後再試一次；持續失敗可透過官方 LINE 聯絡青曦。</p>
          </div>
        )
      }

      <form 
        id="requirement-form" 
        action={requirementFormAction}
        method="POST"
        class="requirement-form"
        data-form-enabled={String(requirementFormEnabled)}
      >
        {
          !requirementFormEnabled && (
            <div class="form-status-notice" role="status">
              <p>表單收件尚未完成設定，目前請透過官方 LINE 聯絡青曦。</p>
            </div>
          )
        }

        <section class="estimator-brief" id="estimator-brief" style="display: none;">
          <div class="estimator-brief-header">
            <p class="estimator-brief-eyebrow">ESTIMATOR SUMMARY</p>
            <h2>已帶入本次裝修估算</h2>
            <p class="estimator-brief-description">
              送出時會一起帶入。
            </p>
          </div>
          <div class="estimator-brief-grid">
            <div class="estimator-brief-item">
              <span>預估總價</span>
              <strong id="estimator-total-range">--</strong>
            </div>
            <div class="estimator-brief-item">
              <span>每坪抓法</span>
              <strong id="estimator-per-ping">--</strong>
            </div>
            <div class="estimator-brief-item">
              <span>專案條件</span>
              <strong id="estimator-project-meta">--</strong>
            </div>
            <div class="estimator-brief-item">
              <span>裝修工項</span>
              <strong id="estimator-selected-items">--</strong>
            </div>
          </div>
        </section>

        <input type="hidden" name="estimator-summary" id="estimator-summary">
        <input type="hidden" name="estimator-total-range" id="estimator-total-range-input">
        <input type="hidden" name="estimator-per-ping-range" id="estimator-per-ping-range-input">
        <input type="hidden" name="estimator-project-type" id="estimator-project-type-input">
        <input type="hidden" name="estimator-quality-level" id="estimator-quality-level-input">
        <input type="hidden" name="estimator-house-condition" id="estimator-house-condition-input">
        <input type="hidden" name="estimator-selected-items" id="estimator-selected-items-input">
        <input type="hidden" name="_subject" value="青曦空間設計｜新的設計需求表單">
        <input type="hidden" name="_next" value={requirementFormSuccessURL}>
        <input type="hidden" name="utm_source" id="utm-source-input">
        <input type="hidden" name="utm_medium" id="utm-medium-input">
        <input type="hidden" name="utm_campaign" id="utm-campaign-input">
        <input type="hidden" name="utm_term" id="utm-term-input">
        <input type="hidden" name="utm_content" id="utm-content-input">
        <input type="hidden" name="landing_page" id="landing-page-input">
        <input type="hidden" name="page_referrer" id="page-referrer-input">

        <!-- 基本資料 -->
        <section class="form-section">
          <h2 class="section-title">第一步｜快速聯絡資訊</h2>

          <div class="form-group">
            <label for="name">姓名 <span class="required">*</span></label>
            <input type="text" id="name" name="name" required data-progress="true">
          </div>

          <div class="form-group">
            <label for="phone">電話</label>
            <input type="tel" id="phone" name="phone" data-progress="true" placeholder="手機或市話都可以">
          </div>

          <div class="form-group">
            <label for="line-id">Line ID</label>
            <input type="text" id="line-id" name="line-id" data-progress="true" placeholder="常用 LINE ID">
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" data-progress="true" placeholder="常用 Email">
          </div>

          <div class="form-group">
            <label for="contact-preference">最方便聯繫你的方式</label>
            <select id="contact-preference" name="contact-preference">
              <option value="">請選擇</option>
              <option value="phone">電話</option>
              <option value="line">LINE</option>
              <option value="email">Email</option>
              <option value="either">都可以</option>
            </select>
          </div>

          <div class="form-group">
            <label for="other-notes-basic">一句話告訴我們你現在最想先解決什麼</label>
            <textarea
              id="other-notes-basic"
              name="other-notes-basic"
              rows="3"
              data-progress="true"
              placeholder="例如預售屋快客變了、老屋想先抓預算、需要三房改兩房、想一起規劃智能家居等"
            ></textarea>
          </div>
        </section>

        <!-- 房屋資料 -->
        <section class="form-section">
          <h2 class="section-title">第二步｜案件基本條件</h2>

          <div class="form-group">
            <label for="address">裝修地址 <span class="required">*</span></label>
            <input type="text" id="address" name="address" required data-progress="true" placeholder="可先填到行政區或社區名稱，例如汐止、板橋、新店央北等">
          </div>

          <div class="form-group">
            <label>是否為預售屋</label>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="presale" value="yes" id="presale-yes" data-progress="true">
                <span>是</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="presale" value="no" id="presale-no" data-progress="true">
                <span>否</span>
              </label>
            </div>
          </div>

          <div id="presale-details" class="conditional-section" style="display: none;">
            <div class="form-group">
              <label>是否需要客變</label>
              <div class="radio-group">
                <label class="radio-label">
                  <input type="radio" name="customer-change" value="yes">
                  <span>是</span>
                </label>
                <label class="radio-label">
                  <input type="radio" name="customer-change" value="no">
                  <span>否</span>
                </label>
              </div>
            </div>

            <div class="form-group">
              <label for="change-deadline">客變到期日</label>
              <input type="date" id="change-deadline" name="change-deadline">
            </div>

            <div class="form-group">
              <label for="presale-notes">備註</label>
              <textarea id="presale-notes" name="presale-notes" rows="3"></textarea>
            </div>
          </div>

          <div class="form-group">
            <label for="handover-date">大概什麼時候交屋</label>
            <input type="date" id="handover-date" name="handover-date" data-progress="true">
          </div>

          <div class="form-group">
            <label for="interior-area">室內總坪數約（含陽台、衛浴）</label>
            <input type="text" id="interior-area" name="interior-area" data-progress="true" placeholder="例如 22 坪、28.5 坪">
          </div>

          <div class="form-group">
            <label>是否為毛胚屋</label>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="house-status" value="raw" data-progress="true">
                <span>是</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="house-status" value="renovated" data-progress="true">
                <span>否</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="house-status" value="other" data-progress="true">
                <span>其他</span>
              </label>
            </div>
          </div>

          <div class="form-group">
            <label for="budget">期望裝修預算</label>
            <select id="budget" name="budget" data-progress="true">
              <option value="">請選擇</option>
              <option value="under-50">50萬以下</option>
              <option value="50-100">50-100萬</option>
              <option value="100-200">100-200萬</option>
              <option value="200-300">200-300萬</option>
              <option value="300-500">300-500萬</option>
              <option value="500-800">500-800萬</option>
              <option value="over-800">800萬以上</option>
              <option value="other">其他</option>
            </select>
            <div id="budget-other-input" class="conditional-input" style="display: none;">
              <input type="text" name="budget-other" placeholder="請填寫預算金額">
            </div>
          </div>
        </section>

        <!-- 空間配置需求 -->
        <section class="form-section">
          <h2 class="section-title">第三步｜空間與方向</h2>

          <div class="form-group">
            <label for="expected-completion">希望什麼時候完工</label>
            <input type="date" id="expected-completion" name="expected-completion" data-progress="true">
          </div>

          <div class="form-group">
            <label>請勾選需要的空間配置（可多選）</label>
            <div class="checkbox-grid">
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="living-room" class="space-checkbox" data-progress="true">
                <span>客廳</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="dining-room" class="space-checkbox" data-progress="true">
                <span>餐廳</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="bathroom" class="space-checkbox" data-progress="true">
                <span>浴廁</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="kitchen" class="space-checkbox" data-progress="true">
                <span>廚房</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="master-bedroom" class="space-checkbox" data-progress="true">
                <span>主臥房</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="children-room" class="space-checkbox">
                <span>小孩房</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="guest-room" class="space-checkbox">
                <span>客房</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="elderly-room" class="space-checkbox">
                <span>孝親房</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="study-room" class="space-checkbox">
                <span>書房</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="walk-in-closet" class="space-checkbox">
                <span>更衣室</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="storage" class="space-checkbox">
                <span>儲藏室</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="spaces" value="tatami-room" class="space-checkbox">
                <span>和室</span>
              </label>
            </div>
          </div>

          <div id="space-quantity-container" class="space-quantity-container" style="display: none;"></div>

          <div class="form-group">
            <label for="priority-needs">最希望優先解決的 1 到 3 件事</label>
            <textarea
              id="priority-needs"
              name="priority-needs"
              rows="3"
              data-progress="true"
              placeholder="例如收納不足、格局想重整、預售屋客變快到期、預算想先抓範圍、需要小孩房與書房共用等"
            ></textarea>
          </div>
        </section>

        <section class="form-section">
          <h2 class="section-title">第四步｜智慧家庭需求</h2>

          <div class="form-group">
            <label>是否需要智慧家庭整合規劃</label>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="smart-home-planning" value="yes" id="smart-home-yes">
                <span>需要</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="smart-home-planning" value="maybe" id="smart-home-maybe">
                <span>想了解</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="smart-home-planning" value="no" id="smart-home-no">
                <span>暫時不需要</span>
              </label>
            </div>
          </div>

          <div id="smart-home-details" class="conditional-section" style="display: none;">
            <div class="form-group">
              <label>希望整合的項目</label>
              <div class="checkbox-grid">
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-features" value="lighting">
                  <span>燈光控制</span>
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-features" value="curtain">
                  <span>電動窗簾</span>
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-features" value="air-conditioning">
                  <span>空調整合</span>
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-features" value="door-lock">
                  <span>智慧門鎖</span>
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-features" value="sensor">
                  <span>感測器自動化</span>
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-features" value="security">
                  <span>監控與安防</span>
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-features" value="network">
                  <span>網路與弱電配置</span>
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-features" value="audio">
                  <span>影音情境整合</span>
                </label>
              </div>
            </div>

            <div class="form-group">
              <label>希望支援的生態系</label>
              <div class="checkbox-grid">
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-ecosystem" value="apple-home">
                  <span>Apple Home</span>
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-ecosystem" value="google-home">
                  <span>Google Home</span>
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-ecosystem" value="alexa">
                  <span>Alexa</span>
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-ecosystem" value="home-assistant">
                  <span>Home Assistant</span>
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" name="smart-home-ecosystem" value="not-sure">
                  <span>還不確定</span>
                </label>
              </div>
            </div>

            <div class="form-group">
              <label>目前是否已有既有設備想整合</label>
              <div class="radio-group">
                <label class="radio-label">
                  <input type="radio" name="existing-smart-devices" value="yes" id="existing-smart-devices-yes">
                  <span>有</span>
                </label>
                <label class="radio-label">
                  <input type="radio" name="existing-smart-devices" value="no" id="existing-smart-devices-no">
                  <span>沒有</span>
                </label>
              </div>
              <div id="existing-smart-devices-input" class="conditional-input" style="display: none;">
                <textarea name="existing-smart-devices-notes" rows="3" placeholder="可填寫目前設備品牌、型號，或想延用的系統"></textarea>
              </div>
            </div>

            <div class="form-group">
              <label for="smart-home-scenes">想實現的生活情境</label>
              <textarea id="smart-home-scenes" name="smart-home-scenes" rows="3" placeholder="例如回家模式、離家模式、起夜動線、語音控制、遠端查看等"></textarea>
            </div>

            <div class="form-group">
              <label for="smart-home-notes">智慧家庭補充說明</label>
              <textarea id="smart-home-notes" name="smart-home-notes" rows="3" placeholder="例如希望前期預留哪些線路、是否重視後續擴充、是否已有跨品牌整合需求"></textarea>
            </div>
          </div>
        </section>

        <section class="form-section">
          <h2 class="section-title">進階補充（選填）</h2>

          <div class="form-group">
            <label for="residents">居住人數</label>
            <select id="residents" name="residents">
              <option value="">請選擇</option>
              <option value="1">1人</option>
              <option value="2">2人</option>
              <option value="3">3人</option>
              <option value="4">4人</option>
              <option value="5">5人</option>
              <option value="6">6人以上</option>
            </select>
          </div>

          <div class="form-group">
            <label>家庭成員組成</label>
            <div class="checkbox-group">
              <label class="checkbox-label">
                <input type="checkbox" name="household-structure" value="single">
                <span>單身居住</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="household-structure" value="couple">
                <span>伴侶 / 夫妻</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="household-structure" value="infant">
                <span>嬰幼兒</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="household-structure" value="child">
                <span>學齡兒童</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="household-structure" value="teen">
                <span>青少年</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="household-structure" value="elder">
                <span>長輩同住</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="household-structure" value="caregiver">
                <span>照護者 / 幫手</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="household-structure" value="other" id="household-structure-other-check">
                <span>其他</span>
              </label>
            </div>
            <div id="household-structure-other-input" class="conditional-input" style="display: none;">
              <input type="text" name="household-structure-other" placeholder="請補充家庭組成，例如假日才會回家的家人、偶爾留宿的親友等">
            </div>
          </div>

          <div class="form-group">
            <label for="family-lifestyle-notes">家庭成員補充</label>
            <textarea
              id="family-lifestyle-notes"
