---
import BaseLayout from "../layouts/BaseLayout.astro";

const requirementFormId =
  import.meta.env.PUBLIC_FORMSPREE_REQUIREMENT_FORM_ID?.trim() || "";
const quickConsultationAction = requirementFormId
  ? `https://formspree.io/f/${requirementFormId}`
  : "";
const quickConsultationEnabled = Boolean(quickConsultationAction);
const siteOrigin = (Astro.site || new URL("https://qingxidesign.tw")).toString();
const consultationSuccessURL = new URL("/consultation-thank-you", siteOrigin).toString();
const contactHeroImage = "/images/portfolio/xizhi-3.jpg";
const contactFormImage = "/images/portfolio/xizhi-1.jpg";
---

<BaseLayout
  title="聯絡我們 - 青曦空間設計"
  description="預約青曦空間設計諮詢，先留下空間條件、預算方向與時程。"
  ogImage="/images/portfolio/xizhi-1.jpg"
  pageType="contact"
>
  <section class="contact-page">
    <div class="contact-shell">
      <div class="contact-hero">
        <div class="contact-copy reveal-up" data-reveal-delay="0">
          <p class="contact-eyebrow">NEXT STEP</p>
          <h1>把想住進去的畫面，先告訴我們。</h1>
          <p class="contact-description">
            從格局、光線、材質到預算節奏，先把空間想像說清楚，後面的討論就會更準。
          </p>

          <div class="contact-highlights">
            <span>住宅 / 客變 / 翻修</span>
            <span>可先線上討論</span>
            <span>汐止工作室可預約</span>
          </div>

          <div class="contact-credential">
            <p class="contact-credential-label">LICENSED PRACTICE</p>
            <p class="contact-credential-title">室內裝修工程管理乙級證照</p>
            <p class="contact-credential-meta">技術士證編號：126-0024871</p>
            <p class="contact-credential-description">
              不只談風格，也一起把施工與時程條件看清楚。
            </p>
          </div>
        </div>

        <div class="contact-hero-visual-stack reveal-up" data-reveal-delay="120">
          <figure class="contact-hero-visual">
            <img
              src={contactHeroImage}
              alt="青曦空間設計作品中的客廳與收邊細節"
              width="1600"
              height="1200"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
            <figcaption>
              <span>CONSULTATION MOOD</span>
              <strong>先讓空間氣氛與生活節奏被看見，再談做法。</strong>
            </figcaption>
          </figure>

          <aside class="contact-aside">
            <p class="aside-label">CONSULTING FLOW</p>
            <ol class="aside-steps">
              <li>先留下空間現況與最在意的生活感</li>
              <li>再一起確認預算、時程與施工條件</li>
              <li>合適的話，再安排後續討論或工作室體驗</li>
            </ol>
          </aside>
        </div>
      </div>

      <section class="contact-ritual reveal-up" data-reveal-delay="40">
        <div class="contact-ritual-copy">
          <p class="contact-eyebrow">HOW TO START</p>
          <h2>先選一個比較舒服的開始方式。</h2>
          <p>
            想先快速聊方向，可以直接進 LINE；若你已經整理好需求，也可以直接往下留下空間條件與生活重點。
          </p>
        </div>

        <div class="contact-actions">
          <a
            href="https://lin.ee/U1HCeW4"
            target="_blank"
            rel="noreferrer"
            class="contact-card contact-card-primary"
            data-contact-cta="line"
          >
            <div class="card-icon line-color">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="64"
                height="64"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
                ></path>
              </svg>
            </div>
            <p class="card-label">即時聯繫</p>
            <h2>加入官方 LINE</h2>
            <p class="card-description">適合先快速聊需求輪廓、預算方向與合作節奏。</p>
            <span class="card-link">立即開始聊</span>
          </a>

          <a
            href="#quick-form-title"
            class="contact-card"
            data-contact-cta="quick-form"
          >
            <div class="card-icon form-color">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="64"
                height="64"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M14 3h7v7"></path>
                <path d="M10 14 21 3"></path>
                <path d="M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"></path>
              </svg>
            </div>
            <p class="card-label">安靜整理</p>
            <h2>留下空間條件</h2>
            <p class="card-description">適合已經有初步想法，想一次把需求與生活重點整理清楚。</p>
            <span class="card-link">往下填表</span>
          </a>
        </div>
      </section>

      <section class="quick-form-panel reveal-up" data-reveal-delay="0">
        <div class="quick-form-copy">
          <p class="quick-form-eyebrow">CONSULTATION NOTE</p>
          <h2 id="quick-form-title">先把空間條件與生活感說清楚。</h2>
          <p class="quick-form-description" id="quick-form-description">
            約 1 分鐘，把最重要的使用情境、預算節奏與時間點留下來，我們後續才知道該從哪裡開始陪你往下走。
          </p>
          <div class="quick-form-highlights">
            <span>約 1 分鐘完成</span>
            <span>先確認方向</span>
            <span>可銜接完整需求表</span>
          </div>
          <figure class="quick-form-visual">
            <img
              src={contactFormImage}
              alt="青曦空間設計作品中的餐廚與光線氛圍"
              width="1600"
              height="1200"
              loading="lazy"
              decoding="async"
            />
            <figcaption>
              <span>SPACE BRIEF</span>
              <strong>把你在意的光、材質、動線與日常節奏，先留在這裡。</strong>
            </figcaption>
          </figure>
        </div>

        <div class="quick-form-shell">
          {
            !quickConsultationEnabled && (
              <div class="quick-form-notice" role="status">
                <p>為確保諮詢品質，線上表單暫停收件。請直接加入官方 LINE，我們將由專人為您服務。</p>
              </div>
            )
          }

          <form
            id="quick-consultation-form"
            action={quickConsultationAction}
            method="POST"
            class="quick-form"
            data-form-enabled={String(quickConsultationEnabled)}
          >
            <input type="hidden" name="_subject" value="青曦空間設計｜新的快速諮詢表單" />
            <input type="hidden" name="_next" value={consultationSuccessURL} />
            <input type="hidden" name="form_type" value="quick_consultation" />
            <input type="hidden" name="form_stage" value="stage_1_quick_consultation" />
            <input type="hidden" name="lead_intent" id="quick-lead-intent" />
            <input type="hidden" name="estimator_summary" id="quick-estimator-summary" />
            <input type="hidden" name="smart_home_quiz_summary" id="quick-smart-home-summary" />
            <input type="hidden" name="utm_source" id="quick-utm-source" />
            <input type="hidden" name="utm_medium" id="quick-utm-medium" />
            <input type="hidden" name="utm_campaign" id="quick-utm-campaign" />
            <input type="hidden" name="utm_term" id="quick-utm-term" />
            <input type="hidden" name="utm_content" id="quick-utm-content" />
            <input type="hidden" name="landing_page" id="quick-landing-page" />
            <input type="hidden" name="page_referrer" id="quick-page-referrer" />

            <div class="quick-form-grid">
              <label class="quick-form-field">
                <span>姓名</span>
                <input type="text" name="name" required />
              </label>
              <label class="quick-form-field">
                <span>聯絡方式</span>
                <input type="text" name="contact_method" placeholder="電話、LINE ID 或 Email" required />
              </label>
              <label class="quick-form-field">
                <span>空間類型</span>
                <select name="space_type" required>
                  <option value="">請選擇</option>
                  <option value="new-home">新成屋 / 預售屋</option>
                  <option value="old-home">中古屋 / 老屋</option>
                  <option value="commercial">商業空間</option>
                  <option value="community">社區公設 / 其他</option>
                </select>
              </label>
              <label class="quick-form-field">
                <span>大概什麼時候開始</span>
                <select name="timeline">
                  <option value="">請選擇</option>
                  <option value="urgent">三個月內</option>
                  <option value="planned">三到六個月內</option>
                  <option value="flexible">半年以上</option>
                </select>
              </label>
              <label class="quick-form-field quick-form-field-full">
                <span>目前最想先確認的事</span>
                <textarea
                  id="quick-consultation-focus"
                  name="consultation_focus"
                  rows="4"
                  placeholder="預算方向、空間條件、智能家居需求等"
                  required
                ></textarea>
              </label>
            </div>

            <div class="quick-form-actions">
              <button type="submit" class="quick-form-submit">送出快速諮詢</button>
              <a
                href="/requirement-form"
                class="quick-form-secondary is-disabled"
                data-ready-link="requirement-form"
                data-contact-cta="requirement-form"
                aria-disabled="true"
              >先填 3 項基本資訊，再填完整需求表</a>
            </div>
          </form>
        </div>
      </section>

      <section class="social-panel reveal-up" data-reveal-delay="80">
        <div class="social-copy">
          <p class="social-label">FOLLOW QINGXI</p>
          <h2>也可以先從社群看看青曦。</h2>
        </div>

        <div class="social-section">
          <a href="mailto:qingxi.ds@outlook.com" class="social-icon-small" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path>
            </svg>
          </a>
          <a href="https://www.facebook.com/profile.php?id=61562661642204" target="_blank" rel="noreferrer" class="social-icon-small" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path>
            </svg>
          </a>
          <a href="https://www.instagram.com/qingxi.ds/" target="_blank" rel="noreferrer" class="social-icon-small" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path>
            </svg>
          </a>
          <a href="https://www.threads.net/@qingxi.ds?hl=zh-tw" target="_blank" rel="noreferrer" class="social-icon-small" aria-label="Threads">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.781 3.631 2.695 6.541 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 013.02.142l-.126.742a12.986 12.986 0 00-2.877-.12c-1.112.061-2.024.399-2.716.997-.644.558-.968 1.283-.91 2.042.046.739.427 1.361 1.03 1.696.562.312 1.29.467 2.16.433 1.197-.065 2.124-.493 2.75-1.275.528-.66.863-1.552.998-2.652.047-.385.076-.774.088-1.166.002-.138.008-.276.008-.413a8.97 8.97 0 00-.084-1.207c-.096-.689-.263-1.331-.494-1.909a4.692 4.692 0 00-.934-1.443c-.37-.404-.8-.727-1.277-.966a4.978 4.978 0 00-1.608-.436c-.606-.056-1.227-.045-1.848.034-1.396.177-2.695.663-3.859 1.443-1.165.78-2.033 1.754-2.584 2.896-.55 1.142-.832 2.408-.84 3.766.008 1.358.29 2.624.84 3.766.551 1.142 1.42 2.116 2.584 2.896 1.164.78 2.463 1.266 3.859 1.443.621.079 1.242.09 1.848.034.606-.056 1.182-.197 1.725-.423.544-.227 1.048-.525 1.512-.895l1.382 1.465c-.593.472-1.228.866-1.903 1.181-.674.315-1.393.543-2.152.682-.76.14-1.554.203-2.382.19z"></path>
            </svg>
          </a>
          <a href="https://www.xiaohongshu.com/search_result?keyword=%E9%9D%92%E6%9B%A6&source=unknown" target="_blank" rel="noreferrer" class="social-icon-small" aria-label="小紅書">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.018 17.563c-.623.4-1.359.637-2.118.637-1.953 0-3.537-1.584-3.537-3.537v-3.726c0-1.953 1.584-3.537 3.537-3.537.759 0 1.495.237 2.118.637V6.3c-.677-.258-1.401-.4-2.159-.4-3.037 0-5.5 2.463-5.5 5.5v3.2c0 3.037 2.463 5.5 5.5 5.5.758 0 1.482-.142 2.159-.4v-1.737z"></path>
            </svg>
          </a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding: 6rem 1.5rem 5rem;
    background:
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.06), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(245, 240, 234, 1) 100%);
  }

  .contact-shell {
    max-width: 1180px;
    margin: 0 auto;
  }

  .contact-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
    gap: 2.4rem;
    align-items: end;
    min-height: max(700px, calc(100svh - 9rem));
  }

  .contact-copy h1 {
    margin: 0;
    max-width: 10ch;
    font-family: var(--font-display);
    font-size: clamp(4rem, 8vw, 6.8rem);
    line-height: 1.25;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--gray-darkest);
  }

  .contact-eyebrow,
  .aside-label,
  .social-label,
  .card-label,
  .quick-form-eyebrow {
    margin: 0 0 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--tiffany-dark);
    text-transform: uppercase;
  }

  .contact-description {
    margin: 1.55rem 0 0;
    max-width: 34rem;
    font-size: 1.1rem;
    line-height: 1.95;
    letter-spacing: 0.01em;
    color: color-mix(in srgb, var(--gray-darkest) 62%, transparent);
  }

  .contact-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .contact-highlights span {
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--gray-dark);
    letter-spacing: 0.04em;
    box-shadow: 0 16px 36px rgba(var(--brand-dark-rgb), 0.06);
    backdrop-filter: blur(18px);
  }

  .contact-credential {
    margin-top: 1.6rem;
    padding: 1.6rem 1.7rem;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.08), transparent 34%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.74) 0%, rgba(246, 241, 236, 0.58) 100%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 24px 56px rgba(var(--brand-dark-rgb), 0.08);
    backdrop-filter: blur(22px);
  }

  .contact-hero-visual-stack {
    display: grid;
    gap: 1.2rem;
    align-self: stretch;
  }

  .contact-hero-visual {
    position: relative;
    margin: 0;
    min-height: 440px;
    border-radius: 34px;
    overflow: hidden;
    box-shadow: 0 32px 90px rgba(var(--brand-dark-rgb), 0.16);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .contact-hero-visual img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .contact-hero-visual figcaption {
    position: absolute;
    inset: auto 1.3rem 1.3rem 1.3rem;
    display: grid;
    gap: 0.45rem;
    padding: 1rem 1.05rem;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(18, 18, 18, 0.22), rgba(18, 18, 18, 0.54));
    color: var(--white);
