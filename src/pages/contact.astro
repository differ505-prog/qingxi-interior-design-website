  }

  .card-link::after {
    content: "→";
    transition: transform 0.25s ease;
  }

  .contact-card:hover .card-link::after {
    transform: translateX(4px);
  }

  .quick-form-panel {
    margin-top: 2.25rem;
    padding: 2rem;
    border-radius: 32px;
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.16), transparent 32%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(244, 248, 248, 1) 100%);
    border: 1px solid rgba(129, 199, 212, 0.16);
    box-shadow: 0 24px 60px rgba(47, 47, 47, 0.06);
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 1.5rem;
    align-items: start;
  }

  .quick-form-copy h2 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(1.8rem, 2.8vw, 2.8rem);
    line-height: 1.42;
    font-weight: 500;
    color: var(--gray-darkest);
    letter-spacing: 0.05em;
  }

  .quick-form-description {
    margin: 1rem 0 0;
    color: var(--gray-medium);
    line-height: 1.9;
    max-width: 34rem;
  }

  .quick-form-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.5rem;
  }

  .quick-form-highlights span {
    padding: 0.7rem 0.95rem;
    border-radius: 999px;
