---
import BaseLayout from "../layouts/BaseLayout.astro";

const requirementFormId =
  import.meta.env.PUBLIC_FORMSPREE_REQUIREMENT_FORM_ID?.trim() || "xrevzvnp";
const quickConsultationAction = requirementFormId
  ? `https://formspree.io/f/${requirementFormId}`
  : "";
const quickConsultationEnabled = Boolean(quickConsultationAction);
const siteOrigin = (Astro.site || new URL("https://qingxidesign.tw")).toString();
const consultationSuccessURL = new URL("/consultation-thank-you", siteOrigin).toString();
---

<BaseLayout
  title="聯絡我們 - 青曦空間設計"
  description="預約青曦空間設計的室內設計諮詢，透過 LINE、需求表或聯絡頁整理你的空間條件、預算與裝修時程。"
  ogImage="/images/portfolio/xizhi-1.jpg"
  pageType="contact"
>
  <section class="contact-page">
    <div class="contact-shell">
      <div class="contact-hero">
        <div class="contact-copy">
          <p class="contact-eyebrow">NEXT STEP</p>
          <h1>讓諮詢過程和空間一樣，清楚、安定、好開始。</h1>
          <p class="contact-description">
            不論你正在準備新成屋、預售屋客變，或想整理既有住宅，
            青曦會先陪你把需求、預算與時程梳理清楚，再進入下一步。
          </p>

          <div class="contact-highlights">
            <span>初步諮詢免費</span>
            <span>大台北地區服務</span>
            <span>設計施工整合</span>
          </div>

        <div class="contact-credential">
          <p class="contact-credential-label">PROFESSIONAL ASSURANCE</p>
          <p class="contact-credential-title">建築物室內裝修工程管理乙級技術士</p>
          <p class="contact-credential-meta">技術士證編號：126-0024871</p>
          <p class="contact-credential-description">
            諮詢時不只談風格，也能同步協助你釐清工程管理、施工節點與執行風險。
          </p>
        </div>
        </div>

        <aside class="contact-aside">
          <p class="aside-label">CONSULTING FLOW</p>
          <ol class="aside-steps">
            <li>留下需求方向與空間資訊</li>
            <li>確認預算帶與裝修時程</li>
            <li>安排後續討論與現場評估</li>
          </ol>
        </aside>
      </div>

      <div class="contact-actions">
        <a
          href="https://lin.ee/U1HCeW4"
          target="_blank"
          rel="noreferrer"
          class="contact-card contact-card-primary"
          data-contact-cta="line"
        >
          <div class="card-icon line-color">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="64"
              height="64"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
              ></path>
            </svg>
          </div>
          <p class="card-label">即時聯繫</p>
          <h2>加入官方 LINE</h2>
          <p class="card-description">適合想先快速聊需求、預算方向與時程的人。</p>
          <span class="card-link">立即開始對話</span>
        </a>

        <a href="/requirement-form" class="contact-card" data-contact-cta="requirement-form">
          <div class="card-icon form-color">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="64"
              height="64"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <line x1="10" y1="9" x2="8" y2="9"></line>
            </svg>
          </div>
          <p class="card-label">進一步整理</p>
          <h2>填寫線上需求表</h2>
          <p class="card-description">適合已先釐清方向，想一次補齊空間條件、需求細節與預算資訊的人。</p>
          <span class="card-link">前往完整需求表</span>
        </a>
      </div>

      <section class="quick-form-panel">
        <div class="quick-form-copy">
          <p class="quick-form-eyebrow">QUICK CONSULTATION</p>
          <h2 id="quick-form-title">如果你還沒準備好完整需求，先留下核心資訊就可以。</h2>
          <p class="quick-form-description" id="quick-form-description">
            這是第一階段精簡表單，適合想先確認預算方向、服務方式與時程可行性的人。
            若之後需要更完整評估，再補填設計需求表即可。
          </p>
          <div class="quick-form-highlights">
            <span>約 1 分鐘完成</span>
            <span>先確認方向再深入</span>
            <span>適合第一次接觸</span>
          </div>
        </div>

        <div class="quick-form-shell">
          {
            !quickConsultationEnabled && (
              <div class="quick-form-notice" role="status">
                <p>表單收件尚未完成設定，目前請先透過官方 LINE 聯絡青曦。</p>
              </div>
            )
          }

          <form
            id="quick-consultation-form"
            action={quickConsultationAction}
            method="POST"
            class="quick-form"
            data-form-enabled={String(quickConsultationEnabled)}
          >
            <input type="hidden" name="_subject" value="青曦空間設計｜新的快速諮詢表單" />
            <input type="hidden" name="_next" value={consultationSuccessURL} />
            <input type="hidden" name="form_type" value="quick_consultation" />
            <input type="hidden" name="form_stage" value="stage_1_quick_consultation" />
            <input type="hidden" name="lead_intent" id="quick-lead-intent" />
            <input type="hidden" name="estimator_summary" id="quick-estimator-summary" />
            <input type="hidden" name="smart_home_quiz_summary" id="quick-smart-home-summary" />
            <input type="hidden" name="utm_source" id="quick-utm-source" />
            <input type="hidden" name="utm_medium" id="quick-utm-medium" />
            <input type="hidden" name="utm_campaign" id="quick-utm-campaign" />
            <input type="hidden" name="utm_term" id="quick-utm-term" />
            <input type="hidden" name="utm_content" id="quick-utm-content" />
            <input type="hidden" name="landing_page" id="quick-landing-page" />
            <input type="hidden" name="page_referrer" id="quick-page-referrer" />

            <div class="quick-form-grid">
              <label class="quick-form-field">
                <span>姓名</span>
                <input type="text" name="name" required />
              </label>
              <label class="quick-form-field">
                <span>聯絡方式</span>
                <input type="text" name="contact_method" placeholder="電話、LINE ID 或 Email" required />
              </label>
              <label class="quick-form-field">
                <span>空間類型</span>
                <select name="space_type" required>
                  <option value="">請選擇</option>
                  <option value="new-home">新成屋 / 預售屋</option>
                  <option value="old-home">中古屋 / 老屋</option>
                  <option value="commercial">商業空間</option>
                  <option value="community">社區公設 / 其他</option>
                </select>
              </label>
              <label class="quick-form-field">
                <span>預計時程</span>
                <select name="timeline">
                  <option value="">請選擇</option>
                  <option value="urgent">三個月內</option>
                  <option value="planned">三到六個月內</option>
                  <option value="flexible">半年以上</option>
                </select>
              </label>
              <label class="quick-form-field quick-form-field-full">
                <span>目前最想先確認的事</span>
                <textarea
                  id="quick-consultation-focus"
                  name="consultation_focus"
                  rows="4"
                  placeholder="例如預算大概怎麼抓、交屋後想怎麼安排、是否能連同智能家居一起規劃等"
                  required
                ></textarea>
              </label>
            </div>

            <div class="quick-form-actions">
              <button type="submit" class="quick-form-submit">送出快速諮詢</button>
              <a href="/requirement-form" class="quick-form-secondary">我已整理好資訊，改填完整需求表</a>
            </div>
          </form>
        </div>
      </section>

      <section class="social-panel">
        <div class="social-copy">
          <p class="social-label">FOLLOW QINGXI</p>
          <h2>從社群看更多日常靈感與更新。</h2>
        </div>

        <div class="social-section">
          <a href="mailto:qingxi.ds@outlook.com" class="social-icon-small" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path>
            </svg>
          </a>
          <a href="https://www.facebook.com/profile.php?id=61562661642204" target="_blank" rel="noreferrer" class="social-icon-small" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path>
            </svg>
          </a>
          <a href="https://www.instagram.com/qingxi.ds/" target="_blank" rel="noreferrer" class="social-icon-small" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path>
            </svg>
          </a>
          <a href="https://www.threads.net/@qingxi.ds?hl=zh-tw" target="_blank" rel="noreferrer" class="social-icon-small" aria-label="Threads">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.781 3.631 2.695 6.541 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 013.02.142l-.126.742a12.986 12.986 0 00-2.877-.12c-1.112.061-2.024.399-2.716.997-.644.558-.968 1.283-.91 2.042.046.739.427 1.361 1.03 1.696.562.312 1.29.467 2.16.433 1.197-.065 2.124-.493 2.75-1.275.528-.66.863-1.552.998-2.652.047-.385.076-.774.088-1.166.002-.138.008-.276.008-.413a8.97 8.97 0 00-.084-1.207c-.096-.689-.263-1.331-.494-1.909a4.692 4.692 0 00-.934-1.443c-.37-.404-.8-.727-1.277-.966a4.978 4.978 0 00-1.608-.436c-.606-.056-1.227-.045-1.848.034-1.396.177-2.695.663-3.859 1.443-1.165.78-2.033 1.754-2.584 2.896-.55 1.142-.832 2.408-.84 3.766.008 1.358.29 2.624.84 3.766.551 1.142 1.42 2.116 2.584 2.896 1.164.78 2.463 1.266 3.859 1.443.621.079 1.242.09 1.848.034.606-.056 1.182-.197 1.725-.423.544-.227 1.048-.525 1.512-.895l1.382 1.465c-.593.472-1.228.866-1.903 1.181-.674.315-1.393.543-2.152.682-.76.14-1.554.203-2.382.19z"></path>
            </svg>
          </a>
          <a href="https://www.xiaohongshu.com/search_result?keyword=%E9%9D%92%E6%9B%A6&source=unknown" target="_blank" rel="noreferrer" class="social-icon-small" aria-label="小紅書">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.018 17.563c-.623.4-1.359.637-2.118.637-1.953 0-3.537-1.584-3.537-3.537v-3.726c0-1.953 1.584-3.537 3.537-3.537.759 0 1.495.237 2.118.637V6.3c-.677-.258-1.401-.4-2.159-.4-3.037 0-5.5 2.463-5.5 5.5v3.2c0 3.037 2.463 5.5 5.5 5.5.758 0 1.482-.142 2.159-.4v-1.737z"></path>
            </svg>
          </a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding: 5rem 1.5rem 4.5rem;
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.12), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(246, 247, 246, 1) 100%);
  }

  .contact-shell {
    max-width: 1180px;
    margin: 0 auto;
  }

  .contact-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 360px);
    gap: 2rem;
    align-items: end;
  }

  .contact-copy h1 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(2.4rem, 4vw, 4.4rem);
    line-height: 1.28;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--gray-darkest);
  }

  .contact-eyebrow,
  .aside-label,
  .social-label,
  .card-label,
  .quick-form-eyebrow {
    margin: 0 0 0.9rem;
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    color: var(--tiffany-dark);
    text-transform: uppercase;
  }

  .contact-description {
    margin: 1.35rem 0 0;
    max-width: 43rem;
    font-size: 1.05rem;
    line-height: 1.95;
    color: var(--gray-medium);
  }

  .contact-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .contact-highlights span {
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(129, 199, 212, 0.18);
    color: var(--gray-dark);
    letter-spacing: 0.04em;
    box-shadow: 0 10px 22px rgba(47, 47, 47, 0.04);
  }

  .contact-credential {
    margin-top: 1.6rem;
    padding: 1.3rem 1.4rem;
    border-radius: 24px;
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.14), transparent 34%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 249, 249, 1) 100%);
    border: 1px solid rgba(129, 199, 212, 0.2);
    box-shadow: 0 18px 40px rgba(47, 47, 47, 0.05);
  }

  .contact-credential-label {
    margin: 0;
    color: var(--tiffany-dark);
    font-size: 0.76rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .contact-credential-title {
    margin: 0.7rem 0 0;
    font-family: "Noto Serif TC", serif;
    font-size: 1.25rem;
    line-height: 1.55;
    color: var(--gray-darkest);
    letter-spacing: 0.05em;
  }

  .contact-credential-meta {
    margin: 0.45rem 0 0;
    color: var(--tiffany-dark);
    font-size: 0.95rem;
    letter-spacing: 0.04em;
  }

  .contact-credential-description {
    margin: 0.7rem 0 0;
    color: var(--gray-medium);
    line-height: 1.85;
  }

  .contact-aside {
    padding: 1.75rem;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.18), transparent 32%),
      linear-gradient(135deg, rgba(31, 31, 31, 1) 0%, rgba(47, 47, 47, 1) 100%);
    color: var(--white);
    box-shadow: 0 26px 60px rgba(17, 17, 17, 0.16);
  }

  .contact-aside .aside-label {
    color: rgba(255, 255, 255, 0.62);
  }

  .aside-steps {
    margin: 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.86);
  }

  .contact-actions {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .contact-card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    padding: 2rem;
    border-radius: 30px;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(129, 199, 212, 0.14);
    box-shadow: 0 22px 45px rgba(47, 47, 47, 0.06);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease,
      background-color 0.3s ease;
  }

  .contact-card::after {
    content: "";
    position: absolute;
    inset: auto 2rem 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(129, 199, 212, 0.5), transparent);
  }

  .contact-card:hover {
    transform: translateY(-6px);
    border-color: rgba(129, 199, 212, 0.36);
    box-shadow: 0 28px 60px rgba(129, 199, 212, 0.14);
  }

  .contact-card-primary {
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.16), transparent 30%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(245, 249, 249, 1) 100%);
  }

  .card-icon {
    width: 64px;
    height: 64px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(129, 199, 212, 0.12);
    transition: transform 0.3s ease, color 0.3s ease, background-color 0.3s ease;
  }

  .card-icon svg {
    width: 32px;
    height: 32px;
  }

  .line-color {
    color: #06c755;
  }

  .form-color {
    color: var(--tiffany-dark);
  }

  .contact-card:hover .card-icon {
    transform: scale(1.08);
    background: rgba(129, 199, 212, 0.2);
  }

  .contact-card h2 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(1.6rem, 2.4vw, 2.2rem);
    line-height: 1.35;
    color: var(--gray-darkest);
    font-weight: 500;
  }

  .card-description {
    margin: 0;
    color: var(--gray-medium);
    line-height: 1.85;
    max-width: 32rem;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: auto;
    color: var(--tiffany-dark);
    letter-spacing: 0.08em;
  }

  .card-link::after {
    content: "→";
    transition: transform 0.25s ease;
  }

  .contact-card:hover .card-link::after {
    transform: translateX(4px);
  }

  .quick-form-panel {
    margin-top: 2.25rem;
    padding: 2rem;
    border-radius: 32px;
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.16), transparent 32%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(244, 248, 248, 1) 100%);
    border: 1px solid rgba(129, 199, 212, 0.16);
    box-shadow: 0 24px 60px rgba(47, 47, 47, 0.06);
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 1.5rem;
    align-items: start;
  }

  .quick-form-copy h2 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(1.8rem, 2.8vw, 2.8rem);
    line-height: 1.42;
    font-weight: 500;
    color: var(--gray-darkest);
    letter-spacing: 0.05em;
  }

  .quick-form-description {
    margin: 1rem 0 0;
    color: var(--gray-medium);
    line-height: 1.9;
    max-width: 34rem;
  }

  .quick-form-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.5rem;
  }

  .quick-form-highlights span {
    padding: 0.7rem 0.95rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(129, 199, 212, 0.18);
    color: var(--gray-dark);
    letter-spacing: 0.04em;
    box-shadow: 0 10px 22px rgba(47, 47, 47, 0.04);
  }

  .quick-form-shell {
    padding: 1.5rem;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(129, 199, 212, 0.14);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .quick-form-notice {
    margin-bottom: 1rem;
    padding: 1rem 1.1rem;
    border-radius: 18px;
    background: rgba(250, 248, 241, 0.95);
    border: 1px solid rgba(207, 188, 136, 0.28);
    color: var(--gray-dark);
    line-height: 1.75;
  }

  .quick-form-notice p {
    margin: 0;
  }

  .quick-form {
    display: grid;
    gap: 1.25rem;
  }

  .quick-form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .quick-form-field {
    display: grid;
    gap: 0.5rem;
  }

  .quick-form-field span {
    color: var(--gray-darkest);
    font-size: 0.95rem;
    letter-spacing: 0.03em;
  }

  .quick-form-field input,
  .quick-form-field select,
  .quick-form-field textarea {
    width: 100%;
    padding: 0.95rem 1rem;
    border-radius: 18px;
    border: 1px solid rgba(129, 199, 212, 0.22);
    background: rgba(255, 255, 255, 0.98);
    color: var(--gray-darkest);
    font: inherit;
    line-height: 1.6;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      background-color 0.25s ease;
  }

  .quick-form-field input::placeholder,
  .quick-form-field textarea::placeholder {
    color: rgba(108, 108, 108, 0.72);
  }

  .quick-form-field input:focus,
  .quick-form-field select:focus,
  .quick-form-field textarea:focus {
    outline: none;
    border-color: rgba(129, 199, 212, 0.48);
    box-shadow: 0 0 0 4px rgba(129, 199, 212, 0.12);
    background: rgba(252, 255, 255, 1);
  }

  .quick-form-field textarea {
    resize: vertical;
    min-height: 132px;
  }

  .quick-form-field-full {
    grid-column: 1 / -1;
  }

  .quick-form-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
  }

  .quick-form-submit,
  .quick-form-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    font-size: 1rem;
    text-decoration: none;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease,
      background-color 0.25s ease;
  }

  .quick-form-submit {
    border: 1px solid var(--gray-darkest);
    background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--tiffany-dark) 100%);
    color: var(--white);
    cursor: pointer;
    font-weight: 500;
  }

  .quick-form-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 28px rgba(47, 47, 47, 0.18);
  }

  .quick-form-secondary {
    border: 1px solid rgba(129, 199, 212, 0.22);
    background: rgba(255, 255, 255, 0.9);
    color: var(--gray-darkest);
  }

  .quick-form-secondary:hover {
    transform: translateY(-2px);
    background: rgba(245, 250, 250, 1);
    box-shadow: 0 14px 24px rgba(129, 199, 212, 0.12);
  }

  .social-panel {
    margin-top: 2.25rem;
    padding: 1.6rem 1.75rem;
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(129, 199, 212, 0.14);
    box-shadow: 0 18px 40px rgba(47, 47, 47, 0.04);
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    align-items: center;
  }

  .social-copy h2 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    line-height: 1.45;
    font-weight: 500;
    color: var(--gray-darkest);
  }

  .social-section {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.85rem;
  }

  .social-icon-small {
    width: 54px;
    height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--white);
    border: 1px solid rgba(129, 199, 212, 0.18);
    border-radius: 50%;
    color: var(--gray-medium);
    transition:
      transform 0.25s ease,
      color 0.25s ease,
      background-color 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
    box-shadow: 0 10px 22px rgba(47, 47, 47, 0.04);
  }

  .social-icon-small:hover {
    background: var(--tiffany-primary);
    border-color: var(--tiffany-primary);
    color: var(--white);
    transform: translateY(-3px);
    box-shadow: 0 14px 24px rgba(129, 199, 212, 0.24);
  }

  @media (max-width: 900px) {
    .contact-hero,
    .contact-actions,
    .quick-form-panel,
    .social-panel {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: stretch;
    }

    .social-section {
      justify-content: flex-start;
    }
  }

  @media (max-width: 768px) {
    .contact-page {
      padding: 4rem 1.25rem 3.5rem;
    }

    .contact-card,
    .contact-aside,
    .quick-form-panel,
    .quick-form-shell,
    .social-panel {
      padding: 1.5rem;
      border-radius: 22px;
    }

    .quick-form-grid,
    .quick-form-actions {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: stretch;
    }

    .quick-form-submit,
    .quick-form-secondary {
      width: 100%;
    }

    .social-copy h2 {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  // @ts-nocheck
  const quickConsultationForm = document.getElementById("quick-consultation-form");
  const quickUtmSource = document.getElementById("quick-utm-source");
  const quickUtmMedium = document.getElementById("quick-utm-medium");
  const quickUtmCampaign = document.getElementById("quick-utm-campaign");
  const quickUtmTerm = document.getElementById("quick-utm-term");
  const quickUtmContent = document.getElementById("quick-utm-content");
  const quickLandingPage = document.getElementById("quick-landing-page");
  const quickPageReferrer = document.getElementById("quick-page-referrer");
  const quickLeadIntent = document.getElementById("quick-lead-intent");
  const quickEstimatorSummary = document.getElementById("quick-estimator-summary");
  const quickSmartHomeSummary = document.getElementById("quick-smart-home-summary");
  const quickConsultationFocus = document.getElementById("quick-consultation-focus");
  const quickFormTitle = document.getElementById("quick-form-title");
  const quickFormDescription = document.getElementById("quick-form-description");

  function fillQuickConsultationAttribution() {
    const searchParams = new URLSearchParams(window.location.search);

    if (quickUtmSource) quickUtmSource.value = searchParams.get("utm_source") || "";
    if (quickUtmMedium) quickUtmMedium.value = searchParams.get("utm_medium") || "";
    if (quickUtmCampaign) quickUtmCampaign.value = searchParams.get("utm_campaign") || "";
    if (quickUtmTerm) quickUtmTerm.value = searchParams.get("utm_term") || "";
    if (quickUtmContent) quickUtmContent.value = searchParams.get("utm_content") || "";
    if (quickLandingPage) quickLandingPage.value = window.location.href;
    if (quickPageReferrer) quickPageReferrer.value = document.referrer || "";
    if (quickLeadIntent) quickLeadIntent.value = searchParams.get("intent") || "";
  }

  function hydrateEstimatorSummary() {
    const searchParams = new URLSearchParams(window.location.search);
    const intent = searchParams.get("intent") || "";

    try {
      const snapshotRaw = window.sessionStorage.getItem("renovationEstimateSnapshot");
      if (!snapshotRaw) return;

      const snapshot = JSON.parse(snapshotRaw);
      const summaryText = [
        `估價摘要：${snapshot.totalRange || "--"}`,
        `每坪抓法：${snapshot.perPingRange || "--"}`,
        `專案條件：${[snapshot.projectTypeLabel, snapshot.qualityLevelLabel, snapshot.houseConditionLabel].filter(Boolean).join(" / ") || "--"}`,
        `工項：${Array.isArray(snapshot.selectedItems) && snapshot.selectedItems.length ? snapshot.selectedItems.join("、") : "尚未勾選"}`,
      ].join(" ｜ ");

      if (quickEstimatorSummary) quickEstimatorSummary.value = summaryText;

      if (intent === "report") {
        if (quickFormTitle) quickFormTitle.textContent = "想索取費用拆解報告，先留下這次估價的聯絡資訊就可以。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會依你這次試算的條件，進一步整理更好判讀的初步拆解方向，方便你理解預算主要落點與下一步建議。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我想索取費用拆解報告，目前估價結果約為 ${snapshot.totalRange || "--"}，想先了解主要預算分配與下一步建議。`;
        }
      }

      if (intent === "studio-visit") {
        if (quickFormTitle) quickFormTitle.textContent = "如果你想直接來汐止工作室體驗，先留下聯絡資訊就可以。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會依你這次估價方向安排後續聯繫，方便你到現場喝杯咖啡、看真實材質與施工細節，並直接體驗智能家居。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我想預約汐止工作室參觀，目前估價結果約為 ${snapshot.totalRange || "--"}，也想現場看看材質、施工細節與智能家居體驗。`;
        }
      }
    } catch (error) {
      console.warn("Unable to hydrate estimator summary on contact page.", error);
    }
  }

  function hydrateSmartHomeQuizSummary() {
    const searchParams = new URLSearchParams(window.location.search);
    const intent = searchParams.get("intent") || "";

    if (intent !== "smart-home-quiz" && intent !== "smart-home-studio-visit") {
      return;
    }

    try {
      const snapshotRaw = window.sessionStorage.getItem("smartHomeQuizSnapshot");
      if (!snapshotRaw) return;

      const snapshot = JSON.parse(snapshotRaw);
      const summaryText = [
        `推薦情境包：${snapshot.packageTitle || "--"}`,
        `方案層級：${snapshot.tierTitle || "--"}`,
        `智能預算方向：${snapshot.budgetRange || "--"}`,
        `弱電 / 控制預留：${snapshot.weakRange || "--"}`,
        `回答重點：${Array.isArray(snapshot.selectedAnswers) && snapshot.selectedAnswers.length ? snapshot.selectedAnswers.join("、") : "--"}`,
      ].join(" ｜ ");

      if (quickSmartHomeSummary) quickSmartHomeSummary.value = summaryText;

      if (intent === "smart-home-quiz") {
        if (quickFormTitle) quickFormTitle.textContent = "想帶著智能家居快篩結果深入聊，先留下聯絡資訊就可以。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會依你這次的生活情境快篩結果，進一步整理適合的智能家居方向、弱電預留與下一步建議。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我剛完成智能家居需求快篩，結果偏向「${snapshot.packageTitle || "--"}」，想進一步了解 ${snapshot.budgetRange || "--"} 的做法與弱電規劃方向。`;
        }
      }

      if (intent === "smart-home-studio-visit") {
        if (quickFormTitle) quickFormTitle.textContent = "如果你想直接來工作室體驗智能家居，先留下聯絡資訊就可以。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會依你這次快篩結果安排後續聯繫，方便你到汐止工作室喝杯咖啡、體驗情境操作並看真實材質與施工細節。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我想預約汐止工作室體驗，我的智能家居快篩結果偏向「${snapshot.packageTitle || "--"}」，也想現場看看弱電、材質與情境控制的實際做法。`;
        }
      }
    } catch (error) {
      console.warn("Unable to hydrate smart home quiz summary on contact page.", error);
    }
  }

  fillQuickConsultationAttribution();
  hydrateEstimatorSummary();
  hydrateSmartHomeQuizSummary();

  if (quickConsultationForm?.dataset.formEnabled !== "true") {
    quickConsultationForm?.addEventListener("submit", function(event) {
      event.preventDefault();
      window.alert("表單收件尚未完成設定，請先透過官方 LINE 聯絡青曦。");
    });
  } else {
    quickConsultationForm?.addEventListener("submit", function() {
      const submittedData = new FormData(quickConsultationForm);

      window.trackLeadEvent?.("quick_consultation_submit", {
        form_name: "quick_consultation_form",
        space_type: submittedData.get("space_type") || "",
        timeline: submittedData.get("timeline") || "",
      });
    });
  }

  document.querySelectorAll("[data-contact-cta]").forEach((link) => {
    link.addEventListener("click", function() {
      window.trackLeadEvent?.("contact_cta_click", {
        cta_type: link.getAttribute("data-contact-cta") || "",
        page_path: window.location.pathname,
      });
    });
  });
</script>
