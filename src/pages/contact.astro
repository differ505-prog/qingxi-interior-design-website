    letter-spacing: 0.04em;
    box-shadow: 0 10px 22px rgba(47, 47, 47, 0.04);
  }

  .quick-form-direct-note {
    margin: 1rem 0 0;
    color: var(--gray-medium);
    line-height: 1.75;
  }

  .quick-form-shell {
    padding: 1.5rem;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(129, 199, 212, 0.14);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .quick-form-success[hidden] {
    display: none;
  }

  .quick-form-success {
    display: grid;
    gap: 1rem;
    align-content: start;
    padding: 0.35rem 0;
  }

  .quick-form-success-badge {
    margin: 0;
    color: #06c755;
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .quick-form-success h3 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(1.7rem, 2.4vw, 2.3rem);
    line-height: 1.45;
    font-weight: 500;
    color: var(--gray-darkest);
  }

  .quick-form-success-description,
  .quick-form-success-note {
    margin: 0;
    color: var(--gray-medium);
    line-height: 1.85;
  }

  .quick-form-line-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 54px;
    padding: 1rem 1.35rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #1f8f47 0%, #06c755 100%);
    color: var(--white);
    text-decoration: none;
    font-weight: 500;
    transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
    box-shadow: 0 18px 30px rgba(6, 199, 85, 0.18);
  }

  .quick-form-line-button:hover {
    transform: translateY(-2px);
    filter: saturate(1.04);
    box-shadow: 0 20px 34px rgba(6, 199, 85, 0.22);
  }

  .quick-form-notice {
    margin-bottom: 1rem;
    padding: 1rem 1.1rem;
    border-radius: 18px;
    background: rgba(250, 248, 241, 0.95);
    border: 1px solid rgba(207, 188, 136, 0.28);
    color: var(--gray-dark);
    line-height: 1.75;
  }

  .quick-form-notice p {
    margin: 0;
  }

  .quick-form {
    display: grid;
    gap: 1.25rem;
  }

  .quick-form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .quick-form-field {
    display: grid;
    gap: 0.5rem;
  }

  .quick-form-field span {
    color: var(--gray-darkest);
    font-size: 0.95rem;
    letter-spacing: 0.03em;
  }

  .quick-form-field input,
  .quick-form-field select,
  .quick-form-field textarea {
    width: 100%;
    padding: 0.95rem 1rem;
    border-radius: 18px;
    border: 1px solid rgba(129, 199, 212, 0.22);
    background: rgba(255, 255, 255, 0.98);
    color: var(--gray-darkest);
    font: inherit;
    line-height: 1.6;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      background-color 0.25s ease;
  }

  .quick-form-field input::placeholder,
  .quick-form-field textarea::placeholder {
    color: rgba(108, 108, 108, 0.72);
  }

  .quick-form-field input:focus,
  .quick-form-field select:focus,
  .quick-form-field textarea:focus {
    outline: none;
    border-color: rgba(129, 199, 212, 0.48);
    box-shadow: 0 0 0 4px rgba(129, 199, 212, 0.12);
    background: rgba(252, 255, 255, 1);
  }

  .quick-form-field textarea {
    resize: vertical;
    min-height: 132px;
  }

  .quick-form-field-full {
    grid-column: 1 / -1;
  }

  .quick-form-actions {
    display: grid;
    gap: 0.9rem;
  }

  .quick-form-submit,
  .quick-form-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    font-size: 1rem;
    text-decoration: none;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease,
      background-color 0.25s ease;
  }

  .quick-form-submit {
    width: 100%;
    border: 1px solid var(--gray-darkest);
    background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--tiffany-dark) 100%);
    color: var(--white);
    cursor: pointer;
    font-weight: 500;
  }

  .quick-form-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 28px rgba(47, 47, 47, 0.18);
  }

  .quick-form-submit:disabled {
    cursor: wait;
    opacity: 0.78;
    transform: none;
    box-shadow: none;
  }

  .quick-form-secondary {
    justify-content: flex-start;
    min-height: auto;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--tiffany-dark);
    letter-spacing: 0.04em;
  }

  .quick-form-secondary:hover {
    transform: none;
    background: transparent;
    box-shadow: none;
    color: var(--gray-darkest);
  }

  .social-panel {
    margin-top: 2.25rem;
    padding: 1.6rem 1.75rem;
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(129, 199, 212, 0.14);
    box-shadow: 0 18px 40px rgba(47, 47, 47, 0.04);
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    align-items: center;
  }

  .social-copy h2 {
    margin: 0;
    font-family: "Noto Serif TC", serif;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    line-height: 1.45;
    font-weight: 500;
    color: var(--gray-darkest);
  }

  .social-section {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.85rem;
  }

  .social-icon-small {
    width: 54px;
    height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--white);
    border: 1px solid rgba(129, 199, 212, 0.18);
    border-radius: 50%;
    color: var(--gray-medium);
    transition:
      transform 0.25s ease,
      color 0.25s ease,
      background-color 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
    box-shadow: 0 10px 22px rgba(47, 47, 47, 0.04);
  }

  .social-icon-small:hover {
    background: var(--tiffany-primary);
    border-color: var(--tiffany-primary);
    color: var(--white);
    transform: translateY(-3px);
    box-shadow: 0 14px 24px rgba(129, 199, 212, 0.24);
  }

  @media (max-width: 900px) {
    .contact-hero,
    .contact-actions,
    .quick-form-panel,
    .social-panel {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: stretch;
    }

    .social-section {
      justify-content: flex-start;
    }
  }

  @media (max-width: 768px) {
    .contact-page {
      padding: 4rem 1.25rem 3.5rem;
    }

    .contact-card,
    .contact-aside,
    .quick-form-panel,
    .quick-form-shell,
    .social-panel {
      padding: 1.5rem;
      border-radius: 22px;
    }

    .quick-form-grid,
    .quick-form-actions {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: stretch;
    }

    .quick-form-submit,
    .quick-form-secondary {
      width: 100%;
    }

    .social-copy h2 {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  // @ts-nocheck
  const quickConsultationForm = document.getElementById("quick-consultation-form");
  const quickFormSubmit = document.getElementById("quick-form-submit");
  const quickFormSuccess = document.getElementById("quick-form-success");
  const quickUtmSource = document.getElementById("quick-utm-source");
  const quickUtmMedium = document.getElementById("quick-utm-medium");
  const quickUtmCampaign = document.getElementById("quick-utm-campaign");
  const quickUtmTerm = document.getElementById("quick-utm-term");
  const quickUtmContent = document.getElementById("quick-utm-content");
  const quickLandingPage = document.getElementById("quick-landing-page");
  const quickPageReferrer = document.getElementById("quick-page-referrer");
  const quickLeadIntent = document.getElementById("quick-lead-intent");
  const quickEstimatorSummary = document.getElementById("quick-estimator-summary");
  const quickSmartHomeSummary = document.getElementById("quick-smart-home-summary");
  const quickConsultationFocus = document.getElementById("quick-consultation-focus");
  const quickFormTitle = document.getElementById("quick-form-title");
  const quickFormDescription = document.getElementById("quick-form-description");
  const requirementReadyLink = document.querySelector("[data-ready-link='requirement-form']");
  const requirementPrefillStorageKey = "requirementFormPrefill";

  function persistRequirementPrefill() {
    if (!quickConsultationForm) return;

    const nameValue = quickConsultationForm.querySelector("input[name='name']")?.value.trim() || "";
    const contactValue = quickConsultationForm.querySelector("input[name='contact_method']")?.value.trim() || "";
    const focusValue = quickConsultationForm.querySelector("textarea[name='consultation_focus']")?.value.trim() || "";

    if (!nameValue || !contactValue || !focusValue) return;

    window.sessionStorage.setItem(
      requirementPrefillStorageKey,
      JSON.stringify({
        name: nameValue,
        contactMethod: contactValue,
        consultationFocus: focusValue,
      }),
    );
  }

  function fillQuickConsultationAttribution() {
    const searchParams = new URLSearchParams(window.location.search);

    if (quickUtmSource) quickUtmSource.value = searchParams.get("utm_source") || "";
    if (quickUtmMedium) quickUtmMedium.value = searchParams.get("utm_medium") || "";
    if (quickUtmCampaign) quickUtmCampaign.value = searchParams.get("utm_campaign") || "";
    if (quickUtmTerm) quickUtmTerm.value = searchParams.get("utm_term") || "";
    if (quickUtmContent) quickUtmContent.value = searchParams.get("utm_content") || "";
    if (quickLandingPage) quickLandingPage.value = window.location.href;
    if (quickPageReferrer) quickPageReferrer.value = document.referrer || "";
    if (quickLeadIntent) quickLeadIntent.value = searchParams.get("intent") || "layout-check";
  }

  function showQuickFormError(message) {
    if (!quickConsultationForm) return;

    let notice = quickConsultationForm.querySelector(".quick-form-notice.is-inline-error");
    if (!notice) {
      notice = document.createElement("div");
      notice.className = "quick-form-notice is-inline-error";
      quickConsultationForm.prepend(notice);
    }

    notice.innerHTML = `<p>${message}</p>`;
  }

  function showQuickFormSuccess() {
    if (!quickConsultationForm || !quickFormSuccess) return;

    quickConsultationForm.hidden = true;
    quickFormSuccess.hidden = false;
  }

  function hydrateEstimatorSummary() {
    const searchParams = new URLSearchParams(window.location.search);
    const intent = searchParams.get("intent") || "";

    try {
      const snapshotRaw = window.sessionStorage.getItem("renovationEstimateSnapshot");
      if (!snapshotRaw) return;

      const snapshot = JSON.parse(snapshotRaw);
      const summaryText = [
        `估價摘要：${snapshot.totalRange || "--"}`,
        `每坪抓法：${snapshot.perPingRange || "--"}`,
        `專案條件：${[snapshot.projectTypeLabel, snapshot.qualityLevelLabel, snapshot.houseConditionLabel].filter(Boolean).join(" / ") || "--"}`,
        `工項：${Array.isArray(snapshot.selectedItems) && snapshot.selectedItems.length ? snapshot.selectedItems.join("、") : "尚未勾選"}`,
      ].join(" ｜ ");

      if (quickEstimatorSummary) quickEstimatorSummary.value = summaryText;

      if (intent === "budget-review") {
        if (quickFormTitle) quickFormTitle.textContent = "想帶著估價結果，再做一次免費初步健檢？";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會一併參考你這次的估價摘要、房屋條件與目前卡住的空間痛點，幫你先抓下一步判斷方向。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我想帶著目前約 ${snapshot.totalRange || "--"} 的估價結果，先做一次初步格局與裝修方向健檢。`;
        }
      }

      if (intent === "report") {
        if (quickFormTitle) quickFormTitle.textContent = "想索取費用拆解報告，先留下這次估價的聯絡資訊就可以。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會依你這次試算條件，整理更好判讀的初步拆解方向，方便你理解預算落點與下一步建議。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我想索取費用拆解報告，目前估價結果約為 ${snapshot.totalRange || "--"}，想先了解主要預算分配與下一步建議。`;
        }
      } else if (intent === "studio-visit") {
        if (quickFormTitle) quickFormTitle.textContent = "如果你想直接來汐止工作室體驗，先留下聯絡資訊就可以。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會依你這次估價方向安排後續聯繫，方便你到現場看材質、施工細節，並直接體驗智能家居。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我想預約汐止工作室參觀，目前估價結果約為 ${snapshot.totalRange || "--"}，也想現場看看材質、施工細節與智能家居體驗。`;
        }
      }
    } catch (error) {
      console.warn("Unable to hydrate estimator summary on contact page.", error);
    }
  }

  function hydrateSmartHomeQuizSummary() {
    const searchParams = new URLSearchParams(window.location.search);
    const intent = searchParams.get("intent") || "";

    if (intent !== "smart-home-quiz" && intent !== "smart-home-studio-visit") {
      return;
    }

    try {
      const snapshotRaw = window.sessionStorage.getItem("smartHomeQuizSnapshot");
      if (!snapshotRaw) return;

      const snapshot = JSON.parse(snapshotRaw);
      const summaryText = [
        `推薦情境包：${snapshot.packageTitle || "--"}`,
        `方案層級：${snapshot.tierTitle || "--"}`,
        `智能預算方向：${snapshot.budgetRange || "--"}`,
        `弱電 / 控制預留：${snapshot.weakRange || "--"}`,
        `回答重點：${Array.isArray(snapshot.selectedAnswers) && snapshot.selectedAnswers.length ? snapshot.selectedAnswers.join("、") : "--"}`,
      ].join(" ｜ ");

      if (quickSmartHomeSummary) quickSmartHomeSummary.value = summaryText;

      if (intent === "smart-home-quiz") {
        if (quickFormTitle) quickFormTitle.textContent = "想帶著智能家居快篩結果深入聊，先留下聯絡資訊就可以。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會依你這次快篩結果，整理適合的智能家居方向、弱電預留與下一步建議。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我剛完成智能家居需求快篩，結果偏向「${snapshot.packageTitle || "--"}」，想進一步了解 ${snapshot.budgetRange || "--"} 的做法與弱電規劃方向。`;
        }
      }

      if (intent === "smart-home-studio-visit") {
        if (quickFormTitle) quickFormTitle.textContent = "如果你想直接來工作室體驗智能家居，先留下聯絡資訊就可以。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會依你這次快篩結果安排後續聯繫，方便你到汐止工作室體驗情境操作，並看真實材質與施工細節。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我想預約汐止工作室體驗，我的智能家居快篩結果偏向「${snapshot.packageTitle || "--"}」，也想現場看看弱電、材質與情境控制的實際做法。`;
        }
      }
    } catch (error) {
      console.warn("Unable to hydrate smart home quiz summary on contact page.", error);
    }
  }

  fillQuickConsultationAttribution();
  hydrateEstimatorSummary();
  hydrateSmartHomeQuizSummary();
  requirementReadyLink?.addEventListener("click", function() {
    persistRequirementPrefill();
  });

  if (quickConsultationForm?.dataset.formEnabled !== "true") {
    quickConsultationForm?.addEventListener("submit", function(event) {
      event.preventDefault();
      window.alert("表單收件尚未完成設定，請先透過官方 LINE 聯絡青曦。");
    });
  } else {
    quickConsultationForm?.addEventListener("submit", async function(event) {
      event.preventDefault();

      const submittedData = new FormData(quickConsultationForm);
      persistRequirementPrefill();

      if (quickFormSubmit instanceof HTMLButtonElement) {
        quickFormSubmit.disabled = true;
        quickFormSubmit.textContent = "送出中...";
      }

      try {
        await new Promise((resolve) => window.setTimeout(resolve, 1000));

        const response = await fetch(quickConsultationForm.action, {
          method: "POST",
          body: submittedData,
          headers: {
            Accept: "application/json",
          },
        });

        if (!response.ok) {
          throw new Error(`Submission failed with status ${response.status}`);
        }

        window.trackLeadEvent?.("layout_check_submit", {
          form_name: "layout_check_form",
          property_region: submittedData.get("property_region") || "",
          house_status: submittedData.get("house_status") || "",
          lead_intent: submittedData.get("lead_intent") || "layout-check",
        });

        showQuickFormSuccess();
      } catch (error) {
        console.warn("Unable to submit layout check form.", error);
        showQuickFormError("送出時暫時沒有成功，請稍後再試一次；若趕時間，也可以直接加入官方 LINE 傳送平面圖。");
      } finally {
        if (quickFormSubmit instanceof HTMLButtonElement) {
          quickFormSubmit.disabled = false;
          quickFormSubmit.textContent = "送出需求，取得免費健檢";
        }
      }
    });
  }

  document.querySelectorAll("[data-contact-cta]").forEach((link) => {
    link.addEventListener("click", function() {
      window.trackLeadEvent?.("contact_cta_click", {
        cta_type: link.getAttribute("data-contact-cta") || "",
        page_path: window.location.pathname,
      });
    });
  });
</script>
