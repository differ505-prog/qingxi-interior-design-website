</style>

<script>
  // @ts-nocheck
  const contactReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const contactRevealTargets = Array.from(document.querySelectorAll(".reveal-up"));
  const quickConsultationForm = document.getElementById("quick-consultation-form");
  const quickUtmSource = document.getElementById("quick-utm-source");
  const quickUtmMedium = document.getElementById("quick-utm-medium");
  const quickUtmCampaign = document.getElementById("quick-utm-campaign");
  const quickUtmTerm = document.getElementById("quick-utm-term");
  const quickUtmContent = document.getElementById("quick-utm-content");
  const quickLandingPage = document.getElementById("quick-landing-page");
  const quickPageReferrer = document.getElementById("quick-page-referrer");
  const quickLeadIntent = document.getElementById("quick-lead-intent");
  const quickEstimatorSummary = document.getElementById("quick-estimator-summary");
  const quickSmartHomeSummary = document.getElementById("quick-smart-home-summary");
  const quickConsultationFocus = document.getElementById("quick-consultation-focus");
  const quickFormTitle = document.getElementById("quick-form-title");
  const quickFormDescription = document.getElementById("quick-form-description");
  const requirementReadyLink = document.querySelector("[data-ready-link='requirement-form']");
  const requirementPrefillStorageKey = "requirementFormPrefill";

  if (contactReducedMotion.matches) {
    contactRevealTargets.forEach((node) => node.classList.add("is-visible"));
  } else if (contactRevealTargets.length) {
    const contactObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const element = entry.target;
          const delay = Number(element.getAttribute("data-reveal-delay") || "0");
          window.setTimeout(() => {
            element.classList.add("is-visible");
          }, delay);
          contactObserver.unobserve(element);
        });
      },
      {
        threshold: 0.15,
        rootMargin: "0px 0px -8% 0px",
      },
    );

    contactRevealTargets.forEach((node) => contactObserver.observe(node));
  }

  function toggleRequirementReadyLink() {
    if (!requirementReadyLink || !quickConsultationForm) return;

    const nameValue = quickConsultationForm.querySelector("input[name='name']")?.value.trim() || "";
    const contactValue = quickConsultationForm.querySelector("input[name='contact_method']")?.value.trim() || "";
    const focusValue = quickConsultationForm.querySelector("textarea[name='consultation_focus']")?.value.trim() || "";
    const isReady = Boolean(nameValue && contactValue && focusValue);

    requirementReadyLink.classList.toggle("is-disabled", !isReady);
    requirementReadyLink.setAttribute("aria-disabled", String(!isReady));
    requirementReadyLink.textContent = isReady
      ? "進一步填完整需求表"
      : "先填 3 項基本資訊，再填完整需求表";
  }

  function persistRequirementPrefill() {
    if (!quickConsultationForm) return;

    const nameValue = quickConsultationForm.querySelector("input[name='name']")?.value.trim() || "";
    const contactValue = quickConsultationForm.querySelector("input[name='contact_method']")?.value.trim() || "";
    const focusValue = quickConsultationForm.querySelector("textarea[name='consultation_focus']")?.value.trim() || "";

    if (!nameValue || !contactValue || !focusValue) return;

    window.sessionStorage.setItem(
      requirementPrefillStorageKey,
      JSON.stringify({
        name: nameValue,
        contactMethod: contactValue,
        consultationFocus: focusValue,
      }),
    );
  }

  function fillQuickConsultationAttribution() {
    const searchParams = new URLSearchParams(window.location.search);

    if (quickUtmSource) quickUtmSource.value = searchParams.get("utm_source") || "";
    if (quickUtmMedium) quickUtmMedium.value = searchParams.get("utm_medium") || "";
    if (quickUtmCampaign) quickUtmCampaign.value = searchParams.get("utm_campaign") || "";
    if (quickUtmTerm) quickUtmTerm.value = searchParams.get("utm_term") || "";
    if (quickUtmContent) quickUtmContent.value = searchParams.get("utm_content") || "";
    if (quickLandingPage) quickLandingPage.value = window.location.href;
    if (quickPageReferrer) quickPageReferrer.value = document.referrer || "";
    if (quickLeadIntent) quickLeadIntent.value = searchParams.get("intent") || "";
  }

  function hydrateEstimatorSummary() {
    const searchParams = new URLSearchParams(window.location.search);
    const intent = searchParams.get("intent") || "";

    try {
      const snapshotRaw = window.sessionStorage.getItem("renovationEstimateSnapshot");
      if (!snapshotRaw) return;

      const snapshot = JSON.parse(snapshotRaw);
      const summaryText = [
        `估價摘要：${snapshot.totalRange || "--"}`,
        `每坪抓法：${snapshot.perPingRange || "--"}`,
        `專案條件：${[snapshot.projectTypeLabel, snapshot.qualityLevelLabel, snapshot.houseConditionLabel].filter(Boolean).join(" / ") || "--"}`,
        `工項：${Array.isArray(snapshot.selectedItems) && snapshot.selectedItems.length ? snapshot.selectedItems.join("、") : "尚未勾選"}`,
      ].join(" ｜ ");

      if (quickEstimatorSummary) quickEstimatorSummary.value = summaryText;

      if (intent === "report") {
        if (quickFormTitle) quickFormTitle.textContent = "想索取拆解報告，先留聯絡資訊。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會接著整理這次試算的拆解方向。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我想索取費用拆解報告，目前估價結果約為 ${snapshot.totalRange || "--"}，想先了解主要預算分配與下一步建議。`;
        }
      }

      if (intent === "studio-visit") {
        if (quickFormTitle) quickFormTitle.textContent = "想來汐止工作室體驗，先留聯絡資訊。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會安排後續聯繫與現場體驗。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我想預約汐止工作室參觀，目前估價結果約為 ${snapshot.totalRange || "--"}，也想現場看看材質、施工細節與智能家居體驗。`;
        }
      }
    } catch (error) {
      console.warn("Unable to hydrate estimator summary on contact page.", error);
    }
  }

  function hydrateSmartHomeQuizSummary() {
    const searchParams = new URLSearchParams(window.location.search);
    const intent = searchParams.get("intent") || "";

    if (intent !== "smart-home-quiz" && intent !== "smart-home-studio-visit") {
      return;
    }

    try {
      const snapshotRaw = window.sessionStorage.getItem("smartHomeQuizSnapshot");
      if (!snapshotRaw) return;

      const snapshot = JSON.parse(snapshotRaw);
      const summaryText = [
        `推薦情境包：${snapshot.packageTitle || "--"}`,
        `方案層級：${snapshot.tierTitle || "--"}`,
        `智能預算方向：${snapshot.budgetRange || "--"}`,
        `弱電 / 控制預留：${snapshot.weakRange || "--"}`,
        `回答重點：${Array.isArray(snapshot.selectedAnswers) && snapshot.selectedAnswers.length ? snapshot.selectedAnswers.join("、") : "--"}`,
      ].join(" ｜ ");

      if (quickSmartHomeSummary) quickSmartHomeSummary.value = summaryText;

      if (intent === "smart-home-quiz") {
        if (quickFormTitle) quickFormTitle.textContent = "想帶著快篩結果深入聊，先留聯絡資訊。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會接著整理適合的智能家居方向。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我剛完成智能家居需求快篩，結果偏向「${snapshot.packageTitle || "--"}」，想進一步了解 ${snapshot.budgetRange || "--"} 的做法與弱電規劃方向。`;
        }
      }

      if (intent === "smart-home-studio-visit") {
        if (quickFormTitle) quickFormTitle.textContent = "想來工作室體驗智能家居，先留聯絡資訊。";
        if (quickFormDescription) {
          quickFormDescription.textContent =
            "青曦會安排後續聯繫與現場體驗。";
        }
        if (quickConsultationFocus && !quickConsultationFocus.value) {
          quickConsultationFocus.value =
            `我想預約汐止工作室體驗，我的智能家居快篩結果偏向「${snapshot.packageTitle || "--"}」，也想現場看看弱電、材質與情境控制的實際做法。`;
        }
      }
    } catch (error) {
      console.warn("Unable to hydrate smart home quiz summary on contact page.", error);
    }
  }

  fillQuickConsultationAttribution();
  hydrateEstimatorSummary();
  hydrateSmartHomeQuizSummary();
  toggleRequirementReadyLink();

  quickConsultationForm?.addEventListener("input", toggleRequirementReadyLink);
  requirementReadyLink?.addEventListener("click", function(event) {
    if (requirementReadyLink.getAttribute("aria-disabled") === "true") {
      event.preventDefault();
      return;
    }

    persistRequirementPrefill();
  });

  if (quickConsultationForm?.dataset.formEnabled !== "true") {
    quickConsultationForm?.addEventListener("submit", function(event) {
      event.preventDefault();
      window.alert("表單收件尚未完成設定，請先透過官方 LINE 聯絡青曦。");
    });
  } else {
    quickConsultationForm?.addEventListener("submit", function() {
      const submittedData = new FormData(quickConsultationForm);

      window.trackLeadEvent?.("quick_consultation_submit", {
        form_name: "quick_consultation_form",
        space_type: submittedData.get("space_type") || "",
        timeline: submittedData.get("timeline") || "",
      });
    });
  }

  document.querySelectorAll("[data-contact-cta]").forEach((link) => {
    link.addEventListener("click", function() {
      window.trackLeadEvent?.("contact_cta_click", {
        cta_type: link.getAttribute("data-contact-cta") || "",
        page_path: window.location.pathname,
      });
    });
  });
</script>
