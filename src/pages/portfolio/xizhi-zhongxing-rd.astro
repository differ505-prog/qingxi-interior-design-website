---
import BaseLayout from '../../layouts/BaseLayout.astro';

const project = {
  title: '汐止中興路住宅',
  label: 'FEATURED RESIDENCE',
  subtitle: '以沉穩灰階與俐落線條，整理出耐住也耐看的日常空間。',
  story:
    '這個案子以低彩度材質與乾淨收邊為主軸，讓客廳、餐廚與主臥維持一致的安定感。青曦把照明、櫃體比例與動線一併納入，讓空間在入住之後仍保有舒服節奏。',
  facts: [
    { label: '空間類型', value: '住宅空間設計' },
    { label: '風格關鍵', value: '灰階、線性照明、俐落收納' },
    { label: '規劃重點', value: '公私領域節奏一致' },
  ],
  highlights: [
    {
      title: '客廳',
      text: '用大面白牆與黑色量體收斂視覺焦點，讓日常停留更安定。',
    },
    {
      title: '餐廚',
      text: '櫃體、吧台與燈光同時整合，兼顧備餐效率與整體感。',
    },
    {
      title: '主臥',
      text: '維持低干擾配色與間接照明，讓休息空間回到最舒適的狀態。',
    },
  ],
  images: [
    {
      src: '/images/portfolio/xizhi-1.jpg',
      alt: '汐止中興路住宅客廳',
      layout: 'is-wide',
    },
    {
      src: '/images/portfolio/xizhi-2.jpg',
      alt: '汐止中興路住宅餐廚',
      layout: 'is-standard',
    },
    {
      src: '/images/portfolio/xizhi-3.jpg',
      alt: '汐止中興路住宅主臥',
      layout: 'is-tall',
    },
  ],
};
---

<BaseLayout title={`${project.title} - 青曦空間設計`}>
  <div class="project-page">
    <section class="project-hero">
      <div class="project-hero-shell">
        <div class="project-copy">
          <p class="section-subtitle">{project.label}</p>
          <h1>{project.title}</h1>
          <p class="project-subtitle">{project.subtitle}</p>
          <p class="project-story">{project.story}</p>
        </div>

        <aside class="project-facts">
          <p class="facts-label">CASE NOTES</p>
          <ul>
            {project.facts.map((fact) => (
              <li>
                <span>{fact.label}</span>
                <strong>{fact.value}</strong>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section class="project-highlight-section">
      <div class="project-highlight-card">
        <div class="highlight-copy">
          <p class="section-subtitle">DESIGN DIRECTION</p>
          <h2>把材質、照明與收納節奏，整理成更安定的居住感</h2>
          <p>
            這個案例不是用大量裝飾來堆疊氛圍，而是回到比例、光線與動線的平衡。
            讓空間在白天俐落，夜晚也能保有沉靜層次。
          </p>
        </div>
        <figure class="project-feature-image gallery-item" data-index="0">
          <img
            src={project.images[0].src}
            alt={project.images[0].alt}
            loading="eager"
          />
        </figure>
      </div>
    </section>

    <section class="highlights-section">
      <div class="highlights-grid">
        {project.highlights.map((item) => (
          <article class="highlight-item">
            <p class="section-subtitle">SPACE HIGHLIGHT</p>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="gallery-section">
      <div class="gallery-header">
        <p class="section-subtitle">PROJECT GALLERY</p>
        <h2>以更像案例提案的方式，完整呈現空間節奏</h2>
      </div>

      <div class="gallery-grid editorial-grid">
        {project.images.map((img, i) => (
          <figure class={`gallery-item ${img.layout}`} data-index={i}>
            <div class="gallery-thumb">
              <img src={img.src} alt={img.alt} loading="lazy" />
              <div class="thumb-overlay">
                <span>查看大圖</span>
              </div>
            </div>
          </figure>
        ))}
      </div>
    </section>

    <div class="lightbox" id="lightbox">
      <button class="lightbox-close" aria-label="關閉">&times;</button>
      <button class="lightbox-nav lightbox-prev" aria-label="上一張">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="lightbox-nav lightbox-next" aria-label="下一張">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
      <div class="lightbox-content">
        <img id="lightbox-img" src="" alt="" />
      </div>
      <div class="lightbox-counter" id="lightbox-counter"></div>
    </div>

    <section class="contact-section">
      <div class="contact-inner">
        <p class="section-subtitle contact-subtitle">NEXT STEP</p>
        <h2 class="contact-title">喜歡這種安定俐落的空間節奏？</h2>
        <p class="contact-desc">歡迎和青曦聊聊你的住宅需求，從設計到工程，我們會幫你把節奏與預算一起整理好。</p>
        <div class="contact-cards">
          <a href="https://lin.ee/U1HCeW4" target="_blank" class="contact-card">
            <div class="contact-icon line-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596a.624.624 0 01-.199.031c-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595a.62.62 0 01.194-.033c.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"></path>
              </svg>
            </div>
            <span>LINE 諮詢</span>
          </a>
          <a href="mailto:qingxi.ds@outlook.com" class="contact-card">
            <div class="contact-icon email-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path>
              </svg>
            </div>
            <span>Email 聯繫</span>
          </a>
          <a href="/contact" class="contact-card">
            <div class="contact-icon form-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
              </svg>
            </div>
            <span>預約諮詢</span>
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .project-page {
    padding-top: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(247, 247, 247, 1) 100%);
  }

  .section-subtitle {
    margin: 0 0 0.8rem;
    color: var(--tiffany-dark);
    font-size: 0.8rem;
    letter-spacing: 0.26em;
    font-weight: 600;
  }

  .project-hero {
    padding: 7rem 2rem 3rem;
  }

  .project-hero-shell,
  .project-highlight-card,
  .highlights-grid,
  .gallery-section,
  .contact-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .project-hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 360px);
    gap: 2rem;
    align-items: end;
  }

  .project-copy h1 {
    margin: 0;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(2.6rem, 5vw, 4.6rem);
    line-height: 1.18;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--gray-darkest);
  }

  .project-subtitle {
    margin: 1.25rem 0 0;
    font-size: 1.18rem;
    line-height: 1.8;
    color: var(--gray-dark);
    max-width: 42rem;
  }

  .project-story {
    margin: 1.25rem 0 0;
    font-size: 1rem;
    line-height: 1.9;
    color: var(--gray-medium);
    max-width: 40rem;
  }

  .project-facts {
    padding: 1.5rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(129, 199, 212, 0.16);
    box-shadow: 0 22px 45px rgba(47, 47, 47, 0.08);
    backdrop-filter: blur(16px);
  }

  .facts-label {
    margin: 0 0 1rem;
    font-size: 0.82rem;
    letter-spacing: 0.24em;
    color: var(--tiffany-dark);
  }

  .project-facts ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-facts li {
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(47, 47, 47, 0.08);
  }

  .project-facts li:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .project-facts span,
  .project-facts strong {
    display: block;
  }

  .project-facts span {
    margin-bottom: 0.35rem;
    color: var(--gray-medium);
    font-size: 0.88rem;
    letter-spacing: 0.08em;
  }

  .project-facts strong {
    color: var(--gray-darkest);
    font-size: 1rem;
    line-height: 1.7;
    font-weight: 600;
  }

  .project-highlight-section {
    padding: 1rem 2rem 3rem;
  }

  .project-highlight-card {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 2rem;
    align-items: center;
    padding: 2rem;
    border-radius: 32px;
    background: linear-gradient(135deg, rgba(19, 19, 19, 1) 0%, rgba(38, 38, 38, 1) 100%);
    color: var(--white);
    box-shadow: 0 28px 70px rgba(17, 17, 17, 0.18);
  }

  .highlight-copy h2 {
    margin: 0;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.35;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .highlight-copy p:last-child {
    margin: 1rem 0 0;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.9;
  }

  .project-feature-image,
  .gallery-item {
    margin: 0;
    cursor: pointer;
  }

  .project-feature-image img,
  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-feature-image {
    overflow: hidden;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
  }

  .project-feature-image img {
    aspect-ratio: 4 / 3;
    display: block;
  }

  .project-feature-image:hover img,
  .gallery-item:hover img {
    transform: scale(1.04);
  }

  .highlights-section {
    padding: 0 2rem 3rem;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .highlight-item {
    padding: 1.5rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(129, 199, 212, 0.12);
    box-shadow: 0 18px 40px rgba(47, 47, 47, 0.06);
  }

  .highlight-item h3 {
    margin: 0;
    font-size: 1.3rem;
    color: var(--gray-darkest);
  }

  .highlight-item p:last-child {
    margin: 0.85rem 0 0;
    color: var(--gray-medium);
    line-height: 1.8;
  }

  .gallery-section {
    padding: 0 2rem 5rem;
  }

  .gallery-header {
    max-width: 760px;
    margin-bottom: 2rem;
  }

  .gallery-header h2 {
    margin: 0;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.4;
    font-weight: 500;
    color: var(--gray-darkest);
  }

  .editorial-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .gallery-item.is-wide {
    grid-column: span 7;
  }

  .gallery-item.is-standard {
    grid-column: span 5;
  }

  .gallery-item.is-tall {
    grid-column: span 12;
  }

  .gallery-thumb {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    background: var(--gray-bg);
    min-height: 340px;
  }

  .gallery-item.is-wide .gallery-thumb {
    aspect-ratio: 16 / 11;
  }

  .gallery-item.is-standard .gallery-thumb {
    aspect-ratio: 4 / 5;
  }

  .gallery-item.is-tall .gallery-thumb {
    aspect-ratio: 16 / 9;
  }

  .thumb-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: end;
    justify-content: flex-start;
    padding: 1.2rem;
    background: linear-gradient(180deg, rgba(10, 10, 10, 0.02) 0%, rgba(10, 10, 10, 0.42) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .thumb-overlay span {
    padding: 0.55rem 0.95rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.16);
    color: var(--white);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    backdrop-filter: blur(10px);
  }

  .gallery-item:hover .thumb-overlay {
    opacity: 1;
  }

  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox-content {
    max-width: 90vw;
    max-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-content img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 10px 60px rgba(0, 0, 0, 0.5);
    animation: lightboxIn 0.3s ease;
  }

  @keyframes lightboxIn {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
  }

  .lightbox-close,
  .lightbox-nav {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .lightbox-close {
    top: 1.5rem;
    right: 1.5rem;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: none;
    background: none;
    font-size: 2.5rem;
    cursor: pointer;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: rotate(90deg);
  }

  .lightbox-nav {
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.1);
    cursor: pointer;
  }

  .lightbox-nav:hover {
    background: rgba(129, 199, 212, 0.4);
    border-color: var(--tiffany-primary);
  }

  .lightbox-prev { left: 1.5rem; }
  .lightbox-next { right: 1.5rem; }

  .lightbox-counter {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    letter-spacing: 0.1em;
  }

  .contact-section {
    background: var(--gray-darkest);
    color: white;
    padding: 4.5rem 2rem;
  }

  .contact-inner {
    text-align: center;
  }

  .contact-subtitle {
    color: var(--tiffany-light);
  }

  .contact-title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    font-family: 'Noto Serif TC', serif;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .contact-desc {
    max-width: 680px;
    margin: 1rem auto 0;
    color: var(--gray-light);
    line-height: 1.85;
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    margin-top: 2.25rem;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.6rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    text-decoration: none;
    color: white;
    transition: all 0.3s ease;
  }

  .contact-card:hover {
    background: rgba(129, 199, 212, 0.15);
    border-color: var(--tiffany-primary);
    transform: translateY(-4px);
  }

  .contact-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: all 0.3s;
  }

  .line-icon { color: #06c755; }
  .email-icon { color: var(--tiffany-primary); }
  .form-icon { color: var(--tiffany-light); }

  .contact-card:hover .contact-icon {
    transform: scale(1.12);
  }

  .contact-card span {
    font-size: 0.92rem;
    letter-spacing: 0.05em;
  }

  @media (max-width: 960px) {
    .project-hero-shell,
    .project-highlight-card,
    .highlights-grid {
      grid-template-columns: 1fr;
    }

    .editorial-grid {
      grid-template-columns: 1fr;
    }

    .gallery-item.is-wide,
    .gallery-item.is-standard,
    .gallery-item.is-tall {
      grid-column: span 1;
    }

    .gallery-item.is-standard .gallery-thumb,
    .gallery-item.is-wide .gallery-thumb,
    .gallery-item.is-tall .gallery-thumb {
      aspect-ratio: 4 / 3;
    }
  }

  @media (max-width: 768px) {
    .project-hero,
    .project-highlight-section,
    .highlights-section,
    .gallery-section,
    .contact-section {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .project-hero {
      padding-top: 6rem;
    }

    .project-highlight-card {
      padding: 1.5rem;
      border-radius: 24px;
    }

    .gallery-thumb {
      min-height: 0;
      border-radius: 18px;
    }

    .contact-cards {
      grid-template-columns: 1fr;
    }

    .lightbox-nav {
      width: 42px;
      height: 42px;
    }

    .lightbox-prev { left: 0.75rem; }
    .lightbox-next { right: 0.75rem; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('.gallery-item');
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxCounter = document.getElementById('lightbox-counter');
    const closeBtn = document.querySelector('.lightbox-close');
    const prevBtn = document.querySelector('.lightbox-prev');
    const nextBtn = document.querySelector('.lightbox-next');

    const images = Array.from(items)
      .map((item) => item.querySelector('img'))
      .filter(Boolean)
      .map((img) => ({ src: img.src, alt: img.alt }));
    let currentIdx = 0;

    function openLightbox(idx) {
      currentIdx = idx;
      lightboxImg.src = images[idx].src;
      lightboxImg.alt = images[idx].alt;
      lightboxCounter.textContent = `${idx + 1} / ${images.length}`;
      lightbox.classList.add('active');
      document.body.style.overflow = 'hidden';
      prevBtn.style.display = images.length > 1 ? 'flex' : 'none';
      nextBtn.style.display = images.length > 1 ? 'flex' : 'none';
    }

    function closeLightbox() {
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
    }

    items.forEach((item, i) => {
      item.addEventListener('click', () => openLightbox(i));
    });

    closeBtn?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    prevBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      currentIdx = (currentIdx - 1 + images.length) % images.length;
      openLightbox(currentIdx);
    });

    nextBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      currentIdx = (currentIdx + 1) % images.length;
      openLightbox(currentIdx);
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox?.classList.contains('active')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') prevBtn?.click();
      if (e.key === 'ArrowRight') nextBtn?.click();
    });
  });
</script>
