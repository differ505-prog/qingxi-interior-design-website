    box-shadow: 0 10px 60px rgba(0, 0, 0, 0.5);
    animation: lightboxIn 0.3s ease;
  }

  @keyframes lightboxIn {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
  }

  .lightbox-close,
  .lightbox-nav {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.3s ease;
