---
import BaseLayout from '../../layouts/BaseLayout.astro';

const project = {
  title: '住宅空間精選',
  label: 'CURATED RESIDENCE',
  subtitle: '用灰階、燈光與收納整理出舒服耐看的住宅空間。',
  story:
    '從客廳、餐廚到臥室，都把收納、照明與日常使用一起整理好，讓入住後更順手。',
  facts: [
    { label: '空間類型', value: '住宅空間設計' },
    { label: '風格關鍵', value: '灰階、線性照明、俐落收納' },
    { label: '規劃重點', value: '公共區與私領域都更好使用' },
  ],
  images: [
    {
      src: '/images/portfolio/xizhi-1.jpg',
      alt: '住宅空間客廳畫面',
      layout: 'is-wide',
    },
    {
      src: '/images/portfolio/xizhi-2.jpg',
      alt: '住宅空間餐廚畫面',
      layout: 'is-standard',
    },
    {
      src: '/images/portfolio/xizhi-3.jpg',
      alt: '住宅空間主臥畫面',
      layout: 'is-immersive',
    },
    {
      src: '/images/portfolio/xizhi-zhongxing-rd/living-room-after.jpg',
      alt: '住宅空間客廳改造後畫面',
      layout: 'is-standard',
    },
    {
      src: '/images/portfolio/xizhi-zhongxing-rd/bathroom-portrait.jpg',
      alt: '住宅空間浴室直式畫面',
      layout: 'is-portrait',
    },
  ],
};
const projectDescription =
  "青曦住宅空間精選案例，整理客廳、餐廚、主臥與浴室的實際照片，並呈現設計圖面與工程前後對比。";
const projectStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    name: project.title,
    description: projectDescription,
    image: project.images.map((image) => image.src),
    about: ["住宅空間設計", "室內設計", "工程前後對比", "設計圖面"],
  },
];

const primaryGalleryImages = project.images.slice(0, 2);
const secondaryGalleryImages = project.images.slice(2);
const drawingBoards = [
  {
    label: 'LAYOUT PLAN',
    title: '平面佈置圖',
    description: '整理空間配置、動線與家具位置，讓日常使用更順手。',
    image: '/images/portfolio/xizhi-zhongxing-rd/layout-plan.jpg',
    alt: '住宅空間平面佈置圖',
  },
  {
    label: 'CEILING & LIGHTING',
    title: '天花與照明圖',
    description: '整理天花、燈具與空調位置，讓施工與後續使用都更清楚。',
    image: '/images/portfolio/xizhi-zhongxing-rd/ceiling-lighting-plan.jpg',
    alt: '住宅空間綜合天花與照明配置圖',
  },
  {
    label: 'CABINET DETAIL',
    title: '櫃體與立面圖',
    description: '以客廳電視牆為例，整理木作做法與尺寸，讓現場施工更容易對齊。',
    image: '/images/portfolio/xizhi-zhongxing-rd/tv-wall-elevation-reinforcement.jpg',
    alt: '客廳電視牆補強木作立面圖',
  },
];
const renovationComparisons = [
  {
    label: 'PUBLIC AREA',
    title: '客廳改造前後',
    summary: '從原始現場到完工後的樣子，可以直接看見採光、動線與收納的差異。',
    beforeImage: '/images/portfolio/xizhi-zhongxing-rd/living-room-before.jpg',
    beforeAlt: '客廳改造前現場照片',
    beforeTitle: '改造前',
    beforeCaption: '拆除與管線整理階段',
    afterImage: '/images/portfolio/xizhi-zhongxing-rd/living-room-after.jpg',
    afterAlt: '客廳改造後完工照片',
    afterTitle: '完成後',
    afterCaption: '',
  },
  {
    label: 'PRIVATE AREA',
    title: '浴室改造前後',
    summary: '透過改造前後的對照，可以看見材質更新與使用便利性的差異。',
    beforeImage: '/images/portfolio/xizhi-zhongxing-rd/bathroom-before.jpg',
    beforeAlt: '浴室改造前拆除後現場照片',
    beforeTitle: '改造前',
    beforeCaption: '',
    afterImage: '/images/portfolio/xizhi-zhongxing-rd/bathroom-portrait.jpg',
    afterAlt: '浴室改造後完工照片',
    afterTitle: '完成後',
    afterCaption: '',
  },
];
---

<BaseLayout
  title={`${project.title} - 青曦空間設計`}
  description={projectDescription}
  ogImage={project.images[0].src}
  pageType="collection"
  structuredData={projectStructuredData}
>
  <div class="project-page">
    <section class="project-hero">
      <div class="project-hero-shell">
        <div class="project-copy">
          <p class="section-subtitle">{project.label}</p>
          <h1>{project.title}</h1>
          <p class="project-subtitle">{project.subtitle}</p>
          <p class="project-story">{project.story}</p>
        </div>

        <aside class="project-facts">
          <p class="facts-label">DESIGN NOTES</p>
          <ul>
            {project.facts.map((fact) => (
              <li>
                <span>{fact.label}</span>
                <strong>{fact.value}</strong>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section class="project-highlight-section">
      <div class="project-highlight-card">
        <div class="highlight-copy">
          <p class="section-subtitle">DESIGN FRAME</p>
          <h2>把收納、燈光和日常使用整理得更清楚</h2>
          <p>
            從客廳到臥室，都把好看和好住一起考慮，讓生活更順手。
          </p>
        </div>
        <figure class="project-feature-image gallery-item" data-index="0">
          <img
            src={project.images[0].src}
            alt={project.images[0].alt}
            loading="eager"
          />
        </figure>
      </div>
    </section>

    <section class="gallery-section">
      <div class="gallery-header">
        <p class="section-subtitle">SPACE GALLERY</p>
        <h2>看看這個家完成後的樣子</h2>
      </div>

      <div class="gallery-stack">
        <div class="gallery-row gallery-row-primary">
          {primaryGalleryImages.map((img, i) => (
            <figure class={`gallery-item ${img.layout}`} data-index={i}>
              <div class="gallery-thumb">
                <img src={img.src} alt={img.alt} loading="lazy" />
              </div>
            </figure>
          ))}
        </div>

        <div class="gallery-row gallery-row-secondary">
          {secondaryGalleryImages.map((img, i) => (
            <figure class={`gallery-item ${img.layout}`} data-index={i + primaryGalleryImages.length}>
              <div class="gallery-thumb">
                <img src={img.src} alt={img.alt} loading="lazy" />
              </div>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="comparison-section">
      <div class="comparison-header">
        <p class="section-subtitle">BEFORE & AFTER</p>
        <h2>工程前後對比</h2>
        <p>用前後照片對照，更容易看見空間整理完成後的差異。</p>
      </div>

      <div class="comparison-stack">
        {renovationComparisons.map((item) => (
          <article class="comparison-card">
            <div class="comparison-copy">
              <p class="comparison-label">{item.label}</p>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </div>

            <div class="comparison-grid">
              <figure class="comparison-media">
                <img src={item.beforeImage} alt={item.beforeAlt} loading="lazy" />
                <figcaption>
                  <strong>{item.beforeTitle}</strong>
                  {item.beforeCaption && <span>{item.beforeCaption}</span>}
                </figcaption>
              </figure>

              <figure class="comparison-media">
                <img src={item.afterImage} alt={item.afterAlt} loading="lazy" />
                <figcaption>
                  <strong>{item.afterTitle}</strong>
                  {item.afterCaption && <span>{item.afterCaption}</span>}
                </figcaption>
              </figure>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="drawing-section">
      <div class="drawing-header">
        <p class="section-subtitle">DRAWING PACKAGE</p>
        <h2>設計圖紙</h2>
        <p>從平面配置、照明安排到立面細節，讓施工內容更容易理解。</p>
      </div>

      <div class="drawing-grid">
        {drawingBoards.map((drawing) => (
          <article class="drawing-card">
            <figure class="drawing-media">
              <img src={drawing.image} alt={drawing.alt} loading="lazy" />
            </figure>
            <div class="drawing-copy">
              <p class="drawing-label">{drawing.label}</p>
              <h3>{drawing.title}</h3>
              <p>{drawing.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <div class="lightbox" id="lightbox">
      <button class="lightbox-close" aria-label="關閉">&times;</button>
      <button class="lightbox-nav lightbox-prev" aria-label="上一張">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="lightbox-nav lightbox-next" aria-label="下一張">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
      <div class="lightbox-content">
        <img id="lightbox-img" src="" alt="" />
      </div>
      <div class="lightbox-counter" id="lightbox-counter"></div>
    </div>

    <section class="contact-section">
      <div class="contact-inner">
        <p class="section-subtitle contact-subtitle">NEXT STEP</p>
        <h2 class="contact-title">喜歡這樣的空間方向嗎？</h2>
        <p class="contact-desc">歡迎和青曦聊聊你的住宅需求，我們會協助你整理需求、預算與施工安排。</p>
        <div class="contact-cards">
          <a href="https://lin.ee/U1HCeW4" target="_blank" class="contact-card">
            <div class="contact-icon line-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596a.624.624 0 01-.199.031c-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595a.62.62 0 01.194-.033c.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"></path>
              </svg>
            </div>
            <span>LINE 諮詢</span>
          </a>
          <a href="mailto:qingxi.ds@outlook.com" class="contact-card">
            <div class="contact-icon email-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path>
              </svg>
            </div>
            <span>Email 聯繫</span>
          </a>
          <a href="/contact" class="contact-card">
            <div class="contact-icon form-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
              </svg>
            </div>
            <span>預約諮詢</span>
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .project-page {
    padding-top: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(246, 247, 248, 1) 100%);
  }

  .section-subtitle {
    margin: 0 0 0.8rem;
    color: var(--tiffany-dark);
    font-size: 0.8rem;
    letter-spacing: 0.26em;
    font-weight: 600;
  }

  .project-hero {
    padding: 7rem 2rem 3rem;
  }

  .project-hero-shell,
  .project-highlight-card,
  .gallery-section,
  .contact-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .project-hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 360px);
    gap: 2rem;
    align-items: end;
  }

  .project-copy h1 {
    margin: 0;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(2.6rem, 5vw, 4.6rem);
    line-height: 1.18;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--gray-darkest);
  }

  .project-subtitle {
    margin: 1.25rem 0 0;
    font-size: 1.18rem;
    line-height: 1.8;
    color: var(--gray-dark);
    max-width: 42rem;
  }

  .project-story {
    margin: 1.25rem 0 0;
    font-size: 1rem;
    line-height: 1.9;
    color: var(--gray-medium);
    max-width: 40rem;
  }

  .project-facts {
    padding: 1.5rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(98, 106, 112, 0.16);
    box-shadow: 0 22px 45px rgba(47, 47, 47, 0.08);
    backdrop-filter: blur(16px);
  }

  .facts-label {
    margin: 0 0 1rem;
    font-size: 0.82rem;
    letter-spacing: 0.24em;
    color: var(--tiffany-dark);
  }

  .project-facts ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-facts li {
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(47, 47, 47, 0.08);
  }

  .project-facts li:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .project-facts span,
  .project-facts strong {
    display: block;
  }

  .project-facts span {
    margin-bottom: 0.35rem;
    color: var(--gray-medium);
    font-size: 0.88rem;
    letter-spacing: 0.08em;
  }

  .project-facts strong {
    color: var(--gray-darkest);
    font-size: 1rem;
    line-height: 1.7;
    font-weight: 600;
  }

  .project-highlight-section {
    padding: 1rem 2rem 3rem;
  }

  .drawing-section,
  .comparison-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 5rem;
  }

  .project-highlight-card {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 2rem;
    align-items: center;
    padding: 2rem;
    border-radius: 32px;
    background: linear-gradient(135deg, rgba(19, 19, 19, 1) 0%, rgba(38, 38, 38, 1) 100%);
    color: var(--white);
    box-shadow: 0 28px 70px rgba(17, 17, 17, 0.18);
  }

  .highlight-copy h2 {
    margin: 0;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.35;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .highlight-copy p:last-child {
    margin: 1rem 0 0;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.9;
  }

  .project-feature-image,
  .gallery-item {
    margin: 0;
    cursor: pointer;
  }

  .project-feature-image img,
  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-feature-image {
    overflow: hidden;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
  }

  .project-feature-image img {
    aspect-ratio: 4 / 3;
    display: block;
  }

  .project-feature-image:hover img,
  .gallery-item:hover img {
    transform: scale(1.04);
  }

  .gallery-section {
    padding: 0 2rem 5rem;
  }

  .drawing-header,
  .comparison-header {
    max-width: 760px;
    margin-bottom: 2rem;
  }

  .drawing-header h2,
  .comparison-header h2 {
    margin: 0;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.4;
    font-weight: 500;
    color: var(--gray-darkest);
  }

  .drawing-header p:last-child,
  .comparison-header p:last-child {
    margin: 0.95rem 0 0;
    color: var(--gray-medium);
    line-height: 1.85;
  }

  .gallery-header {
    max-width: 760px;
    margin-bottom: 2rem;
  }

  .gallery-header h2 {
    margin: 0;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.4;
    font-weight: 500;
    color: var(--gray-darkest);
  }

  .gallery-stack {
    display: grid;
    gap: 1.5rem;
  }

  .gallery-row {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .gallery-row-primary {
    grid-template-columns: minmax(0, 1.22fr) minmax(240px, 0.78fr);
  }

  .gallery-row-secondary {
    grid-template-columns: minmax(240px, 0.82fr) minmax(0, 1.18fr);
    padding-left: clamp(0rem, 3vw, 2rem);
  }

  .gallery-item {
    margin: 0;
    align-self: start;
  }

  .gallery-thumb {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    background: var(--gray-bg);
    box-shadow: 0 18px 40px rgba(47, 47, 47, 0.08);
  }

  .gallery-item.is-wide .gallery-thumb {
    height: clamp(290px, 34vw, 420px);
  }

  .gallery-item.is-standard .gallery-thumb {
    height: clamp(280px, 31vw, 380px);
  }

  .gallery-item.is-immersive .gallery-thumb {
    height: clamp(240px, 24vw, 300px);
  }

  .gallery-item.is-portrait .gallery-thumb {
    height: clamp(250px, 26vw, 320px);
  }

  .gallery-row-primary .gallery-item.is-standard {
    margin-top: clamp(1.5rem, 3vw, 2.75rem);
  }

  .gallery-row-secondary .gallery-item.is-immersive {
    margin-top: clamp(0.5rem, 1.8vw, 1.4rem);
  }

  .drawing-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .drawing-card,
  .comparison-card {
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(98, 106, 112, 0.14);
    border-radius: 26px;
    box-shadow: 0 18px 40px rgba(47, 47, 47, 0.06);
  }

  .drawing-card {
    overflow: hidden;
  }

  .drawing-media {
    margin: 0;
    background: #f7f9f9;
    border-bottom: 1px solid rgba(98, 106, 112, 0.12);
  }

  .drawing-media img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .drawing-copy {
    padding: 1.4rem;
  }

  .drawing-label,
  .comparison-label {
    margin: 0;
    color: var(--tiffany-dark);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    font-weight: 600;
  }

  .drawing-copy h3,
  .comparison-copy h3 {
    margin: 0.7rem 0 0;
    font-family: 'Noto Serif TC', serif;
    font-size: 1.45rem;
    line-height: 1.45;
    font-weight: 500;
    color: var(--gray-darkest);
  }

  .drawing-copy p:last-child,
  .comparison-copy p:last-child {
    margin: 0.8rem 0 0;
    color: var(--gray-medium);
    line-height: 1.85;
  }

  .comparison-stack {
    display: grid;
    gap: 1.5rem;
  }

  .comparison-card {
    padding: 1.5rem;
  }

  .comparison-copy {
    max-width: 42rem;
    margin-bottom: 1.25rem;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .comparison-media {
    margin: 0;
    overflow: hidden;
    border-radius: 22px;
    background: #f7f9f9;
