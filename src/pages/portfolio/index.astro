---
import BaseLayout from '../../layouts/BaseLayout.astro';

const featuredProject = {
  title: '住宅空間設計',
  coverImage: '/images/portfolio/xizhi-1.jpg',
  summary: '整理最能看出實際完工感受的住宅照片。',
  slug: 'xizhi-zhongxing-rd',
  label: 'RESIDENTIAL INTERIOR',
};

const editorialNotes = ['住宅完工', '前後對照', '商空與戶外'];
const poolFeature = {
  image: '/images/portfolio/hualien-sherlock-pool.jpg',
  alt: '夜間泳池與建築外觀畫面',
  title: '泳池與戶外水景規劃',
  summary: '除了室內空間，也能協助規劃泳池、水景與戶外動線。',
};
const commercialFeature = {
  image: '/images/portfolio/restaurant-commercial-the-wrice.jpg',
  alt: '餐飲商空門面與室內畫面',
  title: '餐飲商空與店面形象規劃',
  summary:
    '從門面到室內，協助整理品牌形象與使用動線。',
};

const spatialMoments = [
  {
    image: '/images/portfolio/xizhi-1.jpg',
    alt: '住宅空間客廳畫面',
  },
  {
    image: '/images/portfolio/xizhi-2.jpg',
    alt: '住宅空間餐廚畫面',
  },
  {
    image: '/images/portfolio/xizhi-3.jpg',
    alt: '住宅空間主臥畫面',
  },
  {
    image: '/images/portfolio/xizhi-zhongxing-rd/living-room-after.jpg',
    alt: '住宅空間客廳改造後畫面',
  },
  {
    image: '/images/portfolio/xizhi-zhongxing-rd/bathroom-portrait.jpg',
    alt: '住宅空間浴室直式畫面',
  },
];

const primaryMoments = spatialMoments.slice(0, 2);
const secondaryMoments = spatialMoments.slice(2);
---

<style>
  .portfolio-page {
    padding: 7rem 1.5rem 6rem;
    background:
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.05), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(246, 241, 236, 1) 100%);
  }

  .portfolio-hero {
    max-width: 1180px;
    margin: 0 auto;
    min-height: calc(100vh - 8rem);
    display: grid;
    grid-template-columns: minmax(320px, 0.94fr) minmax(0, 1.06fr);
    gap: 1.5rem;
    align-items: end;
  }

  .portfolio-hero > * {
    min-width: 0;
  }

  h1 {
    margin: 0;
    font-weight: 400;
    color: var(--gray-darkest);
    letter-spacing: 0.1em;
    line-height: 1.04;
    font-family: var(--font-display);
    font-size: clamp(4rem, 8vw, 6.8rem);
  }
  
  .section-subtitle {
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    color: var(--tiffany-dark);
    margin: 0 0 0.8rem;
    font-weight: 600;
  }

  .portfolio-hero-copy {
    display: grid;
    align-content: end;
  }

  .portfolio-intro {
    margin: 1.5rem 0 0;
    max-width: 36rem;
    color: color-mix(in srgb, var(--gray-darkest) 62%, transparent);
    line-height: 1.84;
    letter-spacing: 0.01em;
    font-size: 1.08rem;
  }

  .portfolio-notes {
    margin: 1.75rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    max-width: 760px;
  }

  .portfolio-notes span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.68rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--gray-dark);
    letter-spacing: 0.08em;
    box-shadow: 0 18px 40px rgba(var(--brand-dark-rgb), 0.06);
    backdrop-filter: blur(18px);
  }

  .portfolio-container {
    max-width: 1180px;
    margin: 0 auto;
  }

  .reveal-up {
    opacity: 0;
    transform: translate3d(0, 28px, 0);
    transition:
      opacity 1s var(--motion-standard),
      transform 1s var(--motion-standard);
    will-change: opacity, transform;
  }

  .reveal-up.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .portfolio-metrics {
    margin: 2.2rem 0 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    max-width: 880px;
  }

  .portfolio-hero-visual {
    position: relative;
    margin: 0;
    min-height: 100%;
    overflow: hidden;
    border-radius: 36px;
    box-shadow: 0 38px 96px rgba(var(--brand-dark-rgb), 0.16);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .portfolio-hero-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(15, 15, 15, 0.1) 0%, rgba(15, 15, 15, 0.38) 100%),
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.18), transparent 34%);
  }

  .portfolio-hero-visual img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 620px;
    object-fit: cover;
  }

  .portfolio-hero-visual figcaption {
    position: absolute;
    left: 1.6rem;
    right: 1.6rem;
    bottom: 1.6rem;
    z-index: 1;
    padding: 1.15rem 1.2rem 1.2rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: var(--white);
    backdrop-filter: blur(18px) saturate(135%);
  }

  .portfolio-hero-visual span,
  .portfolio-hero-visual strong {
    display: block;
  }

  .portfolio-hero-visual span {
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.72);
  }

  .portfolio-hero-visual strong {
    margin-top: 0.55rem;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.2vw, 2.15rem);
    font-weight: 500;
    line-height: 1.24;
    letter-spacing: 0.06em;
  }

  .portfolio-metric {
    padding: 1.45rem 1.3rem;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.7) 0%, rgba(246, 241, 236, 0.52) 100%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 20px 46px rgba(var(--brand-dark-rgb), 0.06);
    backdrop-filter: blur(20px) saturate(135%);
  }

  .portfolio-metric strong,
  .portfolio-metric span {
    display: block;
  }

  .portfolio-metric strong {
    color: var(--gray-darkest);
    font-size: 1rem;
    letter-spacing: 0.05em;
  }

  .portfolio-metric span {
    margin-top: 0.35rem;
    color: var(--gray-medium);
    line-height: 1.7;
    font-size: 0.92rem;
  }

  .featured-showcase {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 2rem;
    align-items: center;
    min-height: 100vh;
  }

  .featured-showcase > * {
    min-width: 0;
  }

  .featured-media {
    position: relative;
    overflow: hidden;
    border-radius: 34px;
    background: var(--gray-bg);
    box-shadow: 0 36px 96px rgba(var(--brand-dark-rgb), 0.14);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .featured-media img {
    display: block;
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 11;
    object-fit: cover;
  }

  .featured-copy {
    padding: clamp(2rem, 4vw, 3.5rem);
    border-radius: 34px;
    background:
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.09), transparent 28%),
      linear-gradient(135deg, rgba(27, 27, 27, 1) 0%, rgba(41, 41, 41, 1) 100%);
    color: var(--white);
    box-shadow: 0 34px 88px rgba(var(--brand-dark-rgb), 0.18);
    border: 1px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(26px) saturate(140%);
  }

  .featured-label {
    margin: 0 0 0.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    color: rgba(255, 255, 255, 0.66);
  }

  .featured-copy h2 {
    margin: 0;
    max-width: 9ch;
    font-size: clamp(2.8rem, 5vw, 4.8rem);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: 0.08em;
  }

  .featured-copy p {
    margin: 1.3rem 0 0;
    color: rgba(255, 255, 255, 0.64);
    line-height: 1.82;
    letter-spacing: 0.01em;
  }

  .featured-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .featured-link,
  .featured-secondary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 150px;
    padding: 0.9rem 1.35rem;
    border-radius: 999px;
    text-decoration: none;
    letter-spacing: 0.08em;
    transition:
      transform 0.25s ease,
      background-color var(--motion-duration-fast) var(--motion-standard),
      border-color var(--motion-duration-fast) var(--motion-standard),
      color var(--motion-duration-fast) var(--motion-standard);
  }

  .featured-link {
    background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--tiffany-dark) 100%);
    color: var(--white);
    border: 1px solid rgba(170, 159, 149, 0.24);
  }

  .featured-secondary-link {
    background: rgba(255, 255, 255, 0.12);
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.34);
    box-shadow: 0 12px 22px rgba(20, 20, 20, 0.14);
  }

  .featured-link:hover,
  .featured-secondary-link:hover {
    transform: translateY(-2px);
  }

  .featured-link:hover {
    background: linear-gradient(135deg, rgba(52, 47, 43, 1) 0%, rgba(103, 92, 84, 1) 100%);
  }

  .moments-section {
    margin-top: 2rem;
    min-height: 100vh;
    display: grid;
    align-content: center;
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 2.5rem;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(3.2rem, 6vw, 5.8rem);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: 0.08em;
    color: var(--gray-darkest);
  }

  .section-heading p {
    margin: 1.2rem 0 0;
    color: color-mix(in srgb, var(--gray-darkest) 62%, transparent);
    line-height: 1.85;
  }

  .moments-stack {
    display: grid;
    gap: 1.5rem;
  }

  .moments-row {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .moments-row > * {
    min-width: 0;
  }

  .moments-row-primary {
    grid-template-columns: minmax(0, 1.22fr) minmax(240px, 0.78fr);
  }

  .moments-row-secondary {
    grid-template-columns: minmax(240px, 0.82fr) minmax(0, 1.18fr);
    padding-left: clamp(0rem, 3vw, 2rem);
  }

  .moment-card {
    margin: 0;
    overflow: hidden;
    border-radius: 30px;
    background: var(--gray-bg);
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 20px 48px rgba(var(--brand-dark-rgb), 0.08);
  }

  .moment-card img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: var(--moment-height);
    object-fit: cover;
    transition: transform 1s var(--motion-standard);
  }

  .moment-card:hover img {
    transform: scale(1.03);
  }

  .moment-card.is-wide {
    --moment-height: clamp(290px, 34vw, 420px);
  }

  .moment-card.is-portrait {
    --moment-height: clamp(280px, 31vw, 380px);
  }

  .moment-card.is-intimate {
    --moment-height: clamp(240px, 24vw, 300px);
  }

  .moment-card.is-balanced {
    --moment-height: clamp(250px, 26vw, 320px);
  }

  .moments-row-primary .moment-card.is-portrait {
    margin-top: clamp(1.5rem, 3vw, 2.75rem);
  }

  .moments-row-secondary .moment-card.is-intimate {
    margin-top: clamp(0.5rem, 1.8vw, 1.4rem);
  }

  .moment-card figcaption {
    padding: 1rem 1.2rem 1.2rem;
    color: var(--gray-dark);
    letter-spacing: 0.06em;
  }

  .capability-stack {
    margin-top: 2rem;
    display: grid;
    gap: 1.5rem;
  }

  .pool-feature {
    display: grid;
    grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1.05fr);
    gap: 1.5rem;
    align-items: center;
    padding: clamp(1.6rem, 3vw, 2.6rem);
    border-radius: 30px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.72) 0%, rgba(246, 241, 236, 0.56) 100%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 24px 56px rgba(var(--brand-dark-rgb), 0.08);
    backdrop-filter: blur(22px) saturate(135%);
  }

  .pool-feature > * {
    min-width: 0;
  }

  .pool-feature-media {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: 22px;
    background: var(--gray-bg);
  }

  .pool-feature-media img {
    display: block;
    width: 100%;
    max-width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .pool-feature-badge {
    position: absolute;
    left: 1rem;
    top: 1rem;
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    background: rgba(17, 17, 17, 0.58);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: var(--white);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    backdrop-filter: blur(10px);
  }

  .pool-feature-copy {
    min-width: 0;
  }

  .pool-feature-label {
    margin: 0;
    color: var(--tiffany-dark);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    font-weight: 600;
  }

  .pool-feature h3 {
    margin: 0.7rem 0 0;
    color: var(--gray-darkest);
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: 0.08em;
  }

  .pool-feature p:last-child {
    margin: 0.85rem 0 0;
    color: color-mix(in srgb, var(--gray-darkest) 62%, transparent);
    line-height: 1.85;
  }

  .portfolio-cta {
    margin-top: 5rem;
    min-height: 100vh;
    padding: clamp(2.5rem, 5vw, 4rem);
    border-radius: 34px;
    background:
      radial-gradient(circle at top right, rgba(159, 147, 136, 0.08), transparent 30%),
      linear-gradient(135deg, rgba(243, 245, 246, 0.8) 0%, rgba(255, 255, 255, 0.68) 100%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 32px 84px rgba(var(--brand-dark-rgb), 0.1);
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) auto;
    gap: 1.5rem;
    align-items: center;
    backdrop-filter: blur(26px) saturate(135%);
  }

  .portfolio-cta h2 {
    margin: 0;
    max-width: 10ch;
    font-size: clamp(3rem, 6vw, 5.4rem);
    font-family: var(--font-display);
    font-weight: 400;
    color: var(--gray-darkest);
    line-height: 1.08;
    letter-spacing: 0.08em;
  }

  .portfolio-cta p {
    margin: 1.25rem 0 0;
    color: color-mix(in srgb, var(--gray-darkest) 62%, transparent);
    line-height: 1.85;
    max-width: 42rem;
  }

  .portfolio-cta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    background: linear-gradient(135deg, var(--gray-darkest) 0%, var(--tiffany-dark) 100%);
    color: var(--white);
    border: 1px solid rgba(170, 159, 149, 0.24);
    letter-spacing: 0.08em;
    transition:
      transform var(--motion-duration-fast) var(--motion-standard),
      background-color var(--motion-duration-fast) var(--motion-standard),
      border-color var(--motion-duration-fast) var(--motion-standard);
  }

  .portfolio-cta a:hover {
    transform: translateY(-2px);
    background: linear-gradient(135deg, rgba(52, 47, 43, 1) 0%, rgba(103, 92, 84, 1) 100%);
  }

  @media (max-width: 960px) {
    .portfolio-metrics,
    .portfolio-hero,
    .featured-showcase,
    .portfolio-cta {
      grid-template-columns: 1fr;
    }

    .moments-row-primary,
    .moments-row-secondary,
    .pool-feature {
      grid-template-columns: 1fr;
      padding-left: 0;
    }

    .moments-row-primary .moment-card.is-portrait,
    .moments-row-secondary .moment-card.is-intimate {
      margin-top: 0;
    }

    .moment-card.is-wide,
    .moment-card.is-portrait,
    .moment-card.is-intimate,
    .moment-card.is-balanced {
      --moment-height: clamp(220px, 62vw, 320px);
    }
  }

  @media (max-width: 768px) {
    .portfolio-page {
      padding: 6rem 1.25rem 4rem;
    }

    .portfolio-hero,
    .featured-showcase,
    .moments-section,
    .portfolio-cta {
      min-height: auto;
    }

    h1,
    .section-heading h2,
    .featured-copy h2,
    .pool-feature h3,
    .portfolio-cta h2 {
      line-height: 1.14;
    }

    h1 {
      font-size: clamp(2.4rem, 10vw, 3.4rem);
      letter-spacing: 0.06em;
    }

    .portfolio-hero-visual {
      border-radius: 24px;
    }

    .portfolio-hero-visual img {
      min-height: 320px;
    }

    .portfolio-hero-visual figcaption {
      left: 1rem;
      right: 1rem;
      bottom: 1rem;
      padding: 0.95rem 1rem 1rem;
    }

    .featured-copy,
    .portfolio-cta {
      padding: 1.6rem;
    }

    .section-heading h2 {
      font-size: clamp(2.4rem, 10vw, 3.4rem);
    }

    .portfolio-cta h2 {
      font-size: clamp(2.4rem, 10vw, 3.4rem);
    }
  }
</style>

<BaseLayout
  title="精選作品 - 青曦空間設計"
  description="瀏覽青曦空間設計的精選作品，從住宅、商空到戶外規劃，快速了解實際完工照片與案例內容。"
  ogImage="/images/portfolio/xizhi-1.jpg"
  pageType="collection"
>
  <div class="portfolio-page">
    <header class="portfolio-hero reveal-up" data-reveal-delay="0">
      <div class="portfolio-hero-copy">
        <h6 class="section-subtitle">CURATED WORK</h6>
        <h1>精選作品</h1>
        <p class="portfolio-intro">
          以住宅為主，也收錄商空與戶外規劃，讓你直接看完成後的樣子。
        </p>
        <div class="portfolio-notes">
          {editorialNotes.map((note) => (
            <span>{note}</span>
          ))}
        </div>
        <div class="portfolio-metrics">
          <article class="portfolio-metric">
            <strong>住宅案例</strong>
            <span>直接看主要空間完工照。</span>
          </article>
          <article class="portfolio-metric">
            <strong>前後對照</strong>
            <span>更快判斷是不是你要的方向。</span>
          </article>
        </div>
      </div>
      <figure class="portfolio-hero-visual">
        <img
          src={featuredProject.coverImage}
          alt={featuredProject.title}
          width="1600"
          height="1200"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <figcaption>
          <span>{featuredProject.label}</span>
          <strong>先讓空間照片說話，再決定要不要深入看案例。</strong>
        </figcaption>
      </figure>
    </header>

    <div class="portfolio-container">
      <section class="featured-showcase">
        <figure class="featured-media reveal-up" data-reveal-delay="0">
          <img
            src={featuredProject.coverImage}
            alt={featuredProject.title}
            width="1600"
            height="1000"
            sizes="(max-width: 900px) 100vw, 56vw"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </figure>

        <div class="featured-copy reveal-up" data-reveal-delay="120">
          <p class="featured-label">{featuredProject.label}</p>
          <h2>先看住宅完工後的樣子</h2>
          <p>
            從客廳、餐廚到臥室，直接判斷這是不是你要的方向。
          </p>
          <div class="featured-actions">
            <a
              href={`/portfolio/${featuredProject.slug}`}
              class="featured-link"
            >
              查看案例詳情
            </a>
            <a href="/contact" class="featured-secondary-link">預約諮詢</a>
          </div>
        </div>
      </section>

      <section class="moments-section">
        <div class="section-heading reveal-up" data-reveal-delay="0">
          <h2>看看不同空間的實際照片</h2>
          <p>收錄住宅、商空與戶外照片，讓你更快找到偏好的空間感。</p>
        </div>

        <div class="moments-stack">
          <div class="moments-row moments-row-primary">
            {primaryMoments.map((moment, index) => (
              <figure class={`moment-card reveal-up ${index === 0 ? 'is-wide' : 'is-portrait'}`} data-reveal-delay={String(index * 90)}>
                <img
                  src={moment.image}
                  alt={moment.alt}
                  width="1200"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            ))}
          </div>

          <div class="moments-row moments-row-secondary">
            {secondaryMoments.map((moment, index) => (
              <figure class={`moment-card reveal-up ${index === 0 ? 'is-intimate' : 'is-balanced'}`} data-reveal-delay={String(index * 90)}>
                <img
                  src={moment.image}
                  alt={moment.alt}
                  width="1200"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            ))}
          </div>
        </div>

        <div class="capability-stack">
          <article class="pool-feature reveal-up" data-reveal-delay="80">
            <figure class="pool-feature-media">
              <img
                src={poolFeature.image}
                alt={poolFeature.alt}
                width="1200"
                height="900"
                loading="lazy"
                decoding="async"
              />
              <span class="pool-feature-badge">POOL DESIGN</span>
            </figure>
            <div class="pool-feature-copy">
              <p class="pool-feature-label">OUTDOOR PLANNING</p>
              <h3>{poolFeature.title}</h3>
              <p>{poolFeature.summary}</p>
            </div>
          </article>

          <article class="pool-feature reveal-up" data-reveal-delay="140">
            <figure class="pool-feature-media">
              <img
                src={commercialFeature.image}
                alt={commercialFeature.alt}
                width="1200"
                height="900"
                loading="lazy"
                decoding="async"
              />
              <span class="pool-feature-badge">COMMERCIAL SPACE</span>
            </figure>
            <div class="pool-feature-copy">
              <p class="pool-feature-label">RESTAURANT DESIGN</p>
              <h3>{commercialFeature.title}</h3>
              <p>{commercialFeature.summary}</p>
            </div>
          </article>
        </div>
      </section>

      <section class="portfolio-cta reveal-up" data-reveal-delay="0">
        <div>
          <h2>如果你已經看出偏好，下一步就直接講需求。</h2>
          <p>
            把喜歡的案例、需求與預算講清楚，方向就會快很多。
          </p>
        </div>
        <a href="/contact">直接聊需求</a>
      </section>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const portfolioRevealTargets = Array.from(document.querySelectorAll(".reveal-up"));

  if (reducedMotion.matches) {
    portfolioRevealTargets.forEach((node) => node.classList.add("is-visible"));
  } else if (portfolioRevealTargets.length) {
    const portfolioObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const element = entry.target;
          const delay = Number(element.getAttribute("data-reveal-delay") || "0");
          window.setTimeout(() => {
            element.classList.add("is-visible");
          }, delay);
          portfolioObserver.unobserve(element);
        });
      },
      {
        threshold: 0.15,
        rootMargin: "0px 0px -8% 0px",
      },
    );

    portfolioRevealTargets.forEach((node) => portfolioObserver.observe(node));
  }
</script>
