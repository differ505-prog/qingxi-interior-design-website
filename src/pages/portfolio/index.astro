---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = [
  {
    title: '汐止中興路住宅',
    coverImage: '/images/portfolio/xizhi-1.jpg',
    summary: '以沉穩灰階與俐落線條，整理出耐住也耐看的居住節奏。',
    slug: 'xizhi-zhongxing-rd'
  }
];
---

<style>
  .portfolio-page {
    padding: 6.5rem 1.5rem 5rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(247, 247, 247, 1) 100%);
  }

  .portfolio-hero {
    max-width: 860px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  h1 {
    margin: 0;
    font-weight: 500;
    color: var(--gray-darkest);
    letter-spacing: 0.06em;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(2.4rem, 5vw, 4rem);
  }
  
  .section-subtitle {
    font-size: 0.85rem;
    letter-spacing: 0.28em;
    color: var(--tiffany-dark);
    text-align: center;
    margin: 0 0 0.8rem;
    font-weight: 600;
  }

  .portfolio-intro {
    margin: 1.15rem auto 0;
    max-width: 42rem;
    color: var(--gray-medium);
    line-height: 1.9;
    font-size: 1rem;
  }
  
  .portfolio-container {
    max-width: 1080px;
    margin: 0 auto;
  }
  
  .portfolio-grid {
    display: grid;
    gap: 2.25rem;
    grid-template-columns: 1fr;
  }
  
  @media (min-width: 640px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .portfolio-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    
    .portfolio-grid.single-item {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
    
    .portfolio-grid.two-items {
      grid-template-columns: repeat(2, 1fr);
      max-width: 900px;
      margin: 0 auto;
    }
  }
</style>

<BaseLayout title="作品集 - 青曦空間設計">
  <div class="portfolio-page">
    <header class="portfolio-hero">
      <h6 class="section-subtitle">WORKS</h6>
      <h1>精選作品集</h1>
      <p class="portfolio-intro">
        以住宅日常為核心，透過材質、比例與光線的整合，
        讓每個案例都回到更安定、更耐看的居住感。
      </p>
    </header>
    <div class="portfolio-container">
      <div class={`portfolio-grid ${projects.length === 1 ? 'single-item' : projects.length === 2 ? 'two-items' : ''}`}>
        {projects.map(project => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
