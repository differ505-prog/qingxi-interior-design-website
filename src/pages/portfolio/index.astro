---
import BaseLayout from '../../layouts/BaseLayout.astro';

const featuredProject = {
  title: '住宅空間設計',
  coverImage: '/images/portfolio/xizhi-1.jpg',
  summary: '以住宅空間為主軸，精選最能呈現生活質感、光線與細節層次的畫面。',
  slug: 'xizhi-zhongxing-rd',
  label: 'RESIDENTIAL INTERIOR',
};

const editorialNotes = ['住宅', '商空', '光線', '材質', '場域氛圍'];
const poolFeature = {
  image: '/images/portfolio/hualien-sherlock-pool.jpg',
  alt: '夜間泳池與建築外觀畫面',
  title: '泳池與戶外水景規劃',
  summary: '除了室內空間，青曦也能整合泳池、水景、動線與夜間氛圍，規劃更完整的場域體驗。',
};
const commercialFeature = {
  image: '/images/portfolio/restaurant-commercial-the-wrice.jpg',
  alt: '餐飲商空門面與室內畫面',
  title: '餐飲商空與店面形象規劃',
  summary:
    '從門面識別、外觀材質到室內第一眼的氛圍安排，讓品牌形象、來客感受與空間完成度一起被看見。',
};

const spatialMoments = [
  {
    image: '/images/portfolio/xizhi-1.jpg',
    alt: '住宅空間客廳畫面',
  },
  {
    image: '/images/portfolio/xizhi-2.jpg',
    alt: '住宅空間餐廚畫面',
  },
  {
    image: '/images/portfolio/xizhi-3.jpg',
    alt: '住宅空間主臥畫面',
  },
  {
    image: '/images/portfolio/xizhi-zhongxing-rd/bathroom-portrait.jpg',
    alt: '住宅空間浴室直式畫面',
  },
];

const primaryMoments = spatialMoments.slice(0, 2);
const secondaryMoments = spatialMoments.slice(2, 4);
---

<style>
  .portfolio-page {
    padding: 6.5rem 1.5rem 5rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(247, 247, 247, 1) 100%);
  }

  .portfolio-hero {
    max-width: 920px;
    margin: 0 auto;
    text-align: center;
  }

  h1 {
    margin: 0;
    font-weight: 500;
    color: var(--gray-darkest);
    letter-spacing: 0.06em;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(2.4rem, 5vw, 4rem);
  }
  
  .section-subtitle {
    font-size: 0.85rem;
    letter-spacing: 0.28em;
    color: var(--tiffany-dark);
    text-align: center;
    margin: 0 0 0.8rem;
    font-weight: 600;
  }

  .portfolio-intro {
    margin: 1.15rem auto 0;
    max-width: 48rem;
    color: var(--gray-medium);
    line-height: 1.9;
    font-size: 1rem;
  }

  .portfolio-notes {
    margin: 1.75rem auto 0;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    max-width: 760px;
  }

  .portfolio-notes span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.68rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(129, 199, 212, 0.16);
    color: var(--gray-dark);
    letter-spacing: 0.08em;
    box-shadow: 0 14px 28px rgba(47, 47, 47, 0.04);
  }

  .portfolio-container {
    max-width: 1180px;
    margin: 0 auto;
  }

  .portfolio-metrics {
    margin: 2rem auto 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    max-width: 880px;
  }

  .portfolio-metric {
    padding: 1.2rem 1rem;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(129, 199, 212, 0.14);
    box-shadow: 0 18px 35px rgba(47, 47, 47, 0.05);
  }

  .portfolio-metric strong,
  .portfolio-metric span {
    display: block;
  }

  .portfolio-metric strong {
    color: var(--gray-darkest);
    font-size: 1rem;
    letter-spacing: 0.05em;
  }

  .portfolio-metric span {
    margin-top: 0.35rem;
    color: var(--gray-medium);
    line-height: 1.7;
    font-size: 0.92rem;
  }

  .featured-showcase {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 2rem;
    align-items: center;
  }

  .featured-showcase > * {
    min-width: 0;
  }

  .featured-media {
    position: relative;
    overflow: hidden;
    border-radius: 30px;
    background: var(--gray-bg);
    box-shadow: 0 30px 70px rgba(47, 47, 47, 0.12);
  }

  .featured-media img {
    display: block;
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 11;
    object-fit: cover;
  }

  .featured-copy {
    padding: 2rem;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.18), transparent 28%),
      linear-gradient(135deg, rgba(27, 27, 27, 1) 0%, rgba(41, 41, 41, 1) 100%);
    color: var(--white);
    box-shadow: 0 26px 60px rgba(17, 17, 17, 0.16);
  }

  .featured-label {
    margin: 0 0 0.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    color: rgba(255, 255, 255, 0.66);
  }

  .featured-copy h2 {
    margin: 0;
    font-size: clamp(1.7rem, 2.5vw, 2.4rem);
    font-family: 'Noto Serif TC', serif;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: 0.05em;
  }

  .featured-copy p {
    margin: 1rem 0 0;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.9;
  }

  .featured-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .featured-link,
  .featured-secondary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 150px;
    padding: 0.9rem 1.35rem;
    border-radius: 999px;
    text-decoration: none;
    letter-spacing: 0.08em;
    transition:
      transform 0.25s ease,
      background-color 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease;
  }

  .featured-link {
    background: var(--tiffany-primary);
    color: var(--gray-darkest);
    border: 1px solid var(--tiffany-primary);
  }

  .featured-secondary-link {
    background: rgba(255, 255, 255, 0.08);
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.18);
  }

  .featured-link:hover,
  .featured-secondary-link:hover {
    transform: translateY(-2px);
  }

  .moments-section {
    margin-top: 4rem;
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 1.75rem;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    font-family: 'Noto Serif TC', serif;
    font-weight: 500;
    line-height: 1.4;
    color: var(--gray-darkest);
  }

  .section-heading p {
    margin: 0.9rem 0 0;
    color: var(--gray-medium);
    line-height: 1.85;
  }

  .moments-stack {
    display: grid;
    gap: 1.5rem;
  }

  .moments-row {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .moments-row > * {
    min-width: 0;
  }

  .moments-row-primary {
    grid-template-columns: minmax(0, 1.22fr) minmax(240px, 0.78fr);
  }

  .moments-row-secondary {
    grid-template-columns: minmax(240px, 0.82fr) minmax(0, 1.18fr);
    padding-left: clamp(0rem, 3vw, 2rem);
  }

  .moment-card {
    margin: 0;
    overflow: hidden;
    border-radius: 28px;
    background: var(--gray-bg);
    position: relative;
  }

  .moment-card img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: var(--moment-height);
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-shadow: 0 18px 40px rgba(47, 47, 47, 0.08);
  }

  .moment-card:hover img {
    transform: scale(1.03);
  }

  .moment-card.is-wide {
    --moment-height: clamp(290px, 34vw, 420px);
  }

  .moment-card.is-portrait {
    --moment-height: clamp(280px, 31vw, 380px);
  }

  .moment-card.is-intimate {
    --moment-height: clamp(240px, 24vw, 300px);
  }

  .moment-card.is-balanced {
    --moment-height: clamp(250px, 26vw, 320px);
  }

  .moments-row-primary .moment-card.is-portrait {
    margin-top: clamp(1.5rem, 3vw, 2.75rem);
  }

  .moments-row-secondary .moment-card.is-intimate {
    margin-top: clamp(0.5rem, 1.8vw, 1.4rem);
  }

  .moment-card figcaption {
    padding: 1rem 1.2rem 1.2rem;
    color: var(--gray-dark);
    letter-spacing: 0.06em;
  }

  .capability-stack {
    margin-top: 2rem;
    display: grid;
    gap: 1.5rem;
  }

  .pool-feature {
    display: grid;
    grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1.05fr);
    gap: 1.5rem;
    align-items: center;
    padding: 1.4rem;
    border-radius: 28px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 248, 248, 1) 100%);
    border: 1px solid rgba(129, 199, 212, 0.16);
    box-shadow: 0 18px 38px rgba(47, 47, 47, 0.06);
  }

  .pool-feature > * {
    min-width: 0;
  }

  .pool-feature-media {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: 22px;
    background: var(--gray-bg);
  }

  .pool-feature-media img {
    display: block;
    width: 100%;
    max-width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .pool-feature-badge {
    position: absolute;
    left: 1rem;
    top: 1rem;
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    background: rgba(17, 17, 17, 0.58);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: var(--white);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    backdrop-filter: blur(10px);
  }

  .pool-feature-copy {
    min-width: 0;
  }

  .pool-feature-label {
    margin: 0;
    color: var(--tiffany-dark);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    font-weight: 600;
  }

  .pool-feature h3 {
    margin: 0.7rem 0 0;
    color: var(--gray-darkest);
    font-size: clamp(1.45rem, 2.5vw, 2rem);
    font-family: 'Noto Serif TC', serif;
    font-weight: 500;
    line-height: 1.45;
  }

  .pool-feature p:last-child {
    margin: 0.85rem 0 0;
    color: var(--gray-medium);
    line-height: 1.85;
  }

  .portfolio-cta {
    margin-top: 4rem;
    padding: 2.5rem;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.2), transparent 30%),
      linear-gradient(135deg, rgba(244, 247, 247, 1) 0%, rgba(255, 255, 255, 1) 100%);
    border: 1px solid rgba(129, 199, 212, 0.18);
    box-shadow: 0 20px 40px rgba(47, 47, 47, 0.06);
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) auto;
    gap: 1.5rem;
    align-items: center;
  }

  .portfolio-cta h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-family: 'Noto Serif TC', serif;
    font-weight: 500;
    color: var(--gray-darkest);
  }

  .portfolio-cta p {
    margin: 0.85rem 0 0;
    color: var(--gray-medium);
    line-height: 1.85;
    max-width: 42rem;
  }

  .portfolio-cta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    background: var(--gray-darkest);
    color: var(--white);
    letter-spacing: 0.08em;
    transition: transform 0.25s ease, background-color 0.25s ease;
  }

  .portfolio-cta a:hover {
    transform: translateY(-2px);
    background: var(--gray-dark);
  }

  @media (max-width: 960px) {
    .portfolio-metrics,
    .featured-showcase,
    .portfolio-cta {
      grid-template-columns: 1fr;
    }

    .moments-row-primary,
    .moments-row-secondary,
    .pool-feature {
      grid-template-columns: 1fr;
      padding-left: 0;
    }

    .moments-row-primary .moment-card.is-portrait,
    .moments-row-secondary .moment-card.is-intimate {
      margin-top: 0;
    }

    .moment-card.is-wide,
    .moment-card.is-portrait,
    .moment-card.is-intimate,
    .moment-card.is-balanced {
      --moment-height: clamp(220px, 62vw, 320px);
    }
  }

  @media (max-width: 768px) {
    .portfolio-page {
      padding: 6rem 1.25rem 4rem;
    }

    .featured-copy,
    .portfolio-cta {
      padding: 1.6rem;
    }
  }
</style>

<BaseLayout title="精選作品 - 青曦空間設計">
  <div class="portfolio-page">
    <header class="portfolio-hero">
      <h6 class="section-subtitle">CURATED WORK</h6>
      <h1>精選作品</h1>
      <p class="portfolio-intro">
        以住宅空間為核心，收錄最能代表質感的畫面，
        也延伸呈現商空與戶外場域的整體規劃能力。
      </p>
      <div class="portfolio-notes">
        {editorialNotes.map((note) => (
          <span>{note}</span>
        ))}
      </div>
      <div class="portfolio-metrics">
        <article class="portfolio-metric">
          <strong>住宅主軸</strong>
          <span>以日常生活感受為核心，整理出舒服、耐看的空間節奏。</span>
        </article>
        <article class="portfolio-metric">
          <strong>材質與光線</strong>
          <span>讓白天與夜晚都保有清楚層次與舒服氛圍。</span>
        </article>
        <article class="portfolio-metric">
          <strong>整體質感</strong>
          <span>從第一眼的氛圍到細節收尾，都看得到空間的完整度。</span>
        </article>
      </div>
    </header>

    <div class="portfolio-container">
      <section class="featured-showcase">
        <figure class="featured-media">
          <img src={featuredProject.coverImage} alt={featuredProject.title} />
        </figure>

        <div class="featured-copy">
          <p class="featured-label">{featuredProject.label}</p>
          <h2>看見住宅空間真正的質感</h2>
          <p>
            從開闊的公共區域、安定的私領域，到日夜之間的光線層次，
            讓你更直接感受到青曦在住宅空間設計、材質比例與整體完成度上的掌握。
          </p>
          <div class="featured-actions">
            <a
              href={`/portfolio/${featuredProject.slug}`}
              class="featured-link"
            >
              查看案例詳情
            </a>
            <a href="/contact" class="featured-secondary-link">預約諮詢</a>
          </div>
        </div>
      </section>

      <section class="moments-section">
        <div class="section-heading">
          <h2>從室內到夜景，看見空間完整的氣質與層次</h2>
          <p>收錄住宅、餐飲商空與戶外場域的代表畫面，讓你更直接感受青曦對比例、材質、光線與整體氛圍的掌握。</p>
        </div>

        <div class="moments-stack">
          <div class="moments-row moments-row-primary">
            {primaryMoments.map((moment, index) => (
              <figure class={`moment-card ${index === 0 ? 'is-wide' : 'is-portrait'}`}>
                <img src={moment.image} alt={moment.alt} loading="lazy" />
              </figure>
            ))}
          </div>

          <div class="moments-row moments-row-secondary">
            {secondaryMoments.map((moment, index) => (
              <figure class={`moment-card ${index === 0 ? 'is-intimate' : 'is-balanced'}`}>
                <img src={moment.image} alt={moment.alt} loading="lazy" />
              </figure>
            ))}
          </div>
        </div>

        <div class="capability-stack">
          <article class="pool-feature">
            <figure class="pool-feature-media">
              <img src={poolFeature.image} alt={poolFeature.alt} loading="lazy" />
              <span class="pool-feature-badge">POOL DESIGN</span>
            </figure>
            <div class="pool-feature-copy">
              <p class="pool-feature-label">OUTDOOR PLANNING</p>
              <h3>{poolFeature.title}</h3>
              <p>{poolFeature.summary}</p>
            </div>
          </article>

          <article class="pool-feature">
            <figure class="pool-feature-media">
              <img src={commercialFeature.image} alt={commercialFeature.alt} loading="lazy" />
              <span class="pool-feature-badge">COMMERCIAL SPACE</span>
            </figure>
            <div class="pool-feature-copy">
              <p class="pool-feature-label">RESTAURANT DESIGN</p>
              <h3>{commercialFeature.title}</h3>
              <p>{commercialFeature.summary}</p>
            </div>
          </article>
        </div>
      </section>

      <section class="portfolio-cta">
        <div>
          <h2>想讓你的空間也呈現這樣的質感與完整度？</h2>
          <p>
            從初步諮詢、設計提案到工程落地，青曦會陪你一起釐清需求、預算與理想中的空間樣貌。
          </p>
        </div>
        <a href="/contact">開始諮詢</a>
      </section>
    </div>
  </div>
</BaseLayout>
