---
import BaseLayout from '../../layouts/BaseLayout.astro';

const featuredProject = {
  title: '空間作品精選',
  coverImage: '/images/portfolio/xizhi-1.jpg',
  summary: '以材質、光線與場域節奏為主，整理出更耐看的精選空間畫面。',
  slug: 'xizhi-zhongxing-rd',
  label: 'CURATED PORTFOLIO',
};

const editorialNotes = ['室內', '光線', '材質', '夜景', '場域氛圍'];

const spatialMoments = [
  {
    image: '/images/portfolio/xizhi-1.jpg',
    alt: '住宅空間客廳畫面',
  },
  {
    image: '/images/portfolio/xizhi-2.jpg',
    alt: '住宅空間餐廚畫面',
  },
  {
    image: '/images/portfolio/xizhi-3.jpg',
    alt: '住宅空間主臥畫面',
  },
  {
    image: '/images/portfolio/xizhi-zhongxing-rd/bathroom-portrait.jpg',
    alt: '住宅空間浴室直式畫面',
  },
  {
    image: '/images/portfolio/hualien-sherlock-pool.jpg',
    alt: '夜間泳池與建築外觀畫面',
  },
];

const primaryMoments = spatialMoments.slice(0, 2);
const secondaryMoments = spatialMoments.slice(2, 4);
const closingMoment = spatialMoments[4];
---

<style>
  .portfolio-page {
    padding: 6.5rem 1.5rem 5rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(247, 247, 247, 1) 100%);
  }

  .portfolio-hero {
    max-width: 920px;
    margin: 0 auto;
    text-align: center;
  }

  h1 {
    margin: 0;
    font-weight: 500;
    color: var(--gray-darkest);
    letter-spacing: 0.06em;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(2.4rem, 5vw, 4rem);
  }
  
  .section-subtitle {
    font-size: 0.85rem;
    letter-spacing: 0.28em;
    color: var(--tiffany-dark);
    text-align: center;
    margin: 0 0 0.8rem;
    font-weight: 600;
  }

  .portfolio-intro {
    margin: 1.15rem auto 0;
    max-width: 48rem;
    color: var(--gray-medium);
    line-height: 1.9;
    font-size: 1rem;
  }

  .portfolio-notes {
    margin: 1.75rem auto 0;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    max-width: 760px;
  }

  .portfolio-notes span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.68rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(129, 199, 212, 0.16);
    color: var(--gray-dark);
    letter-spacing: 0.08em;
    box-shadow: 0 14px 28px rgba(47, 47, 47, 0.04);
  }

  .portfolio-container {
    max-width: 1180px;
    margin: 0 auto;
  }

  .portfolio-metrics {
    margin: 2rem auto 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    max-width: 880px;
  }

  .portfolio-metric {
    padding: 1.2rem 1rem;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(129, 199, 212, 0.14);
    box-shadow: 0 18px 35px rgba(47, 47, 47, 0.05);
  }

  .portfolio-metric strong,
  .portfolio-metric span {
    display: block;
  }

  .portfolio-metric strong {
    color: var(--gray-darkest);
    font-size: 1rem;
    letter-spacing: 0.05em;
  }

  .portfolio-metric span {
    margin-top: 0.35rem;
    color: var(--gray-medium);
    line-height: 1.7;
    font-size: 0.92rem;
  }

  .featured-showcase {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 2rem;
    align-items: center;
  }

  .featured-media {
    position: relative;
    overflow: hidden;
    border-radius: 30px;
    background: var(--gray-bg);
    box-shadow: 0 30px 70px rgba(47, 47, 47, 0.12);
  }

  .featured-media img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 11;
    object-fit: cover;
  }

  .featured-copy {
    padding: 2rem;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.18), transparent 28%),
      linear-gradient(135deg, rgba(27, 27, 27, 1) 0%, rgba(41, 41, 41, 1) 100%);
    color: var(--white);
    box-shadow: 0 26px 60px rgba(17, 17, 17, 0.16);
  }

  .featured-label {
    margin: 0 0 0.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    color: rgba(255, 255, 255, 0.66);
  }

  .featured-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 3rem);
    font-family: 'Noto Serif TC', serif;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: 0.05em;
  }

  .featured-copy p {
    margin: 1rem 0 0;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.9;
  }

  .featured-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .featured-link,
  .featured-secondary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 150px;
    padding: 0.9rem 1.35rem;
    border-radius: 999px;
    text-decoration: none;
    letter-spacing: 0.08em;
    transition:
      transform 0.25s ease,
      background-color 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease;
  }

  .featured-link {
    background: var(--tiffany-primary);
    color: var(--gray-darkest);
    border: 1px solid var(--tiffany-primary);
  }

  .featured-secondary-link {
    background: rgba(255, 255, 255, 0.08);
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.18);
  }

  .featured-link:hover,
  .featured-secondary-link:hover {
    transform: translateY(-2px);
  }

  .moments-section {
    margin-top: 4rem;
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 1.75rem;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    font-family: 'Noto Serif TC', serif;
    font-weight: 500;
    line-height: 1.4;
    color: var(--gray-darkest);
  }

  .section-heading p {
    margin: 0.9rem 0 0;
    color: var(--gray-medium);
    line-height: 1.85;
  }

  .moments-stack {
    display: grid;
    gap: 1.5rem;
  }

  .moments-row {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .moments-row-primary {
    grid-template-columns: minmax(0, 1.22fr) minmax(240px, 0.78fr);
  }

  .moments-row-secondary {
    grid-template-columns: minmax(240px, 0.82fr) minmax(0, 1.18fr);
    padding-left: clamp(0rem, 3vw, 2rem);
  }

  .moments-row-closing {
    grid-template-columns: 1fr;
    padding-left: clamp(0rem, 4vw, 3rem);
  }

  .moment-card {
    margin: 0;
    overflow: hidden;
    border-radius: 28px;
    background: var(--gray-bg);
    position: relative;
  }

  .moment-card img {
    display: block;
    width: 100%;
    height: var(--moment-height);
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-shadow: 0 18px 40px rgba(47, 47, 47, 0.08);
  }

  .moment-card:hover img {
    transform: scale(1.03);
  }

  .moment-card.is-wide {
    --moment-height: clamp(290px, 34vw, 420px);
  }

  .moment-card.is-portrait {
    --moment-height: clamp(280px, 31vw, 380px);
  }

  .moment-card.is-intimate {
    --moment-height: clamp(240px, 24vw, 300px);
  }

  .moment-card.is-balanced {
    --moment-height: clamp(250px, 26vw, 320px);
  }

  .moment-card.is-cinematic {
    --moment-height: clamp(300px, 34vw, 430px);
  }

  .moments-row-primary .moment-card.is-portrait {
    margin-top: clamp(1.5rem, 3vw, 2.75rem);
  }

  .moments-row-secondary .moment-card.is-intimate {
    margin-top: clamp(0.5rem, 1.8vw, 1.4rem);
  }

  .moment-card figcaption {
    padding: 1rem 1.2rem 1.2rem;
    color: var(--gray-dark);
    letter-spacing: 0.06em;
  }

  .moment-card.is-cinematic figcaption {
    position: absolute;
    left: 1.35rem;
    bottom: 1.35rem;
    padding: 0.7rem 0.9rem;
    border-radius: 999px;
    background: rgba(17, 17, 17, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    letter-spacing: 0.12em;
    font-size: 0.78rem;
  }

  .portfolio-cta {
    margin-top: 4rem;
    padding: 2.5rem;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(160, 217, 217, 0.2), transparent 30%),
      linear-gradient(135deg, rgba(244, 247, 247, 1) 0%, rgba(255, 255, 255, 1) 100%);
    border: 1px solid rgba(129, 199, 212, 0.18);
    box-shadow: 0 20px 40px rgba(47, 47, 47, 0.06);
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) auto;
    gap: 1.5rem;
    align-items: center;
  }

  .portfolio-cta h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-family: 'Noto Serif TC', serif;
    font-weight: 500;
    color: var(--gray-darkest);
  }

  .portfolio-cta p {
    margin: 0.85rem 0 0;
    color: var(--gray-medium);
    line-height: 1.85;
    max-width: 42rem;
  }

  .portfolio-cta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    background: var(--gray-darkest);
    color: var(--white);
    letter-spacing: 0.08em;
    transition: transform 0.25s ease, background-color 0.25s ease;
  }

  .portfolio-cta a:hover {
    transform: translateY(-2px);
    background: var(--gray-dark);
  }

  @media (max-width: 960px) {
    .portfolio-metrics,
    .featured-showcase,
    .portfolio-cta {
      grid-template-columns: 1fr;
    }

    .moments-row-primary,
    .moments-row-secondary,
    .moments-row-closing {
      grid-template-columns: 1fr;
      padding-left: 0;
    }

    .moments-row-primary .moment-card.is-portrait,
    .moments-row-secondary .moment-card.is-intimate {
      margin-top: 0;
    }

    .moment-card.is-wide,
    .moment-card.is-portrait,
    .moment-card.is-intimate,
    .moment-card.is-balanced,
    .moment-card.is-cinematic {
      --moment-height: clamp(220px, 62vw, 320px);
    }
  }

  @media (max-width: 768px) {
    .portfolio-page {
      padding: 6rem 1.25rem 4rem;
    }

    .featured-copy,
    .portfolio-cta {
      padding: 1.6rem;
    }
  }
</style>

<BaseLayout title="作品集 - 青曦空間設計">
  <div class="portfolio-page">
    <header class="portfolio-hero">
      <h6 class="section-subtitle">CURATED WORK</h6>
      <h1>精選空間畫面</h1>
      <p class="portfolio-intro">
        先不急著區分哪一張來自哪個案名，而是把不同場域裡最能代表質感的畫面整理在一起。
        讓比例、材質、光線與留白自己說話。
      </p>
      <div class="portfolio-notes">
        {editorialNotes.map((note) => (
          <span>{note}</span>
        ))}
      </div>
      <div class="portfolio-metrics">
        <article class="portfolio-metric">
          <strong>畫面節奏</strong>
          <span>用主次、疏密與比例，維持觀看時的呼吸感。</span>
        </article>
        <article class="portfolio-metric">
          <strong>材質與光線</strong>
          <span>讓白天與夜晚都有層次，而不是只靠單一裝飾撐場。</span>
        </article>
        <article class="portfolio-metric">
          <strong>精選敘事</strong>
          <span>先呈現整體氣質，再讓細節慢慢被看見。</span>
        </article>
      </div>
    </header>

    <div class="portfolio-container">
      <section class="featured-showcase">
        <figure class="featured-media">
          <img src={featuredProject.coverImage} alt={featuredProject.title} />
        </figure>

        <div class="featured-copy">
          <p class="featured-label">{featuredProject.label}</p>
          <h2>像一本精選集一樣觀看空間，而不是逐張對照案名</h2>
          <p>
            目前作品數量還在持續累積，所以首頁先以質感與編排為主。
            你會先看到場域氛圍、光線與材料關係，再進一步理解青曦的設計與落地能力。
          </p>
          <div class="featured-actions">
            <a
              href={`/portfolio/${featuredProject.slug}`}
              class="featured-link"
            >
              進入精選空間
            </a>
            <a href="/contact" class="featured-secondary-link">預約諮詢</a>
          </div>
        </div>
      </section>

      <section class="moments-section">
        <div class="section-heading">
          <h2>讓室內、夜景與不同場域，自然落在同一套觀看節奏裡</h2>
          <p>
            不急著分類成住宅、旅宿或單一空間用途，而是先把好看的畫面與整體氣質整理出來。
          </p>
        </div>

        <div class="moments-stack">
          <div class="moments-row moments-row-primary">
            {primaryMoments.map((moment, index) => (
              <figure class={`moment-card ${index === 0 ? 'is-wide' : 'is-portrait'}`}>
                <img src={moment.image} alt={moment.alt} loading="lazy" />
              </figure>
            ))}
          </div>

          <div class="moments-row moments-row-secondary">
            {secondaryMoments.map((moment, index) => (
              <figure class={`moment-card ${index === 0 ? 'is-intimate' : 'is-balanced'}`}>
                <img src={moment.image} alt={moment.alt} loading="lazy" />
              </figure>
            ))}
          </div>

          {closingMoment && (
            <div class="moments-row moments-row-closing">
              <figure class="moment-card is-cinematic">
                <img src={closingMoment.image} alt={closingMoment.alt} loading="lazy" />
                <figcaption>POOLSCAPE AT NIGHT</figcaption>
              </figure>
            </div>
          )}
        </div>
      </section>

      <section class="portfolio-cta">
        <div>
          <h2>想把你的空間也整理成這樣的質感與節奏？</h2>
          <p>
            從初步諮詢、設計提案到工程落地，青曦會陪你把需求、預算與完成後的整體氣質一起想清楚。
          </p>
        </div>
        <a href="/contact">開始諮詢</a>
      </section>
    </div>
  </div>
</BaseLayout>
