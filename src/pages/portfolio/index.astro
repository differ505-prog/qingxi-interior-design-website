---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = [
  {
    title: '住宅空間設計',
    coverImage: '/images/汐止中興路-客廳-01.jpg',
    summary: '',
    slug: 'xizhi-zhongxing-rd'
  }
];
---

<style>
  h1 {
    font-weight: 300;
    color: var(--gray-dark);
    letter-spacing: 0.1em;
    font-family: 'Noto Serif TC', serif;
  }
  
  .section-subtitle {
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    color: var(--tiffany-primary);
    text-align: center;
    margin: 0 0 0.5rem;
    font-weight: 500;
  }
  
  .portfolio-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .portfolio-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }
  
  @media (min-width: 640px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .portfolio-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    
    .portfolio-grid.single-item {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
    
    .portfolio-grid.two-items {
      grid-template-columns: repeat(2, 1fr);
      max-width: 900px;
      margin: 0 auto;
    }
  }
</style>

<BaseLayout title="作品集 - 青曦空間設計">
  <div class="container mx-auto px-4 py-16">
    <h6 class="section-subtitle">WORKS</h6>
    <h1 class="text-4xl font-bold text-center mb-12">作品集</h1>
    <div class="portfolio-container">
      <div class={`portfolio-grid ${projects.length === 1 ? 'single-item' : projects.length === 2 ? 'two-items' : ''}`}>
        {projects.map(project => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
