---
const {
  title = "青曦空間設計 - 大台北專業室內設計",
  description = "青曦空間設計提供大台北地區專業室內設計服務，包含住宅、商業空間、社區公設等。從設計規劃到工程施作，為您打造理想空間。",
  ogImage = "/images/og-default.jpg",
} = Astro.props;

// Get canonical URL
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://www.qingxi-ds.com",
);

// 維護模式檢查（用於注入到 HTML 中）
const MAINTENANCE_MODE =
  import.meta.env.MAINTENANCE_MODE === "true" ||
  import.meta.env.PUBLIC_MAINTENANCE_MODE === "true" ||
  false; // 預設為 false，線上部署時在 Vercel 設置環境變數為 true
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="室內設計,大台北,住宅設計,商業空間設計,裝潢,工程施作,青曦空間設計,台北室內設計,新北室內設計,室內裝修"
    />
    <meta name="author" content="青曦空間設計" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content="青曦空間設計" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Preload Critical Resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&family=Noto+Serif+TC:wght@300;400;500;600;700&display=swap"
      as="style"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&family=Noto+Serif+TC:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "青曦空間設計",
        "image": "https://www.qingxi-ds.com/images/og-default.jpg",
        "@id": "https://www.qingxi-ds.com",
        "url": "https://www.qingxi-ds.com",
        "telephone": "+886-XXX-XXX-XXX",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "台北市",
          "addressRegion": "台北",
          "addressCountry": "TW"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 25.033,
          "longitude": 121.5654
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "18:00"
        },
        "sameAs": [
          "https://www.facebook.com/profile.php?id=61562661642204",
          "https://www.instagram.com/qingxi.ds/",
          "https://lin.ee/U1HCeW4"
        ],
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "5",
          "reviewCount": "1"
        },
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "室內設計服務",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "住宅空間設計",
                "description": "專業住宅室內設計服務，從平面規劃到完工交屋"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "商業空間設計",
                "description": "商業空間室內設計與裝修服務"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "社區公設設計",
                "description": "社區公共空間設計規劃服務"
              }
            }
          ]
        }
      }
    </script>
  
  <!-- Google Analytics 4 (僅在生產環境載入) -->
  {import.meta.env.PROD && (
    <>
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX" is:inline></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-XXXXXXXXXX', {
          'anonymize_ip': true,
          'cookie_flags': 'SameSite=None;Secure'
        });
      </script>
    </>
  )}
  
  <style>
      :root {
        /* 灰色系 - 主基调 */
        --gray-darkest: #2f2f2f;
        --gray-dark: #4a4a4a;
        --gray-medium: #7a7a7a;
        --gray-light: #b0b0b0;
        --gray-lighter: #d8d8d8;
        --gray-bg: #f5f5f5;

        /* 白色系 */
        --white: #ffffff;
        --off-white: #fafafa;

        /* Tiffany绿色系 - 点缀色 */
        --tiffany-primary: #81c7d4;
        --tiffany-dark: #69b8c4;
        --tiffany-light: #a0d9d9;
        --tiffany-pale: #e6f5f7;

        /* 语义化颜色 */
        --primary: var(--gray-dark);
        --accent: var(--tiffany-primary);
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "Noto Sans TC", sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        margin: 0;
        color: var(--gray-dark);
        background:
          radial-gradient(circle at top, rgba(160, 217, 217, 0.12), transparent 28%),
          linear-gradient(180deg, #ffffff 0%, #f7f7f5 100%);
      }

      .site-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .site-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        border-bottom: 1px solid rgba(129, 199, 212, 0.26);
        background: rgba(255, 255, 255, 0.82);
        backdrop-filter: blur(18px);
        box-shadow: 0 10px 30px rgba(47, 47, 47, 0.08);
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease,
          background-color 0.3s ease;
      }

      .site-nav.scrolled {
        background: rgba(255, 255, 255, 0.92);
        box-shadow: 0 16px 36px rgba(47, 47, 47, 0.12);
      }

      .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0.95rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
      }

      .brand-link {
        display: inline-flex;
        flex-direction: column;
        gap: 0.2rem;
        text-decoration: none;
        color: var(--gray-darkest);
      }

      .brand-title {
        font-family: "Noto Serif TC", serif;
        font-size: 1.25rem;
        letter-spacing: 0.16em;
      }

      .brand-subtitle {
        font-size: 0.68rem;
        letter-spacing: 0.24em;
        color: var(--gray-medium);
        text-transform: uppercase;
      }

      /* 導覽列拉霸機效果 */
      .nav-item {
        position: relative;
        height: 24px;
        min-width: 80px;
        display: inline-block;
        overflow: hidden;
      }

      .nav-link {
        position: relative;
        display: block;
        width: 100%;
        height: 100%;
        text-decoration: none;
        color: var(--gray-dark);
        transition: color 0.3s ease;
        font-size: 1rem;
      }

      .nav-text-container {
        position: relative;
        width: 100%;
        height: 100%;
        transition: transform 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
      }

      .nav-text {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
      }

      .nav-text-en {
        position: absolute;
        top: 0;
      }

      .nav-text-zh {
        position: absolute;
        top: 100%;
      }

      .nav-link:hover .nav-text-container {
        transform: translateY(-100%);
      }

      .nav-link:hover {
        color: var(--tiffany-primary);
      }

      .nav-links {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .nav-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.8rem 1.2rem;
        border-radius: 999px;
        background: var(--gray-darkest);
        color: var(--white);
        text-decoration: none;
        font-size: 0.92rem;
        letter-spacing: 0.08em;
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease,
          background-color 0.25s ease;
      }

      .nav-cta:hover {
        transform: translateY(-2px);
        background: var(--tiffany-dark);
        box-shadow: 0 12px 24px rgba(129, 199, 212, 0.22);
      }

      /* 漢堡選單按鈕 */
      .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 5px;
      }

      .hamburger span {
        width: 25px;
        height: 3px;
        background: var(--gray-dark);
        transition: all 0.3s ease;
        border-radius: 2px;
      }

      .hamburger.active span:nth-child(1) {
        transform: rotate(45deg) translate(8px, 8px);
      }

      .hamburger.active span:nth-child(2) {
        opacity: 0;
      }

      .hamburger.active span:nth-child(3) {
        transform: rotate(-45deg) translate(7px, -7px);
      }

      /* 手機版樣式 */
      @media (max-width: 768px) {
        .hamburger {
          display: flex;
        }

        .nav-links {
          position: fixed;
          top: 78px;
          right: -100%;
          width: min(320px, calc(100vw - 2rem));
          height: auto;
          background: rgba(255, 255, 255, 0.96);
          backdrop-filter: blur(18px);
          flex-direction: column;
          gap: 0.4rem;
          padding: 1rem;
          border-radius: 24px;
          transition: right 0.3s ease;
          box-shadow: 0 18px 40px rgba(0, 0, 0, 0.16);
          z-index: 999;
          border: 1px solid rgba(129, 199, 212, 0.24);
        }

        .nav-links.active {
          right: 1rem;
        }

        .nav-item {
          width: 100%;
          min-width: unset;
          height: 50px;
          display: flex;
          align-items: center;
          justify-content: center;
          border-radius: 14px;
        }

        .nav-link {
          width: 100%;
          padding: 1rem 1.25rem;
          font-size: 1.1rem;
          border-radius: 14px;
        }

        .nav-text {
          justify-content: center;
        }

        .nav-link:hover {
          background: rgba(129, 199, 212, 0.12);
        }

        .nav-cta {
          width: 100%;
          margin-top: 0.5rem;
        }
      }

      /* Skip to main content link */
      .skip-to-main {
        position: absolute;
        top: -40px;
        left: 0;
        background: var(--tiffany-primary);
        color: white;
        padding: 8px 16px;
        text-decoration: none;
        border-radius: 0 0 4px 0;
        z-index: 100;
        font-weight: 500;
        transition: top 0.3s;
      }

      .skip-to-main:focus {
        top: 0;
      }

      /* Improved focus states */
      a:focus,
      button:focus {
        outline: 2px solid var(--tiffany-primary);
        outline-offset: 2px;
      }

      .site-main {
        flex: 1;
        padding-top: 78px;
      }

      .site-footer {
        background:
          linear-gradient(180deg, rgba(47, 47, 47, 0.98) 0%, rgba(31, 31, 31, 1) 100%);
        color: var(--white);
        border-top: 1px solid rgba(129, 199, 212, 0.28);
      }

      .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3.5rem 1.5rem 2rem;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) repeat(2, minmax(180px, 220px));
        gap: 2rem;
        align-items: start;
      }

      .footer-brand {
        max-width: 420px;
      }

      .footer-brand h2 {
        margin: 0 0 0.75rem;
        font-family: "Noto Serif TC", serif;
        font-size: 1.5rem;
        font-weight: 500;
        letter-spacing: 0.08em;
      }

      .footer-brand p,
      .footer-column p,
      .footer-column a {
        margin: 0;
        color: rgba(255, 255, 255, 0.72);
        line-height: 1.8;
        text-decoration: none;
      }

      .footer-note {
        margin-top: 1.25rem;
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.55rem 0.85rem;
        border: 1px solid rgba(129, 199, 212, 0.22);
        border-radius: 999px;
        color: rgba(255, 255, 255, 0.88);
        background: rgba(255, 255, 255, 0.04);
        font-size: 0.88rem;
      }

      .footer-column h3 {
        margin: 0 0 1rem;
        font-size: 0.82rem;
        letter-spacing: 0.22em;
        color: rgba(255, 255, 255, 0.56);
        text-transform: uppercase;
        font-weight: 500;
      }

      .footer-links,
      .footer-contact {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .footer-links a:hover,
      .footer-contact a:hover {
        color: var(--tiffany-light);
      }

      .footer-bottom {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
      }

      .footer-bottom p,
      .footer-bottom a {
        margin: 0;
        color: rgba(255, 255, 255, 0.56);
        text-decoration: none;
        font-size: 0.92rem;
      }

      @media (max-width: 900px) {
        .footer-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <a href="#main-content" class="skip-to-main">跳至主要內容</a>

      <nav class="site-nav" role="navigation" aria-label="主要導覽">
        <div class="nav-inner">
          <a href="/" class="brand-link" aria-label="青曦空間設計首頁">
            <span class="brand-title">青曦空間設計</span>
            <span class="brand-subtitle">QINGXI INTERIOR DESIGN</span>
          </a>

          <button class="hamburger" id="hamburger" aria-label="選單">
            <span></span>
            <span></span>
            <span></span>
          </button>

          <div class="nav-links" id="navLinks">
            <span class="nav-item">
              <a href="/" class="nav-link">
                <div class="nav-text-container">
                  <span class="nav-text nav-text-en">Home</span>
                  <span class="nav-text nav-text-zh">首頁</span>
                </div>
              </a>
            </span>
            <span class="nav-item">
              <a href="/portfolio" class="nav-link">
                <div class="nav-text-container">
                  <span class="nav-text nav-text-en">Portfolio</span>
                  <span class="nav-text nav-text-zh">作品集</span>
                </div>
              </a>
            </span>
            <span class="nav-item">
              <a href="/blog" class="nav-link">
                <div class="nav-text-container">
                  <span class="nav-text nav-text-en">Blog</span>
                  <span class="nav-text nav-text-zh">知識分享</span>
                </div>
              </a>
            </span>
            <span class="nav-item">
              <a href="/tools" class="nav-link">
                <div class="nav-text-container">
                  <span class="nav-text nav-text-en">Tools</span>
                  <span class="nav-text nav-text-zh">裝修工具</span>
                </div>
              </a>
            </span>
            <span class="nav-item">
              <a href="/#workflow" class="nav-link">
                <div class="nav-text-container">
                  <span class="nav-text nav-text-en">Workflow</span>
                  <span class="nav-text nav-text-zh">服務流程</span>
                </div>
              </a>
            </span>
            <a href="/contact" class="nav-cta">預約諮詢</a>
          </div>
        </div>
      </nav>

      <main id="main-content" class="site-main" role="main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-inner">
          <div class="footer-grid">
            <section class="footer-brand" aria-label="品牌資訊">
              <h2>青曦空間設計</h2>
              <p>
                專注於大台北住宅與商業空間規劃，從設計提案到工程整合，以安定、耐看的空間語言回應每位屋主的生活方式。
              </p>
              <div class="footer-note">大台北地區服務・住宅與商空整合規劃</div>
            </section>

            <section class="footer-column" aria-label="網站導覽">
              <h3>Explore</h3>
              <ul class="footer-links">
                <li><a href="/portfolio">作品集</a></li>
                <li><a href="/blog">知識分享</a></li>
                <li><a href="/tools">裝修工具</a></li>
                <li><a href="/#workflow">服務流程</a></li>
              </ul>
            </section>

            <section class="footer-column" aria-label="聯絡方式">
              <h3>Contact</h3>
              <ul class="footer-contact">
                <li><a href="/contact">預約諮詢表單</a></li>
                <li><a href="https://lin.ee/U1HCeW4" target="_blank" rel="noreferrer">官方 LINE</a></li>
                <li><a href="https://www.instagram.com/qingxi.ds/" target="_blank" rel="noreferrer">Instagram</a></li>
                <li><a href="https://www.facebook.com/profile.php?id=61562661642204" target="_blank" rel="noreferrer">Facebook</a></li>
              </ul>
            </section>
          </div>

          <div class="footer-bottom">
            <p>&copy; 2025 青曦空間設計. All rights reserved.</p>
            <a href="/policies">網站政策</a>
          </div>
        </div>
      </footer>
    </div>

    <script define:vars={{ maintenanceMode: MAINTENANCE_MODE }} is:inline>
      // 維護模式檢查（客戶端重定向，作為 middleware 的備用方案）
      if (maintenanceMode && window.location.pathname !== "/coming-soon") {
        window.location.replace("/coming-soon");
      }

      const hamburger = document.getElementById("hamburger");
      const navLinks = document.getElementById("navLinks");

      hamburger?.addEventListener("click", () => {
        hamburger.classList.toggle("active");
        navLinks?.classList.toggle("active");
      });

      // 點擊連結後關閉選單
      navLinks?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          hamburger?.classList.remove("active");
          navLinks?.classList.remove("active");
        });
      });

      // 滾動時增強導航欄陰影效果
      const nav = document.querySelector('.site-nav');
      
      window.addEventListener('scroll', () => {
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        
        nav?.classList.toggle('scrolled', scrollTop > 10);
      }, { passive: true });
    </script>
  </body>
</html>
