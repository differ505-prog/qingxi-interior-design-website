    <script define:vars={{ maintenanceMode: MAINTENANCE_MODE }} is:inline>
      // 維護模式檢查（客戶端重定向，作為 middleware 的備用方案）
      if (maintenanceMode && window.location.pathname !== "/coming-soon") {
        window.location.replace("/coming-soon");
      }

      const hamburger = document.getElementById("hamburger");
      const navLinks = document.getElementById("navLinks");

      hamburger?.addEventListener("click", () => {
        const nextExpanded = !hamburger.classList.contains("active");
        hamburger.classList.toggle("active", nextExpanded);
        hamburger.setAttribute("aria-expanded", nextExpanded ? "true" : "false");
        navLinks?.classList.toggle("active", nextExpanded);
      });

      // 點擊連結後關閉選單
      navLinks?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          hamburger?.classList.remove("active");
          hamburger?.setAttribute("aria-expanded", "false");
          navLinks?.classList.remove("active");
        });
      });

      // 滾動時增強導航欄陰影效果
      const nav = document.querySelector('.site-nav');
      
      window.addEventListener('scroll', () => {
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        
        nav?.classList.toggle('scrolled', scrollTop > 10);
      }, { passive: true });
    </script>
