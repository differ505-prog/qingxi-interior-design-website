---
import { SITE_DESCRIPTION, SITE_NAME, SITE_ORIGIN } from "../lib/site-metadata";

const {
  title = SITE_NAME,
  description = SITE_DESCRIPTION,
  ogImage = "/images/og-default.jpg",
  ogImageAlt,
  noindex = false,
  pageType = "website",
  structuredData,
  publishedTime,
  modifiedTime,
} = Astro.props;

const siteName = SITE_NAME;
const googleAnalyticsId =
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim() || "G-7ME23MTBKR";
const normalizedTitle =
  typeof title === "string"
    ? title.replace(/\s*[-|｜]\s*青曦空間設計\s*$/u, "").trim()
    : siteName;
const pageTitle =
  normalizedTitle && normalizedTitle !== siteName
    ? `${siteName} | ${normalizedTitle}`
    : siteName;
const siteOrigin = (Astro.site || new URL(SITE_ORIGIN)).toString();
const ogImageURL = new URL(ogImage, siteOrigin).toString();
const pageURL = new URL(Astro.url.pathname, siteOrigin).toString();
const robotsContent = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const resolvedOgImageAlt =
  typeof ogImageAlt === "string" && ogImageAlt.trim() ? ogImageAlt.trim() : pageTitle;
const pageSchemaType =
  pageType === "collection"
    ? "CollectionPage"
    : pageType === "contact"
      ? "ContactPage"
      : pageType === "service"
        ? "Service"
        : "WebPage";

// Get canonical URL
const canonicalURL = new URL(
  Astro.url.pathname,
  siteOrigin,
);
const canonicalString = canonicalURL.toString();
const customStructuredData = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const baseStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    url: siteOrigin,
    inLanguage: "zh-TW",
    description: SITE_DESCRIPTION,
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: siteName,
    image: ogImageURL,
    "@id": siteOrigin,
    url: siteOrigin,
    priceRange: "$$",
    address: {
      "@type": "PostalAddress",
      addressLocality: "台北市",
      addressRegion: "台北",
      addressCountry: "TW",
    },
    openingHoursSpecification: {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "09:00",
      closes: "18:00",
    },
    areaServed: ["台北市", "新北市"],
    email: "qingxi.ds@outlook.com",
    contactPoint: {
      "@type": "ContactPoint",
      contactType: "customer support",
      email: "qingxi.ds@outlook.com",
      availableLanguage: ["zh-Hant", "zh-TW"],
    },
    sameAs: [
      "https://www.facebook.com/profile.php?id=61562661642204",
      "https://www.instagram.com/qingxi.ds/",
      "https://lin.ee/U1HCeW4",
    ],
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "室內設計服務",
      itemListElement: [
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "住宅空間設計",
            description: "專業住宅室內設計服務，從平面規劃到完工交屋",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "商業空間設計",
            description: "商業空間室內設計與裝修服務",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "社區公設設計",
            description: "社區公共空間設計規劃服務",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "智能家居整合",
            description: "整合 Home Assistant、NAS、弱電規劃與跨品牌設備控制",
          },
        },
      ],
    },
  },
  {
    "@context": "https://schema.org",
    "@type": pageSchemaType,
    name: pageTitle,
    headline: pageTitle,
    description,
    url: canonicalString,
    inLanguage: "zh-TW",
    isPartOf: {
      "@type": "WebSite",
      name: siteName,
      url: siteOrigin,
    },
  },
];
const allStructuredData = [...baseStructuredData, ...customStructuredData];

// 維護模式檢查（用於注入到 HTML 中）
const MAINTENANCE_MODE =
  import.meta.env.MAINTENANCE_MODE === "true" ||
  import.meta.env.PUBLIC_MAINTENANCE_MODE === "true" ||
  false; // 預設為 false，線上部署時在 Vercel 設置環境變數為 true
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta
      name="keywords"
      content="室內設計,大台北,住宅設計,商業空間設計,裝潢,工程施作,青曦空間設計,台北室內設計,新北室內設計,室內裝修"
    />
    <meta name="author" content="青曦空間設計" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" type="application/xml" href={`${siteOrigin}/sitemap.xml`} />
    <link rel="alternate" type="text/plain" href={`${siteOrigin}/llms.txt`} title="LLMs.txt" />
    <link rel="icon" type="image/png" href="/images/brand/qingxi-logo.png" />
    <link rel="shortcut icon" href="/images/brand/qingxi-logo.png" />
    <link rel="apple-touch-icon" href="/images/brand/qingxi-logo.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={pageType === "article" ? "article" : "website"} />
    <meta property="og:url" content={pageURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content={resolvedOgImageAlt} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content="青曦空間設計" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={pageURL} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />
    <meta property="twitter:image:alt" content={resolvedOgImageAlt} />

    <!-- Preload Critical Resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=Noto+Serif+TC:wght@300;400;500;600;700&display=swap"
      as="style"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=Noto+Serif+TC:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org Structured Data -->
    {allStructuredData.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <slot name="head" />
  
  <!-- Google Analytics 4 (僅在生產環境且已設定時載入) -->
  {import.meta.env.PROD && googleAnalyticsId && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`} is:inline></script>
      <script define:vars={{ googleAnalyticsId }} is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', googleAnalyticsId, {
          'anonymize_ip': true,
          'cookie_flags': 'SameSite=None;Secure'
        });
      </script>
    </>
  )}
  <script is:inline>
    // @ts-ignore custom analytics helper
    window.trackLeadEvent = function(name, params = {}) {
      if (typeof window.gtag === 'function') {
        window.gtag('event', name, params);
      }
    };

    const OFFICIAL_LINE_URLS = [
      'https://lin.ee/U1HCeW4',
      'https://line.me/R/ti/p/@example'
    ];

    function normalizeTrackingUrl(value) {
      try {
        return new URL(value, window.location.origin).toString();
      } catch (_error) {
        return '';
      }
    }

    function extractLinkLabel(anchor) {
      if (!(anchor instanceof HTMLAnchorElement)) return '';
      const text = (anchor.dataset.lineLabel || anchor.getAttribute('aria-label') || anchor.textContent || '').trim();
      if (text) return text.slice(0, 80);
      return anchor.pathname || anchor.href;
    }

    document.addEventListener('click', function(event) {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const anchor = target.closest('a[href]');
      if (!(anchor instanceof HTMLAnchorElement)) return;

      const href = normalizeTrackingUrl(anchor.href);
      if (!href || !OFFICIAL_LINE_URLS.includes(href)) return;

      window.trackLeadEvent?.('official_line_click', {
        page_path: window.location.pathname,
        page_location: window.location.href,
        destination_url: href,
        link_label: extractLinkLabel(anchor)
      });
    });
  </script>
  
  <style>
      :root {
        /* 灰色系 - 主基调 */
        --gray-darkest: #342f2b;
        --gray-dark: #534b44;
        --gray-medium: #7b736b;
        --gray-light: #aea59c;
        --gray-lighter: #ddd5cc;
        --gray-bg: #f3efea;

        /* 白色系 */
        --white: #ffffff;
        --off-white: #f8f4ef;

        /* 全站藝術感中性色 */
        --art-accent-solid: #6b625b;
        --art-accent-text: #5f5650;
        --art-accent-line: rgba(115, 103, 94, 0.14);
        --art-accent-line-strong: rgba(115, 103, 94, 0.24);
        --art-accent-glow: rgba(159, 147, 136, 0.035);
        --art-accent-glow-soft: rgba(159, 147, 136, 0.018);
        --art-accent-focus: rgba(115, 103, 94, 0.1);
        --art-paper: #f6f2ed;
        --art-paper-deep: #ede7e0;
        --art-card: rgba(255, 255, 255, 0.92);
        --art-card-soft: rgba(247, 242, 236, 0.92);
        --art-card-muted: rgba(241, 235, 229, 0.95);
        --font-sans: "Noto Sans TC", "PingFang TC", "Microsoft JhengHei", sans-serif;
        --font-serif: "Noto Serif TC", "Songti TC", "PMingLiU", serif;
        --type-overline-spacing: 0.18em;
        --type-title-tracking: 0.022em;
        --type-body-tracking: 0.05em;
        --type-body-line-height: 1.78;
        --type-cta-tracking: 0.06em;

        /* 中性深浅层次 */
        --tiffany-primary: var(--art-accent-solid);
        --tiffany-dark: var(--art-accent-text);
        --tiffany-light: #a2968b;
        --tiffany-pale: rgba(241, 234, 227, 0.92);

        /* 语义化颜色 */
        --primary: var(--gray-dark);
        --accent: var(--tiffany-primary);
      }

      html {
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
      }

      body {
        font-family: var(--font-sans);
        font-weight: 400;
        line-height: var(--type-body-line-height);
        letter-spacing: var(--type-body-tracking);
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        margin: 0;
        color: var(--gray-dark);
        background:
          radial-gradient(circle at top, var(--art-accent-glow), transparent 28%),
          linear-gradient(180deg, var(--art-paper) 0%, var(--art-paper-deep) 100%);
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        text-wrap: balance;
      }

      p,
      li,
      blockquote {
        text-wrap: pretty;
        line-height: var(--type-body-line-height);
        letter-spacing: var(--type-body-tracking);
      }

      input,
      button,
      textarea,
      select {
        font: inherit;
      }

      .site-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .site-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        border-bottom: 1px solid var(--art-accent-line);
        background: rgba(247, 250, 250, 0.84);
        backdrop-filter: blur(18px);
        box-shadow: 0 10px 30px rgba(47, 47, 47, 0.08);
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease,
          background-color 0.3s ease;
      }

      .site-nav.scrolled {
        background: rgba(247, 250, 250, 0.94);
        box-shadow: 0 16px 36px rgba(47, 47, 47, 0.12);
      }

      .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0.95rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
      }

      .brand-link {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        text-decoration: none;
        color: var(--gray-darkest);
      }

      .brand-mark {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        overflow: hidden;
        flex: 0 0 44px;
        background: rgba(255, 255, 255, 0.86);
        border: 1px solid var(--art-accent-line);
        box-shadow: 0 10px 22px rgba(47, 47, 47, 0.06);
      }

      .brand-mark img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        transform: scale(1.24);
      }

      .brand-copy {
        display: inline-flex;
        flex-direction: column;
        gap: 0.2rem;
      }

      .brand-title {
        font-family: var(--font-serif);
        font-size: 1.25rem;
        font-weight: 600;
        line-height: 1.15;
        letter-spacing: 0.12em;
      }

      .brand-subtitle {
        font-size: 0.68rem;
        letter-spacing: 0.2em;
        color: var(--gray-medium);
        text-transform: uppercase;
      }

      .nav-item {
        display: inline-flex;
      }

      .nav-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.35rem 0.15rem;
        text-decoration: none;
        color: var(--gray-dark);
        transition: color 0.3s ease;
        font-size: 0.965rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        white-space: nowrap;
      }

      .nav-text-window {
        --nav-text-height: 1.45em;
        display: inline-flex;
        height: var(--nav-text-height);
        overflow: hidden;
      }

      .nav-text-track {
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .nav-text {
        min-height: var(--nav-text-height);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
      }

      .nav-text-en {
        font-size: 0.82em;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .nav-link:hover .nav-text-track,
      .nav-link:focus-visible .nav-text-track {
        transform: translateY(calc(var(--nav-text-height) * -1));
      }

      .nav-link:hover {
        color: var(--art-accent-text);
      }

      .nav-links {
        display: flex;
        gap: clamp(1rem, 1.8vw, 1.6rem);
        align-items: center;
      }

      .nav-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.8rem 1.2rem;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(73, 64, 57, 1) 0%, rgba(101, 91, 84, 1) 100%);
        color: var(--white);
        text-decoration: none;
        font-size: 0.92rem;
        font-weight: 500;
        letter-spacing: var(--type-cta-tracking);
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease,
          background-color 0.25s ease;
        box-shadow: 0 14px 24px rgba(47, 47, 47, 0.14);
      }

      .nav-cta:hover {
        transform: translateY(-2px);
        background: linear-gradient(135deg, rgba(52, 47, 43, 1) 0%, rgba(103, 92, 84, 1) 100%);
        box-shadow: 0 16px 28px rgba(47, 47, 47, 0.18);
      }

      /* 漢堡選單按鈕 */
      .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 5px;
      }

      .hamburger span {
        width: 25px;
        height: 3px;
        background: var(--gray-dark);
        transition: all 0.3s ease;
        border-radius: 2px;
      }

      .hamburger.active span:nth-child(1) {
        transform: rotate(45deg) translate(8px, 8px);
      }

      .hamburger.active span:nth-child(2) {
        opacity: 0;
      }

      .hamburger.active span:nth-child(3) {
        transform: rotate(-45deg) translate(7px, -7px);
      }

      /* 手機版樣式 */
      @media (max-width: 768px) {
        .hamburger {
          display: flex;
        }

        .nav-links {
          position: fixed;
          top: 78px;
          right: -100%;
          width: min(320px, calc(100vw - 2rem));
          height: auto;
          background: rgba(247, 250, 250, 0.96);
          backdrop-filter: blur(18px);
          flex-direction: column;
          gap: 0.4rem;
          padding: 1rem;
          border-radius: 24px;
          transition: right 0.3s ease;
          box-shadow: 0 18px 40px rgba(47, 47, 47, 0.16);
          z-index: 999;
          border: 1px solid var(--art-accent-line);
        }

        .nav-links.active {
          right: 1rem;
        }

        .brand-mark {
          width: 40px;
          height: 40px;
          border-radius: 12px;
          flex-basis: 40px;
        }

        .brand-title {
          font-size: 1.1rem;
          letter-spacing: 0.12em;
        }

        .brand-subtitle {
          font-size: 0.62rem;
          letter-spacing: 0.18em;
        }

        .nav-item {
          width: 100%;
          display: flex;
        }

        .nav-link {
          width: 100%;
          padding: 1rem 1.25rem;
          font-size: 1.1rem;
          border-radius: 14px;
          justify-content: center;
        }

        .nav-text-window {
          height: auto;
          overflow: visible;
        }

        .nav-text-track {
          transform: none !important;
        }

        .nav-text {
          min-height: auto;
        }

        .nav-text-en {
          display: none;
        }

        .nav-link:hover {
          background: rgba(240, 247, 247, 0.96);
        }

        .nav-cta {
          width: 100%;
          margin-top: 0.5rem;
        }
      }

      /* Skip to main content link */
      .skip-to-main {
        position: absolute;
        top: -40px;
        left: 0;
        background: var(--art-accent-solid);
        color: white;
        padding: 8px 16px;
        text-decoration: none;
        border-radius: 0 0 4px 0;
        z-index: 100;
        font-weight: 500;
        transition: top 0.3s;
      }

      .skip-to-main:focus {
        top: 0;
      }

      /* Improved focus states */
      a:focus,
      button:focus {
        outline: 2px solid var(--art-accent-solid);
        outline-offset: 2px;
      }

      .site-main {
        flex: 1;
        padding-top: 78px;
      }

      .site-footer {
        background:
          linear-gradient(180deg, rgba(44, 39, 35, 0.98) 0%, rgba(32, 28, 25, 1) 100%);
        color: var(--white);
        border-top: 1px solid rgba(164, 171, 160, 0.2);
      }

      .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3.5rem 1.5rem 2rem;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) repeat(2, minmax(180px, 220px));
        gap: 2rem;
        align-items: start;
      }

      .footer-brand {
        max-width: 420px;
      }

      .footer-logo {
        display: block;
        width: min(240px, 100%);
        height: auto;
        margin-bottom: 1rem;
      }

      .footer-brand h2 {
        margin: 0 0 0.75rem;
        font-family: var(--font-serif);
        font-size: 1.5rem;
        font-weight: 600;
        line-height: 1.4;
        letter-spacing: var(--type-title-tracking);
      }

      .footer-brand p,
      .footer-column p,
      .footer-column a {
        margin: 0;
        color: rgba(255, 255, 255, 0.72);
        line-height: 1.8;
        letter-spacing: var(--type-body-tracking);
        text-decoration: none;
      }

      .footer-column h3 {
        margin: 0 0 1rem;
        font-size: 0.82rem;
        letter-spacing: var(--type-overline-spacing);
        color: rgba(255, 255, 255, 0.56);
        text-transform: uppercase;
        font-weight: 600;
      }

      .footer-links,
      .footer-contact {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .footer-links a:hover,
      .footer-contact a:hover {
        color: rgba(236, 231, 224, 0.92);
      }

      .footer-bottom {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
      }

      .footer-bottom p,
      .footer-bottom a {
        margin: 0;
        color: rgba(255, 255, 255, 0.56);
        text-decoration: none;
        font-size: 0.92rem;
        letter-spacing: var(--type-body-tracking);
      }

      @media (max-width: 900px) {
        .footer-grid {
